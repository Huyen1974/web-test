  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "OPS Proxy API key (same key as Agent Data)"
      }
    },
    "parameters": {
      "itemId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" },
        "description": "Item ID"
      },
      "fields": {
        "name": "fields",
        "in": "query",
        "schema": { "type": "string" },
        "description": "Comma-separated field names to return (e.g. id,name,status)"
      },
      "filter": {
        "name": "filter",
        "in": "query",
        "schema": { "type": "string" },
        "description": "Directus filter as JSON object (e.g. {\"status\":{\"_eq\":\"active\"}})"
      },
      "sort": {
        "name": "sort",
        "in": "query",
        "schema": { "type": "string" },
        "description": "Sort field, prefix with - for descending (e.g. -date_created)"
      },
      "limit": {
        "name": "limit",
        "in": "query",
        "schema": { "type": "integer", "default": 25 },
        "description": "Maximum items to return"
      },
      "offset": {
        "name": "offset",
        "in": "query",
        "schema": { "type": "integer", "default": 0 },
        "description": "Number of items to skip"
      }
    },
    "schemas": {
      "Task": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "status": { "type": "string" },
          "priority": { "type": "string" },
          "date_created": { "type": "string", "format": "date-time" }
        }
      },
      "TaskInput": {
        "type": "object",
        "properties": {
          "content_checklist": { "type": "string", "description": "Checklist content" },
          "content_brief": { "type": "string", "description": "Brief/summary" },
          "content_requirements": { "type": "string", "description": "Requirements" },
          "status": { "type": "string", "description": "Task status" },
          "checklist_version": { "type": "integer", "description": "Checklist version number" }
        }
      },
      "TaskComment": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "task_id": { "type": "integer" },
          "content": { "type": "string" },
          "agent_type": { "type": "string" },
          "tab_scope": { "type": "string" },
          "action": { "type": "string" },
          "date_created": { "type": "string", "format": "date-time" }
        }
      },
      "TaskCommentInput": {
        "type": "object",
        "properties": {
          "task_id": { "type": "integer" },
          "content": { "type": "string" },
          "agent_type": { "type": "string", "description": "Agent identifier: gpt, claude, codex, gemini, claude_code" },
          "tab_scope": { "type": "string", "description": "Tab: discussion, checklist, reports, targets, rules, prompt, test, verify, plan" },
          "action": { "type": "string" }
        },
        "required": ["task_id", "content"]
      },
      "AiTask": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "status": { "type": "string" },
          "assigned_agent": { "type": "string" },
          "work_type": { "type": "string" },
          "task_id": { "type": "integer" },
          "result_summary": { "type": "string" }
        }
      },
      "AiTaskInput": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "result_summary": { "type": "string" },
          "assigned_agent": { "type": "string" }
        }
      },
      "AiTaskCreate": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "Task name" },
          "status": { "type": "string", "enum": ["draft", "pending", "in_progress", "completed", "failed"], "default": "draft" },
          "assigned_agent": { "type": "string", "description": "Agent to assign: claude_code, codex, gpt, gemini" },
          "prompt_payload": { "type": "string", "description": "Task instructions/prompt" },
          "priority": { "type": "string", "enum": ["low", "normal", "high", "urgent"], "default": "normal" },
          "task_id": { "type": "integer", "description": "Parent task reference" },
          "source_agent": { "type": "string", "description": "Agent creating this task" },
          "expected_output": { "type": "string", "description": "Description of expected result" }
        },
        "required": ["name", "assigned_agent", "prompt_payload"]
      },
      "Post": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "title": { "type": "string" },
          "status": { "type": "string" },
          "slug": { "type": "string" },
          "content": { "type": "string" },
          "date_created": { "type": "string", "format": "date-time" }
        }
      },
      "PostInput": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "status": { "type": "string" },
          "slug": { "type": "string" },
          "content": { "type": "string" }
        },
        "required": ["title"]
      },
      "Page": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "title": { "type": "string" },
          "permalink": { "type": "string" },
          "status": { "type": "string" },
          "blocks": { "type": "array", "items": { "type": "object" } },
          "date_created": { "type": "string", "format": "date-time" },
          "date_updated": { "type": "string", "format": "date-time" }
        }
      },
      "Navigation": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "title": { "type": "string" },
          "items": { "type": "array", "items": { "type": "object" } }
        }
      },
      "Globals": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "url": { "type": "string" },
          "logo": { "type": "string" },
          "social_links": { "type": "array", "items": { "type": "object" } },
          "og_image": { "type": "string" }
        }
      }
    }
  }
}
