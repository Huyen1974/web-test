    "/items/navigation": {
      "get": {
        "operationId": "listNavigation",
        "summary": "List navigation menus",
        "description": "List navigation menus (main, footer).",
        "parameters": [
          { "$ref": "#/components/parameters/fields" },
          { "$ref": "#/components/parameters/filter" },
          { "$ref": "#/components/parameters/limit" }
        ],
