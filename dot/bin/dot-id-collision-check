#!/usr/bin/env bash
# =============================================================================
# dot-id-collision-check — Phát hiện trùng code cross-collection (TD-111)
# =============================================================================
# CHECKED-NO-DUPLICATE: [searched dot/bin/dot-*collision* — no existing tool]
# VERSION: 1.0.0
#
# Quét TẤT CẢ collections có field `code`, phát hiện trùng code giữa các
# collections. Ghi system_issues nếu trùng.
#
# Usage:
#   dot-id-collision-check [--cloud] [--fix]
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/../config/environment.sh"

VERSION="1.0.0"
CREATE_ISSUES=false

for arg in "$@"; do
  case "$arg" in
    --fix) CREATE_ISSUES=true ;;
    --help|-h)
      echo "dot-id-collision-check v${VERSION} — Phát hiện trùng code cross-collection"
      echo ""
      echo "Usage:"
      echo "  dot-id-collision-check [--cloud]        Kiểm tra trùng code"
      echo "  dot-id-collision-check [--cloud] --fix   Kiểm tra + ghi system_issues"
      echo ""
      exit 0
      ;;
  esac
done

init_environment "$@"
BASE_URL="$DIRECTUS_URL"

# Auth
if [[ -z "${DOT_TOKEN:-}" ]]; then
  local_auth="${SCRIPT_DIR}/dot-auth"
  if [[ -f "$local_auth" ]]; then
    source "$local_auth" "$@"
  fi
fi

if [[ -z "${DOT_TOKEN:-}" ]]; then
  echo "[ERR] Xác thực thất bại" >&2
  exit 1
fi

echo "========================================="
echo "DOT Tool: ID Collision Check v${VERSION}"
echo "========================================="
print_environment_banner "$@"

# Use Python for the actual work (portable, handles associative data)
python3 - "$BASE_URL" "$DOT_TOKEN" "$CREATE_ISSUES" <<'PYEOF'
import sys, json, subprocess

BASE_URL = sys.argv[1]
TOKEN = sys.argv[2]
CREATE_ISSUES = sys.argv[3] == "true"

COLLECTIONS = [
    ("meta_catalog", "code"),
    ("table_registry", "table_id"),
    ("modules", "code"),
    ("workflows", "process_code"),
    ("workflow_steps", "code"),
    ("workflow_change_requests", "code"),
    ("dot_tools", "code"),
    ("ui_pages", "code"),
    ("collection_registry", "code"),
    ("tasks", "code"),
    ("agents", "code"),
    ("checkpoint_types", "code"),
    ("checkpoint_sets", "code"),
    ("checkpoint_instances", "code"),
    ("entity_dependencies", "code"),
    ("table_proposals", "code"),
    ("system_issues", "code"),
]

def api_get(path):
    url = f"{BASE_URL}{path}"
    result = subprocess.run(
        ["curl", "-sS", "--globoff", "--max-time", "15", url,
         "-H", f"Authorization: Bearer {TOKEN}"],
        capture_output=True, text=True
    )
    if result.returncode != 0:
        return None
    try:
        return json.loads(result.stdout)
    except json.JSONDecodeError:
        return None

def api_post(path, data):
    url = f"{BASE_URL}{path}"
    result = subprocess.run(
        ["curl", "-sS", "--globoff", "--max-time", "15", "-X", "POST", url,
         "-H", f"Authorization: Bearer {TOKEN}",
         "-H", "Content-Type: application/json",
         "-d", json.dumps(data)],
        capture_output=True, text=True
    )
    if result.returncode != 0:
        return None
    try:
        return json.loads(result.stdout)
    except json.JSONDecodeError:
        return None

# Collect all codes: code -> [(collection, id), ...]
code_map = {}
total_codes = 0
total_collections = 0

for collection, code_field in COLLECTIONS:
    resp = api_get(f"/items/{collection}?fields=id,{code_field}&limit=-1")
    if not resp or "data" not in resp:
        print(f"[WARN] Bỏ qua {collection}")
        continue

    total_collections += 1
    items = resp["data"]
    count = len(items)

    for item in items:
        c = item.get(code_field)
        if not c or c == "null":
            continue
        total_codes += 1
        key = str(c)
        if key not in code_map:
            code_map[key] = []
        code_map[key].append((collection, item.get("id")))

    print(f"[INFO] {collection}: {count} items (code field: {code_field})")

print()
print("=========================================")
print("KẾT QUẢ KIỂM TRA")
print("=========================================")
print()

collisions = []
for code, locations in sorted(code_map.items()):
    if len(locations) > 1:
        # Check if they span multiple collections
        cols = set(loc[0] for loc in locations)
        if len(cols) > 1:
            loc_str = ", ".join(f"{c}:{i}" for c, i in locations)
            print(f"[WARN] TRÙNG: {code} → {loc_str}")
            collisions.append((code, loc_str))

print()
print(f"Tổng kết:")
print(f"  Collections quét: {total_collections}")
print(f"  Tổng codes: {total_codes}")
print(f"  Trùng cross-collection: {len(collisions)}")
print()

if len(collisions) == 0:
    print("[OK]   Không phát hiện trùng code cross-collection")
else:
    print(f"[WARN] Phát hiện {len(collisions)} trùng code!")
    if CREATE_ISSUES:
        print()
        print("Ghi system_issues...")
        for dup_code, dup_locs in collisions:
            result = api_post("/items/system_issues", {
                "title": f"ID Collision: {dup_code}",
                "description": f"Code {dup_code} trùng ở nhiều collections: {dup_locs}",
                "severity": "warning",
                "category": "data_integrity",
                "status": "open",
                "source": "dot-id-collision-check",
            })
            if result:
                print(f"[OK]   Đã ghi issue: {dup_code}")
            else:
                print(f"[WARN] Không ghi được issue cho {dup_code}")

print()
print("=========================================")
print("DOT Tool: ID Collision Check — HOÀN TẤT")
print("=========================================")

sys.exit(0 if len(collisions) == 0 else 1)
PYEOF
