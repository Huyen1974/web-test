#!/usr/bin/env bash
# =============================================================================
# dot-schema-table-proposals-ensure - Ensure table_proposals collection in Directus
# =============================================================================
# VERSION: 1.0.0
# CHANGELOG:
#   v1.0.0 (2026-03-05): Initial version for TABLE-MODULE-V2
#     - table_proposals: 8 fields (source_collection, proposal_type, position_type,
#       position_index, position_context, description, status, user_created, date_created)
#     - No relations (source_collection is text, not FK)
#     - Idempotent: checks existence before create, patches missing fields
#     - Based on dot-schema-checkpoints-ensure pattern
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOT_AUTH="${SCRIPT_DIR}/dot-auth"

# Source environment configuration
source "${SCRIPT_DIR}/../config/environment.sh"

VERSION="1.0.0"
COLLECTION="table_proposals"

# Logging
log_info() { echo "[INFO] $1"; }
log_ok()   { echo "[OK]   $1"; }
log_warn() { echo "[WARN] $1"; }
log_skip() { echo "[SKIP] $1"; }
log_err()  { echo "[ERR]  $1" >&2; }

require_cmds() {
  for cmd in curl jq; do
    command -v "$cmd" >/dev/null 2>&1 || { log_err "Missing required command: $cmd"; exit 1; }
  done
}

api_request() {
  local method="$1" url="$2" data="${3-}"
  if [[ -n "${data-}" ]]; then
    curl -sS --globoff -X "$method" "$url" \
      -H "Authorization: Bearer $DOT_TOKEN" \
      -H "Content-Type: application/json" \
      -d "$data" -w "\n%{http_code}"
  else
    curl -sS --globoff -X "$method" "$url" \
      -H "Authorization: Bearer $DOT_TOKEN" \
      -w "\n%{http_code}"
  fi
}

REQUIRED_FIELDS=(source_collection proposal_type position_type position_index position_context description status user_created date_created)

field_payload() {
  case "$1" in
    source_collection)
      cat <<'JSON'
{"field":"source_collection","type":"string","meta":{"required":true,"interface":"input","width":"half","note":"Directus collection name this proposal targets (e.g. workflows, tasks)"},"schema":{"is_nullable":false}}
JSON
      ;;
    proposal_type)
      cat <<'JSON'
{"field":"proposal_type","type":"string","meta":{"required":true,"interface":"select-dropdown","options":{"choices":[{"text":"Thêm hàng","value":"add_row"},{"text":"Thêm cột","value":"add_column"},{"text":"Sửa đổi","value":"modify"},{"text":"Xóa","value":"delete"}]},"width":"half","note":"Type of table change proposed"},"schema":{"is_nullable":false}}
JSON
      ;;
    position_type)
      cat <<'JSON'
{"field":"position_type","type":"string","meta":{"required":true,"interface":"select-dropdown","options":{"choices":[{"text":"Hàng","value":"row"},{"text":"Cột","value":"column"}]},"width":"half","note":"Whether proposal targets a row or column position"},"schema":{"is_nullable":false}}
JSON
      ;;
    position_index)
      cat <<'JSON'
{"field":"position_index","type":"integer","meta":{"required":true,"interface":"input","width":"half","note":"0-based index of insert position (e.g. 0 = before first, n = after last)"},"schema":{"is_nullable":false}}
JSON
      ;;
    position_context)
      cat <<'JSON'
{"field":"position_context","type":"string","meta":{"required":false,"interface":"input","width":"full","note":"Human-readable context (e.g. 'Sau hàng: Tên bước X')"},"schema":{"is_nullable":true}}
JSON
      ;;
    description)
      cat <<'JSON'
{"field":"description","type":"text","meta":{"required":true,"interface":"input-multiline","width":"full","note":"Free-text description of the proposed change"},"schema":{"is_nullable":false}}
JSON
      ;;
    status)
      cat <<'JSON'
{"field":"status","type":"string","meta":{"required":true,"interface":"select-dropdown","options":{"choices":[{"text":"Nháp","value":"draft"},{"text":"Đang xem xét","value":"reviewing"},{"text":"Đã duyệt","value":"approved"},{"text":"Đã áp dụng","value":"applied"},{"text":"Từ chối","value":"rejected"}]},"width":"half","note":"Proposal lifecycle status"},"schema":{"is_nullable":false,"default_value":"draft"}}
JSON
      ;;
    user_created)
      cat <<'JSON'
{"field":"user_created","type":"uuid","meta":{"interface":"select-dropdown-m2o","special":["user-created"],"readonly":true,"width":"half","note":"Auto: who created this proposal"},"schema":{"is_nullable":true}}
JSON
      ;;
    date_created)
      cat <<'JSON'
{"field":"date_created","type":"timestamp","meta":{"interface":"datetime","special":["date-created"],"readonly":true,"width":"half","note":"Auto: creation timestamp"},"schema":{"is_nullable":false}}
JSON
      ;;
    *) return 1 ;;
  esac
}

collection_exists() {
  local resp body code
  resp=$(api_request GET "${BASE_URL}/collections/${COLLECTION}")
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"
  [[ "$code" == "200" ]]
}

field_exists() {
  local field_name="$1"
  local resp body code
  resp=$(api_request GET "${BASE_URL}/fields/${COLLECTION}")
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"
  if [[ "$code" == "200" ]]; then
    echo "$body" | jq -e --arg field "$field_name" '.data[]? | select(.field == $field)' >/dev/null 2>&1
    return $?
  fi
  return 1
}

create_collection() {
  local payload
  payload=$(jq -nc \
    --arg collection "$COLLECTION" \
    '{
      collection: $collection,
      schema: {},
      meta: {
        collection: $collection,
        icon: "rate_review",
        note: "Table change proposals for TABLE-MODULE-V2 - Created by DOT v1.0.0",
        display_template: "{{source_collection}} — {{proposal_type}} [{{status}}]",
        sort_field: "date_created"
      }
    }')

  log_info "Creating collection ${COLLECTION}"
  local resp body code
  resp=$(api_request POST "${BASE_URL}/collections" "$payload")
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"

  if [[ "$code" != "200" ]]; then
    log_err "Failed to create collection ${COLLECTION} (HTTP $code)"
    echo "$body" | head -c 300 >&2
    exit 1
  fi
  log_ok "Collection ${COLLECTION} created"
}

create_field() {
  local field_name="$1"
  local payload resp body code
  payload=$(field_payload "$field_name")

  log_info "Creating field ${COLLECTION}.${field_name}"
  resp=$(api_request POST "${BASE_URL}/fields/${COLLECTION}" "$payload")
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"

  if [[ "$code" != "200" ]]; then
    log_err "Failed to create field ${COLLECTION}.${field_name} (HTTP $code)"
    echo "$body" | head -c 200 >&2
    exit 1
  fi
  log_ok "Field ${COLLECTION}.${field_name} created"
}

setup_permissions() {
  log_info "Setting up permissions..."

  # Public read access (for displaying proposals inline)
  local public_read
  public_read=$(jq -nc \
    --arg collection "$COLLECTION" \
    '{
      role: null,
      collection: $collection,
      action: "read",
      fields: ["*"],
      permissions: {},
      validation: {}
    }')

  local resp code
  resp=$(api_request POST "${BASE_URL}/permissions" "$public_read")
  code="${resp##*$'\n'}"

  if [[ "$code" == "200" ]]; then
    log_ok "Public READ permission created"
  elif [[ "$code" == "400" ]]; then
    log_skip "Public READ permission already exists"
  else
    log_warn "Could not create public READ permission (HTTP $code)"
  fi

  # Public create access (for submitting proposals without auth)
  local public_create
  public_create=$(jq -nc \
    --arg collection "$COLLECTION" \
    '{
      role: null,
      collection: $collection,
      action: "create",
      fields: ["source_collection", "proposal_type", "position_type", "position_index", "position_context", "description"],
      permissions: {},
      validation: {}
    }')

  resp=$(api_request POST "${BASE_URL}/permissions" "$public_create")
  code="${resp##*$'\n'}"

  if [[ "$code" == "200" ]]; then
    log_ok "Public CREATE permission created (limited fields)"
  elif [[ "$code" == "400" ]]; then
    log_skip "Public CREATE permission already exists"
  else
    log_warn "Could not create public CREATE permission (HTTP $code)"
  fi
}

verify_fields() {
  local resp body code missing=()
  resp=$(api_request GET "${BASE_URL}/fields/${COLLECTION}")
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"

  if [[ "$code" != "200" ]]; then
    log_err "Failed to list fields for ${COLLECTION} (HTTP $code)"
    exit 1
  fi

  local field_count
  field_count=$(echo "$body" | jq '.data | length')

  for field in "${REQUIRED_FIELDS[@]}"; do
    if ! echo "$body" | jq -e --arg field "$field" '.data[]? | select(.field == $field)' >/dev/null 2>&1; then
      missing+=("$field")
    fi
  done

  if [[ "${#missing[@]}" -gt 0 ]]; then
    log_err "Missing required fields: ${missing[*]}"
    exit 1
  fi

  log_ok "${COLLECTION}: All required fields present (${field_count} total)"
}

show_help() {
  cat << EOF
dot-schema-table-proposals-ensure v${VERSION} - Ensure table_proposals collection

Usage:
  dot-schema-table-proposals-ensure [options]

Options:
  --local       Use local development environment
  --cloud       Use cloud/production environment (default)
  --dry-run     Show what would be done without making changes
  --help, -h    Show this help message

Collection: table_proposals (9 fields)
  - source_collection  Target Directus collection name (required)
  - proposal_type      add_row|add_column|modify|delete (required)
  - position_type      row|column (required)
  - position_index     0-based insert position (required)
  - position_context   Human-readable context (nullable)
  - description        Free-text proposal description (required)
  - status             draft|reviewing|approved|applied|rejected (default: draft)
  - user_created       Auto: creator UUID
  - date_created       Auto: creation timestamp

EOF
  show_environment_help
}

main() {
  local DRY_RUN=false

  for arg in "$@"; do
    case "$arg" in
      --help|-h) show_help; exit 0 ;;
      --dry-run) DRY_RUN=true ;;
    esac
  done

  require_cmds
  init_environment "$@"
  BASE_URL="$DIRECTUS_URL"

  echo "========================================="
  echo "DOT Tool: Schema Table Proposals Ensure v${VERSION}"
  echo "========================================="
  print_environment_banner "$@"
  echo "Ensuring table_proposals collection for TABLE-MODULE-V2"
  echo ""

  if [[ "$DRY_RUN" == "true" ]]; then
    log_warn "DRY RUN MODE - No changes will be made"
    echo ""
  fi

  # Authentication
  if [[ -z "${DOT_TOKEN:-}" ]]; then
    if [[ ! -f "$DOT_AUTH" ]]; then
      log_err "dot-auth not found at ${DOT_AUTH}"
      exit 1
    fi
    log_info "Authenticating with Directus..."
    source "$DOT_AUTH" "$@"
  fi

  if [[ -z "${DOT_TOKEN:-}" ]]; then
    log_err "DOT_TOKEN is empty after authentication"
    exit 1
  fi

  # === COLLECTION ===
  echo ""
  echo "--- Collection: ${COLLECTION} ---"

  if collection_exists; then
    log_skip "Collection '${COLLECTION}' already exists"
  else
    if [[ "$DRY_RUN" == "true" ]]; then
      log_info "Would create collection '${COLLECTION}'"
    else
      create_collection
    fi
  fi

  # === FIELDS ===
  log_info "Ensuring required fields..."
  for field in "${REQUIRED_FIELDS[@]}"; do
    if field_exists "$field"; then
      log_skip "Field ${COLLECTION}.${field} already exists"
    else
      if [[ "$DRY_RUN" == "true" ]]; then
        log_info "Would create field ${COLLECTION}.${field}"
      else
        create_field "$field"
      fi
    fi
  done

  # === PERMISSIONS ===
  echo ""
  if [[ "$DRY_RUN" != "true" ]]; then
    setup_permissions
  else
    log_info "Would create public READ + CREATE permissions"
  fi

  # === VERIFICATION ===
  echo ""
  if [[ "$DRY_RUN" != "true" ]]; then
    log_info "Running final verification..."
    if ! collection_exists; then
      log_err "Collection ${COLLECTION} missing after ensure"
      exit 1
    fi
    verify_fields
  fi

  log_ok "Collection table_proposals ready"
  echo ""
  echo "========================================="
  echo "DOT Tool: Schema Table Proposals Ensure - COMPLETE"
  echo "========================================="
}

main "$@"
