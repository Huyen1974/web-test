JSON
			;;
		workflow_change_requests.dsl_diff)
			cat <<'JSON'
{"field":"dsl_diff","type":"json","meta":{"required":false,"interface":"input-code","options":{"language":"json"},"width":"full","note":"Preview and apply payload for DSL changes"},"schema":{"is_nullable":true}}
