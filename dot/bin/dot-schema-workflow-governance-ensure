{"block_key":"code_review_loop","title":"Code Review Loop","description":"Review with retry loop when rejected.","category":"validation","template_steps":[{"template_key":"code_review","step_type":"agent_call","title":"Code Review","actor_type":"claude_code","actor_param":"reviewer_actor_type","config":{"role":"code_reviewer"},"sort_order":10},{"template_key":"quality_gate","step_type":"condition","title":"Pass?","config":{"condition":"review_passed"},"sort_order":20},{"template_key":"approve_action","step_type":"action","title":"Approve","config":{"result":"approve"},"sort_order":30},{"template_key":"retry_loop","step_type":"loop","title":"Retry Loop","config":{"loop":"retry"},"sort_order":40}],"template_relations":[{"from_template_key":"code_review","to_template_key":"quality_gate","relation_type":"sequence","sort_order":10},{"from_template_key":"quality_gate","to_template_key":"approve_action","relation_type":"conditional","label":"pass","condition_expression":"review_passed","sort_order":20},{"from_template_key":"quality_gate","to_template_key":"retry_loop","relation_type":"conditional","label":"fail","condition_expression":"!review_passed","sort_order":30},{"from_template_key":"retry_loop","to_template_key":"code_review","relation_type":"loop_back","label":"retry","sort_order":40}],"input_params":{"reviewer_actor_type":"claude_code"},"version":1,"status":"active"}
JSON
			;;
		approval_with_retry)
			cat <<'JSON'
{"block_key":"approval_with_retry","title":"Approval With Retry","description":"Human approval with timeout and reminder loop.","category":"approval","template_steps":[{"template_key":"human_approval","step_type":"human_checkpoint","title":"Human Approval","actor_type":"user","config":{"role":"approver"},"sort_order":10},{"template_key":"approval_timeout","step_type":"wait_for_event","title":"Wait For Timeout","config":{"event":"timeout"},"sort_order":20},{"template_key":"reminder_notify","step_type":"agent_call","title":"Send Reminder","actor_type":"system","actor_param":"notify_actor_type","config":{"role":"notifier"},"sort_order":30}],"template_relations":[{"from_template_key":"human_approval","to_template_key":"approval_timeout","relation_type":"sequence","sort_order":10},{"from_template_key":"approval_timeout","to_template_key":"reminder_notify","relation_type":"sequence","sort_order":20},{"from_template_key":"reminder_notify","to_template_key":"human_approval","relation_type":"loop_back","label":"remind","sort_order":30}],"input_params":{"notify_actor_type":"system"},"version":1,"status":"active"}
JSON
			;;
		agent_dispatch_block)
			cat <<'JSON'
{"block_key":"agent_dispatch_block","title":"Agent Dispatch Block","description":"Dispatch execution to an agent and validate the result.","category":"dispatch","template_steps":[{"template_key":"executor_call","step_type":"agent_call","title":"Dispatch Agent","actor_type":"codex","actor_param":"executor_actor_type","config":{"role":"executor"},"sort_order":10},{"template_key":"wait_done","step_type":"wait_for_event","title":"Wait Done","config":{"event":"done"},"sort_order":20},{"template_key":"validate_action","step_type":"action","title":"Validate Result","config":{"result":"validate"},"sort_order":30}],"template_relations":[{"from_template_key":"executor_call","to_template_key":"wait_done","relation_type":"sequence","sort_order":10},{"from_template_key":"wait_done","to_template_key":"validate_action","relation_type":"sequence","sort_order":20}],"input_params":{"executor_actor_type":"codex"},"version":1,"status":"active"}
JSON
			;;
		*)
			log_err "Unknown block payload: $1"
			exit 1
			;;
	esac
}

upsert_block() {
	local block_key="$1"
	local payload="$2"
	local resp body code existing_id update_resp update_code

	resp=$(api_request GET "${BASE_URL}/items/block_library?filter[block_key][_eq]=${block_key}&limit=1")
	body="${resp%$'\n'*}"
	code="${resp##*$'\n'}"

	if [[ "$code" != "200" ]]; then
		log_err "Failed to query block_library for ${block_key} (HTTP $code)"
		exit 1
	fi

	existing_id=$(echo "$body" | jq -r '.data[0].id // empty')
	if [[ -n "$existing_id" ]]; then
		update_resp=$(api_request PATCH "${BASE_URL}/items/block_library/${existing_id}" "$payload")
		update_code="${update_resp##*$'\n'}"
		if [[ "$update_code" != "200" ]]; then
			log_err "Failed to update block ${block_key} (HTTP $update_code)"
			exit 1
		fi
		log_ok "Block ${block_key} updated"
	else
		update_resp=$(api_request POST "${BASE_URL}/items/block_library" "$payload")
		update_code="${update_resp##*$'\n'}"
		if [[ "$update_code" != "200" ]]; then
			log_err "Failed to create block ${block_key} (HTTP $update_code)"
			exit 1
		fi
		log_ok "Block ${block_key} created"
	fi
}

seed_blocks() {
	echo ""
	echo "--- Seed: block_library ---"
	for block_key in planning_council ai_review_block code_review_loop approval_with_retry agent_dispatch_block; do
		local payload
		payload=$(block_payload "$block_key")
		if [[ "$DRY_RUN" == "true" ]]; then
			log_info "Would upsert block ${block_key}"
		else
			upsert_block "$block_key" "$payload"
		fi
	done
}

main() {
	DRY_RUN=false
	SEED_BLOCKS=false
	ENV_ARGS=()

	for arg in "$@"; do
		case "$arg" in
			--dry-run) DRY_RUN=true ;;
			--seed-blocks) SEED_BLOCKS=true ;;
			--local|--cloud) ENV_ARGS+=("$arg") ;;
			--help|-h)
				cat <<EOF
dot-schema-workflow-governance-ensure v${VERSION}

Usage:
  dot-schema-workflow-governance-ensure [--local|--cloud] [--dry-run] [--seed-blocks]

Ensures:
  - workflow_steps
  - workflow_step_relations
  - block_library
  - workflow_change_requests
  - AI Agent permissions
  - Optional block seed data
EOF
				exit 0
				;;
		esac
	done

	require_cmds
	init_environment "$@"
	BASE_URL="$DIRECTUS_URL"

	echo "========================================="
	echo "DOT Tool: Workflow Governance Ensure v${VERSION}"
	echo "========================================="
	print_environment_banner "$@"
	echo "Ensuring M-002 Phase 2A schema"
	echo ""

	if [[ "$DRY_RUN" == "true" ]]; then
		log_warn "DRY RUN MODE - No changes will be made"
		echo ""
	fi

	if [[ -z "${DOT_TOKEN:-}" ]]; then
		log_info "Authenticating with Directus..."
		source "$DOT_AUTH" "$@"
	fi

	if [[ -z "${DOT_TOKEN:-}" ]]; then
		log_err "DOT_TOKEN is empty after authentication"
		exit 1
	fi

	ensure_collection \
		"workflow_steps" \
		"route" \
		"Workflow DSL steps. step_key uniqueness is enforced per workflow by governance validation." \
		"{{title}} ({{step_type}})" \
		"sort_order" \
		workflow_id step_key step_type title description actor_type config position_x position_y block_id sort_order trigger_in_text trigger_out_text date_created date_updated

	ensure_collection \
		"workflow_step_relations" \
		"share" \
		"Workflow DSL relations between workflow_steps." \
		"{{relation_type}}" \
		"sort_order" \
		workflow_id from_step_id to_step_id relation_type condition_expression label sort_order

	ensure_collection \
		"block_library" \
		"view_quilt" \
		"Reusable Lego-style workflow blocks for governance assembly." \
		"{{title}} v{{version}}" \
		"date_created" \
		block_key title description category template_steps template_relations input_params version status date_created

	ensure_collection \
		"workflow_change_requests" \
		"rule_folder" \
		"Governed workflow change requests. DSL changes must pass through this gate." \
		"{{title}} ({{status}})" \
		"date_created" \
		workflow_id change_type title description position_context suggested_actor_type suggested_block_id status schema_warnings dsl_diff approved_by applied_at task_id date_created

	echo ""
	echo "--- Relations ---"
	if [[ "$DRY_RUN" == "true" ]]; then
		log_info "Would create workflow DSL relations"
	else
		ensure_relation "workflow_steps.workflow_id -> workflows" "$(jq -nc '{
			collection:"workflow_steps",
			field:"workflow_id",
			related_collection:"workflows",
			meta:{one_field:"dsl_steps",one_deselect_action:"nullify"},
			schema:{on_delete:"CASCADE"}
		}')"
		ensure_relation "workflow_steps.block_id -> block_library" "$(jq -nc '{
			collection:"workflow_steps",
			field:"block_id",
			related_collection:"block_library",
			meta:{one_field:"generated_steps",one_deselect_action:"nullify"},
			schema:{on_delete:"SET NULL"}
		}')"
		ensure_relation "workflow_step_relations.workflow_id -> workflows" "$(jq -nc '{
			collection:"workflow_step_relations",
			field:"workflow_id",
			related_collection:"workflows",
			meta:{one_field:"dsl_relations",one_deselect_action:"nullify"},
			schema:{on_delete:"CASCADE"}
		}')"
		ensure_relation "workflow_step_relations.from_step_id -> workflow_steps" "$(jq -nc '{
			collection:"workflow_step_relations",
			field:"from_step_id",
			related_collection:"workflow_steps",
			meta:{one_field:null,one_deselect_action:"nullify"},
			schema:{on_delete:"CASCADE"}
		}')"
		ensure_relation "workflow_step_relations.to_step_id -> workflow_steps" "$(jq -nc '{
			collection:"workflow_step_relations",
			field:"to_step_id",
			related_collection:"workflow_steps",
			meta:{one_field:null,one_deselect_action:"nullify"},
			schema:{on_delete:"CASCADE"}
		}')"
		ensure_relation "workflow_change_requests.workflow_id -> workflows" "$(jq -nc '{
			collection:"workflow_change_requests",
			field:"workflow_id",
			related_collection:"workflows",
			meta:{one_field:"change_requests",one_deselect_action:"nullify"},
			schema:{on_delete:"CASCADE"}
		}')"
		ensure_relation "workflow_change_requests.suggested_block_id -> block_library" "$(jq -nc '{
			collection:"workflow_change_requests",
			field:"suggested_block_id",
			related_collection:"block_library",
			meta:{one_field:"change_requests",one_deselect_action:"nullify"},
			schema:{on_delete:"SET NULL"}
		}')"
		ensure_relation "workflow_change_requests.task_id -> tasks" "$(jq -nc '{
			collection:"workflow_change_requests",
			field:"task_id",
			related_collection:"tasks",
			meta:{one_field:null,one_deselect_action:"nullify"},
			schema:{on_delete:"SET NULL"}
		}')"
	fi

	ensure_permissions

	if [[ "$SEED_BLOCKS" == "true" ]]; then
		seed_blocks
	fi

	echo ""
	echo "========================================="
	echo "DOT Tool: Workflow Governance Ensure - COMPLETE"
	echo "========================================="
}

main "$@"
