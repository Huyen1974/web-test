#!/usr/bin/env bash
# =============================================================================
# dot-schema-workflow-governance-ensure - Ensure M-002 Phase 2A schema in Directus
# =============================================================================
# VERSION: 1.1.0
# CHANGELOG:
#   v1.0.0 (2026-03-03): Create workflow DSL + governance foundation
#     - workflow_steps
#     - workflow_step_relations
#     - block_library
#     - workflow_change_requests
#     - AI Agent permissions
#     - Optional block seed data
#   v1.1.0 (2026-03-03): Extend workflow_steps for supervisor-readable trigger text
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOT_AUTH="${SCRIPT_DIR}/dot-auth"
DOT_PERMISSION="${SCRIPT_DIR}/dot-permission-ensure"

source "${SCRIPT_DIR}/../config/environment.sh"

VERSION="1.1.0"

log_info() { echo "[INFO] $1"; }
log_ok() { echo "[OK]   $1"; }
log_warn() { echo "[WARN] $1"; }
log_skip() { echo "[SKIP] $1"; }
log_err() { echo "[ERR]  $1" >&2; }

require_cmds() {
	for cmd in curl jq; do
		command -v "$cmd" >/dev/null 2>&1 || { log_err "Missing required command: $cmd"; exit 1; }
	done
}

api_request() {
	local method="$1" url="$2" data="${3-}"
	if [[ -n "${data-}" ]]; then
		curl -sS --globoff -X "$method" "$url" \
			-H "Authorization: Bearer $DOT_TOKEN" \
			-H "Content-Type: application/json" \
			-d "$data" -w "\n%{http_code}"
	else
		curl -sS --globoff -X "$method" "$url" \
			-H "Authorization: Bearer $DOT_TOKEN" \
			-w "\n%{http_code}"
	fi
}

collection_exists() {
	local collection="$1"
	local resp code
	resp=$(api_request GET "${BASE_URL}/collections/${collection}")
	code="${resp##*$'\n'}"
	[[ "$code" == "200" ]]
}

field_exists() {
	local collection="$1" field="$2"
	local resp body code
	resp=$(api_request GET "${BASE_URL}/fields/${collection}")
	body="${resp%$'\n'*}"
	code="${resp##*$'\n'}"
	[[ "$code" == "200" ]] || return 1
	echo "$body" | jq -e --arg field "$field" '.data[]? | select(.field == $field)' >/dev/null 2>&1
}

create_collection() {
	local collection="$1" icon="$2" note="$3" display_template="$4" sort_field="$5"
	local payload
	payload=$(jq -nc \
		--arg collection "$collection" \
		--arg icon "$icon" \
		--arg note "$note" \
		--arg display_template "$display_template" \
		--arg sort_field "$sort_field" \
		'{
			collection: $collection,
			schema: {},
			meta: {
				collection: $collection,
				icon: $icon,
				note: $note,
				display_template: $display_template,
				sort_field: $sort_field
			}
		}')

	local resp body code
	resp=$(api_request POST "${BASE_URL}/collections" "$payload")
	body="${resp%$'\n'*}"
	code="${resp##*$'\n'}"

	if [[ "$code" != "200" ]]; then
		log_err "Failed to create collection ${collection} (HTTP $code)"
		echo "$body" | head -c 300 >&2
		exit 1
	fi

	log_ok "Collection ${collection} created"
}

create_field() {
	local collection="$1" field="$2"
	local payload resp body code
	payload=$(field_payload "$collection" "$field")

	resp=$(api_request POST "${BASE_URL}/fields/${collection}" "$payload")
	body="${resp%$'\n'*}"
	code="${resp##*$'\n'}"

	if [[ "$code" != "200" ]]; then
		log_err "Failed to create field ${collection}.${field} (HTTP $code)"
		echo "$body" | head -c 200 >&2
		exit 1
	fi

	log_ok "Field ${collection}.${field} created"
}

ensure_relation() {
	local label="$1" payload="$2"
	local resp code
	resp=$(api_request POST "${BASE_URL}/relations" "$payload")
	code="${resp##*$'\n'}"

	if [[ "$code" == "200" ]]; then
		log_ok "Relation ${label} created"
	elif [[ "$code" == "400" ]]; then
		log_skip "Relation ${label} already exists"
	else
		log_warn "Relation ${label} returned HTTP $code"
	fi
}

ensure_permission() {
	local collection="$1" action="$2" fields="$3"
	if [[ "$DRY_RUN" == "true" ]]; then
		log_info "Would ensure AI Agent permission ${collection}.${action}"
		return 0
	fi

	"$DOT_PERMISSION" "${ENV_ARGS[@]}" --policy ai-agent --collection "$collection" --action "$action" --fields "$fields"
}

