ensure_collection() {
	local collection="$1" icon="$2" note="$3" display_template="$4" sort_field="$5"
	shift 5
	local fields=("$@")

	echo ""
	echo "--- Collection: ${collection} ---"

	if collection_exists "$collection"; then
		log_skip "Collection '${collection}' already exists"
	else
		if [[ "$DRY_RUN" == "true" ]]; then
			log_info "Would create collection '${collection}'"
		else
			create_collection "$collection" "$icon" "$note" "$display_template" "$sort_field"
		fi
	fi

	for field in "${fields[@]}"; do
		if field_exists "$collection" "$field"; then
			log_skip "Field ${collection}.${field} already exists"
		else
			if [[ "$DRY_RUN" == "true" ]]; then
				log_info "Would create field ${collection}.${field}"
			else
				create_field "$collection" "$field"
			fi
		fi
	done
}

ensure_permissions() {
	local STEP_FIELDS='["workflow_id","step_key","step_type","title","description","actor_type","config","position_x","position_y","block_id","sort_order","trigger_in_text","trigger_out_text","date_created","date_updated"]'
	local RELATION_FIELDS='["workflow_id","from_step_id","to_step_id","relation_type","condition_expression","label","sort_order"]'
	local WCR_CREATE_FIELDS='["workflow_id","change_type","title","description","position_context","suggested_actor_type","suggested_block_id","status","schema_warnings","dsl_diff","approved_by","applied_at","task_id","date_created"]'
	local WCR_UPDATE_FIELDS='["status","schema_warnings","dsl_diff"]'

	echo ""
	echo "--- Permissions: AI Agent ---"

	ensure_permission "workflow_steps" "read" '["*"]'
	ensure_permission "workflow_steps" "create" "$STEP_FIELDS"
	ensure_permission "workflow_steps" "update" "$STEP_FIELDS"
	ensure_permission "workflow_steps" "delete" '["id"]'

	ensure_permission "workflow_step_relations" "read" '["*"]'
	ensure_permission "workflow_step_relations" "create" "$RELATION_FIELDS"
	ensure_permission "workflow_step_relations" "update" "$RELATION_FIELDS"
	ensure_permission "workflow_step_relations" "delete" '["id"]'

	ensure_permission "block_library" "read" '["*"]'

	ensure_permission "workflow_change_requests" "read" '["*"]'
	ensure_permission "workflow_change_requests" "create" "$WCR_CREATE_FIELDS"
	ensure_permission "workflow_change_requests" "update" "$WCR_UPDATE_FIELDS"
}

