#!/usr/bin/env bash
# =============================================================================
# dot-dependency-scan — Scan Directus relations -> populate entity_dependencies
# =============================================================================
# CHECKED-NO-DUPLICATE: [grep dot/bin/ for "dependency-scan" — no match]
# VERSION: 2.0.0
#
# Scans Directus relations API and known entity relationships to populate
# the entity_dependencies collection. Idempotent: checks source+target
# before creating.
#
# Usage:
#   dot-dependency-scan [--cloud|--local] [--dry-run]
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/../config/environment.sh"

VERSION="3.0.0"
DRY_RUN=""

log_info() { echo "[INFO] $1"; }
log_ok()   { echo "[OK]   $1"; }
log_warn() { echo "[WARN] $1"; }
log_skip() { echo "[SKIP] $1"; }
log_err()  { echo "[ERR]  $1" >&2; }

show_help() {
  cat << EOF
dot-dependency-scan v${VERSION}

Scans Directus relations and known entity relationships to populate
the entity_dependencies collection. Idempotent — won't create duplicates.

Usage:
  dot-dependency-scan [--cloud|--local] [--dry-run]

EOF
  show_environment_help
}

main() {
  for arg in "$@"; do
    case "$arg" in
      --dry-run) DRY_RUN="1" ;;
      --help|-h) show_help; exit 0 ;;
    esac
  done

  init_environment "$@"
  local BASE_URL="$DIRECTUS_URL"

  echo "========================================="
  echo "DOT Tool: Dependency Scan v${VERSION}"
  echo "========================================="
  print_environment_banner "$@"

  # Auth
  if [[ -z "${DOT_TOKEN:-}" ]]; then
    source "${SCRIPT_DIR}/dot-auth" "$@"
  fi
  if [[ -z "${DOT_TOKEN:-}" ]]; then
    log_err "Authentication failed"; exit 1
  fi

  local tmp_py
  tmp_py=$(mktemp /tmp/dot-dep-scan-XXXXXX.py)
  trap "rm -f '$tmp_py'" EXIT

  cat > "$tmp_py" << 'PYEOF'
import json, os, sys, ssl, urllib.request, urllib.parse

base_url = os.environ['BASE_URL']
token = os.environ['DOT_TOKEN']
dry_run = os.environ.get('DRY_RUN', '')

ctx = ssl.create_default_context()
ctx.check_hostname = False
ctx.verify_mode = ssl.CERT_NONE

def api(method, path, data=None):
    url = f'{base_url}{path}'
    payload = json.dumps(data).encode() if data else None
    req = urllib.request.Request(url, data=payload, method=method,
        headers={'Authorization': f'Bearer {token}', 'Content-Type': 'application/json'})
    try:
        resp = urllib.request.urlopen(req, context=ctx)
        return resp.status, json.loads(resp.read())
    except urllib.error.HTTPError as e:
        body = e.read().decode()
        try:
            return e.code, json.loads(body)
        except:
            return e.code, {'error': body[:300]}

def get_items(collection, fields='*', filters=None, limit=500):
    """Fetch items from a collection."""
    params = f'fields={fields}&limit={limit}'
    if filters:
        params += f'&{filters}'
    code, resp = api('GET', f'/items/{collection}?{params}')
    if code == 200:
        return resp.get('data', [])
    print(f'  [WARN] Failed to fetch {collection}: HTTP {code}')
    return []

def get_next_dep_code():
    """Get the next DEP-NNNN code."""
    code, resp = api('GET', '/items/entity_dependencies?sort=-code&limit=1&fields=code&filter[code][_nnull]=true')
    if code == 200 and resp.get('data'):
        last = resp['data'][0].get('code', '')
        import re
        m = re.search(r'\d+$', last)
        if m:
            return int(m.group()) + 1
    return 1

# Initialize counter
_next_code_num = get_next_dep_code()

def dep_exists(source_type, source_code, target_type, target_code, relation_type):
    """Check if a dependency already exists."""
    f = (f'filter[source_type][_eq]={urllib.parse.quote(source_type)}'
         f'&filter[source_code][_eq]={urllib.parse.quote(source_code)}'
         f'&filter[target_type][_eq]={urllib.parse.quote(target_type)}'
         f'&filter[target_code][_eq]={urllib.parse.quote(target_code)}'
         f'&filter[relation_type][_eq]={urllib.parse.quote(relation_type)}')
    code, resp = api('GET', f'/items/entity_dependencies?{f}&limit=1&fields=id')
    if code == 200 and resp.get('data'):
        return True
    return False

def create_dep(source_type, source_code, target_type, target_code,
               relation_type, direction='forward', confidence=1.0):
    """Create a dependency record with explicit DEP-NNNN code."""
    global _next_code_num

    if dep_exists(source_type, source_code, target_type, target_code, relation_type):
        return 'skip'

    dep_code = f'DEP-{_next_code_num:04d}'

    if dry_run:
        print(f'  [DRY]  {dep_code}: {source_code} --[{relation_type}]--> {target_code}')
        _next_code_num += 1
        return 'dry'

    payload = {
        'code': dep_code,
        'source_type': source_type,
        'source_code': source_code,
        'target_type': target_type,
        'target_code': target_code,
        'relation_type': relation_type,
        'direction': direction,
        'auto_detected': True,
        'confidence': confidence,
        'status': 'active',
    }
    code, resp = api('POST', f'/items/entity_dependencies', payload)
    if code == 200:
        _next_code_num += 1
        return 'created'
    else:
        print(f'  [ERR]  Failed to create dep {dep_code} {source_code}->{target_code}: HTTP {code} — {json.dumps(resp)[:100]}')
        return 'error'

# ===================================================================
# Build collection→entity_type map dynamically from meta_catalog
# ===================================================================
print('Loading meta_catalog...')
cat_items_raw = get_items('meta_catalog', fields='entity_type,registry_collection', limit=100)
COLLECTION_TO_ENTITY = {}
for c in cat_items_raw:
    et = c.get('entity_type', '')
    rc = c.get('registry_collection', '')
    if et and rc:
        COLLECTION_TO_ENTITY[rc] = et
print(f'  Mapped {len(COLLECTION_TO_ENTITY)} collections to entity types')

# Code field overrides (most collections use "code")
CODE_FIELD = {
    'workflows': 'process_code',
    'table_registry': 'table_id',
}

def get_code_field(collection):
    return CODE_FIELD.get(collection, 'code')

stats = {'created': 0, 'skipped': 0, 'errors': 0}

def track(result):
    if result == 'created':
        stats['created'] += 1
    elif result == 'skip':
        stats['skipped'] += 1
    elif result == 'error':
        stats['errors'] += 1
    elif result == 'dry':
        stats['created'] += 1

# ===================================================================
# SCAN 1: Schema-level relations (M2O between registry collections)
# ===================================================================
print()
print('=== Scan 1: Schema Relations ===')

code, resp = api('GET', '/relations')
if code == 200:
    relations = resp.get('data', [])
    print(f'  Found {len(relations)} total Directus relations')

    for rel in relations:
        col = rel.get('collection', '')
        field = rel.get('field', '')
        related = rel.get('related_collection', '')

        if not col or not related:
            continue
        if col.startswith('directus_') or related.startswith('directus_'):
            continue
        # Skip user_created/user_updated fields
        if field in ('user_created', 'user_updated'):
            continue

        src_type = COLLECTION_TO_ENTITY.get(col)
        tgt_type = COLLECTION_TO_ENTITY.get(related)

        # Both collections must be registry collections
        if src_type and tgt_type:
            track(create_dep(src_type, f'{col}.{field}', tgt_type, related,
                           'belongs_to', 'forward', 1.0))
else:
    print(f'  [WARN] Could not fetch relations: HTTP {code}')

# ===================================================================
# SCAN 2: Checkpoint Set Items (CP <-> CPS) — junction table
# ===================================================================
print()
print('=== Scan 2: Checkpoint Set Items ===')

cps_items = get_items('checkpoint_set_items',
    fields='id,type_id.code,set_id.code',
    limit=500)
print(f'  Found {len(cps_items)} checkpoint_set_items')

for item in cps_items:
    cp_code = (item.get('type_id') or {}).get('code', '')
    cps_code = (item.get('set_id') or {}).get('code', '')
    if cp_code and cps_code:
        track(create_dep('checkpoint_type', cp_code, 'checkpoint_set', cps_code,
                        'belongs_to', 'forward', 1.0))

# ===================================================================
# SCAN 3: Workflow Steps -> Workflows (instance-level)
# ===================================================================
print()
print('=== Scan 3: Workflow Steps -> Workflows ===')

wf_steps = get_items('workflow_steps',
    fields='id,code,workflow_id.process_code',
    limit=500)
print(f'  Found {len(wf_steps)} workflow_steps')

for step in wf_steps:
    step_code = step.get('code', '')
    wf_code = (step.get('workflow_id') or {}).get('process_code', '')
    if step_code and wf_code:
        track(create_dep('workflow_step', step_code, 'workflow', wf_code,
                        'belongs_to', 'forward', 1.0))

# ===================================================================
# SCAN 4: Workflow Steps with Checkpoint Sets (uses)
# ===================================================================
print()
print('=== Scan 4: Workflow Steps <-> Checkpoint Sets ===')

wf_steps_cps = get_items('workflow_steps',
    fields='id,code,checkpoint_set_id.code',
    filters='filter[checkpoint_set_id][_nnull]=true',
    limit=500)
print(f'  Found {len(wf_steps_cps)} workflow_steps with checkpoint_sets')

for step in wf_steps_cps:
    step_code = step.get('code', '')
    cps_code = (step.get('checkpoint_set_id') or {}).get('code', '')
    if step_code and cps_code:
        track(create_dep('workflow_step', step_code, 'checkpoint_set', cps_code,
                        'uses', 'forward', 1.0))

# ===================================================================
# SCAN 4b: Workflow Change Requests -> Workflows
# ===================================================================
print()
print('=== Scan 4b: WCR -> Workflows ===')

wcrs = get_items('workflow_change_requests',
    fields='id,title,workflow_id.process_code',
    limit=500)
print(f'  Found {len(wcrs)} workflow_change_requests')

for wcr in wcrs:
    wcr_title = wcr.get('title', '')
    wf_code = (wcr.get('workflow_id') or {}).get('process_code', '')
    if wcr_title and wf_code:
        wcr_id = wcr.get('id', '')
        track(create_dep('wcr', f'WCR-{wcr_id}', 'workflow', wf_code,
                        'belongs_to', 'forward', 1.0))

# ===================================================================
# SCAN 4c: Workflows -> Tasks
# ===================================================================
print()
print('=== Scan 4c: Workflows -> Tasks ===')

wf_tasks = get_items('workflows',
    fields='id,process_code,task_id.name',
    filters='filter[task_id][_nnull]=true',
    limit=500)
print(f'  Found {len(wf_tasks)} workflows with tasks')

for wf in wf_tasks:
    wf_code = wf.get('process_code', '')
    task_id = wf.get('task_id')
    if wf_code and task_id and isinstance(task_id, dict):
        task_name = task_id.get('name', '')
        if task_name:
            track(create_dep('workflow', wf_code, 'task', f'task-{wf.get("id","")}',
                            'belongs_to', 'forward', 0.9))

# ===================================================================
# SCAN 5: Workflow Step Relations (step -> step)
# ===================================================================
print()
print('=== Scan 5: Workflow Step Relations ===')

step_rels = get_items('workflow_step_relations',
    fields='id,from_step_id.code,to_step_id.code,relation_type',
    limit=500)
print(f'  Found {len(step_rels)} step relations')

for rel in step_rels:
    from_code = (rel.get('from_step_id') or {}).get('code', '')
    to_code = (rel.get('to_step_id') or {}).get('code', '')
    rel_type = rel.get('relation_type', 'related')
    if from_code and to_code:
        # Map relation_type to our standard types
        dep_rel = 'sequence' if rel_type in ('next', 'sequence') else \
                  'triggers' if rel_type in ('triggers',) else 'related'
        track(create_dep('workflow_step', from_code, 'workflow_step', to_code,
                        dep_rel, 'forward', 1.0))

# ===================================================================
# SCAN 6: Meta Catalog -> Collections (registry_collection field)
# ===================================================================
print()
print('=== Scan 6: Meta Catalog -> Collections ===')

cat_items = get_items('meta_catalog',
    fields='id,code,registry_collection',
    filters='filter[registry_collection][_nnull]=true',
    limit=100)
print(f'  Found {len(cat_items)} meta_catalog entries with registry_collection')

for item in cat_items:
    cat_code = item.get('code', '')
    reg_col = item.get('registry_collection', '')
    if cat_code and reg_col:
        # Find the collection code in collection_registry
        cols = get_items('collection_registry',
            fields='code',
            filters=f'filter[collection_name][_eq]={urllib.parse.quote(reg_col)}',
            limit=1)
        if cols:
            col_code = cols[0].get('code', '')
            if col_code:
                track(create_dep('collection', col_code, 'collection', reg_col,
                                'contains', 'forward', 0.9))

# ===================================================================
# SCAN 7: DEPENDS_ON — table_registry → collections (functional dep)
# ===================================================================
print()
print('=== Scan 7: table_registry -> collections (depends_on) ===')

tbl_items = get_items('table_registry',
    fields='id,table_id,collection',
    filters='filter[collection][_nnull]=true',
    limit=200)
print(f'  Found {len(tbl_items)} table_registry entries with collection')

for item in tbl_items:
    tbl_code = item.get('table_id', '')
    col_name = item.get('collection', '')
    if tbl_code and col_name:
        track(create_dep('table', tbl_code, 'collection', col_name,
                        'depends_on', 'forward', 0.9))

# ===================================================================
# SCAN 8: DEPENDS_ON — workflow_steps with checkpoint_sets (functional)
# ===================================================================
print()
print('=== Scan 8: workflow_steps depends_on checkpoint_sets ===')

# Re-scan steps with checkpoint_set_id but as depends_on (functional dep)
for step in wf_steps_cps:
    step_code = step.get('code', '')
    cps_code = (step.get('checkpoint_set_id') or {}).get('code', '')
    if step_code and cps_code:
        track(create_dep('workflow_step', step_code, 'checkpoint_set', cps_code,
                        'depends_on', 'forward', 0.9))

# ===================================================================
# SCAN 9: DEPENDS_ON — DOT tools → collections they operate on
# ===================================================================
print()
print('=== Scan 9: DOT tools depends_on collections ===')

import os, glob

dot_bin_dir = os.environ.get('DOT_BIN_DIR', '')
if not dot_bin_dir:
    # Try to find dot/bin relative to script
    script_dir = os.path.dirname(os.path.abspath(__file__)) if '__file__' in dir() else ''
    if not script_dir:
        # Fallback: check common locations
        for candidate in ['/opt/incomex/web-test/dot/bin', './dot/bin']:
            if os.path.isdir(candidate):
                dot_bin_dir = candidate
                break

if dot_bin_dir and os.path.isdir(dot_bin_dir):
    # Get all registered collections
    all_collections = set(COLLECTION_TO_ENTITY.keys())

    dot_scripts = sorted(glob.glob(os.path.join(dot_bin_dir, 'dot-*')))
    print(f'  Scanning {len(dot_scripts)} DOT scripts for collection references')

    # Get DOT tools from registry
    dot_tools = get_items('dot_tools', fields='code,name', limit=200)
    name_to_code = {}
    for dt in dot_tools:
        name = dt.get('name', '')
        code = dt.get('code', '')
        if name and code:
            name_to_code[name] = code

    for script_path in dot_scripts:
        script_name = os.path.basename(script_path)
        dot_code = name_to_code.get(script_name, '')
        if not dot_code:
            continue

        try:
            with open(script_path, 'r', errors='ignore') as f:
                content = f.read()
        except:
            continue

        # Find collection references in script content
        for col_name in all_collections:
            # Look for collection name as a string literal or API path
            if f"'{col_name}'" in content or f'"{col_name}"' in content or f'/items/{col_name}' in content:
                track(create_dep('dot_tool', dot_code, 'collection', col_name,
                                'depends_on', 'forward', 0.8))
else:
    print('  [SKIP] Cannot find dot/bin directory for DOT script scanning')

# ===================================================================
# SCAN 10: DEPENDS_ON — pages → collections (functional dep)
# ===================================================================
print()
print('=== Scan 10: pages depends_on collections ===')

pages = get_items('ui_pages', fields='code,route', limit=100)
print(f'  Found {len(pages)} ui_pages')

# Map page routes to known collection usage patterns
page_collection_map = {
    '/knowledge/registries': ['meta_catalog', 'table_registry'],
    '/knowledge': ['meta_catalog'],
}

for page in pages:
    page_code = page.get('code', '')
    route = page.get('route', '')
    if not page_code or not route:
        continue
    for route_prefix, cols in page_collection_map.items():
        if route.startswith(route_prefix):
            for col in cols:
                track(create_dep('page', page_code, 'collection', col,
                                'depends_on', 'forward', 0.7))

# ===================================================================
# Summary
# ===================================================================
print()
print('=========================================')
print(f'Dependency Scan Complete')
print(f'  Created:  {stats["created"]}')
print(f'  Skipped:  {stats["skipped"]} (already exist)')
print(f'  Errors:   {stats["errors"]}')
total_code, total_resp = api('GET', '/items/entity_dependencies?aggregate[count]=id')
if total_code == 200:
    total = total_resp.get('data', [{}])[0].get('count', {}).get('id', '?')
    print(f'  Total in DB: {total}')
print('=========================================')
PYEOF

  BASE_URL="$BASE_URL" DOT_TOKEN="$DOT_TOKEN" DRY_RUN="${DRY_RUN}" \
    DOT_BIN_DIR="${SCRIPT_DIR}" \
    python3 "$tmp_py" < /dev/null

  rm -f "$tmp_py"

  echo ""
  echo "========================================="
  echo "DOT Tool: Dependency Scan - COMPLETE"
  echo "========================================="
}

main "$@"
