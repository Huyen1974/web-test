#!/usr/bin/env bash
# =============================================================================
# dot-species-register — Register a species in entity_species
# =============================================================================
# CHECKED-NO-DUPLICATE: [searched dot/bin/dot-*species* — no species register tool]
# VERSION: 1.0.0
# §0-E DOT-FIRST: All governance declarations MUST go through DOT tools.
#
# Usage:
#   dot-species-register <species_code> <display_name> <composition_level> <management_mode> [options]
#
# Options:
#   --prefix P            Entity code prefix (e.g. DOT-, WKF-)
#   --description D       Description text
#   --cloud|--local       Environment
#   --dry-run             Preview mode
#   --help, -h            Show help
#
# Examples:
#   dot-species-register dot_tool "DOT Tool" atom governed --prefix DOT-
#   dot-species-register workflow "Workflow" compound governed --prefix WKF-
#
# species_code is IMMUTABLE after creation.
# Auto-generates code SPE-XXX from species_code.
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/../config/environment.sh"

VERSION="1.0.0"

show_help() {
  cat << 'EOF'
dot-species-register v1.0.0 — Register species in entity_species

Usage: dot-species-register <species_code> <display_name> <composition_level> <management_mode> [options]

Positional:
  species_code          Machine-readable ID (IMMUTABLE). e.g. dot_tool, workflow
  display_name          Human-readable name. e.g. "DOT Tool"
  composition_level     atom|molecule|compound|material|product|building
  management_mode       governed|observed|excluded

Options:
  --prefix P            Code prefix (e.g. DOT-, WKF-)
  --description D       Description
  --cloud|--local       Environment
  --dry-run             Preview mode
  --help, -h            This help

Idempotent: skips if species_code already exists.
Auto-generates code SPE-XXX from species_code.
EOF
  show_environment_help
}

main() {
  local SPECIES_CODE="" DISPLAY_NAME="" COMP_LEVEL="" MGMT_MODE=""
  local PREFIX="" DESCRIPTION="" DRY_RUN=""
  local POSITIONAL=()

  while [[ $# -gt 0 ]]; do
    case $1 in
      --prefix) PREFIX="$2"; shift 2 ;;
      --description) DESCRIPTION="$2"; shift 2 ;;
      --dry-run) DRY_RUN="1"; shift ;;
      --help|-h) show_help; exit 0 ;;
      --local|--cloud) shift ;;
      -*) echo "[ERR] Unknown option: $1" >&2; exit 1 ;;
      *) POSITIONAL+=("$1"); shift ;;
    esac
  done

  if [[ ${#POSITIONAL[@]} -lt 4 ]]; then
    echo "[ERR] 4 positional args required: species_code display_name composition_level management_mode" >&2
    exit 1
  fi

  SPECIES_CODE="${POSITIONAL[0]}"
  DISPLAY_NAME="${POSITIONAL[1]}"
  COMP_LEVEL="${POSITIONAL[2]}"
  MGMT_MODE="${POSITIONAL[3]}"

  # Validate
  case "$COMP_LEVEL" in
    atom|molecule|compound|material|product|building) ;;
    *) echo "[ERR] Invalid composition_level: $COMP_LEVEL" >&2; exit 1 ;;
  esac
  case "$MGMT_MODE" in
    governed|observed|excluded) ;;
    *) echo "[ERR] Invalid management_mode: $MGMT_MODE" >&2; exit 1 ;;
  esac

  init_environment "$@" 2>/dev/null || init_environment
  local BASE_URL="$DIRECTUS_URL"

  if [[ -z "${DOT_TOKEN:-}" ]]; then
    source "${SCRIPT_DIR}/dot-auth" "$@" 2>/dev/null || source "${SCRIPT_DIR}/dot-auth"
  fi
  if [[ -z "${DOT_TOKEN:-}" ]]; then
    echo "[ERR] Authentication failed" >&2; exit 1
  fi

  # Check if exists
  local CHECK_RESP CHECK_CODE
  CHECK_RESP=$(curl -sS --globoff -k -X GET \
    "${BASE_URL}/items/entity_species?filter[species_code][_eq]=${SPECIES_CODE}&fields=id,code,species_code" \
    -H "Authorization: Bearer $DOT_TOKEN" -w "\n%{http_code}")
  CHECK_CODE="${CHECK_RESP##*$'\n'}"
  local CHECK_BODY="${CHECK_RESP%$'\n'*}"

  if [[ "$CHECK_CODE" == "200" ]]; then
    local EXISTING
    EXISTING=$(echo "$CHECK_BODY" | jq '.data | length')
    if [[ "$EXISTING" -gt 0 ]]; then
      local EX_CODE
      EX_CODE=$(echo "$CHECK_BODY" | jq -r '.data[0].code')
      echo "[SKIP] species_code '${SPECIES_CODE}' already registered as ${EX_CODE}"
      exit 0
    fi
  fi

  # Generate code: SPE-XXX (uppercase first 3 chars of species_code)
  local CODE_SUFFIX
  CODE_SUFFIX=$(echo "$SPECIES_CODE" | tr '[:lower:]' '[:upper:]' | sed 's/_//g' | cut -c1-3)
  local NEW_CODE="SPE-${CODE_SUFFIX}"

  # Check for code collision
  local CODE_CHECK
  CODE_CHECK=$(curl -sS --globoff -k -X GET \
    "${BASE_URL}/items/entity_species?filter[code][_eq]=${NEW_CODE}&fields=id" \
    -H "Authorization: Bearer $DOT_TOKEN")
  local CODE_EXISTS
  CODE_EXISTS=$(echo "$CODE_CHECK" | jq '.data | length' 2>/dev/null || echo "0")
  if [[ "$CODE_EXISTS" -gt 0 ]]; then
    # Append more chars to make unique
    CODE_SUFFIX=$(echo "$SPECIES_CODE" | tr '[:lower:]' '[:upper:]' | sed 's/_//g' | cut -c1-4)
    NEW_CODE="SPE-${CODE_SUFFIX}"
  fi

  if [[ -n "$DRY_RUN" ]]; then
    echo "[DRY] Would register species '${SPECIES_CODE}' as ${NEW_CODE}"
    echo "  display_name=${DISPLAY_NAME} level=${COMP_LEVEL} mode=${MGMT_MODE} prefix=${PREFIX:-NULL}"
    exit 0
  fi

  local PAYLOAD
  PAYLOAD=$(jq -nc \
    --arg code "$NEW_CODE" \
    --arg sc "$SPECIES_CODE" \
    --arg dn "$DISPLAY_NAME" \
    --arg cl "$COMP_LEVEL" \
    --arg mm "$MGMT_MODE" \
    --arg pf "$PREFIX" \
    --arg desc "$DESCRIPTION" \
    '{
      code: $code,
      species_code: $sc,
      display_name: $dn,
      composition_level: $cl,
      management_mode: $mm,
      status: "active"
    }
    + (if $pf != "" then {prefix: $pf} else {} end)
    + (if $desc != "" then {description: $desc} else {} end)')

  local RESP RESP_CODE
  RESP=$(curl -sS --globoff -k -X POST "${BASE_URL}/items/entity_species" \
    -H "Authorization: Bearer $DOT_TOKEN" \
    -H "Content-Type: application/json" \
    -d "$PAYLOAD" -w "\n%{http_code}")
  RESP_CODE="${RESP##*$'\n'}"

  if [[ "$RESP_CODE" == "200" ]]; then
    echo "[OK] Registered species '${SPECIES_CODE}' as ${NEW_CODE} (${DISPLAY_NAME}, ${COMP_LEVEL}/${MGMT_MODE})"
  else
    local RESP_BODY="${RESP%$'\n'*}"
    echo "[ERR] Failed: HTTP ${RESP_CODE}" >&2
    echo "$RESP_BODY" | head -c 200 >&2
    exit 1
  fi
}

main "$@"
