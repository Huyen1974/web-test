#!/usr/bin/env bash
# =============================================================================
# dot-registry-crosscheck — Kiểm chứng ngược: xuôi (snapshot) vs ngược (baseline + changelog)
# =============================================================================
# CHECKED-NO-DUPLICATE: [searched dot/bin/ for "crosscheck" — no match]
# VERSION: 3.0.0
#
# NGUYÊN TẮC: "2×3=6, verify 6÷3=2" (Huyen)
#
# Phương pháp kiểm chứng ngược:
#   XUÔI  = live count từ collection (snapshot hiện tại)
#   NGƯỢC = baseline_count + SUM(changelog created) - SUM(changelog deleted)
#
# Nếu hệ thống nhất quán: XUÔI == NGƯỢC cho mọi entity type.
#
# Output: bảng 19 types × xuôi × ngược × khớp/lệch
# Nếu LỆCH → ghi system_issues nghiêm_trọng (với --write).
#
# Usage:
#   dot-registry-crosscheck [--cloud|--local] [--write]
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/../config/environment.sh"

VERSION="3.0.0"
WRITE_ISSUES=""

for arg in "$@"; do
  case "$arg" in
    --write) WRITE_ISSUES="yes" ;;
    --help|-h)
      head -20 "$0" | tail -18
      show_environment_help
      exit 0
      ;;
  esac
done

init_environment "$@"

echo ""
echo "═══════════════════════════════════════════════════════════"
echo "  KIỂM CHỨNG NGƯỢC v${VERSION}"
echo "  Xuôi (live count) vs Ngược (baseline + changelog)"
echo "═══════════════════════════════════════════════════════════"
print_environment_banner "$@"

TOKEN="${DIRECTUS_TOKEN:-}"
if [[ -z "$TOKEN" ]]; then
  echo -e "${RED}[LỖI]${NC} Không thể xác thực với Directus" >&2
  exit 1
fi

tmp_py=$(mktemp /tmp/dot-crosscheck-XXXXXX.py)
trap "rm -f '$tmp_py'" EXIT

cat > "$tmp_py" << 'PYEOF'
import json, os, sys, ssl, urllib.request, urllib.parse

base_url = os.environ['DIRECTUS_URL']
token = os.environ['DIRECTUS_TOKEN']
write_issues = os.environ.get('WRITE_ISSUES', '') == 'yes'

ctx = ssl.create_default_context()
ctx.check_hostname = False
ctx.verify_mode = ssl.CERT_NONE

def api_get(path):
    url = base_url + path
    req = urllib.request.Request(url, headers={'Authorization': f'Bearer {token}'})
    try:
        resp = urllib.request.urlopen(req, context=ctx, timeout=30)
        return json.loads(resp.read())
    except Exception as e:
        return {'error': str(e)}

def api_post(path, data):
    url = base_url + path
    payload = json.dumps(data).encode()
    req = urllib.request.Request(url, data=payload, headers={
        'Authorization': f'Bearer {token}',
        'Content-Type': 'application/json'
    }, method='POST')
    try:
        resp = urllib.request.urlopen(req, context=ctx, timeout=30)
        return json.loads(resp.read())
    except Exception as e:
        return {'error': str(e)}

def api_aggregate_count(collection, filter_qs=''):
    """Đếm live từ collection bằng aggregate API"""
    path = f'/items/{collection}?aggregate[count]=id'
    if filter_qs:
        path += '&' + filter_qs
    resp = api_get(path)
    if 'error' in resp:
        return None
    data = resp.get('data', [])
    if data and isinstance(data, list) and len(data) > 0:
        cnt = data[0].get('count', {})
        return int(cnt.get('id', 0) if isinstance(cnt, dict) else cnt)
    return None

# ============================================================
# Bước 1: Lấy meta_catalog
# ============================================================
resp = api_get('/items/meta_catalog?fields=id,code,name,entity_type,registry_collection,actual_count,record_count,orphan_count,baseline_count,status&sort=code&limit=-1')
catalog = resp.get('data', [])
if not catalog:
    print('[LỖI] Không thể đọc meta_catalog')
    sys.exit(1)

active_catalog = [e for e in catalog if e.get('status') in ('active', 'published')]
print(f'[INFO] {len(catalog)} loại ({len(active_catalog)} active)')

# ============================================================
# Bước 2: Lấy changelog stats per entity_type
# ============================================================
changelog_resp = api_get('/items/registry_changelog?fields=entity_type,action&limit=-1')
changelog = changelog_resp.get('data', [])
print(f'[INFO] {len(changelog)} bản ghi changelog')

changelog_stats = {}
for entry in changelog:
    et = entry.get('entity_type', '')
    action = entry.get('action', '')
    if et not in changelog_stats:
        changelog_stats[et] = {'create': 0, 'update': 0, 'delete': 0}
    if 'create' in action:
        changelog_stats[et]['create'] += 1
    elif 'delete' in action:
        changelog_stats[et]['delete'] += 1
    elif 'update' in action:
        changelog_stats[et]['update'] += 1

print()

# ============================================================
# KIỂM CHỨNG CHÍNH: Xuôi vs Ngược per entity type
# ============================================================
print('╔══════════════════════════════════════════════════════════╗')
print('║  KIỂM CHỨNG NGƯỢC: Xuôi (live) vs Ngược (baseline+Δ)  ║')
print('╚══════════════════════════════════════════════════════════╝')

header = f'{"Mã":<10} {"Tên":<22} {"Xuôi":<8} {"Base":<8} {"+Tạo":<6} {"-Xoá":<6} {"Ngược":<8} {"Kết quả"}'
print(header)
print('─' * 85)

MATCH = 0
MISMATCH = 0
NO_BASELINE = 0
NO_COLLECTION = 0
issues_to_write = []
results_json = []

for entry in active_catalog:
    et = entry.get('entity_type', '')
    code = entry.get('code', '')
    name = (entry.get('name', '') or '')[:20]
    col = entry.get('registry_collection', '')
    baseline = entry.get('baseline_count') or 0

    # Xuôi: live count from collection
    if col:
        xuoi = api_aggregate_count(col)
    else:
        xuoi = None

    # Changelog deltas
    stats = changelog_stats.get(et, {'create': 0, 'update': 0, 'delete': 0})
    created = stats['create']
    deleted = stats['delete']

    # Ngược = baseline + created - deleted
    if baseline > 0:
        nguoc = baseline + created - deleted
    else:
        nguoc = None

    result_row = {
        'code': code,
        'name': entry.get('name', ''),
        'entity_type': et,
        'xuoi': xuoi,
        'baseline': baseline,
        'created': created,
        'deleted': deleted,
        'nguoc': nguoc,
        'status': 'pending',
    }

    # Determine status
    if xuoi is None:
        status_str = '⚠️ N/A (collection)'
        NO_COLLECTION += 1
        result_row['status'] = 'no_collection'
    elif nguoc is None or baseline <= 0:
        status_str = '⚠️ CHƯA BASELINE'
        NO_BASELINE += 1
        result_row['status'] = 'no_baseline'
    elif xuoi == nguoc:
        status_str = '✅ KHỚP'
        MATCH += 1
        result_row['status'] = 'match'
    else:
        delta = xuoi - nguoc
        status_str = f'❌ LỆCH {delta:+d}'
        MISMATCH += 1
        result_row['status'] = 'mismatch'
        result_row['delta'] = delta
        issues_to_write.append({
            'entity_type': et,
            'entity_code': code,
            'title': f'{code} — Kiểm chứng ngược lệch: xuôi={xuoi}, ngược={nguoc} (Δ={delta:+d})',
            'issue_type': 'sai_lệch_dữ_liệu',
            'severity': 'nghiêm_trọng' if abs(delta) > 3 else 'cảnh_báo',
        })

    results_json.append(result_row)

    xuoi_str = str(xuoi) if xuoi is not None else '—'
    nguoc_str = str(nguoc) if nguoc is not None else '—'
    base_str = str(baseline) if baseline > 0 else '—'

    print(f'{code:<10} {name:<22} {xuoi_str:<8} {base_str:<8} {"+"+str(created):<6} {"-"+str(deleted):<6} {nguoc_str:<8} {status_str}')

print()

# ============================================================
# Ghi vấn đề vào system_issues
# ============================================================
if issues_to_write and write_issues:
    print(f'[GHI] {len(issues_to_write)} vấn đề vào system_issues...')
    written = 0
    skipped = 0
    for issue in issues_to_write:
        et_filter = urllib.parse.quote(issue['entity_type'])
        existing = api_get(
            f'/items/system_issues?filter[entity_type][_eq]={et_filter}'
            f'&filter[source][_eq]=dot-registry-crosscheck'
            f'&filter[status][_in]=mở,đang_xử_lý'
            f'&limit=1&fields=id'
        )
        if existing.get('data', []):
            skipped += 1
            continue
        result = api_post('/items/system_issues', {
            'title': issue['title'][:500],
            'entity_type': issue['entity_type'],
            'entity_code': issue['entity_code'],
            'issue_type': issue['issue_type'],
            'severity': issue['severity'],
            'source': 'dot-registry-crosscheck',
            'status': 'mở',
        })
        if 'error' not in result:
            written += 1
    print(f'  Đã ghi: {written}, Bỏ qua (trùng): {skipped}')
    print()
elif issues_to_write:
    print(f'[THÔNG TIN] {len(issues_to_write)} vấn đề (dùng --write để ghi vào system_issues)')
    print()

# ============================================================
# TỔNG KẾT
# ============================================================
total_checked = MATCH + MISMATCH
total_all = total_checked + NO_BASELINE + NO_COLLECTION

print('═══════════════════════════════════════════════════════════')
print(f'  KIỂM CHỨNG NGƯỢC v3: {MATCH}/{total_checked} KHỚP, {MISMATCH} LỆCH')
print('═══════════════════════════════════════════════════════════')
print(f'  Tổng entity types:    {len(active_catalog)}')
print(f'  Có baseline + xuôi:   {total_checked}')
print(f'    KHỚP:               {MATCH}')
print(f'    LỆCH:               {MISMATCH}')
print(f'  Chưa baseline:        {NO_BASELINE}')
print(f'  Không collection:     {NO_COLLECTION}')
if issues_to_write:
    print(f'  VẤN ĐỀ:              {len(issues_to_write)}')
print('═══════════════════════════════════════════════════════════')

# Output JSON for programmatic consumption
json_path = os.environ.get('CROSSCHECK_JSON', '')
if json_path:
    with open(json_path, 'w') as f:
        json.dump({
            'match': MATCH,
            'mismatch': MISMATCH,
            'no_baseline': NO_BASELINE,
            'no_collection': NO_COLLECTION,
            'total': len(active_catalog),
            'results': results_json,
        }, f, ensure_ascii=False, indent=2)
    print(f'[INFO] JSON output: {json_path}')

if MISMATCH > 0:
    sys.exit(1)
else:
    sys.exit(0)
PYEOF

DIRECTUS_URL="$DIRECTUS_URL" DIRECTUS_TOKEN="$TOKEN" \
  WRITE_ISSUES="${WRITE_ISSUES}" \
  python3 "$tmp_py" < /dev/null

exit_code=$?

echo ""
echo "═══════════════════════════════════════════════════════════"
echo "  DOT Tool: Kiểm chứng ngược — HOÀN THÀNH"
echo "═══════════════════════════════════════════════════════════"

exit $exit_code
