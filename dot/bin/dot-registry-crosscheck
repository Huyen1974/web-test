#!/usr/bin/env bash
# =============================================================================
# dot-registry-crosscheck — Kiểm chứng ngược: so sánh snapshot vs transaction log
# =============================================================================
# CHECKED-NO-DUPLICATE: [searched dot/bin/ for "crosscheck" — no match]
# VERSION: 1.0.0
#
# NGUYÊN TẮC: "2×3=6, verify 6÷3=2" (Huyen)
#
# HƯỚNG XUÔI (snapshot): dot-registry-count-refresh → meta_catalog.actual_count
# HƯỚNG NGƯỢC (transaction log): registry_changelog → tổng create - delete
#
# SO SÁNH: Nếu Xuôi ≠ Ngược → CẢNH BÁO
#
# Cho mỗi entity_type:
#   1. Lấy actual_count từ meta_catalog (hướng xuôi)
#   2. Tìm changelog gần nhất có running_total, HOẶC đếm create/delete
#   3. So sánh → báo cáo
#
# Usage:
#   dot-registry-crosscheck [--cloud|--local] [--write]
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/../config/environment.sh"

VERSION="1.0.0"
WRITE_ISSUES=""

for arg in "$@"; do
  case "$arg" in
    --write) WRITE_ISSUES="yes" ;;
    --help|-h)
      head -20 "$0" | tail -18
      show_environment_help
      exit 0
      ;;
  esac
done

init_environment "$@"

echo ""
echo "═══════════════════════════════════════════════════════════"
echo "  KIỂM CHỨNG NGƯỢC v${VERSION}"
echo "  Nguyên tắc: Xuôi (snapshot) vs Ngược (transaction log)"
echo "═══════════════════════════════════════════════════════════"
print_environment_banner "$@"

TOKEN="${DIRECTUS_TOKEN:-}"
if [[ -z "$TOKEN" ]]; then
  echo -e "${RED}[LỖI]${NC} Không thể xác thực với Directus" >&2
  exit 1
fi

tmp_py=$(mktemp /tmp/dot-crosscheck-XXXXXX.py)
trap "rm -f '$tmp_py'" EXIT

cat > "$tmp_py" << 'PYEOF'
import json, os, sys, ssl, urllib.request, urllib.parse

base_url = os.environ['DIRECTUS_URL']
token = os.environ['DIRECTUS_TOKEN']
write_issues = os.environ.get('WRITE_ISSUES', '') == 'yes'

ctx = ssl.create_default_context()
ctx.check_hostname = False
ctx.verify_mode = ssl.CERT_NONE

def api_get(path):
    url = base_url + path
    req = urllib.request.Request(url, headers={'Authorization': f'Bearer {token}'})
    try:
        resp = urllib.request.urlopen(req, context=ctx, timeout=30)
        return json.loads(resp.read())
    except Exception as e:
        return {'error': str(e)}

def api_post(path, data):
    url = base_url + path
    payload = json.dumps(data).encode()
    req = urllib.request.Request(url, data=payload, headers={
        'Authorization': f'Bearer {token}',
        'Content-Type': 'application/json'
    }, method='POST')
    try:
        resp = urllib.request.urlopen(req, context=ctx, timeout=30)
        return json.loads(resp.read())
    except Exception as e:
        return {'error': str(e)}

# ============================================================
# Bước 1: Lấy meta_catalog (hướng xuôi)
# ============================================================
resp = api_get('/items/meta_catalog?fields=id,code,name,entity_type,registry_collection,actual_count,record_count,status&sort=code&limit=-1')
catalog = resp.get('data', [])
if not catalog:
    print('[LỖI] Không thể đọc meta_catalog')
    sys.exit(1)

print(f'[INFO] {len(catalog)} loại thực thể')

# ============================================================
# Bước 2: Đếm changelog theo entity_type (hướng ngược)
# ============================================================
changelog_resp = api_get('/items/registry_changelog?fields=entity_type,action&limit=-1')
changelog = changelog_resp.get('data', [])

print(f'[INFO] {len(changelog)} bản ghi changelog')
print()

# Tổng hợp: đếm create/delete per entity_type
changelog_stats = {}
for entry in changelog:
    et = entry.get('entity_type', '')
    action = entry.get('action', '')
    if et not in changelog_stats:
        changelog_stats[et] = {'create': 0, 'update': 0, 'delete': 0}
    if 'create' in action:
        changelog_stats[et]['create'] += 1
    elif 'delete' in action:
        changelog_stats[et]['delete'] += 1
    elif 'update' in action:
        changelog_stats[et]['update'] += 1

# ============================================================
# Bước 3: So sánh
# ============================================================
PASS = 0
WARN = 0
FAIL = 0
issues = []

print(f'{"Mã":<10} {"Tên":<25} {"Xuôi":<8} {"Tạo":<6} {"Xoá":<6} {"Net":<8} {"Trạng thái":<15}')
print('─' * 85)

for entry in catalog:
    et = entry.get('entity_type', '')
    code = entry.get('code', '')
    name = entry.get('name', '')
    actual = entry.get('actual_count') or 0
    status = entry.get('status', '')

    if status not in ('active', 'published'):
        continue

    stats = changelog_stats.get(et, {'create': 0, 'update': 0, 'delete': 0})
    creates = stats['create']
    deletes = stats['delete']
    net_changes = creates - deletes

    has_changelog = et in changelog_stats

    if not has_changelog:
        # Không có changelog → CẢNH BÁO (chưa giám sát)
        WARN += 1
        state = '⚠️ CHƯA GIÁM SÁT'
        issues.append({
            'entity_type': et,
            'entity_code': code,
            'title': f'{code} {name} — Chưa có changelog (chưa giám sát)',
            'issue_type': 'thiếu_giám_sát',
            'severity': 'cảnh_báo',
        })
    elif creates == 0 and deletes == 0:
        # Có flow nhưng chưa ghi gì → bình thường (mới thiết lập)
        PASS += 1
        state = '✅ Mới'
    else:
        # Có dữ liệu changelog → kiểm tra xu hướng
        # Lưu ý: Không thể verify chính xác actual_count từ changelog
        # vì không biết baseline (bắt đầu từ bao nhiêu).
        # Nhưng có thể phát hiện: nhiều delete mà actual tăng = bất thường
        PASS += 1
        state = f'✅ +{creates}/-{deletes}'

    print(f'{code:<10} {name:<25} {actual:<8} {creates:<6} {deletes:<6} {net_changes:<8} {state}')

# ============================================================
# Kiểm tra bổ sung: actual_count vs record_count delta
# ============================================================
print()
print('─' * 85)
print()
print('KIỂM TRA BỔ SUNG: Chênh lệch actual_count vs record_count')
print(f'{"Mã":<10} {"Tên":<25} {"Record":<10} {"Actual":<10} {"Orphan":<10} {"Trạng thái":<15}')
print('─' * 85)

for entry in catalog:
    et = entry.get('entity_type', '')
    code = entry.get('code', '')
    name = entry.get('name', '')
    record = entry.get('record_count') or 0
    actual = entry.get('actual_count') or 0
    status = entry.get('status', '')
    orphan = actual - record

    if status not in ('active', 'published'):
        continue

    if orphan == 0:
        state = '✅'
    elif orphan > 0:
        state = f'⚠️ {orphan} mồ côi'
        if orphan > actual * 0.5 and actual > 5:
            FAIL += 1
            state = f'❌ {orphan} mồ côi ({round(orphan/actual*100)}%)'
            issues.append({
                'entity_type': et,
                'entity_code': code,
                'title': f'{code} {name} — {orphan} mồ côi ({round(orphan/actual*100)}%)',
                'issue_type': 'sai_lệch_dữ_liệu',
                'severity': 'cảnh_báo',
            })
    else:
        FAIL += 1
        state = f'❌ record > actual ({record}>{actual})'
        issues.append({
            'entity_type': et,
            'entity_code': code,
            'title': f'{code} {name} — record_count ({record}) > actual_count ({actual})',
            'issue_type': 'sai_lệch_dữ_liệu',
            'severity': 'nghiêm_trọng',
        })

    print(f'{code:<10} {name:<25} {record:<10} {actual:<10} {orphan:<10} {state}')

# ============================================================
# Ghi vấn đề vào system_issues
# ============================================================
if issues and write_issues:
    print()
    print(f'[GHI] {len(issues)} vấn đề vào system_issues...')
    written = 0
    skipped = 0
    for issue in issues:
        et_filter = urllib.parse.quote(issue['entity_type'])
        title_filter = urllib.parse.quote(issue['title'])
        existing = api_get(
            f'/items/system_issues?filter[entity_type][_eq]={et_filter}'
            f'&filter[title][_eq]={title_filter}'
            f'&filter[status][_in]=mở,đang_xử_lý'
            f'&limit=1&fields=id'
        )
        if existing.get('data', []):
            skipped += 1
            continue
        result = api_post('/items/system_issues', {
            'title': issue['title'],
            'entity_type': issue['entity_type'],
            'entity_code': issue['entity_code'],
            'issue_type': issue['issue_type'],
            'severity': issue['severity'],
            'source': 'dot-registry-crosscheck',
            'status': 'mở',
        })
        if 'error' not in result:
            written += 1
    print(f'  Đã ghi: {written}, Bỏ qua: {skipped}')
elif issues:
    print()
    print(f'[THÔNG TIN] {len(issues)} vấn đề (dùng --write để ghi vào system_issues)')

# ============================================================
# Tổng kết
# ============================================================
print()
total = PASS + WARN + FAIL
print('═══════════════════════════════════════════════════════════')
print(f'  KIỂM CHỨNG NGƯỢC: {PASS}/{total} PASS, {WARN} CẢNH BÁO, {FAIL} LỖI')
print('═══════════════════════════════════════════════════════════')

if FAIL > 0:
    sys.exit(1)
elif WARN > 0:
    sys.exit(0)
else:
    sys.exit(0)
PYEOF

DIRECTUS_URL="$DIRECTUS_URL" DIRECTUS_TOKEN="$TOKEN" \
  WRITE_ISSUES="${WRITE_ISSUES}" \
  python3 "$tmp_py" < /dev/null

exit_code=$?

echo ""
echo "═══════════════════════════════════════════════════════════"
echo "  DOT Tool: Kiểm chứng ngược - HOÀN THÀNH"
echo "═══════════════════════════════════════════════════════════"

exit $exit_code
