#!/usr/bin/env bash
# =============================================================================
# dot-schema-registry-changelog-ensure - Ensure registry_changelog collection
# =============================================================================
# VERSION: 1.0.0
# CHECKED-NO-DUPLICATE: [grep dot/bin/ for "changelog" — no match]
# CHANGELOG:
#   v1.0.0 (2026-03-10): Initial version for Watchdog System
#     - registry_changelog: tracks all entity changes for watchdog system
#     - 13 fields: code, timestamp, entity_type, entity_code, entity_name,
#       action, collection_name, changed_by, alert_level, alert_detail,
#       resolved, resolved_by, resolved_at
#     - Idempotent: checks existence before create
#     - Based on dot-schema-entity-dependencies-ensure pattern
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOT_AUTH="${SCRIPT_DIR}/dot-auth"

# Source environment configuration
source "${SCRIPT_DIR}/../config/environment.sh"

VERSION="1.0.0"
COLLECTION="registry_changelog"

# Logging
log_info() { echo "[INFO] $1"; }
log_ok()   { echo "[OK]   $1"; }
log_warn() { echo "[WARN] $1"; }
log_skip() { echo "[SKIP] $1"; }
log_err()  { echo "[ERR]  $1" >&2; }

require_cmds() {
  for cmd in curl jq; do
    command -v "$cmd" >/dev/null 2>&1 || { log_err "Missing required command: $cmd"; exit 1; }
  done
}

api_request() {
  local method="$1" url="$2" data="${3-}"
  if [[ -n "${data-}" ]]; then
    curl -sS --globoff -X "$method" "$url" \
      -H "Authorization: Bearer $DOT_TOKEN" \
      -H "Content-Type: application/json" \
      -d "$data" -w "\n%{http_code}"
  else
    curl -sS --globoff -X "$method" "$url" \
      -H "Authorization: Bearer $DOT_TOKEN" \
      -w "\n%{http_code}"
  fi
}

# Required fields list (for verification)
REQUIRED_FIELDS=(code timestamp entity_type entity_code entity_name action collection_name changed_by alert_level alert_detail resolved resolved_by resolved_at)

field_payload() {
  case "$1" in
    code)
      cat <<'JSON'
{"field":"code","type":"string","meta":{"required":true,"interface":"input","width":"half","note":"Auto-ID: CLG-NNNN","options":{"placeholder":"CLG-0001"}},"schema":{"is_nullable":false,"is_unique":true,"max_length":20}}
JSON
      ;;
    timestamp)
      cat <<'JSON'
{"field":"timestamp","type":"timestamp","meta":{"special":["date-created"],"readonly":true,"width":"half","note":"When the change occurred"},"schema":{"is_nullable":false}}
JSON
      ;;
    entity_type)
      cat <<'JSON'
{"field":"entity_type","type":"string","meta":{"required":true,"interface":"select-dropdown","width":"half","note":"Type of entity changed","options":{"choices":[{"text":"Checkpoint Type","value":"checkpoint_type"},{"text":"Checkpoint Set","value":"checkpoint_set"},{"text":"Workflow","value":"workflow"},{"text":"Workflow Step","value":"workflow_step"},{"text":"DOT Tool","value":"dot_tool"},{"text":"Page","value":"page"},{"text":"Collection","value":"collection"},{"text":"Module","value":"module"},{"text":"Agent","value":"agent"},{"text":"Task","value":"task"},{"text":"Catalog","value":"catalog"},{"text":"Entity Dependency","value":"entity_dependency"},{"text":"WCR","value":"wcr"},{"text":"Table Proposal","value":"table_proposal"},{"text":"Checkpoint Instance","value":"checkpoint_instance"}]}},"schema":{"is_nullable":false,"max_length":50}}
JSON
      ;;
    entity_code)
      cat <<'JSON'
{"field":"entity_code","type":"string","meta":{"interface":"input","width":"half","note":"Entity code (null if orphan)"},"schema":{"is_nullable":true,"max_length":50}}
JSON
      ;;
    entity_name)
      cat <<'JSON'
{"field":"entity_name","type":"string","meta":{"interface":"input","width":"full","note":"Entity display name"},"schema":{"is_nullable":true,"max_length":255}}
JSON
      ;;
    action)
      cat <<'JSON'
{"field":"action","type":"string","meta":{"required":true,"interface":"select-dropdown","width":"half","note":"What happened","options":{"choices":[{"text":"Created","value":"created"},{"text":"Updated","value":"updated"},{"text":"Deleted","value":"deleted"}]}},"schema":{"is_nullable":false,"max_length":20}}
JSON
      ;;
    collection_name)
      cat <<'JSON'
{"field":"collection_name","type":"string","meta":{"required":true,"interface":"input","width":"half","note":"Source Directus collection"},"schema":{"is_nullable":false,"max_length":100}}
JSON
      ;;
    changed_by)
      cat <<'JSON'
{"field":"changed_by","type":"string","meta":{"interface":"input","width":"half","note":"User/agent/flow that made the change","default_value":"directus_flow"},"schema":{"is_nullable":true,"max_length":100,"default_value":"directus_flow"}}
JSON
      ;;
    alert_level)
      cat <<'JSON'
{"field":"alert_level","type":"string","meta":{"required":true,"interface":"select-dropdown","width":"half","note":"Alert severity","default_value":"ok","options":{"choices":[{"text":"OK","value":"ok"},{"text":"Warning","value":"warning"},{"text":"Critical","value":"critical"}]}},"schema":{"is_nullable":false,"max_length":20,"default_value":"ok"}}
JSON
      ;;
    alert_detail)
      cat <<'JSON'
{"field":"alert_detail","type":"text","meta":{"interface":"input-multiline","width":"full","note":"Alert description if warning/critical"},"schema":{"is_nullable":true}}
JSON
      ;;
    resolved)
      cat <<'JSON'
{"field":"resolved","type":"boolean","meta":{"interface":"boolean","width":"half","note":"Has this alert been resolved?","default_value":false},"schema":{"is_nullable":false,"default_value":false}}
JSON
      ;;
    resolved_by)
      cat <<'JSON'
{"field":"resolved_by","type":"string","meta":{"interface":"input","width":"half","note":"Who resolved the alert"},"schema":{"is_nullable":true,"max_length":100}}
JSON
      ;;
    resolved_at)
      cat <<'JSON'
{"field":"resolved_at","type":"timestamp","meta":{"interface":"datetime","width":"half","note":"When resolved"},"schema":{"is_nullable":true}}
JSON
      ;;
    *) return 1 ;;
  esac
}

collection_exists() {
  local resp body code
  resp=$(api_request GET "${BASE_URL}/collections/${COLLECTION}")
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"
  [[ "$code" == "200" ]]
}

field_exists() {
  local field_name="$1"
  local resp body code
  resp=$(api_request GET "${BASE_URL}/fields/${COLLECTION}")
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"
  if [[ "$code" == "200" ]]; then
    echo "$body" | jq -e --arg field "$field_name" '.data[]? | select(.field == $field)' >/dev/null 2>&1
    return $?
  fi
  return 1
}

create_collection() {
  local payload
  payload=$(jq -nc \
    --arg collection "$COLLECTION" \
    '{
      collection: $collection,
      schema: {},
      meta: {
        collection: $collection,
        icon: "history",
        note: "Registry changelog — Tracks all entity changes for watchdog system — Created by DOT v1.0.0",
        display_template: "{{code}}: {{action}} {{entity_type}}/{{entity_code}}",
        sort_field: "-timestamp"
      }
    }')

  log_info "Creating collection ${COLLECTION}"
  local resp body code
  resp=$(api_request POST "${BASE_URL}/collections" "$payload")
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"

  if [[ "$code" != "200" ]]; then
    log_err "Failed to create collection ${COLLECTION} (HTTP $code)"
    echo "$body" | head -c 300 >&2
    exit 1
  fi
  log_ok "Collection ${COLLECTION} created"
}

create_field() {
  local field_name="$1"
  local payload resp body code
  payload=$(field_payload "$field_name")

  log_info "Creating field ${COLLECTION}.${field_name}"
  resp=$(api_request POST "${BASE_URL}/fields/${COLLECTION}" "$payload")
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"

  if [[ "$code" != "200" ]]; then
    log_err "Failed to create field ${COLLECTION}.${field_name} (HTTP $code)"
    echo "$body" | head -c 200 >&2
    exit 1
  fi
  log_ok "Field ${COLLECTION}.${field_name} created"
}

verify_fields() {
  local resp body code missing=()
  resp=$(api_request GET "${BASE_URL}/fields/${COLLECTION}")
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"

  if [[ "$code" != "200" ]]; then
    log_err "Failed to list fields for ${COLLECTION} (HTTP $code)"
    exit 1
  fi

  local field_count
  field_count=$(echo "$body" | jq '.data | length')

  for field in "${REQUIRED_FIELDS[@]}"; do
    if ! echo "$body" | jq -e --arg field "$field" '.data[]? | select(.field == $field)' >/dev/null 2>&1; then
      missing+=("$field")
    fi
  done

  if [[ "${#missing[@]}" -gt 0 ]]; then
    log_err "Missing required fields: ${missing[*]}"
    exit 1
  fi

  log_ok "${COLLECTION}: All required fields present (${field_count} total, including id)"
}

show_help() {
  cat << EOF
dot-schema-registry-changelog-ensure v${VERSION}

Ensures the registry_changelog collection exists in Directus with all
required fields for the Watchdog System.

Usage:
  dot-schema-registry-changelog-ensure [options]

Options:
  --local       Use local development environment
  --cloud       Use cloud/production environment (default)
  --dry-run     Show what would be done without making changes
  --help, -h    Show this help message

Collection: registry_changelog (13 fields + id)
  - code             Auto-ID: CLG-NNNN (unique)
  - timestamp        When the change occurred (auto date-created)
  - entity_type      Type of entity changed (select-dropdown)
  - entity_code      Entity code (null if orphan)
  - entity_name      Entity display name
  - action           created|updated|deleted
  - collection_name  Source Directus collection
  - changed_by       User/agent/flow that made the change
  - alert_level      ok|warning|critical
  - alert_detail     Alert description if warning/critical
  - resolved         Has this alert been resolved?
  - resolved_by      Who resolved the alert
  - resolved_at      When resolved

EOF
  show_environment_help
}

main() {
  local DRY_RUN=false

  for arg in "$@"; do
    case "$arg" in
      --help|-h) show_help; exit 0 ;;
      --dry-run) DRY_RUN=true ;;
    esac
  done

  require_cmds
  init_environment "$@"
  BASE_URL="$DIRECTUS_URL"

  echo "========================================="
  echo "DOT Tool: Schema Registry Changelog Ensure v${VERSION}"
  echo "========================================="
  print_environment_banner "$@"
  echo "Ensuring registry_changelog collection for Watchdog System"
  echo ""

  if [[ "$DRY_RUN" == "true" ]]; then
    log_warn "DRY RUN MODE - No changes will be made"
    echo ""
  fi

  # Authentication
  if [[ -z "${DOT_TOKEN:-}" ]]; then
    if [[ ! -f "$DOT_AUTH" ]]; then
      log_err "dot-auth not found at ${DOT_AUTH}"
      exit 1
    fi
    log_info "Authenticating with Directus..."
    source "$DOT_AUTH" "$@"
  fi

  if [[ -z "${DOT_TOKEN:-}" ]]; then
    log_err "DOT_TOKEN is empty after authentication"
    exit 1
  fi

  # === COLLECTION ===
  echo ""
  echo "--- Collection: ${COLLECTION} ---"

  if collection_exists; then
    log_skip "Collection '${COLLECTION}' already exists"
  else
    if [[ "$DRY_RUN" == "true" ]]; then
      log_info "Would create collection '${COLLECTION}'"
    else
      create_collection
    fi
  fi

  # === FIELDS ===
  log_info "Ensuring required fields..."
  for field in "${REQUIRED_FIELDS[@]}"; do
    if field_exists "$field"; then
      log_skip "Field ${COLLECTION}.${field} already exists"
    else
      if [[ "$DRY_RUN" == "true" ]]; then
        log_info "Would create field ${COLLECTION}.${field}"
      else
        create_field "$field"
      fi
    fi
  done

  # === VERIFICATION ===
  echo ""
  if [[ "$DRY_RUN" != "true" ]]; then
    log_info "Running final verification..."
    if ! collection_exists; then
      log_err "Collection ${COLLECTION} missing after ensure"
      exit 1
    fi
    verify_fields
  fi

  log_ok "Collection registry_changelog ready"
  echo ""
  echo "========================================="
  echo "DOT Tool: Schema Registry Changelog Ensure - COMPLETE"
  echo "========================================="
}

main "$@"
