#!/usr/bin/env bash
# =============================================================================
# dot-registry-count-refresh — Refresh meta_catalog record counts
# =============================================================================
# CHECKED-NO-DUPLICATE: [searched dot/bin/ for "count-refresh" — only this]
# VERSION: 3.0.0
#
# 3-COLUMN COUNTING: record ≠ actual = FIND DIFFERENCES
#
#   record_count = "How many items are RECOGNIZED" (have valid code PREFIX-NNN)
#     → COUNT(registry_collection WHERE code IS NOT NULL AND code LIKE 'PREFIX-%')
#
#   actual_count = "How many items ACTUALLY EXIST" (from INDEPENDENT source)
#     → Model B: filesystem scan (dot-*, *.vue files)
#     → Model A with independent: system API, cross-reference count, etc.
#     → Model A without independent: total COUNT(registry_collection) — flagged
#
#   orphan_count = actual_count - record_count
#     → Positive = entities exist but not recognized (real orphans)
#     → Negative = registry has ghosts
#     → Zero only valid if 2 INDEPENDENT sources agree
#
# Can be triggered by:
#   - CLI: dot-registry-count-refresh [--cloud|--local]
#   - Directus Flow schedule (every 6h) via webhook
#   - Post-deploy hook in deploy-vps.yml
#
# Usage:
#   dot-registry-count-refresh [--cloud|--local] [--dry-run]
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
PROJECT_ROOT="$(cd "$DOT_ROOT/.." && pwd)"

source "${SCRIPT_DIR}/../config/environment.sh"

VERSION="3.0.0"
DRY_RUN=""

show_help() {
  cat << EOF
dot-registry-count-refresh v${VERSION} — Refresh meta_catalog record counts

record = items WITH valid code PREFIX-NNN (recognized entities)
actual = total items from INDEPENDENT source (what really exists)
orphan = actual - record (entities not yet recognized)

Usage:
  dot-registry-count-refresh [--cloud|--local] [--dry-run]

Options:
  --cloud      Use cloud Directus (default)
  --local      Use local Directus
  --dry-run    Show what would be updated without writing
  --help, -h   Show help

EOF
  show_environment_help
}

main() {
  for arg in "$@"; do
    case "$arg" in
      --dry-run) DRY_RUN="1" ;;
      --help|-h) show_help; exit 0 ;;
    esac
  done

  init_environment "$@"
  local BASE_URL="$DIRECTUS_URL"

  echo ""
  echo "======================================================="
  echo "  DOT Tool: Registry Count Refresh v${VERSION}"
  echo "======================================================="
  print_environment_banner "$@"

  # Auth
  if [[ -z "${DOT_TOKEN:-}" ]]; then
    source "${SCRIPT_DIR}/dot-auth" "$@" 2>/dev/null || true
  fi
  if [[ -z "${DOT_TOKEN:-}" ]]; then
    echo "[ERR] Authentication failed" >&2; exit 1
  fi

  # Gather filesystem counts for Model B — ALWAYS (not optional)
  local actual_tools actual_pages
  actual_tools=$(find "${DOT_ROOT}/bin" -name "dot-*" -type f 2>/dev/null | wc -l | tr -d ' ')
  actual_pages=$(find "${PROJECT_ROOT}/web/pages" -name "*.vue" -type f 2>/dev/null | wc -l | tr -d ' ')
  echo "[INFO] Filesystem: ${actual_tools} DOT tools, ${actual_pages} pages"

  local tmp_py
  tmp_py=$(mktemp /tmp/dot-count-refresh-XXXXXX.py)
  trap "rm -f '$tmp_py'" EXIT

  cat > "$tmp_py" << 'PYEOF'
import json, os, sys, ssl, urllib.request
from datetime import datetime, timezone

base_url = os.environ['BASE_URL']
token = os.environ['DOT_TOKEN']
dry_run = os.environ.get('DRY_RUN', '')
actual_tools = int(os.environ.get('ACTUAL_TOOLS', '0'))
actual_pages = int(os.environ.get('ACTUAL_PAGES', '0'))
now_iso = datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%S.000Z')

ctx = ssl.create_default_context()
ctx.check_hostname = False
ctx.verify_mode = ssl.CERT_NONE

def api(method, path, data=None):
    url = base_url + path
    payload = json.dumps(data).encode() if data else None
    req = urllib.request.Request(url, data=payload, method=method,
        headers={'Authorization': f'Bearer {token}', 'Content-Type': 'application/json'})
    try:
        resp = urllib.request.urlopen(req, context=ctx, timeout=30)
        body = resp.read()
        return resp.status, json.loads(body) if body else {}
    except urllib.error.HTTPError as e:
        body = e.read().decode()
        try:
            return e.code, json.loads(body)
        except:
            return e.code, {'error': body[:200]}
    except Exception as e:
        return 0, {'error': str(e)}

def count_total(collection):
    """Count ALL records in a collection via aggregate API."""
    code, resp = api('GET', f'/items/{collection}?aggregate[countDistinct]=id')
    if code != 200:
        return -1
    data = resp.get('data', [])
    if data and isinstance(data[0], dict):
        cd = data[0].get('countDistinct', {})
        if isinstance(cd, dict) and cd.get('id'):
            return int(cd['id'])
    return 0

def count_with_code(collection, prefix, code_field='code'):
    """Count records that have a valid code matching PREFIX-NNN pattern."""
    if not prefix:
        return count_total(collection)  # no prefix known, count all
    encoded = urllib.parse.quote(prefix)
    code, resp = api('GET', f'/items/{collection}?filter[{code_field}][_starts_with]={encoded}&aggregate[countDistinct]=id')
    if code != 200:
        # Field might not exist — fall back to counting all with non-null code_field
        code2, resp2 = api('GET', f'/items/{collection}?filter[{code_field}][_nnull]=true&aggregate[countDistinct]=id')
        if code2 != 200:
            return count_total(collection)  # ultimate fallback
        data = resp2.get('data', [])
        if data and isinstance(data[0], dict):
            cd = data[0].get('countDistinct', {})
            if isinstance(cd, dict) and cd.get('id'):
                return int(cd['id'])
        return 0
    data = resp.get('data', [])
    if data and isinstance(data[0], dict):
        cd = data[0].get('countDistinct', {})
        if isinstance(cd, dict) and cd.get('id'):
            return int(cd['id'])
    return 0

def count_system_collections():
    """Count non-directus_ collections via system API (independent of collection_registry)."""
    code, resp = api('GET', '/collections?limit=-1')
    if code != 200:
        return -1
    data = resp.get('data', [])
    return sum(1 for c in data if not c.get('collection', '').startswith('directus_'))

def count_distinct_refs(collection, field):
    """Count distinct references to entity_type in a related collection."""
    code, resp = api('GET', f'/items/{collection}?aggregate[countDistinct]={field}')
    if code != 200:
        return -1
    data = resp.get('data', [])
    if data and isinstance(data[0], dict):
        cd = data[0].get('countDistinct', {})
        if isinstance(cd, dict) and cd.get(field):
            return int(cd[field])
    return 0

import urllib.parse

# ============================================================
# CODE PREFIX MAP: registry_collection -> (prefix, code_field)
# record_count = items WITH valid code PREFIX-NNN in code_field
# Some collections use different field names for their identifier
# ============================================================
CODE_INFO = {
    'meta_catalog':               ('CAT-',  'code'),
    'table_registry':             ('tbl_',   'table_id'),   # uses table_id, not code
    'modules':                    ('MOD-',  'code'),
    'workflows':                  ('WF-',   'process_code'),  # uses process_code
    'workflow_steps':             ('ND-',   'code'),
    'workflow_change_requests':   ('WCR-',  'code'),
    'dot_tools':                  ('DOT-',  'code'),
    'ui_pages':                   ('PG-',   'code'),
    'collection_registry':        ('COL-',  'code'),
    'tasks':                      ('TASK-', 'code'),
    'agents':                     ('AGT-',  'code'),
    'checkpoint_types':           ('CP-',   'code'),
    'checkpoint_sets':            ('CPS-',  'code'),
    'entity_dependencies':        ('DEP-',  'code'),
    'table_proposals':            ('TP-',   'code'),
    'checkpoint_instances':       ('',      'code'),   # no prefix yet
    'registry_changelog':         ('',      'code'),   # no prefix
    'system_issues':              ('ISS-',  'code'),
}

# ============================================================
# ACTUAL COUNT: independent source per collection
# Model B: filesystem scan
# Model A: system API or total count (flagged if not independent)
# ============================================================
FS_ACTUAL = {
    'dot_tools': actual_tools,       # files on disk
    'ui_pages': actual_pages,        # .vue files on disk
}

SYSTEM_ACTUAL = {
    'collection_registry': count_system_collections,  # /collections system API
}

# Fetch meta_catalog with source_model
code, resp = api('GET', '/items/meta_catalog?fields=id,code,name,entity_type,source_model,registry_collection,record_count,actual_count,orphan_count&sort=code&limit=-1')
if code != 200:
    print(f'[ERR] Failed to fetch meta_catalog: HTTP {code}')
    sys.exit(1)

catalog = resp.get('data', [])
print(f'[INFO] meta_catalog: {len(catalog)} entries')
print()

updated = 0
unchanged = 0
errors = 0
changes = []
uncategorized_entry = None
managed_collections = set()  # track all registry_collection names

for entry in catalog:
    cat_id = entry['id']
    cat_code = entry['code']
    cat_name = entry['name']
    source_model = entry.get('source_model', 'A')
    collection = entry.get('registry_collection', '')
    old_record = entry.get('record_count') or 0
    old_actual = entry.get('actual_count') or 0
    old_orphan = entry.get('orphan_count') or 0

    if not collection:
        print(f'  [SKIP] {cat_code} {cat_name}: no registry_collection')
        continue

    # Track managed collections for uncategorized subtraction
    managed_collections.add(collection)

    # SPECIAL: _uncategorized — count by subtraction (handled after main loop)
    if collection == '_uncategorized':
        uncategorized_entry = entry
        continue

    # METHOD 1: record_count — items WITH valid code PREFIX-NNN
    code_info = CODE_INFO.get(collection, ('', 'code'))
    prefix, code_field = code_info
    if prefix:
        new_record = count_with_code(collection, prefix, code_field)
    else:
        # No code prefix defined → count all (changelog, etc.)
        new_record = count_total(collection)

    if new_record < 0:
        print(f'  [WARN] {cat_code} {cat_name}: collection "{collection}" not accessible')
        errors += 1
        continue

    # METHOD 2: actual_count — from INDEPENDENT source
    if collection in FS_ACTUAL:
        # Model B: filesystem count (truly independent)
        new_actual = FS_ACTUAL[collection]
        count_source = 'filesystem'
    elif collection in SYSTEM_ACTUAL:
        # System API count (truly independent)
        new_actual = SYSTEM_ACTUAL[collection]()
        count_source = 'system-api'
    elif source_model == 'B':
        # Model B without filesystem override — use total count as fallback
        new_actual = count_total(collection)
        count_source = 'directus(NEEDS-FS)'
    else:
        # Model A: use total count (all items, including those without code)
        # If prefix exists, actual may differ from record (items without code = orphans)
        new_actual = count_total(collection)
        count_source = 'directus-total'

    if new_actual < 0:
        new_actual = new_record  # fallback if source fails

    # METHOD 3: orphan_count = actual - record
    # Positive = entities exist but lack proper code (real orphans)
    # Negative = ghost records in registry
    new_orphan = new_actual - new_record

    changed = (new_record != old_record or new_actual != old_actual or new_orphan != old_orphan)
    delta_str = ''
    if changed:
        delta_str = f' (was rec={old_record}/act={old_actual}/orp={old_orphan})'
        changes.append(f'{cat_code}: rec={new_record} act={new_actual} orp={new_orphan}')

    model_tag = f'[{source_model}:{count_source}]'
    if dry_run:
        tag = '[CHG]' if changed else '[OK] '
        print(f'  {tag} {cat_code} {cat_name} {model_tag}: rec={new_record}, act={new_actual}, orp={new_orphan}{delta_str}')
        if changed:
            updated += 1
        else:
            unchanged += 1
        continue

    # PATCH meta_catalog
    patch = {
        'record_count': new_record,
        'actual_count': new_actual,
        'orphan_count': new_orphan,
        'last_scan_date': now_iso,
    }

    p_code, p_resp = api('PATCH', f'/items/meta_catalog/{cat_id}', patch)
    if p_code == 200:
        tag = '[CHG]' if changed else '[OK] '
        print(f'  {tag} {cat_code} {cat_name} {model_tag}: rec={new_record}, act={new_actual}, orp={new_orphan}{delta_str}')
        if changed:
            updated += 1
        else:
            unchanged += 1
    else:
        print(f'  [ERR] {cat_code}: PATCH failed HTTP {p_code}')
        errors += 1

# ============================================================
# SPECIAL: CAT-999 "Chưa phân loại" — count by subtraction
# actual = total Directus collections - managed collections
# ============================================================
if uncategorized_entry:
    entry = uncategorized_entry
    cat_id = entry['id']
    cat_code = entry['code']
    cat_name = entry['name']
    old_record = entry.get('record_count') or 0
    old_actual = entry.get('actual_count') or 0
    old_orphan = entry.get('orphan_count') or 0

    # Count ALL non-system collections in Directus
    total_collections = count_system_collections()

    # Also get list of collections registered in collection_registry
    cr_code, cr_resp = api('GET', '/items/collection_registry?fields=collection_name&limit=-1')
    registered_in_cr = set()
    if cr_code == 200:
        for item in cr_resp.get('data', []):
            cn = item.get('collection_name', '')
            if cn:
                registered_in_cr.add(cn)

    # Uncategorized = total collections - managed - registered in collection_registry
    all_known = managed_collections | registered_in_cr
    new_actual = max(0, total_collections - len(all_known)) if total_collections >= 0 else 0
    new_record = 0  # by definition — nobody owns them
    new_orphan = new_actual  # all are orphans

    count_source = 'subtraction'
    source_model = 'B'
    changed = (new_record != old_record or new_actual != old_actual or new_orphan != old_orphan)
    delta_str = ''
    if changed:
        delta_str = f' (was rec={old_record}/act={old_actual}/orp={old_orphan})'
        changes.append(f'{cat_code}: rec={new_record} act={new_actual} orp={new_orphan}')

    model_tag = f'[{source_model}:{count_source}]'
    if dry_run:
        tag = '[CHG]' if changed else '[OK] '
        print(f'  {tag} {cat_code} {cat_name} {model_tag}: rec={new_record}, act={new_actual}, orp={new_orphan}{delta_str}')
        if changed:
            updated += 1
        else:
            unchanged += 1
    else:
        patch = {
            'record_count': new_record,
            'actual_count': new_actual,
            'orphan_count': new_orphan,
            'last_scan_date': now_iso,
        }
        p_code, p_resp = api('PATCH', f'/items/meta_catalog/{cat_id}', patch)
        if p_code == 200:
            tag = '[CHG]' if changed else '[OK] '
            print(f'  {tag} {cat_code} {cat_name} {model_tag}: rec={new_record}, act={new_actual}, orp={new_orphan}{delta_str}')
            if changed:
                updated += 1
            else:
                unchanged += 1
        else:
            print(f'  [ERR] {cat_code}: PATCH failed HTTP {p_code}')
            errors += 1

print()
print('=========================================')
print(f'Count Refresh v3.0 Complete')
print(f'  Changed:   {updated}')
print(f'  Unchanged: {unchanged}')
print(f'  Errors:    {errors}')
if changes:
    print(f'  Deltas:')
    for c in changes:
        print(f'    {c}')
print('=========================================')
PYEOF

  BASE_URL="$BASE_URL" DOT_TOKEN="$DOT_TOKEN" DRY_RUN="${DRY_RUN:-}" \
    ACTUAL_TOOLS="$actual_tools" ACTUAL_PAGES="$actual_pages" \
    python3 "$tmp_py" < /dev/null

  rm -f "$tmp_py"

  echo ""
  echo "======================================================="
  echo "  DOT Tool: Registry Count Refresh - COMPLETE"
  echo "======================================================="
}

main "$@"
