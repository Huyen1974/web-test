#!/usr/bin/env bash
# =============================================================================
# dot-registry-count-refresh — Refresh meta_catalog record counts
# =============================================================================
# CHECKED-NO-DUPLICATE: [searched dot/bin/ for "count-refresh" — no match]
# VERSION: 1.0.0
#
# Counts actual records in each registry_collection via Directus API
# and updates meta_catalog with fresh record_count, actual_count, orphan_count.
#
# 3 independent counting methods:
#   1. record_count  — countDistinct=id on registry_collection
#   2. actual_count  — same (API-only) or filesystem count (with --full)
#   3. orphan_count  — |record_count - actual_count|
#
# Can be triggered by:
#   - CLI: dot-registry-count-refresh [--cloud|--local]
#   - Directus Flow schedule (every 6h) via webhook
#   - Post-deploy hook in deploy-vps.yml
#
# Usage:
#   dot-registry-count-refresh [--cloud|--local] [--full] [--dry-run]
#
# Options:
#   --full       Include filesystem counts for DOT tools and pages
#   --dry-run    Show what would be updated without writing
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
PROJECT_ROOT="$(cd "$DOT_ROOT/.." && pwd)"

source "${SCRIPT_DIR}/../config/environment.sh"

VERSION="1.0.0"
FULL_MODE=""
DRY_RUN=""

show_help() {
  cat << EOF
dot-registry-count-refresh v${VERSION} — Refresh meta_catalog record counts

Usage:
  dot-registry-count-refresh [--cloud|--local] [--full] [--dry-run]

Options:
  --cloud      Use cloud Directus (default)
  --local      Use local Directus
  --full       Include filesystem counts for DOT tools and pages
  --dry-run    Show what would be updated without writing
  --help, -h   Show help

EOF
  show_environment_help
}

main() {
  for arg in "$@"; do
    case "$arg" in
      --full) FULL_MODE="1" ;;
      --dry-run) DRY_RUN="1" ;;
      --help|-h) show_help; exit 0 ;;
    esac
  done

  init_environment "$@"
  local BASE_URL="$DIRECTUS_URL"

  echo ""
  echo "======================================================="
  echo "  DOT Tool: Registry Count Refresh v${VERSION}"
  echo "======================================================="
  print_environment_banner "$@"

  # Auth
  if [[ -z "${DOT_TOKEN:-}" ]]; then
    source "${SCRIPT_DIR}/dot-auth" "$@" 2>/dev/null || true
  fi
  if [[ -z "${DOT_TOKEN:-}" ]]; then
    echo "[ERR] Authentication failed" >&2; exit 1
  fi

  # Gather filesystem counts if --full
  local actual_tools=0 actual_pages=0
  if [[ -n "$FULL_MODE" ]]; then
    actual_tools=$(find "${DOT_ROOT}/bin" -name "dot-*" -type f 2>/dev/null | wc -l | tr -d ' ')
    actual_pages=$(find "${PROJECT_ROOT}/web/pages" -name "*.vue" -type f 2>/dev/null | wc -l | tr -d ' ')
    echo "[INFO] Filesystem: ${actual_tools} DOT tools, ${actual_pages} pages"
  fi

  local tmp_py
  tmp_py=$(mktemp /tmp/dot-count-refresh-XXXXXX.py)
  trap "rm -f '$tmp_py'" EXIT

  cat > "$tmp_py" << 'PYEOF'
import json, os, sys, ssl, urllib.request
from datetime import datetime, timezone

base_url = os.environ['BASE_URL']
token = os.environ['DOT_TOKEN']
dry_run = os.environ.get('DRY_RUN', '')
full_mode = os.environ.get('FULL_MODE', '')
actual_tools = int(os.environ.get('ACTUAL_TOOLS', '0'))
actual_pages = int(os.environ.get('ACTUAL_PAGES', '0'))
now_iso = datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%S.000Z')

ctx = ssl.create_default_context()
ctx.check_hostname = False
ctx.verify_mode = ssl.CERT_NONE

def api(method, path, data=None):
    url = base_url + path
    payload = json.dumps(data).encode() if data else None
    req = urllib.request.Request(url, data=payload, method=method,
        headers={'Authorization': f'Bearer {token}', 'Content-Type': 'application/json'})
    try:
        resp = urllib.request.urlopen(req, context=ctx, timeout=30)
        body = resp.read()
        return resp.status, json.loads(body) if body else {}
    except urllib.error.HTTPError as e:
        body = e.read().decode()
        try:
            return e.code, json.loads(body)
        except:
            return e.code, {'error': body[:200]}
    except Exception as e:
        return 0, {'error': str(e)}

def count_collection(collection):
    """Count records via aggregate API."""
    code, resp = api('GET', f'/items/{collection}?aggregate[countDistinct]=id')
    if code != 200:
        return -1
    data = resp.get('data', [])
    if data and isinstance(data[0], dict):
        cd = data[0].get('countDistinct', {})
        if isinstance(cd, dict) and cd.get('id'):
            return int(cd['id'])
    return 0

# Fetch meta_catalog
code, resp = api('GET', '/items/meta_catalog?fields=id,code,name,entity_type,registry_collection,record_count,actual_count,orphan_count&sort=code&limit=-1')
if code != 200:
    print(f'[ERR] Failed to fetch meta_catalog: HTTP {code}')
    sys.exit(1)

catalog = resp.get('data', [])
print(f'[INFO] meta_catalog: {len(catalog)} entries')
print()

# Filesystem override map (only in --full mode)
fs_overrides = {}
if full_mode:
    fs_overrides['dot_tools'] = actual_tools
    fs_overrides['ui_pages'] = actual_pages

updated = 0
unchanged = 0
errors = 0
changes = []

for entry in catalog:
    cat_id = entry['id']
    cat_code = entry['code']
    cat_name = entry['name']
    collection = entry.get('registry_collection', '')
    old_record = entry.get('record_count') or 0
    old_actual = entry.get('actual_count') or 0

    if not collection:
        print(f'  [SKIP] {cat_code} {cat_name}: no registry_collection')
        continue

    # Method 1: record_count — count from registry collection
    new_record = count_collection(collection)
    if new_record < 0:
        print(f'  [WARN] {cat_code} {cat_name}: collection "{collection}" not accessible')
        errors += 1
        continue

    # Method 2: actual_count — filesystem override or same as record_count
    if collection in fs_overrides:
        new_actual = fs_overrides[collection]
    else:
        new_actual = new_record

    # Method 3: orphan_count = |actual - record|
    new_orphan = abs(new_actual - new_record)

    changed = (new_record != old_record or new_actual != old_actual)
    delta_str = ''
    if changed:
        delta_str = f' (was {old_record}/{old_actual})'
        changes.append(f'{cat_code}: {old_record}→{new_record}')

    if dry_run:
        tag = '[CHG]' if changed else '[OK] '
        print(f'  {tag} {cat_code} {cat_name}: record={new_record}, actual={new_actual}, orphan={new_orphan}{delta_str}')
        if changed:
            updated += 1
        else:
            unchanged += 1
        continue

    # PATCH meta_catalog
    patch = {
        'record_count': new_record,
        'actual_count': new_actual,
        'orphan_count': new_orphan,
        'last_scan_date': now_iso,
    }

    p_code, p_resp = api('PATCH', f'/items/meta_catalog/{cat_id}', patch)
    if p_code == 200:
        tag = '[CHG]' if changed else '[OK] '
        print(f'  {tag} {cat_code} {cat_name}: record={new_record}, actual={new_actual}, orphan={new_orphan}{delta_str}')
        if changed:
            updated += 1
        else:
            unchanged += 1
    else:
        print(f'  [ERR] {cat_code}: PATCH failed HTTP {p_code}')
        errors += 1

print()
print('=========================================')
print(f'Count Refresh Complete')
print(f'  Changed:   {updated}')
print(f'  Unchanged: {unchanged}')
print(f'  Errors:    {errors}')
if changes:
    print(f'  Deltas:    {", ".join(changes)}')
print('=========================================')
PYEOF

  BASE_URL="$BASE_URL" DOT_TOKEN="$DOT_TOKEN" DRY_RUN="${DRY_RUN:-}" \
    FULL_MODE="${FULL_MODE:-}" ACTUAL_TOOLS="$actual_tools" ACTUAL_PAGES="$actual_pages" \
    python3 "$tmp_py" < /dev/null

  rm -f "$tmp_py"

  echo ""
  echo "======================================================="
  echo "  DOT Tool: Registry Count Refresh - COMPLETE"
  echo "======================================================="
}

main "$@"
