#!/usr/bin/env bash
# =============================================================================
# dot-schema-comments-extend - Add workflow linking fields to task_comments
# =============================================================================
# VERSION: 1.0.0
# CHANGELOG:
#   v1.0.0 (2026-03-03): Add M-002 linking fields to task_comments
#     - workflow_id: integer (nullable) FK -> workflows
#     - bpmn_element_id: string (nullable) - BPMN node/edge ID
#     - Idempotent: checks existence before create
#     - Does NOT modify existing fields
#     - Based on dot-schema-tasks-ensure pattern
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOT_AUTH="${SCRIPT_DIR}/dot-auth"

# Source environment configuration
source "${SCRIPT_DIR}/../config/environment.sh"

VERSION="1.0.0"
COLLECTION="task_comments"

# Logging
log_info() { echo "[INFO] $1"; }
log_ok()   { echo "[OK]   $1"; }
log_warn() { echo "[WARN] $1"; }
log_skip() { echo "[SKIP] $1"; }
log_err()  { echo "[ERR]  $1" >&2; }

require_cmds() {
  for cmd in curl jq; do
    command -v "$cmd" >/dev/null 2>&1 || { log_err "Missing required command: $cmd"; exit 1; }
  done
}

api_request() {
  local method="$1" url="$2" data="${3-}"
  if [[ -n "${data-}" ]]; then
    curl -sS --globoff -X "$method" "$url" \
      -H "Authorization: Bearer $DOT_TOKEN" \
      -H "Content-Type: application/json" \
      -d "$data" -w "\n%{http_code}"
  else
    curl -sS --globoff -X "$method" "$url" \
      -H "Authorization: Bearer $DOT_TOKEN" \
      -w "\n%{http_code}"
  fi
}

# New fields to add (NOT existing fields — we only add these)
NEW_FIELDS=(workflow_id bpmn_element_id)

field_payload() {
  case "$1" in
    workflow_id)
      cat <<'JSON'
{"field":"workflow_id","type":"integer","meta":{"required":false,"interface":"select-dropdown-m2o","special":["m2o"],"width":"half","note":"FK -> workflows (comment linked to which workflow)"},"schema":{"is_nullable":true}}
JSON
      ;;
    bpmn_element_id)
      cat <<'JSON'
{"field":"bpmn_element_id","type":"string","meta":{"required":false,"interface":"input","width":"half","note":"BPMN node/edge ID on diagram"},"schema":{"is_nullable":true}}
JSON
      ;;
    *) return 1 ;;
  esac
}

field_exists() {
  local field_name="$1"
  local resp body code
  resp=$(api_request GET "${BASE_URL}/fields/${COLLECTION}")
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"
  if [[ "$code" == "200" ]]; then
    echo "$body" | jq -e --arg field "$field_name" '.data[]? | select(.field == $field)' >/dev/null 2>&1
    return $?
  fi
  return 1
}

create_field() {
  local field_name="$1"
  local payload resp body code
  payload=$(field_payload "$field_name")

  log_info "Creating field ${COLLECTION}.${field_name}"
  resp=$(api_request POST "${BASE_URL}/fields/${COLLECTION}" "$payload")
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"

  if [[ "$code" != "200" ]]; then
    log_err "Failed to create field ${COLLECTION}.${field_name} (HTTP $code)"
    echo "$body" | head -c 200 >&2
    exit 1
  fi
  log_ok "Field ${COLLECTION}.${field_name} created"
}

setup_relations() {
  log_info "Setting up relations..."

  # task_comments.workflow_id -> workflows (SET NULL on delete)
  local relation_payload
  relation_payload=$(jq -nc '{
    collection: "task_comments",
    field: "workflow_id",
    related_collection: "workflows",
    meta: {
      one_field: "comments",
      sort_field: null,
      one_deselect_action: "nullify"
    },
    schema: {
      on_delete: "SET NULL"
    }
  }')

  local resp code
  resp=$(api_request POST "${BASE_URL}/relations" "$relation_payload")
  code="${resp##*$'\n'}"

  if [[ "$code" == "200" ]]; then
    log_ok "Relation task_comments.workflow_id -> workflows created (SET NULL)"
  elif [[ "$code" == "400" ]]; then
    log_skip "Relation task_comments.workflow_id -> workflows already exists"
  else
    log_warn "Could not create workflow_id relation (HTTP $code)"
  fi
}

verify_new_fields() {
  local resp body code missing=()
  resp=$(api_request GET "${BASE_URL}/fields/${COLLECTION}")
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"

  if [[ "$code" != "200" ]]; then
    log_err "Failed to list fields for ${COLLECTION} (HTTP $code)"
    exit 1
  fi

  local field_count
  field_count=$(echo "$body" | jq '.data | length')

  # Verify new fields exist
  for field in "${NEW_FIELDS[@]}"; do
    if ! echo "$body" | jq -e --arg field "$field" '.data[]? | select(.field == $field)' >/dev/null 2>&1; then
      missing+=("$field")
    fi
  done

  # Also verify existing fields NOT broken
  local existing_fields=(id task_id content agent_type tab_scope action date_created user_created)
  for field in "${existing_fields[@]}"; do
    if ! echo "$body" | jq -e --arg field "$field" '.data[]? | select(.field == $field)' >/dev/null 2>&1; then
      log_err "CRITICAL: Existing field ${COLLECTION}.${field} is MISSING! Schema may be broken."
      exit 1
    fi
  done

  if [[ "${#missing[@]}" -gt 0 ]]; then
    log_err "Missing new fields: ${missing[*]}"
    exit 1
  fi

  log_ok "${COLLECTION}: New fields present + existing fields intact (${field_count} total)"
}

show_help() {
  cat << EOF
dot-schema-comments-extend v${VERSION} - Add workflow linking fields to task_comments

Usage:
  dot-schema-comments-extend [options]

Options:
  --local       Use local development environment
  --cloud       Use cloud/production environment (default)
  --dry-run     Show what would be done without making changes
  --help, -h    Show this help message

New Fields Added to task_comments:
  - workflow_id       M2O -> workflows (SET NULL, nullable)
  - bpmn_element_id   BPMN node/edge ID (string, nullable)

Existing fields are NOT modified:
  id, task_id, content, agent_type, tab_scope, action, date_created, user_created

EOF
  show_environment_help
}

main() {
  local DRY_RUN=false

  for arg in "$@"; do
    case "$arg" in
      --help|-h) show_help; exit 0 ;;
      --dry-run) DRY_RUN=true ;;
    esac
  done

  require_cmds
  init_environment "$@"
  BASE_URL="$DIRECTUS_URL"

  echo "========================================="
  echo "DOT Tool: Schema Comments Extend v${VERSION}"
  echo "========================================="
  print_environment_banner "$@"
  echo "Adding workflow linking fields to task_comments"
  echo ""

  if [[ "$DRY_RUN" == "true" ]]; then
    log_warn "DRY RUN MODE - No changes will be made"
    echo ""
  fi

  # Authentication
  if [[ -z "${DOT_TOKEN:-}" ]]; then
    if [[ ! -f "$DOT_AUTH" ]]; then
      log_err "dot-auth not found at ${DOT_AUTH}"
      exit 1
    fi
    log_info "Authenticating with Directus..."
    source "$DOT_AUTH" "$@"
  fi

  if [[ -z "${DOT_TOKEN:-}" ]]; then
    log_err "DOT_TOKEN is empty after authentication"
    exit 1
  fi

  # === ADD NEW FIELDS ===
  echo ""
  echo "--- Extending: ${COLLECTION} ---"

  log_info "Adding new linking fields..."
  for field in "${NEW_FIELDS[@]}"; do
    if field_exists "$field"; then
      log_skip "Field ${COLLECTION}.${field} already exists"
    else
      if [[ "$DRY_RUN" == "true" ]]; then
        log_info "Would create field ${COLLECTION}.${field}"
      else
        create_field "$field"
      fi
    fi
  done

  # === RELATIONS ===
  echo ""
  if [[ "$DRY_RUN" != "true" ]]; then
    setup_relations
  else
    log_info "Would create relation task_comments.workflow_id -> workflows"
  fi

  # === VERIFICATION ===
  echo ""
  if [[ "$DRY_RUN" != "true" ]]; then
    log_info "Running final verification..."
    verify_new_fields
  fi

  log_ok "task_comments extended with workflow linking fields"
  echo ""
  echo "========================================="
  echo "DOT Tool: Schema Comments Extend - COMPLETE"
  echo "========================================="
}

main "$@"
