#!/usr/bin/env bash
# =============================================================================
# dot-schema-entity-dependencies-ensure - Ensure entity_dependencies collection
# =============================================================================
# VERSION: 1.0.0
# CHECKED-NO-DUPLICATE: [grep dot/bin/ for "entity-dependencies" — no match]
# CHANGELOG:
#   v1.0.0 (2026-03-07): Initial version for TD-101 / Semantic Linking Engine
#     - entity_dependencies: records all links between entities
#     - 12 fields: code, source_type/code, target_type/code, relation_type,
#       direction, auto_detected, confidence, status, date_created, date_updated
#     - Idempotent: checks existence before create
#     - Based on dot-schema-checkpoints-ensure pattern
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOT_AUTH="${SCRIPT_DIR}/dot-auth"

# Source environment configuration
source "${SCRIPT_DIR}/../config/environment.sh"

VERSION="1.0.0"
COLLECTION="entity_dependencies"

# Logging
log_info() { echo "[INFO] $1"; }
log_ok()   { echo "[OK]   $1"; }
log_warn() { echo "[WARN] $1"; }
log_skip() { echo "[SKIP] $1"; }
log_err()  { echo "[ERR]  $1" >&2; }

require_cmds() {
  for cmd in curl jq; do
    command -v "$cmd" >/dev/null 2>&1 || { log_err "Missing required command: $cmd"; exit 1; }
  done
}

api_request() {
  local method="$1" url="$2" data="${3-}"
  if [[ -n "${data-}" ]]; then
    curl -sS --globoff -X "$method" "$url" \
      -H "Authorization: Bearer $DOT_TOKEN" \
      -H "Content-Type: application/json" \
      -d "$data" -w "\n%{http_code}"
  else
    curl -sS --globoff -X "$method" "$url" \
      -H "Authorization: Bearer $DOT_TOKEN" \
      -w "\n%{http_code}"
  fi
}

# Required fields list (for verification)
REQUIRED_FIELDS=(code source_type source_code target_type target_code relation_type direction auto_detected confidence status date_created date_updated)

field_payload() {
  case "$1" in
    code)
      cat <<'JSON'
{"field":"code","type":"string","meta":{"required":true,"interface":"input","width":"half","note":"Auto-ID: DEP-NNNN","options":{"placeholder":"DEP-0001"}},"schema":{"is_nullable":false,"is_unique":true,"max_length":20}}
JSON
      ;;
    source_type)
      cat <<'JSON'
{"field":"source_type","type":"string","meta":{"required":true,"interface":"select-dropdown","width":"half","note":"Entity type of source","options":{"choices":[{"text":"Checkpoint Type","value":"checkpoint_type"},{"text":"Checkpoint Set","value":"checkpoint_set"},{"text":"Workflow","value":"workflow"},{"text":"Workflow Step","value":"workflow_step"},{"text":"DOT Tool","value":"dot_tool"},{"text":"UI Page","value":"ui_page"},{"text":"Collection","value":"collection"},{"text":"Module","value":"module"},{"text":"Agent","value":"agent"},{"text":"Document","value":"document"}]}},"schema":{"is_nullable":false,"max_length":50}}
JSON
      ;;
    source_code)
      cat <<'JSON'
{"field":"source_code","type":"string","meta":{"required":true,"interface":"input","width":"half","note":"Source entity ID (e.g. CP-005, DOT-042)"},"schema":{"is_nullable":false,"max_length":50}}
JSON
      ;;
    target_type)
      cat <<'JSON'
{"field":"target_type","type":"string","meta":{"required":true,"interface":"select-dropdown","width":"half","note":"Entity type of target","options":{"choices":[{"text":"Checkpoint Type","value":"checkpoint_type"},{"text":"Checkpoint Set","value":"checkpoint_set"},{"text":"Workflow","value":"workflow"},{"text":"Workflow Step","value":"workflow_step"},{"text":"DOT Tool","value":"dot_tool"},{"text":"UI Page","value":"ui_page"},{"text":"Collection","value":"collection"},{"text":"Module","value":"module"},{"text":"Agent","value":"agent"},{"text":"Document","value":"document"}]}},"schema":{"is_nullable":false,"max_length":50}}
JSON
      ;;
    target_code)
      cat <<'JSON'
{"field":"target_code","type":"string","meta":{"required":true,"interface":"input","width":"half","note":"Target entity ID (e.g. CPS-001, WF-001)"},"schema":{"is_nullable":false,"max_length":50}}
JSON
      ;;
    relation_type)
      cat <<'JSON'
{"field":"relation_type","type":"string","meta":{"required":true,"interface":"select-dropdown","width":"half","note":"Relationship type","options":{"choices":[{"text":"Belongs To","value":"belongs_to"},{"text":"Contains","value":"contains"},{"text":"Uses","value":"uses"},{"text":"Triggers","value":"triggers"},{"text":"Displays","value":"displays"},{"text":"Extends","value":"extends"},{"text":"Related","value":"related"}]}},"schema":{"is_nullable":false,"max_length":30}}
JSON
      ;;
    direction)
      cat <<'JSON'
{"field":"direction","type":"string","meta":{"required":true,"interface":"select-dropdown","width":"half","note":"Link direction","options":{"choices":[{"text":"Forward","value":"forward"},{"text":"Reverse","value":"reverse"},{"text":"Bidirectional","value":"bidirectional"}]},"default_value":"forward"},"schema":{"is_nullable":false,"max_length":20,"default_value":"forward"}}
JSON
      ;;
    auto_detected)
      cat <<'JSON'
{"field":"auto_detected","type":"boolean","meta":{"required":false,"interface":"boolean","width":"half","note":"true if scan detected, false if manual","default_value":false},"schema":{"is_nullable":false,"default_value":false}}
JSON
      ;;
    confidence)
      cat <<'JSON'
{"field":"confidence","type":"float","meta":{"required":false,"interface":"input","width":"half","note":"0-1. Explicit=1.0, semantic<1.0","options":{"min":0,"max":1,"step":0.1}},"schema":{"is_nullable":false,"default_value":1.0,"numeric_precision":3,"numeric_scale":2}}
JSON
      ;;
    status)
      cat <<'JSON'
{"field":"status","type":"string","meta":{"required":true,"interface":"select-dropdown","width":"half","note":"Dependency status","options":{"choices":[{"text":"Active","value":"active"},{"text":"Deprecated","value":"deprecated"}]},"default_value":"active"},"schema":{"is_nullable":false,"default_value":"active","max_length":20}}
JSON
      ;;
    date_created)
      cat <<'JSON'
{"field":"date_created","type":"timestamp","meta":{"interface":"datetime","special":["date-created"],"readonly":true,"width":"half"},"schema":{"is_nullable":false}}
JSON
      ;;
    date_updated)
      cat <<'JSON'
{"field":"date_updated","type":"timestamp","meta":{"interface":"datetime","special":["date-updated"],"readonly":true,"width":"half"},"schema":{"is_nullable":true}}
JSON
      ;;
    *) return 1 ;;
  esac
}

collection_exists() {
  local resp body code
  resp=$(api_request GET "${BASE_URL}/collections/${COLLECTION}")
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"
  [[ "$code" == "200" ]]
}

field_exists() {
  local field_name="$1"
  local resp body code
  resp=$(api_request GET "${BASE_URL}/fields/${COLLECTION}")
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"
  if [[ "$code" == "200" ]]; then
    echo "$body" | jq -e --arg field "$field_name" '.data[]? | select(.field == $field)' >/dev/null 2>&1
    return $?
  fi
  return 1
}

create_collection() {
  local payload
  payload=$(jq -nc \
    --arg collection "$COLLECTION" \
    '{
      collection: $collection,
      schema: {},
      meta: {
        collection: $collection,
        icon: "link",
        note: "Entity dependency graph — Semantic Linking Engine (Dieu 8/20) — Created by DOT v1.0.0",
        display_template: "{{code}}: {{source_code}} —[{{relation_type}}]→ {{target_code}}",
        sort_field: "code"
      }
    }')

  log_info "Creating collection ${COLLECTION}"
  local resp body code
  resp=$(api_request POST "${BASE_URL}/collections" "$payload")
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"

  if [[ "$code" != "200" ]]; then
    log_err "Failed to create collection ${COLLECTION} (HTTP $code)"
    echo "$body" | head -c 300 >&2
    exit 1
  fi
  log_ok "Collection ${COLLECTION} created"
}

create_field() {
  local field_name="$1"
  local payload resp body code
  payload=$(field_payload "$field_name")

  log_info "Creating field ${COLLECTION}.${field_name}"
  resp=$(api_request POST "${BASE_URL}/fields/${COLLECTION}" "$payload")
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"

  if [[ "$code" != "200" ]]; then
    log_err "Failed to create field ${COLLECTION}.${field_name} (HTTP $code)"
    echo "$body" | head -c 200 >&2
    exit 1
  fi
  log_ok "Field ${COLLECTION}.${field_name} created"
}

verify_fields() {
  local resp body code missing=()
  resp=$(api_request GET "${BASE_URL}/fields/${COLLECTION}")
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"

  if [[ "$code" != "200" ]]; then
    log_err "Failed to list fields for ${COLLECTION} (HTTP $code)"
    exit 1
  fi

  local field_count
  field_count=$(echo "$body" | jq '.data | length')

  for field in "${REQUIRED_FIELDS[@]}"; do
    if ! echo "$body" | jq -e --arg field "$field" '.data[]? | select(.field == $field)' >/dev/null 2>&1; then
      missing+=("$field")
    fi
  done

  if [[ "${#missing[@]}" -gt 0 ]]; then
    log_err "Missing required fields: ${missing[*]}"
    exit 1
  fi

  log_ok "${COLLECTION}: All required fields present (${field_count} total, including id)"
}

show_help() {
  cat << EOF
dot-schema-entity-dependencies-ensure v${VERSION}

Ensures the entity_dependencies collection exists in Directus with all
required fields for the Semantic Linking Engine (Constitution Art. 8/20).

Usage:
  dot-schema-entity-dependencies-ensure [options]

Options:
  --local       Use local development environment
  --cloud       Use cloud/production environment (default)
  --dry-run     Show what would be done without making changes
  --help, -h    Show this help message

Collection: entity_dependencies (12 fields + id)
  - code           Auto-ID: DEP-NNNN (unique)
  - source_type    Entity type of source (checkpoint_type, workflow, etc.)
  - source_code    Source entity ID (CP-005, DOT-042, etc.)
  - target_type    Entity type of target
  - target_code    Target entity ID (CPS-001, WF-001, etc.)
  - relation_type  belongs_to|contains|uses|triggers|displays|extends|related
  - direction      forward|reverse|bidirectional
  - auto_detected  true if scan detected, false if manual
  - confidence     0-1 (explicit=1.0, semantic<1.0)
  - status         active|deprecated
  - date_created   Auto timestamp
  - date_updated   Auto timestamp

EOF
  show_environment_help
}

main() {
  local DRY_RUN=false

  for arg in "$@"; do
    case "$arg" in
      --help|-h) show_help; exit 0 ;;
      --dry-run) DRY_RUN=true ;;
    esac
  done

  require_cmds
  init_environment "$@"
  BASE_URL="$DIRECTUS_URL"

  echo "========================================="
  echo "DOT Tool: Schema Entity Dependencies Ensure v${VERSION}"
  echo "========================================="
  print_environment_banner "$@"
  echo "Ensuring entity_dependencies collection for Semantic Linking Engine"
  echo ""

  if [[ "$DRY_RUN" == "true" ]]; then
    log_warn "DRY RUN MODE - No changes will be made"
    echo ""
  fi

  # Authentication
  if [[ -z "${DOT_TOKEN:-}" ]]; then
    if [[ ! -f "$DOT_AUTH" ]]; then
      log_err "dot-auth not found at ${DOT_AUTH}"
      exit 1
    fi
    log_info "Authenticating with Directus..."
    source "$DOT_AUTH" "$@"
  fi

  if [[ -z "${DOT_TOKEN:-}" ]]; then
    log_err "DOT_TOKEN is empty after authentication"
    exit 1
  fi

  # === COLLECTION ===
  echo ""
  echo "--- Collection: ${COLLECTION} ---"

  if collection_exists; then
    log_skip "Collection '${COLLECTION}' already exists"
  else
    if [[ "$DRY_RUN" == "true" ]]; then
      log_info "Would create collection '${COLLECTION}'"
    else
      create_collection
    fi
  fi

  # === FIELDS ===
  log_info "Ensuring required fields..."
  for field in "${REQUIRED_FIELDS[@]}"; do
    if field_exists "$field"; then
      log_skip "Field ${COLLECTION}.${field} already exists"
    else
      if [[ "$DRY_RUN" == "true" ]]; then
        log_info "Would create field ${COLLECTION}.${field}"
      else
        create_field "$field"
      fi
    fi
  done

  # === VERIFICATION ===
  echo ""
  if [[ "$DRY_RUN" != "true" ]]; then
    log_info "Running final verification..."
    if ! collection_exists; then
      log_err "Collection ${COLLECTION} missing after ensure"
      exit 1
    fi
    verify_fields
  fi

  log_ok "Collection entity_dependencies ready"
  echo ""
  echo "========================================="
  echo "DOT Tool: Schema Entity Dependencies Ensure - COMPLETE"
  echo "========================================="
}

main "$@"
