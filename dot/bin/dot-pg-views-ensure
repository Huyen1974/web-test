#!/usr/bin/env bash
# CHECKED-NO-DUPLICATE: [searched dot/bin/dot-*pg* dot/bin/dot-*view* — no existing tool]
# =============================================================================
# dot-pg-views-ensure — Tạo PostgreSQL tables + refresh function cho registry counting
# =============================================================================
# VERSION: 10.0.0
# CHANGELOG:
#   v1–5: see git history
#   v6.0.0 (2026-03-13): CHỈ đếm 16 nguyên tử, loại CAT-016/017 khỏi UNION ALL
#   v7.0.0 (2026-03-13): Thêm composition_level breakdown vào v_registry_summary
#   v8.0.0 (2026-03-17): Điều 26 v2.1.1 — active_count + test_counting_contract()
#   v9.0.0 (2026-03-17): S128-A — fix critical counting bugs (TD-240/TD-241)
#   v10.0.0 (2026-03-17): S129-A — Security hardening (TD-253/TD-255)
#     - fn_guard_meta_catalog_update/delete: block direct counting field modification
#     - fn_validate_dot_origin: regex validation (prefix+actor+timestamp)
#     - fn_refresh_virtual_summaries: fire on active_count change + session var bypass
#     - test_counting_contract T8: check all triggers enabled
#     - check_registry_coverage: trigger_disabled detection
#     - refresh_registry_counts: session var for meta_catalog guard bypass
#     - meta_catalog.active_count updated from v_registry_counts
#     - test_counting_contract() PG function for self-test
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/../config/environment.sh"

VERSION="10.0.0"
VPS_HOST="38.242.240.89"
VPS_KEY="${HOME}/.ssh/contabo_vps"
PG_CONTAINER="postgres"
PG_USER="directus"
PG_DB="directus"

log_info() { echo "[INFO] $1"; }
log_ok()   { echo "[OK]   $1"; }
log_warn() { echo "[WARN] $1"; }
log_err()  { echo "[ERR]  $1" >&2; }

for arg in "$@"; do
  case "$arg" in
    --help|-h)
      echo "dot-pg-views-ensure v${VERSION} — Tạo PG tables + refresh function cho registry"
      echo ""
      echo "Usage: dot-pg-views-ensure [--cloud] [--refresh]"
      echo ""
      echo "Creates tables: v_registry_counts, v_registry_summary"
      echo "Creates function: refresh_registry_counts()"
      echo ""
      echo "Options:"
      echo "  --refresh   Chỉ chạy refresh (không tạo lại tables)"
      exit 0
      ;;
  esac
done

REFRESH_ONLY=false
for arg in "$@"; do
  [[ "$arg" == "--refresh" ]] && REFRESH_ONLY=true
done

init_environment "$@"
BASE_URL="$DIRECTUS_URL"

# Auth
if [[ -z "${DOT_TOKEN:-}" ]]; then
  local_auth="${SCRIPT_DIR}/dot-auth"
  if [[ -f "$local_auth" ]]; then
    source "$local_auth" "$@"
  fi
fi

if [[ -z "${DOT_TOKEN:-}" ]]; then
  log_err "Xác thực thất bại"
  exit 1
fi

echo "========================================="
echo "DOT Tool: PG Views Ensure v${VERSION}"
echo "========================================="
print_environment_banner "$@"

# =============================================================================
# REFRESH ONLY mode
# =============================================================================
if [[ "$REFRESH_ONLY" == "true" ]]; then
  log_info "Refresh mode: chỉ cập nhật data..."
  ssh -i "$VPS_KEY" "root@${VPS_HOST}" \
    "docker exec ${PG_CONTAINER} psql -U ${PG_USER} -d ${PG_DB} -c 'SELECT refresh_registry_counts();'"
  log_ok "Refresh hoàn tất"
  ssh -i "$VPS_KEY" "root@${VPS_HOST}" \
    "docker exec ${PG_CONTAINER} psql -U ${PG_USER} -d ${PG_DB} -c 'SELECT * FROM v_registry_summary;'"
  exit 0
fi

# =============================================================================
# STEP 1: Create PostgreSQL tables + refresh function via SSH
# =============================================================================
log_info "Step 1: Tạo PostgreSQL tables + function trên VPS..."

TABLE_SQL=$(cat <<'ENDSQL'
-- =============================================================================
-- Tables for registry counting (Directus-compatible — BASE TABLE type)
-- =============================================================================

CREATE TABLE IF NOT EXISTS v_registry_counts (
  id serial PRIMARY KEY,
  cat_code text NOT NULL,
  entity_type text NOT NULL,
  record_count int NOT NULL DEFAULT 0,
  orphan_count int NOT NULL DEFAULT 0,
  count_b int NOT NULL DEFAULT 0,
  count_c int NOT NULL DEFAULT 0,
  cross_check text NOT NULL DEFAULT ''
);
-- Add columns if upgrading from v2
ALTER TABLE v_registry_counts ADD COLUMN IF NOT EXISTS count_b int NOT NULL DEFAULT 0;
ALTER TABLE v_registry_counts ADD COLUMN IF NOT EXISTS count_c int NOT NULL DEFAULT 0;
ALTER TABLE v_registry_counts ADD COLUMN IF NOT EXISTS cross_check text NOT NULL DEFAULT '';
ALTER TABLE v_registry_counts ADD COLUMN IF NOT EXISTS composition_level text NOT NULL DEFAULT 'atom';
ALTER TABLE v_registry_counts ADD COLUMN IF NOT EXISTS active_count int NOT NULL DEFAULT 0;

CREATE TABLE IF NOT EXISTS v_registry_summary (
  id serial PRIMARY KEY,
  total_atoms int NOT NULL DEFAULT 0,
  total_types int NOT NULL DEFAULT 0,
  total_orphans int NOT NULL DEFAULT 0
);
ALTER TABLE v_registry_summary ADD COLUMN IF NOT EXISTS count_atom int NOT NULL DEFAULT 0;
ALTER TABLE v_registry_summary ADD COLUMN IF NOT EXISTS count_molecule int NOT NULL DEFAULT 0;
ALTER TABLE v_registry_summary ADD COLUMN IF NOT EXISTS count_compound int NOT NULL DEFAULT 0;

-- =============================================================================
-- refresh_registry_counts() v7: composition_level from meta_catalog
--   count_a (record_count) = SELECT count(*) trực tiếp
--   count_b = pg_stat_user_tables n_live_tup (after ANALYZE)
--   count_c = count WHERE code IS NOT NULL (có PREFIX-NNN)
--   composition_level = JOIN meta_catalog.composition_level
--   cross_check = KHỚP nếu |count_a - count_b| ≤ 1
--   summary: total + per-level breakdown (atom/molecule/compound)
-- =============================================================================
CREATE OR REPLACE FUNCTION refresh_registry_counts() RETURNS void AS $$
DECLARE
  r RECORD;
BEGIN
  -- ANALYZE all registry tables for accurate pg_stat n_live_tup
  ANALYZE meta_catalog;
  ANALYZE table_registry;
  ANALYZE modules;
  ANALYZE workflows;
  ANALYZE workflow_steps;
  ANALYZE workflow_change_requests;
  ANALYZE dot_tools;
  ANALYZE ui_pages;
  ANALYZE collection_registry;
  ANALYZE tasks;
  ANALYZE agents;
  ANALYZE checkpoint_types;
  ANALYZE checkpoint_sets;
  ANALYZE entity_dependencies;
  ANALYZE table_proposals;
  ANALYZE checkpoint_instances;

  TRUNCATE v_registry_counts;
  INSERT INTO v_registry_counts (id, cat_code, entity_type, record_count, orphan_count, count_b, count_c, cross_check)
  SELECT row_number() OVER ()::int, sub.cat_code, sub.entity_type, sub.count_a, sub.orphan_count, 0, sub.count_c, ''
  FROM (
    SELECT 'CAT-000'::text AS cat_code, 'catalog'::text AS entity_type, count(*)::int AS count_a, count(*) FILTER (WHERE code IS NULL OR code = '')::int AS orphan_count, count(*) FILTER (WHERE code IS NOT NULL AND code != '')::int AS count_c FROM meta_catalog
    UNION ALL SELECT 'CAT-001', 'table', count(*)::int, count(*) FILTER (WHERE table_id IS NULL OR table_id = '')::int, count(*) FILTER (WHERE table_id IS NOT NULL AND table_id != '')::int FROM table_registry
    UNION ALL SELECT 'CAT-002', 'module', count(*)::int, count(*) FILTER (WHERE code IS NULL OR code = '')::int, count(*) FILTER (WHERE code IS NOT NULL AND code != '')::int FROM modules
    UNION ALL SELECT 'CAT-003', 'workflow', count(*)::int, count(*) FILTER (WHERE process_code IS NULL OR process_code = '')::int, count(*) FILTER (WHERE process_code IS NOT NULL AND process_code != '')::int FROM workflows
    UNION ALL SELECT 'CAT-004', 'workflow_step', count(*)::int, count(*) FILTER (WHERE code IS NULL OR code = '')::int, count(*) FILTER (WHERE code IS NOT NULL AND code != '')::int FROM workflow_steps
    UNION ALL SELECT 'CAT-005', 'wcr', count(*)::int, 0::int, 0::int FROM workflow_change_requests
    UNION ALL SELECT 'CAT-006', 'dot_tool', count(*)::int, count(*) FILTER (WHERE code IS NULL OR code = '')::int, count(*) FILTER (WHERE code IS NOT NULL AND code != '')::int FROM dot_tools
    UNION ALL SELECT 'CAT-007', 'page', count(*)::int, count(*) FILTER (WHERE code IS NULL OR code = '')::int, count(*) FILTER (WHERE code IS NOT NULL AND code != '')::int FROM ui_pages
    UNION ALL SELECT 'CAT-008', 'collection', count(*)::int, count(*) FILTER (WHERE code IS NULL OR code = '')::int, count(*) FILTER (WHERE code IS NOT NULL AND code != '')::int FROM collection_registry
    UNION ALL SELECT 'CAT-009', 'task', count(*)::int, 0::int, 0::int FROM tasks
    UNION ALL SELECT 'CAT-010', 'agent', count(*)::int, count(*) FILTER (WHERE code IS NULL OR code = '')::int, count(*) FILTER (WHERE code IS NOT NULL AND code != '')::int FROM agents
    UNION ALL SELECT 'CAT-011', 'checkpoint_type', count(*)::int, count(*) FILTER (WHERE code IS NULL OR code = '')::int, count(*) FILTER (WHERE code IS NOT NULL AND code != '')::int FROM checkpoint_types
    UNION ALL SELECT 'CAT-012', 'checkpoint_set', count(*)::int, count(*) FILTER (WHERE code IS NULL OR code = '')::int, count(*) FILTER (WHERE code IS NOT NULL AND code != '')::int FROM checkpoint_sets
    UNION ALL SELECT 'CAT-013', 'entity_dependency', count(*)::int, count(*) FILTER (WHERE code IS NULL OR code = '')::int, count(*) FILTER (WHERE code IS NOT NULL AND code != '')::int FROM entity_dependencies
    UNION ALL SELECT 'CAT-014', 'table_proposal', count(*)::int, 0::int, 0::int FROM table_proposals
    UNION ALL SELECT 'CAT-015', 'checkpoint_instance', count(*)::int, 0::int, 0::int FROM checkpoint_instances
  ) sub;

  -- Update count_b from pg_stat_user_tables (now accurate after ANALYZE)
  FOR r IN SELECT id, entity_type FROM v_registry_counts
  LOOP
    UPDATE v_registry_counts SET count_b = COALESCE((
      SELECT n_live_tup::int FROM pg_stat_user_tables WHERE relname = (
        CASE r.entity_type
          WHEN 'catalog' THEN 'meta_catalog' WHEN 'table' THEN 'table_registry'
          WHEN 'module' THEN 'modules' WHEN 'workflow' THEN 'workflows'
          WHEN 'workflow_step' THEN 'workflow_steps' WHEN 'wcr' THEN 'workflow_change_requests'
          WHEN 'dot_tool' THEN 'dot_tools' WHEN 'page' THEN 'ui_pages'
          WHEN 'collection' THEN 'collection_registry' WHEN 'task' THEN 'tasks'
          WHEN 'agent' THEN 'agents' WHEN 'checkpoint_type' THEN 'checkpoint_types'
          WHEN 'checkpoint_set' THEN 'checkpoint_sets' WHEN 'entity_dependency' THEN 'entity_dependencies'
          WHEN 'table_proposal' THEN 'table_proposals' WHEN 'checkpoint_instance' THEN 'checkpoint_instances'
        END
      )
    ), 0) WHERE id = r.id;
  END LOOP;

  UPDATE v_registry_counts SET cross_check =
    CASE WHEN abs(record_count - count_b) <= 1 THEN 'KHỚP' ELSE 'LỆCH' END;

  -- Update composition_level from meta_catalog (JOIN on cat_code)
  UPDATE v_registry_counts rc SET composition_level = COALESCE(mc.composition_level, 'atom')
  FROM meta_catalog mc WHERE mc.code = rc.cat_code;

  -- Điều 26 v2.1.1: active_count = record_count (chưa có retired)
  -- Khi S128 deploy status field → active_count = COUNT(*) WHERE status != 'retired'
  UPDATE v_registry_counts SET active_count = record_count;

  -- Update meta_catalog.active_count from v_registry_counts
  UPDATE meta_catalog mc SET active_count = rc.active_count
  FROM v_registry_counts rc WHERE mc.code = rc.cat_code;

  -- Summary: total + per-level breakdown (dùng active_count — Điều 26 v2.1.1)
  DELETE FROM v_registry_summary;
  INSERT INTO v_registry_summary (id, total_atoms, total_types, total_orphans, count_atom, count_molecule, count_compound)
  SELECT 1,
    SUM(active_count)::int,
    COUNT(*)::int,
    SUM(orphan_count)::int,
    COALESCE(SUM(active_count) FILTER (WHERE composition_level = 'atom'), 0)::int,
    COALESCE(SUM(active_count) FILTER (WHERE composition_level = 'molecule'), 0)::int,
    COALESCE(SUM(active_count) FILTER (WHERE composition_level = 'compound'), 0)::int
  FROM v_registry_counts;
END;
$$ LANGUAGE plpgsql;

-- =============================================================================
-- test_counting_contract() — Self-test for counting invariants
-- =============================================================================
DROP FUNCTION IF EXISTS test_counting_contract();
CREATE OR REPLACE FUNCTION test_counting_contract()
RETURNS TABLE(test_name text, expected text, actual text, status text) AS $$
BEGIN
  -- T1: active_count = record_count for all managed (chưa có retired)
  RETURN QUERY
  SELECT 'T1: active=record for all'::text,
    '0 mismatches'::text,
    (SELECT COUNT(*)::text FROM v_registry_counts WHERE active_count != record_count) || ' mismatches',
    CASE WHEN (SELECT COUNT(*) FROM v_registry_counts WHERE active_count != record_count) = 0
      THEN 'PASS' ELSE 'FAIL' END;

  -- T2: CAT-ALL.active_count = SUM(active_count) of all managed meta_catalog (excl CAT-ALL, CAT-999)
  RETURN QUERY
  SELECT 'T2: CAT-ALL active=sum(managed)'::text,
    (SELECT COALESCE(SUM(mc2.active_count), 0)::text FROM meta_catalog mc2
     WHERE mc2.identity_class = 'managed' AND mc2.code NOT IN ('CAT-ALL', 'CAT-999')),
    (SELECT COALESCE(mc.active_count, 0)::text FROM meta_catalog mc WHERE mc.code = 'CAT-ALL'),
    CASE WHEN (SELECT COALESCE(mc.active_count, 0) FROM meta_catalog mc WHERE mc.code = 'CAT-ALL')
      = (SELECT COALESCE(SUM(mc2.active_count), 0) FROM meta_catalog mc2
         WHERE mc2.identity_class = 'managed' AND mc2.code NOT IN ('CAT-ALL', 'CAT-999'))
      THEN 'PASS' ELSE 'FAIL' END;

  -- T3: CAT-ALL.record_count = SUM(record_count) of all managed meta_catalog
  RETURN QUERY
  SELECT 'T3: CAT-ALL record=sum(managed)'::text,
    (SELECT COALESCE(SUM(mc2.record_count), 0)::text FROM meta_catalog mc2
     WHERE mc2.identity_class = 'managed' AND mc2.code NOT IN ('CAT-ALL', 'CAT-999')),
    (SELECT COALESCE(mc.record_count, 0)::text FROM meta_catalog mc WHERE mc.code = 'CAT-ALL'),
    CASE WHEN (SELECT COALESCE(mc.record_count, 0) FROM meta_catalog mc WHERE mc.code = 'CAT-ALL')
      = (SELECT COALESCE(SUM(mc2.record_count), 0) FROM meta_catalog mc2
         WHERE mc2.identity_class = 'managed' AND mc2.code NOT IN ('CAT-ALL', 'CAT-999'))
      THEN 'PASS' ELSE 'FAIL' END;

  -- T4: record_count >= 0 for all
  RETURN QUERY
  SELECT 'T4: record_count >= 0'::text,
    '0 negative'::text,
    (SELECT COUNT(*)::text FROM v_registry_counts WHERE record_count < 0) || ' negative',
    CASE WHEN (SELECT COUNT(*) FROM v_registry_counts WHERE record_count < 0) = 0
      THEN 'PASS' ELSE 'FAIL' END;

  -- T5: Per-level sum matches (atom + molecule + compound = total_atoms in summary)
  RETURN QUERY
  SELECT 'T5: level sums match'::text,
    (SELECT total_atoms::text FROM v_registry_summary WHERE id = 1),
    (SELECT (count_atom + count_molecule + count_compound)::text FROM v_registry_summary WHERE id = 1),
    CASE WHEN (SELECT total_atoms FROM v_registry_summary WHERE id = 1)
      = (SELECT count_atom + count_molecule + count_compound FROM v_registry_summary WHERE id = 1)
      THEN 'PASS' ELSE 'FAIL' END;

  -- T6: 0 SUSPECT origins across all managed collections (S128-A)
  RETURN QUERY
  SELECT 'T6: 0 SUSPECT origins'::text,
    '0'::text,
    (SELECT COALESCE(SUM(cnt), 0)::text FROM (
      SELECT COUNT(*) as cnt FROM task_comments WHERE _dot_origin LIKE 'SUSPECT:%'
      UNION ALL SELECT COUNT(*) FROM dot_tools WHERE _dot_origin LIKE 'SUSPECT:%'
      UNION ALL SELECT COUNT(*) FROM checkpoint_types WHERE _dot_origin LIKE 'SUSPECT:%'
      UNION ALL SELECT COUNT(*) FROM workflows WHERE _dot_origin LIKE 'SUSPECT:%'
      UNION ALL SELECT COUNT(*) FROM checkpoint_sets WHERE _dot_origin LIKE 'SUSPECT:%'
      UNION ALL SELECT COUNT(*) FROM entity_dependencies WHERE _dot_origin LIKE 'SUSPECT:%'
      UNION ALL SELECT COUNT(*) FROM collection_registry WHERE _dot_origin LIKE 'SUSPECT:%'
      UNION ALL SELECT COUNT(*) FROM checkpoint_instances WHERE _dot_origin LIKE 'SUSPECT:%'
      UNION ALL SELECT COUNT(*) FROM taxonomy WHERE _dot_origin LIKE 'SUSPECT:%'
      UNION ALL SELECT COUNT(*) FROM modules WHERE _dot_origin LIKE 'SUSPECT:%'
      UNION ALL SELECT COUNT(*) FROM workflow_steps WHERE _dot_origin LIKE 'SUSPECT:%'
      UNION ALL SELECT COUNT(*) FROM workflow_change_requests WHERE _dot_origin LIKE 'SUSPECT:%'
      UNION ALL SELECT COUNT(*) FROM agents WHERE _dot_origin LIKE 'SUSPECT:%'
      UNION ALL SELECT COUNT(*) FROM ui_pages WHERE _dot_origin LIKE 'SUSPECT:%'
      UNION ALL SELECT COUNT(*) FROM tasks WHERE _dot_origin LIKE 'SUSPECT:%'
      UNION ALL SELECT COUNT(*) FROM table_registry WHERE _dot_origin LIKE 'SUSPECT:%'
      UNION ALL SELECT COUNT(*) FROM meta_catalog WHERE _dot_origin LIKE 'SUSPECT:%'
      UNION ALL SELECT COUNT(*) FROM table_proposals WHERE _dot_origin LIKE 'SUSPECT:%'
    ) t),
    CASE WHEN (SELECT COALESCE(SUM(cnt), 0) FROM (
      SELECT COUNT(*) as cnt FROM task_comments WHERE _dot_origin LIKE 'SUSPECT:%'
      UNION ALL SELECT COUNT(*) FROM dot_tools WHERE _dot_origin LIKE 'SUSPECT:%'
      UNION ALL SELECT COUNT(*) FROM checkpoint_types WHERE _dot_origin LIKE 'SUSPECT:%'
      UNION ALL SELECT COUNT(*) FROM workflows WHERE _dot_origin LIKE 'SUSPECT:%'
      UNION ALL SELECT COUNT(*) FROM checkpoint_sets WHERE _dot_origin LIKE 'SUSPECT:%'
      UNION ALL SELECT COUNT(*) FROM entity_dependencies WHERE _dot_origin LIKE 'SUSPECT:%'
      UNION ALL SELECT COUNT(*) FROM collection_registry WHERE _dot_origin LIKE 'SUSPECT:%'
      UNION ALL SELECT COUNT(*) FROM checkpoint_instances WHERE _dot_origin LIKE 'SUSPECT:%'
      UNION ALL SELECT COUNT(*) FROM taxonomy WHERE _dot_origin LIKE 'SUSPECT:%'
      UNION ALL SELECT COUNT(*) FROM modules WHERE _dot_origin LIKE 'SUSPECT:%'
      UNION ALL SELECT COUNT(*) FROM workflow_steps WHERE _dot_origin LIKE 'SUSPECT:%'
      UNION ALL SELECT COUNT(*) FROM workflow_change_requests WHERE _dot_origin LIKE 'SUSPECT:%'
      UNION ALL SELECT COUNT(*) FROM agents WHERE _dot_origin LIKE 'SUSPECT:%'
      UNION ALL SELECT COUNT(*) FROM ui_pages WHERE _dot_origin LIKE 'SUSPECT:%'
      UNION ALL SELECT COUNT(*) FROM tasks WHERE _dot_origin LIKE 'SUSPECT:%'
      UNION ALL SELECT COUNT(*) FROM table_registry WHERE _dot_origin LIKE 'SUSPECT:%'
      UNION ALL SELECT COUNT(*) FROM meta_catalog WHERE _dot_origin LIKE 'SUSPECT:%'
      UNION ALL SELECT COUNT(*) FROM table_proposals WHERE _dot_origin LIKE 'SUSPECT:%'
    ) t) = 0 THEN 'PASS' ELSE 'FAIL' END;

  -- T7: CAT-ALL never includes log (S128-A)
  RETURN QUERY
  SELECT 'T7: CAT-ALL <= managed sum (no log)'::text,
    'true'::text,
    CASE WHEN (SELECT record_count FROM meta_catalog WHERE code = 'CAT-ALL')
      <= (SELECT COALESCE(SUM(record_count), 0) FROM meta_catalog WHERE identity_class = 'managed' AND code NOT IN ('CAT-ALL', 'CAT-999'))
      THEN 'true' ELSE 'false' END,
    CASE WHEN (SELECT record_count FROM meta_catalog WHERE code = 'CAT-ALL')
      <= (SELECT COALESCE(SUM(record_count), 0) FROM meta_catalog WHERE identity_class = 'managed' AND code NOT IN ('CAT-ALL', 'CAT-999'))
      THEN 'PASS' ELSE 'FAIL' END;
END;
$$ LANGUAGE plpgsql;

-- Run initial refresh
SELECT refresh_registry_counts();

-- Run contract tests
SELECT * FROM test_counting_contract();
ENDSQL
)

ssh -i "$VPS_KEY" "root@${VPS_HOST}" "docker exec -i ${PG_CONTAINER} psql -U ${PG_USER} -d ${PG_DB}" <<< "$TABLE_SQL"

if [[ $? -eq 0 ]]; then
  log_ok "Tables + function tạo thành công"
else
  log_err "Lỗi tạo tables"
  exit 1
fi

# Verify
log_info "Verify tables..."
ssh -i "$VPS_KEY" "root@${VPS_HOST}" "docker exec ${PG_CONTAINER} psql -U ${PG_USER} -d ${PG_DB} -c 'SELECT * FROM v_registry_counts;'"
ssh -i "$VPS_KEY" "root@${VPS_HOST}" "docker exec ${PG_CONTAINER} psql -U ${PG_USER} -d ${PG_DB} -c 'SELECT * FROM v_registry_summary;'"

# =============================================================================
# STEP 2: Register in Directus (idempotent)
# =============================================================================
log_info "Step 2: Register tables in Directus..."

PUBLIC_POLICY="abf8a154-5b1c-4a46-ac9c-7300570f4f17"

REGISTER_SQL=$(cat <<ENDSQL
-- Register collections (idempotent)
INSERT INTO directus_collections (collection, icon, note, hidden, singleton, archive_app_filter, collapse, versioning)
VALUES
  ('v_registry_counts', 'table_chart', 'PG table: đếm record/orphan per entity type', false, false, true, 'open', false),
  ('v_registry_summary', 'functions', 'PG table: tổng hợp registry counts', false, false, true, 'open', false)
ON CONFLICT (collection) DO UPDATE SET
  note = EXCLUDED.note,
  icon = EXCLUDED.icon;

-- Public READ permissions
INSERT INTO directus_permissions (collection, action, permissions, validation, presets, fields, policy)
SELECT 'v_registry_counts', 'read', '{}'::json, '{}'::json, NULL, '*', '${PUBLIC_POLICY}'
WHERE NOT EXISTS (
  SELECT 1 FROM directus_permissions
  WHERE collection = 'v_registry_counts' AND action = 'read' AND policy = '${PUBLIC_POLICY}'
);

INSERT INTO directus_permissions (collection, action, permissions, validation, presets, fields, policy)
SELECT 'v_registry_summary', 'read', '{}'::json, '{}'::json, NULL, '*', '${PUBLIC_POLICY}'
WHERE NOT EXISTS (
  SELECT 1 FROM directus_permissions
  WHERE collection = 'v_registry_summary' AND action = 'read' AND policy = '${PUBLIC_POLICY}'
);
ENDSQL
)

ssh -i "$VPS_KEY" "root@${VPS_HOST}" "docker exec -i ${PG_CONTAINER} psql -U ${PG_USER} -d ${PG_DB}" <<< "$REGISTER_SQL"

if [[ $? -eq 0 ]]; then
  log_ok "Directus registration hoàn tất"
else
  log_warn "Lỗi register — có thể đã tồn tại"
fi

# =============================================================================
# STEP 3: Verify Directus API
# =============================================================================
log_info "Step 3: Verify Directus API..."

API_OUT=$(curl -sS --globoff --max-time 15 \
  "${BASE_URL}/items/v_registry_counts?limit=-1" \
  -H "Authorization: Bearer ${DOT_TOKEN}" 2>/dev/null || echo '{"error":"timeout"}')

if echo "$API_OUT" | python3 -c "import sys,json; d=json.load(sys.stdin); print(f'Directus API: {len(d.get(\"data\",[]))} rows')" 2>/dev/null; then
  log_ok "Directus API hoạt động"
else
  log_warn "Directus API chưa sẵn sàng (restart Directus nếu lần đầu): $API_OUT"
fi

echo ""
echo "========================================="
echo "DOT Tool: PG Views Ensure — HOÀN TẤT"
echo "========================================="
echo ""
echo "Sử dụng:"
echo "  dot-pg-views-ensure --cloud --refresh    # Cập nhật data"
echo "  Nuxt: readItems('v_registry_summary')     # Đọc tổng hợp"
echo "  Nuxt: readItems('v_registry_counts')      # Đọc chi tiết"
