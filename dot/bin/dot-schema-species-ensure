        'status': 'active',
        'description': 'Junction: mapping giua species va collections. Luat Loai v0.5.',
        'layer': 2
    },
    {
        'code': 'CAT-022',
        'name': 'Hang doi kiem dinh',
        'name_en': 'Entity Audit Queue',
        'entity_type': 'collection',
        'source_model': 'A',
        'source_location': 'Directus:entity_audit_queue',
        'registry_collection': 'entity_audit_queue',
        'sync_script': None,
        'sync_frequency': 'realtime',
        'record_count': 0,
        'active_count': 0,
        'ui_page': '/knowledge/registries',
        'status': 'active',
        'description': 'Audit queue cho soft enforcement — records khong auto-resolve species. Luat Loai v0.5.',
        'layer': 2
    },
]

for entry in meta_entries:
    cat_code = entry['code']
    # Check if already exists
    code, resp = api('GET', f'/items/meta_catalog?filter[code][_eq]={cat_code}&fields=id,code')
    if code == 200 and resp.get('data', []):
        print(f'  [SKIP] {cat_code} already exists in meta_catalog')
        continue
    if dry_run:
        print(f'  [DRY] Would create {cat_code} in meta_catalog')
        continue
    code, resp = api('POST', '/items/meta_catalog', entry)
    if code == 200:
        print(f'  [OK]   Created {cat_code} ({entry["name_en"]})')
    else:
        print(f'  [ERR]  Failed {cat_code}: HTTP {code} — {json.dumps(resp)[:150]}')

print()

# ============================================================
# STEP 7: Verify
# ============================================================
print('=' * 60)
print('STEP 7: Verify')
print('=' * 60)
print()

errors = 0

# 7.1 Check 3 collections exist
for coll in ['entity_species', 'species_collection_map', 'entity_audit_queue']:
    if collection_exists(coll):
        print(f'  [OK]   Collection {coll} exists')
    else:
        print(f'  [FAIL] Collection {coll} MISSING')
        errors += 1

# 7.2 Check 4 new fields in collection_registry
for fld in ['storage_role', 'governance_role', 'source_kind', 'migration_state']:
    if field_exists('collection_registry', fld):
        print(f'  [OK]   collection_registry.{fld} exists')
    else:
        print(f'  [FAIL] collection_registry.{fld} MISSING')
        errors += 1

# 7.3 Check API access (public read)
for coll in ['entity_species', 'entity_audit_queue']:
    try:
        url = f'{base_url}/items/{coll}?limit=1'
        req = urllib.request.Request(url, method='GET',
            headers={'Content-Type': 'application/json'})
        resp = urllib.request.urlopen(req, context=ctx)
        if resp.status == 200:
            print(f'  [OK]   Public read {coll}: 200')
        else:
            print(f'  [WARN] Public read {coll}: {resp.status}')
    except urllib.error.HTTPError as e:
        print(f'  [FAIL] Public read {coll}: HTTP {e.code}')
        errors += 1

# 7.4 Check meta_catalog entries
for cat_code in ['CAT-020', 'CAT-021', 'CAT-022']:
    code, resp = api('GET', f'/items/meta_catalog?filter[code][_eq]={cat_code}&fields=id,code')
    if code == 200 and resp.get('data', []):
        print(f'  [OK]   meta_catalog {cat_code} exists')
    else:
        print(f'  [FAIL] meta_catalog {cat_code} MISSING')
        errors += 1

print()
if errors == 0:
    print('VERIFY: ALL CHECKS PASSED')
else:
    print(f'VERIFY: {errors} CHECK(S) FAILED')

print()
print('DONE — Schema Species Ensure complete')
PYEOF

  BASE_URL="$BASE_URL" DOT_TOKEN="$DOT_TOKEN" DRY_RUN="${DRY_RUN}" \
    python3 "$tmp_py" < /dev/null

  rm -f "$tmp_py"

  echo ""
  echo "========================================="
  echo "DOT Tool: Schema Species Ensure - COMPLETE"
  echo "========================================="
}

main "$@"
