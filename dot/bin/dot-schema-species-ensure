        {'required': True, 'interface': 'select-dropdown', 'width': 'half',
         'note': 'Lifecycle status',
         'options': {'choices': [
             {'text': 'Active', 'value': 'active'},
             {'text': 'Deprecated', 'value': 'deprecated'},
             {'text': 'Retired', 'value': 'retired'},
         ]}},
        {'is_nullable': False, 'default_value': 'active'})

    # _dot_origin — DOT provenance tracking
    ensure_field('entity_species', '_dot_origin', 'string',
