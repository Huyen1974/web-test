    ensure_field('entity_species', 'prefix', 'string',
        {'interface': 'input', 'width': 'half',
         'note': 'Entity code prefix (e.g. DOT-, WKF-)'},
        None)

    # description
    ensure_field('entity_species', 'description', 'text',
        {'interface': 'input-multiline', 'width': 'full',
         'note': 'Species description and purpose'},
