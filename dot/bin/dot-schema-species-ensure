# ============================================================
# STEP 5: Set permissions
# ============================================================
print('=' * 60)
print('STEP 5: Set permissions')
print('=' * 60)
print()

new_collections = ['entity_species', 'species_collection_map', 'entity_audit_queue']
for coll in new_collections:
    print(f'--- {coll} ---')
    # Public read for entity_species and entity_audit_queue
    if coll in ('entity_species', 'entity_audit_queue'):
        ensure_public_read(coll)
    # AI Agent CRUD for all
    ensure_permissions(coll, AI_AGENT_POLICY, ['create', 'read', 'update', 'delete'])
    # Public policy read for species_collection_map too (useful for species resolution)
    if coll == 'species_collection_map':
        ensure_public_read(coll)
    print()

