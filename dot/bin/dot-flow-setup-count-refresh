#!/usr/bin/env bash
# =============================================================================
# dot-flow-setup-count-refresh — Create Directus Flow for scheduled count refresh
# =============================================================================
# CHECKED-NO-DUPLICATE: [searched dot/bin/ for "count-refresh" — only dot-registry-count-refresh]
# VERSION: 1.0.0
#
# Creates a Directus Flow with schedule trigger (every 6 hours) that calls
# the Nuxt API endpoint POST /api/registry/refresh-counts to update
# meta_catalog record counts automatically.
#
# Flow: Schedule (0 */6 * * *) → Webhook (POST /api/registry/refresh-counts)
#
# Usage:
#   dot-flow-setup-count-refresh [--cloud|--local] [--dry-run]
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/../config/environment.sh"

VERSION="1.0.0"
DRY_RUN=""

show_help() {
  cat << EOF
dot-flow-setup-count-refresh v${VERSION}

Creates a Directus Flow with schedule trigger (every 6h) that refreshes
meta_catalog record counts via the Nuxt API endpoint.

Usage:
  dot-flow-setup-count-refresh [--cloud|--local] [--dry-run]

EOF
  show_environment_help
}

main() {
  for arg in "$@"; do
    case "$arg" in
      --dry-run) DRY_RUN="1" ;;
      --help|-h) show_help; exit 0 ;;
    esac
  done

  init_environment "$@"
  local BASE_URL="$DIRECTUS_URL"

  echo ""
  echo "======================================================="
  echo "  DOT Tool: Setup Count Refresh Flow v${VERSION}"
  echo "======================================================="
  print_environment_banner "$@"

  # Auth
  if [[ -z "${DOT_TOKEN:-}" ]]; then
    source "${SCRIPT_DIR}/dot-auth" "$@" 2>/dev/null || true
  fi
  if [[ -z "${DOT_TOKEN:-}" ]]; then
    echo "[ERR] Authentication failed" >&2; exit 1
  fi

  local NUXT_INTERNAL_URL="http://incomex-nuxt:3000"
  local FLOW_NAME="[DOT-REG] Count Refresh (6h)"

  local tmp_py
  tmp_py=$(mktemp /tmp/dot-flow-count-XXXXXX.py)
  trap "rm -f '$tmp_py'" EXIT

  cat > "$tmp_py" << 'PYEOF'
import json, os, sys, ssl, urllib.request, urllib.parse, uuid

base_url = os.environ['BASE_URL']
token = os.environ['DOT_TOKEN']
dry_run = os.environ.get('DRY_RUN', '')
nuxt_url = os.environ.get('NUXT_INTERNAL_URL', 'http://incomex-nuxt:3000')
flow_name = os.environ.get('FLOW_NAME', '[DOT-REG] Count Refresh (6h)')

ctx = ssl.create_default_context()
ctx.check_hostname = False
ctx.verify_mode = ssl.CERT_NONE

def api(method, path, data=None):
    url = base_url + path
    payload = json.dumps(data).encode() if data else None
    req = urllib.request.Request(url, data=payload, method=method,
        headers={'Authorization': f'Bearer {token}', 'Content-Type': 'application/json'})
    try:
        resp = urllib.request.urlopen(req, context=ctx, timeout=30)
        body = resp.read()
        return resp.status, json.loads(body) if body else {}
    except urllib.error.HTTPError as e:
        body = e.read().decode()
        try:
            return e.code, json.loads(body)
        except:
            return e.code, {'error': body[:300]}
    except Exception as e:
        return 0, {'error': str(e)}

# 1. Cleanup existing flow with same name
print(f'[INFO] Checking for existing flow: {flow_name}')
encoded_name = urllib.parse.quote(flow_name, safe='')
code, resp = api('GET', f'/flows?filter[name][_eq]={encoded_name}&fields=id,name')
if code == 200:
    existing = resp.get('data', [])
    for f in existing:
        fid = f['id']
        print(f'  Removing existing flow {fid}...')
        if not dry_run:
            api('DELETE', f'/flows/{fid}')

# 2. Create the flow with schedule trigger
print(f'[INFO] Creating flow: {flow_name}')

flow_id = str(uuid.uuid4())
op_webhook_id = str(uuid.uuid4())

flow_payload = {
    'id': flow_id,
    'name': flow_name,
    'icon': 'update',
    'color': '#2ECDA7',
    'description': 'Refreshes meta_catalog record counts every 6 hours by calling Nuxt API',
    'status': 'active',
    'trigger': 'schedule',
    'accountability': 'all',
    'options': {
        'cron': '0 */6 * * *'
    },
    'operation': op_webhook_id
}

op_webhook_payload = {
    'id': op_webhook_id,
    'name': 'Call Refresh Counts API',
    'key': 'call_refresh_api',
    'type': 'request',
    'position_x': 19,
    'position_y': 1,
    'options': {
        'method': 'POST',
        'url': f'{nuxt_url}/api/registry/refresh-counts',
        'headers': [
            {'header': 'Content-Type', 'value': 'application/json'}
        ],
        'body': '{}'
    },
    'flow': flow_id
}

if dry_run:
    print('[DRY] Would create flow:')
    print(json.dumps(flow_payload, indent=2))
    print('[DRY] Would create operation:')
    print(json.dumps(op_webhook_payload, indent=2))
else:
    # Create flow first (without operation reference)
    flow_create = dict(flow_payload)
    del flow_create['operation']
    code, resp = api('POST', '/flows', flow_create)
    if code not in (200, 204):
        print(f'[ERR] Failed to create flow: HTTP {code} — {json.dumps(resp)[:200]}')
        sys.exit(1)
    print(f'[OK]  Flow created: {flow_id}')

    # Create operation
    code, resp = api('POST', '/operations', op_webhook_payload)
    if code not in (200, 204):
        print(f'[ERR] Failed to create operation: HTTP {code} — {json.dumps(resp)[:200]}')
        sys.exit(1)
    print(f'[OK]  Operation created: {op_webhook_id}')

    # Link operation to flow
    code, resp = api('PATCH', f'/flows/{flow_id}', {'operation': op_webhook_id})
    if code == 200:
        print(f'[OK]  Flow linked to operation')
    else:
        print(f'[WARN] Could not link operation to flow: HTTP {code}')

print()
print('=========================================')
print('Count Refresh Flow Setup — Complete')
print(f'  Flow:      {flow_name}')
print(f'  Schedule:  Every 6 hours (0 */6 * * *)')
print(f'  Endpoint:  {nuxt_url}/api/registry/refresh-counts')
print('=========================================')
PYEOF

  BASE_URL="$BASE_URL" DOT_TOKEN="$DOT_TOKEN" DRY_RUN="${DRY_RUN:-}" \
    NUXT_INTERNAL_URL="$NUXT_INTERNAL_URL" FLOW_NAME="$FLOW_NAME" \
    python3 "$tmp_py" < /dev/null

  rm -f "$tmp_py"
}

main "$@"
