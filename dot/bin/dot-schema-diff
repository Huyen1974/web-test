#!/usr/bin/env bash
# =============================================================================
# dot-schema-diff — Compare schema snapshot vs current Directus state
# =============================================================================
# CHECKED-NO-DUPLICATE: [searched dot/bin/dot-schema-diff — no existing tool]
# VERSION: 1.0.0
#
# Calls Directus POST /schema/diff with a baseline snapshot to detect drift.
# Also provides local JSON diff between two snapshot files.
#
# Usage:
#   dot-schema-diff --baseline=FILE [--cloud|--local]
#   dot-schema-diff --file1=FILE --file2=FILE   (local diff, no API call)
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

source "${SCRIPT_DIR}/../config/environment.sh"

VERSION="1.0.0"
BASELINE_FILE=""
FILE1=""
FILE2=""

log_info() { echo "[INFO] $1"; }
log_ok()   { echo "[OK]   $1"; }
log_warn() { echo "[WARN] $1"; }
log_err()  { echo "[ERR]  $1" >&2; }

show_help() {
  cat << EOF
dot-schema-diff v${VERSION} — Compare schema snapshots

Usage:
  dot-schema-diff --baseline=FILE [--cloud|--local]
    Compare baseline snapshot against current live schema via Directus API.

  dot-schema-diff --file1=FILE --file2=FILE
    Local diff between two snapshot files (no API call).

Options:
  --baseline=FILE  Baseline snapshot JSON file
  --file1=FILE     First snapshot (older)
  --file2=FILE     Second snapshot (newer)
  --cloud          Use cloud Directus (default)
  --local          Use local Directus
  --help, -h       Show help

EOF
  show_environment_help
}

diff_local() {
  log_info "Comparing $FILE1 vs $FILE2 (local)..."
  python3 << 'PYEOF'
import json, sys, os

f1 = os.environ['DIFF_FILE1']
f2 = os.environ['DIFF_FILE2']

with open(f1) as a, open(f2) as b:
    d1 = json.load(a)
    d2 = json.load(b)

data1 = d1.get('data', d1)
data2 = d2.get('data', d2)

colls1 = {c['collection']: c for c in data1.get('collections', [])}
colls2 = {c['collection']: c for c in data2.get('collections', [])}

added = set(colls2.keys()) - set(colls1.keys())
removed = set(colls1.keys()) - set(colls2.keys())

fields1 = {}
for f in data1.get('fields', []):
    key = f"{f['collection']}.{f['field']}"
    fields1[key] = f
fields2 = {}
for f in data2.get('fields', []):
    key = f"{f['collection']}.{f['field']}"
    fields2[key] = f

fields_added = set(fields2.keys()) - set(fields1.keys())
fields_removed = set(fields1.keys()) - set(fields2.keys())

print(f"Collections added ({len(added)}):")
for c in sorted(added):
    print(f"  + {c}")
print(f"\nCollections removed ({len(removed)}):")
for c in sorted(removed):
    print(f"  - {c}")
print(f"\nFields added ({len(fields_added)}):")
for f in sorted(fields_added)[:30]:
    print(f"  + {f}")
if len(fields_added) > 30:
    print(f"  ... and {len(fields_added)-30} more")
print(f"\nFields removed ({len(fields_removed)}):")
for f in sorted(fields_removed)[:30]:
    print(f"  - {f}")
if len(fields_removed) > 30:
    print(f"  ... and {len(fields_removed)-30} more")

print(f"\nSummary: +{len(added)} collections, -{len(removed)} collections, +{len(fields_added)} fields, -{len(fields_removed)} fields")
PYEOF
}

diff_api() {
  log_info "Comparing baseline against live schema via API..."

  local resp_file
  resp_file=$(mktemp)
  trap "rm -f '$resp_file'" EXIT

  local http_code
  http_code=$(curl -sS --globoff -X POST "${DIRECTUS_URL}/schema/diff" \
    -H "Authorization: Bearer $DOT_TOKEN" \
    -H "Content-Type: application/json" \
    -d @"$BASELINE_FILE" \
    -o "$resp_file" \
    -w "%{http_code}")

  if [[ "$http_code" == "204" ]]; then
    log_ok "No schema changes detected — current schema matches baseline."
    return 0
  elif [[ "$http_code" == "200" ]]; then
    log_warn "Schema drift detected!"
    python3 -c "
import json
with open('$resp_file') as f:
    d = json.load(f)
diff = d.get('data', d)
print(json.dumps(diff, indent=2)[:3000])
"
    return 0
  else
    log_err "API returned HTTP $http_code"
    cat "$resp_file" 2>/dev/null | head -5
    return 1
  fi
}

main() {
  for arg in "$@"; do
    case "$arg" in
      --baseline=*) BASELINE_FILE="${arg#--baseline=}" ;;
      --file1=*) FILE1="${arg#--file1=}" ;;
      --file2=*) FILE2="${arg#--file2=}" ;;
      --help|-h) show_help; exit 0 ;;
    esac
  done

  echo "========================================="
  echo "DOT Tool: Schema Diff v${VERSION}"
  echo "========================================="

  if [[ -n "$FILE1" && -n "$FILE2" ]]; then
    DIFF_FILE1="$FILE1" DIFF_FILE2="$FILE2" diff_local
  elif [[ -n "$BASELINE_FILE" ]]; then
    init_environment "$@"
    print_environment_banner "$@"

    if [[ -z "${DOT_TOKEN:-}" ]]; then
      local dot_auth="${SCRIPT_DIR}/dot-auth"
      if [[ -f "$dot_auth" ]]; then
        source "$dot_auth" "$@"
      fi
    fi
    if [[ -z "${DOT_TOKEN:-}" ]]; then
      log_err "Authentication failed"
      exit 1
    fi
    diff_api
  else
    log_err "Specify --baseline=FILE or --file1=FILE --file2=FILE"
    exit 1
  fi

  echo ""
  echo "========================================="
  echo "DOT Tool: Schema Diff - COMPLETE"
  echo "========================================="
}

main "$@"
