#!/usr/bin/env bash
# =============================================================================
# dot-label-trigger-setup — Generate + execute auto-label triggers per table
# =============================================================================
# VERSION: 1.0.0
# CHECKED-NO-DUPLICATE: [đã grep dot/bin/dot-label*, không có tool tương tự]
# S123: Reads information_schema.columns per managed table and creates
# appropriate trigger DDL per Luật Nhãn v1.3 Section V.3
# Idempotent: DROP TRIGGER IF EXISTS before CREATE
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/../config/environment.sh"

VERSION="1.0.0"

log_info() { echo "[INFO] $1"; }
log_ok()   { echo "[OK]   $1"; }
log_err()  { echo "[ERR]  $1" >&2; }

run_pg() {
  local sql="$1"
  if [[ "$(detect_environment "${FLAG:-}")" == "local" ]]; then
    echo "$sql" | docker compose exec -T postgres psql -U directus -d directus
  else
    echo "$sql" | ssh -i ~/.ssh/contabo_vps -o ConnectTimeout=10 root@38.242.240.89 \
      "cd /opt/incomex/docker && docker compose exec -T postgres psql -U directus -d directus"
  fi
}

main() {
  local FLAG="${1:-}"
  init_environment "$@"
  print_environment_banner "$@"

  log_info "=== dot-label-trigger-setup v${VERSION} ==="

  # Ensure fn_auto_label_assignment exists
  run_pg "SELECT proname FROM pg_proc WHERE proname='fn_auto_label_assignment';" | grep -q fn_auto_label_assignment || {
    log_err "fn_auto_label_assignment() not found. Run dot-schema-taxonomy-pg-apply first."
    exit 1
  }

  # Generate and execute triggers per managed table
  run_pg "$(cat <<'EOSQL'
DO $$
DECLARE
  tbl RECORD;
  has_name boolean;
  has_desc boolean;
  trigger_ddl text;
  cnt integer := 0;
BEGIN
  FOR tbl IN
    SELECT DISTINCT mc.registry_collection AS tname
    FROM meta_catalog mc
    WHERE mc.registry_collection IS NOT NULL
      AND mc.registry_collection != ''
      AND mc.registry_collection != '_uncategorized'
      AND mc.registry_collection != 'comments'
      AND mc.code NOT IN ('CAT-ALL','CAT-MOL','CAT-CMP','CAT-MAT','CAT-PRD','CAT-BLD','CAT-999')
      AND EXISTS (SELECT 1 FROM information_schema.columns WHERE table_name=mc.registry_collection AND column_name='code')
  LOOP
    SELECT EXISTS(SELECT 1 FROM information_schema.columns WHERE table_name=tbl.tname AND column_name='name') INTO has_name;
    SELECT EXISTS(SELECT 1 FROM information_schema.columns WHERE table_name=tbl.tname AND column_name='description') INTO has_desc;
    EXECUTE format('DROP TRIGGER IF EXISTS trg_label_assign_%I ON %I', tbl.tname, tbl.tname);
    IF has_name AND has_desc THEN
      trigger_ddl := format('CREATE TRIGGER trg_label_assign_%I AFTER INSERT OR UPDATE OF name, description ON %I FOR EACH ROW EXECUTE FUNCTION fn_auto_label_assignment()', tbl.tname, tbl.tname);
    ELSIF has_name THEN
      trigger_ddl := format('CREATE TRIGGER trg_label_assign_%I AFTER INSERT OR UPDATE OF name ON %I FOR EACH ROW EXECUTE FUNCTION fn_auto_label_assignment()', tbl.tname, tbl.tname);
    ELSE
      trigger_ddl := format('CREATE TRIGGER trg_label_assign_%I AFTER INSERT ON %I FOR EACH ROW EXECUTE FUNCTION fn_auto_label_assignment()', tbl.tname, tbl.tname);
    END IF;
    EXECUTE trigger_ddl;
    cnt := cnt + 1;
    RAISE NOTICE 'Trigger for %: name=%, desc=%', tbl.tname, has_name, has_desc;
  END LOOP;
  RAISE NOTICE 'Total: % triggers created', cnt;
END $$;
EOSQL
  )"

  # Verify
  run_pg "SELECT tgname, tgrelid::regclass FROM pg_trigger WHERE tgfoid = 'fn_auto_label_assignment'::regproc ORDER BY tgrelid::regclass::text;"

  log_ok "=== dot-label-trigger-setup v${VERSION} COMPLETE ==="
}

main "$@"
