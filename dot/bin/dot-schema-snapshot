#!/usr/bin/env bash
# =============================================================================
# dot-schema-snapshot — Chụp Directus schema snapshot
# =============================================================================
# CHECKED-NO-DUPLICATE: [searched dot/bin/dot-schema-snapshot — no existing tool]
# VERSION: 1.0.0
#
# Calls Directus /schema/snapshot API to capture current schema state.
# Saves JSON to dot/snapshots/schema-YYYY-MM-DD.json
# Idempotent: running again on same day overwrites the file.
#
# Usage:
#   dot-schema-snapshot [--cloud|--local] [--output FILE]
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

source "${SCRIPT_DIR}/../config/environment.sh"

VERSION="1.0.0"
OUTPUT_FILE=""

log_info() { echo "[INFO] $1"; }
log_ok()   { echo "[OK]   $1"; }
log_err()  { echo "[ERR]  $1" >&2; }

show_help() {
  cat << EOF
dot-schema-snapshot v${VERSION} — Capture Directus schema snapshot

Usage:
  dot-schema-snapshot [--cloud|--local] [--output FILE]

Options:
  --local        Use local Directus
  --cloud        Use cloud Directus (default)
  --output=FILE  Custom output path (default: dot/snapshots/schema-YYYY-MM-DD.json)
  --help, -h     Show help

EOF
  show_environment_help
}

main() {
  for arg in "$@"; do
    case "$arg" in
      --output=*) OUTPUT_FILE="${arg#--output=}" ;;
      --help|-h) show_help; exit 0 ;;
    esac
  done

  init_environment "$@"
  local BASE_URL="$DIRECTUS_URL"

  echo "========================================="
  echo "DOT Tool: Schema Snapshot v${VERSION}"
  echo "========================================="
  print_environment_banner "$@"

  # Auth
  if [[ -z "${DOT_TOKEN:-}" ]]; then
    local dot_auth="${SCRIPT_DIR}/dot-auth"
    if [[ -f "$dot_auth" ]]; then
      source "$dot_auth" "$@"
    fi
  fi

  if [[ -z "${DOT_TOKEN:-}" ]]; then
    log_err "Authentication failed"
    exit 1
  fi

  # Determine output file
  if [[ -z "$OUTPUT_FILE" ]]; then
    OUTPUT_FILE="${DOT_ROOT}/snapshots/schema-$(date +%Y-%m-%d).json"
  fi

  # Capture snapshot
  log_info "Capturing schema snapshot from ${BASE_URL}..."
  local http_code
  http_code=$(curl -sS --globoff -X GET "${BASE_URL}/schema/snapshot" \
    -H "Authorization: Bearer $DOT_TOKEN" \
    -o "$OUTPUT_FILE" \
    -w "%{http_code}")

  if [[ "$http_code" != "200" ]]; then
    log_err "Failed to capture snapshot (HTTP $http_code)"
    cat "$OUTPUT_FILE" 2>/dev/null
    rm -f "$OUTPUT_FILE"
    exit 1
  fi

  # Verify and summarize
  local file_size collections_count fields_count
  file_size=$(wc -c < "$OUTPUT_FILE" | tr -d ' ')
  collections_count=$(python3 -c "
import json
with open('$OUTPUT_FILE') as f:
    d = json.load(f)
data = d.get('data', d)
colls = data.get('collections', [])
print(len(colls))
" 2>/dev/null || echo "?")
  fields_count=$(python3 -c "
import json
with open('$OUTPUT_FILE') as f:
    d = json.load(f)
data = d.get('data', d)
fields = data.get('fields', [])
print(len(fields))
" 2>/dev/null || echo "?")

  log_ok "Snapshot saved: ${OUTPUT_FILE}"
  log_ok "Size: ${file_size} bytes"
  log_ok "Collections: ${collections_count}"
  log_ok "Fields: ${fields_count}"

  echo ""
  echo "========================================="
  echo "DOT Tool: Schema Snapshot - COMPLETE"
  echo "========================================="
}

main "$@"
