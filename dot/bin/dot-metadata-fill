print('=== STEP 3: Fill field notes ===')
print('')

with open(fields_file) as f:
    data = json.load(f)

fields = data.get('data', [])

# Skip system fields
skip_fields = {'id', 'sort', 'user_created', 'user_updated', 'date_created', 'date_updated'}

