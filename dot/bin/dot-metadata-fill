#!/usr/bin/env bash
# =============================================================================
# dot-metadata-fill — Bulk fill metadata (group, note) for collections and fields
# =============================================================================
# CHECKED-NO-DUPLICATE: [searched dot/bin/dot-metadata-fill — no existing tool]
# VERSION: 1.0.0
#
# Fills:
#   1. Collection meta.group for ungrouped collections
#   2. Collection meta.note for collections without descriptions
#   3. Field meta.note for fields without descriptions
#
# Uses Directus Admin API (PATCH /collections, PATCH /fields).
# Idempotent: skips collections/fields that already have values.
#
# Usage:
#   dot-metadata-fill [--cloud|--local] [--dry-run]
#   dot-metadata-fill --fields-only --collection=NAME [--cloud]
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

source "${SCRIPT_DIR}/../config/environment.sh"

VERSION="1.0.0"
DRY_RUN=""
FIELDS_ONLY=""
SINGLE_COLLECTION=""

log_info() { echo "[INFO] $1"; }
log_ok()   { echo "[OK]   $1"; }
log_err()  { echo "[ERR]  $1" >&2; }

show_help() {
  cat << EOF
dot-metadata-fill v${VERSION} — Bulk fill metadata

Usage:
  dot-metadata-fill [--cloud|--local] [--dry-run]
  dot-metadata-fill --fields-only --collection=NAME [--cloud]

Options:
  --local              Use local Directus
  --cloud              Use cloud Directus (default)
  --dry-run            Show what would be done without making changes
  --fields-only        Only fill field notes (skip collection group/note)
  --collection=NAME    Only process this collection
  --help, -h           Show help

EOF
  show_environment_help
}

main() {
  for arg in "$@"; do
    case "$arg" in
      --dry-run) DRY_RUN="1" ;;
      --fields-only) FIELDS_ONLY="1" ;;
      --collection=*) SINGLE_COLLECTION="${arg#--collection=}" ;;
      --help|-h) show_help; exit 0 ;;
    esac
  done

  init_environment "$@"
  local BASE_URL="$DIRECTUS_URL"

  echo "========================================="
  echo "DOT Tool: Metadata Fill v${VERSION}"
  echo "========================================="
  print_environment_banner "$@"

  # Auth
  if [[ -z "${DOT_TOKEN:-}" ]]; then
    local dot_auth="${SCRIPT_DIR}/dot-auth"
    if [[ -f "$dot_auth" ]]; then
      source "$dot_auth" "$@"
    fi
  fi

  if [[ -z "${DOT_TOKEN:-}" ]]; then
    log_err "Authentication failed"
    exit 1
  fi

  # Fetch fields to temp file (needed for step 3)
  local tmp_fields tmp_py
  tmp_fields=$(mktemp)
  tmp_py=$(mktemp /tmp/dot-metadata-fill-XXXXXX.py)
  trap "rm -f '$tmp_fields' '$tmp_py'" EXIT

  log_info "Fetching all fields..."
  local fields_code
  fields_code=$(curl -sS --globoff -X GET "${BASE_URL}/fields?limit=-1" \
    -H "Authorization: Bearer $DOT_TOKEN" \
    -o "$tmp_fields" -w "%{http_code}")

  if [[ "$fields_code" != "200" ]]; then
    log_err "Failed to fetch fields (HTTP $fields_code)"
    exit 1
  fi

  # Write Python script to temp file (avoids bash 3.2 associative array limitation)
  cat > "$tmp_py" << 'PYEOF'
import json, os, sys, ssl, urllib.request

base_url = os.environ['BASE_URL']
token = os.environ['DOT_TOKEN']
dry_run = os.environ.get('DRY_RUN', '')
fields_only = os.environ.get('FIELDS_ONLY', '')
single_coll = os.environ.get('SINGLE_COLLECTION', '')
fields_file = os.environ['FIELDS_FILE']

ctx = ssl.create_default_context()
ctx.check_hostname = False
ctx.verify_mode = ssl.CERT_NONE

def patch_api(url, data):
    """PATCH Directus API. Returns True on success."""
    try:
        payload = json.dumps(data).encode()
        req = urllib.request.Request(url, data=payload, method='PATCH',
            headers={'Authorization': f'Bearer {token}', 'Content-Type': 'application/json'})
        resp = urllib.request.urlopen(req, context=ctx)
        return resp.status == 200
    except Exception as e:
        print(f'  [WARN] PATCH {url}: {e}')
        return False

# ============================================================
# STEP 1: Fill collection groups
# ============================================================
GROUP_MAP = {
    # AI / Agent system
    'agent_views': 'ai_system',
    'ai_discussion_comments': 'ai_system',
    'ai_discussions': 'ai_system',
    'ai_tasks': 'ai_system',
    # Blocks
    'block_button_groups': 'blocks',
    'block_buttons': 'blocks',
    'block_library': 'blocks',
    # Checkpoints
    'checkpoint_instances': 'tasks',
    'checkpoint_rules': 'tasks',
    'checkpoint_type_overrides': 'tasks',
    'checkpoint_types': 'tasks',
    # CRM / Sales
    'billing': 'sales',
    'contacts': 'sales',
    'conversations': 'sales',
    'inbox': 'sales',
    'organizations': 'sales',
    # Content / Website
    'content_requests': 'website',
    'help': 'website',
    'languages': 'website',
    'navigation_navigation_items': 'navigation',
    'pages_blocks': 'pages',
    'pages_translations': 'pages',
    # Document review
    'doc_reviews': 'knowledge_documents',
    # Meta / Registry
    'table_proposals': 'table_registry',
    # OS modules
    'os_projects': 'sales',
    'os_tasks': 'os_projects',
    # Tasks system
    'task_checkpoints': 'tasks',
    'task_comments': 'tasks',
    # Workflows
    'workflow_categories': 'workflows',
    'workflow_change_requests': 'workflows',
    'workflow_step_relations': 'workflows',
    'workflow_steps': 'workflows',
}

if not fields_only:
    print('')
    print('=== STEP 1: Fill collection groups ===')
    print('')
    filled = 0
    for coll, group in sorted(GROUP_MAP.items()):
        url = f'{base_url}/collections/{coll}'
        data = {'meta': {'group': group}}
        if dry_run:
            print(f'  [DRY] {coll} -> group={group}')
            filled += 1
        elif patch_api(url, data):
            print(f'  [OK]   {coll} -> group={group}')
            filled += 1
        else:
            print(f'  [FAIL] {coll}')
    print(f'\n[INFO] Groups filled: {filled}/{len(GROUP_MAP)}')

