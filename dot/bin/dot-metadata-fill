}

# Context-specific overrides: (collection, field) -> note
specific_notes = {
    ('globals', 'social_links'): u'Li\u00ean k\u1ebft m\u1ea1ng x\u00e3 h\u1ed9i hi\u1ec3n th\u1ecb tr\u00ean website (JSON)',
    ('globals', 'og_image'): u'H\u00ecnh \u1ea3nh Open Graph m\u1eb7c \u0111\u1ecbnh cho to\u00e0n website',
    ('posts', 'cost'): u'M\u1ee9c chi ph\u00ed b\u00e0i vi\u1ebft (range text)',
    ('tasks', 'name'): u'T\u00ean task hi\u1ec3n th\u1ecb',
    ('tasks', 'assigned_to'): u'Ng\u01b0\u1eddi/agent \u0111\u01b0\u1ee3c giao task',
    ('tasks', 'workflow_status'): u'Tr\u1ea1ng th\u00e1i duy\u1ec7t: draft \u2192 under_review \u2192 approved',
    ('meta_catalog', 'name'): u'T\u00ean danh m\u1ee5c (ti\u1ebfng Vi\u1ec7t)',
    ('meta_catalog', 'code'): u'M\u00e3 danh m\u1ee5c: CAT-NNN',
    ('table_registry', 'table_id'): u'ID b\u1ea3ng UI duy nh\u1ea5t: tbl_*',
    ('table_registry', 'name'): u'T\u00ean b\u1ea3ng hi\u1ec3n th\u1ecb',
    ('workflows', 'title'): u'T\u00ean quy tr\u00ecnh',
    ('workflows', 'process_code'): u'M\u00e3 quy tr\u00ecnh duy nh\u1ea5t',
    ('workflow_steps', 'title'): u'T\u00ean b\u01b0\u1edbc trong quy tr\u00ecnh',
    ('workflow_steps', 'step_key'): u'Kho\u00e1 b\u01b0\u1edbc duy nh\u1ea5t trong c\u00f9ng quy tr\u00ecnh',
}

filled = 0
skipped = 0
errors = 0

for f in fields:
    coll = f.get('collection', '')
    field = f.get('field', '')

    if coll.startswith('directus_'):
        continue
    if field in skip_fields:
        continue
    if single_coll and coll != single_coll:
        continue

    # Skip if already has note
    meta = f.get('meta') or {}
    existing_note = meta.get('note') or ''
    if existing_note.strip():
        skipped += 1
        continue

    # Determine note
    note = specific_notes.get((coll, field))
    if not note:
        note = common_notes.get(field)
    if not note:
        # Try to infer from field name
        fname = field.lower()
        if fname.endswith('_id') and fname != 'table_id':
            target = fname[:-3]
            note = f'FK \u2192 {target}'
        elif fname.endswith('_at'):
            note = f'Th\u1eddi \u0111i\u1ec3m {fname[:-3].replace("_", " ")}'
        elif fname.startswith('is_'):
            note = f'{fname[3:].replace("_", " ").capitalize()}?'
        elif fname.startswith('has_'):
            note = f'C\u00f3 {fname[4:].replace("_", " ")}?'
        elif fname.startswith('enable_'):
            note = f'B\u1eadt {fname[7:].replace("_", " ")}?'
        elif fname.startswith('total_'):
            note = f'T\u1ed5ng {fname[6:].replace("_", " ")}'
        elif fname.startswith('date_'):
            note = f'Ng\u00e0y {fname[5:].replace("_", " ")}'

    if not note:
        # Generic fallback based on type
        ftype = f.get('type', '')
        if ftype == 'alias':
            note = u'Quan h\u1ec7 li\u00ean k\u1ebft (alias)'
        elif ftype == 'json':
            note = u'D\u1eef li\u1ec7u c\u1ea5u tr\u00fac (JSON)'
        elif ftype == 'boolean':
            note = u'C\u1edd boolean'
        elif ftype == 'text':
            note = u'N\u1ed9i dung v\u0103n b\u1ea3n'
        elif ftype in ('uuid', 'string') and meta.get('special') and 'm2o' in (meta.get('special') or []):
            note = u'FK li\u00ean k\u1ebft (M2O)'
        else:
            note = f'Tr\u01b0\u1eddng {field}'

    if dry_run:
        print(f'  [DRY] {coll}.{field}: {note[:60]}')
        filled += 1
        continue

    # Apply note via API
    try:
        payload = json.dumps({'meta': {'note': note}}).encode()
        url = f'{base_url}/fields/{coll}/{field}'
        req = urllib.request.Request(url, data=payload, method='PATCH',
            headers={'Authorization': f'Bearer {token}', 'Content-Type': 'application/json'})
        resp = urllib.request.urlopen(req, context=ctx)
        if resp.status == 200:
            filled += 1
        else:
            errors += 1
    except Exception as e:
        errors += 1
        if filled < 3:
            print(f'  [ERR] {coll}.{field}: {e}', file=sys.stderr)

    # Progress every 50
    if (filled + errors) % 50 == 0:
        print(f'  ... processed {filled + errors} fields ({filled} filled, {errors} errors)')

print(f'\nField notes: filled={filled}, skipped_existing={skipped}, errors={errors}')
PYEOF

  local result
  result=$(FIELDS_FILE="$tmp_fields" BASE_URL="$BASE_URL" DOT_TOKEN="$DOT_TOKEN" \
    DRY_RUN="${DRY_RUN}" FIELDS_ONLY="${FIELDS_ONLY}" SINGLE_COLLECTION="${SINGLE_COLLECTION}" \
    python3 "$tmp_py" < /dev/null)

  echo "$result"
  rm -f "$tmp_py"

  echo ""
  echo "========================================="
  echo "DOT Tool: Metadata Fill - COMPLETE"
  echo "========================================="
}

main "$@"
