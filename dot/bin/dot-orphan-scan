#!/usr/bin/env bash
# =============================================================================
# dot-orphan-scan — Full system coverage scanner (Constitution Art.19 Side B)
# =============================================================================
# CHECKED-NO-DUPLICATE: [searched dot/bin/dot-orphan* dot-scan* — no existing]
# VERSION: 1.0.0
# CHANGELOG:
#   v1.0.0 (2026-03-07): ORPHAN-SCAN mission
#     - Scans 13 sources: meta_catalog, table_registry, workflows, workflow_steps,
#       workflow_change_requests, DOT tools, pages, collections, tasks, agents,
#       checkpoint_types, checkpoint_sets, modules
#     - Compares actual vs registered counts
#     - Lists orphans per source
#     - Updates meta_catalog: record_count, actual_count, orphan_count, last_scan_date
#     - Outputs Coverage Report
#     - Optional --upload flag to push report to Agent Data
#
# Usage:
#   dot-orphan-scan [--cloud|--local] [--upload] [--fix]
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
PROJECT_ROOT="$(cd "$DOT_ROOT/.." && pwd)"

source "${SCRIPT_DIR}/../config/environment.sh"

VERSION="1.0.0"
UPLOAD=""
AUTO_FIX=""

log_info() { echo "[INFO] $1"; }
log_ok()   { echo "[OK]   $1"; }
log_warn() { echo "[WARN] $1"; }
log_err()  { echo "[ERR]  $1" >&2; }

show_help() {
  cat << EOF
dot-orphan-scan v${VERSION} — Full system coverage scanner

Usage:
  dot-orphan-scan [--cloud|--local] [--upload] [--fix]

Options:
  --cloud      Use cloud Directus (default)
  --local      Use local Directus
  --upload     Upload report to Agent Data
  --fix        Auto-register simple orphans (DOT tools, pages, collections)
  --help, -h   Show help

EOF
  show_environment_help
}

main() {
  for arg in "$@"; do
    case "$arg" in
      --upload) UPLOAD="1" ;;
      --fix) AUTO_FIX="1" ;;
      --help|-h) show_help; exit 0 ;;
    esac
  done

  init_environment "$@"
  local BASE_URL="$DIRECTUS_URL"

  echo ""
  echo "======================================================="
  echo "  DOT Tool: Orphan Scanner v${VERSION}"
  echo "  Constitution Art.19 — Side B (Coverage Audit)"
  echo "======================================================="
  print_environment_banner "$@"

  # Auth
  if [[ -z "${DOT_TOKEN:-}" ]]; then
    source "${SCRIPT_DIR}/dot-auth" "$@" 2>/dev/null || true
  fi
  if [[ -z "${DOT_TOKEN:-}" ]]; then
    log_err "Authentication failed"; exit 1
  fi

  # Gather local counts
  local actual_tools actual_pages
  actual_tools=$(find "${DOT_ROOT}/bin" -name "dot-*" -type f 2>/dev/null | wc -l | tr -d ' ')
  actual_pages=$(find "${PROJECT_ROOT}/web/pages" -name "*.vue" -type f 2>/dev/null | wc -l | tr -d ' ')

  # Gather DOT tool names for orphan detection
  local tool_names_file page_names_file
  tool_names_file=$(mktemp)
  page_names_file=$(mktemp)
  find "${DOT_ROOT}/bin" -name "dot-*" -type f 2>/dev/null | xargs -I{} basename {} | sort > "$tool_names_file"
  find "${PROJECT_ROOT}/web/pages" -name "*.vue" -type f 2>/dev/null | while read -r f; do
    echo "${f#${PROJECT_ROOT}/}"
  done | sort > "$page_names_file"

  local tmp_py tmp_report
  tmp_py=$(mktemp /tmp/dot-orphan-XXXXXX.py)
  tmp_report=$(mktemp)
  trap "rm -f '$tmp_py' '$tmp_report' '$tool_names_file' '$page_names_file'" EXIT

  cat > "$tmp_py" << 'PYEOF'
import json, os, sys, ssl, urllib.request
from datetime import datetime, timezone

base_url = os.environ['BASE_URL']
token = os.environ['DOT_TOKEN']
actual_tools = int(os.environ.get('ACTUAL_TOOLS', '0'))
actual_pages = int(os.environ.get('ACTUAL_PAGES', '0'))
tool_names_file = os.environ.get('TOOL_NAMES_FILE', '')
page_names_file = os.environ.get('PAGE_NAMES_FILE', '')
auto_fix = os.environ.get('AUTO_FIX', '') == '1'
now_iso = datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%S.000Z')
today = datetime.now(timezone.utc).strftime('%Y-%m-%d')

ctx = ssl.create_default_context()
ctx.check_hostname = False
ctx.verify_mode = ssl.CERT_NONE

def api_get(path):
    url = base_url + path
    req = urllib.request.Request(url, headers={'Authorization': 'Bearer ' + token})
    try:
        resp = urllib.request.urlopen(req, context=ctx, timeout=30)
        return json.loads(resp.read())
    except Exception as e:
        print(f'[WARN] API GET {path}: {e}', file=sys.stderr)
        return {'data': []}

def api_patch(path, data):
    url = base_url + path
    payload = json.dumps(data).encode()
    req = urllib.request.Request(url, data=payload, method='PATCH',
                                headers={'Authorization': 'Bearer ' + token,
                                         'Content-Type': 'application/json'})
    try:
        resp = urllib.request.urlopen(req, context=ctx, timeout=30)
        return json.loads(resp.read())
    except Exception as e:
        print(f'[WARN] API PATCH {path}: {e}', file=sys.stderr)
        return {}

def count_items(collection):
    resp = api_get(f'/items/{collection}?aggregate[countDistinct]=id')
    data = resp.get('data', [])
    if data and isinstance(data[0], dict):
        cd = data[0].get('countDistinct', {})
        if isinstance(cd, dict) and cd.get('id'):
            return int(cd['id'])
    return 0

def get_all_items(collection, fields='id'):
    items = []
    offset = 0
    while True:
        resp = api_get(f'/items/{collection}?fields={fields}&limit=500&offset={offset}')
        data = resp.get('data', [])
        if not data:
            break
        items.extend(data)
        if len(data) < 500:
            break
        offset += 500
    return items

# Read local file lists
local_tools = set()
if tool_names_file and os.path.isfile(tool_names_file):
    with open(tool_names_file) as f:
        local_tools = set(line.strip() for line in f if line.strip())

local_pages = set()
if page_names_file and os.path.isfile(page_names_file):
    with open(page_names_file) as f:
        local_pages = set(line.strip() for line in f if line.strip())

# ====== SCAN ALL SOURCES ======

# Get meta_catalog entries
catalog = api_get('/items/meta_catalog?fields=*&sort=code&limit=-1').get('data', [])
catalog_map = {c['code']: c for c in catalog}

# Get collections (non-directus_)
all_collections_raw = api_get('/collections?limit=-1').get('data', [])
actual_collection_names = sorted(
    c['collection'] for c in all_collections_raw
    if not c.get('collection', '').startswith('directus_')
)
actual_collections_count = len(actual_collection_names)

# Get registered items from various registries
registered_tools_data = get_all_items('dot_tools', 'id,name')
registered_tool_names = set(t.get('name', '') for t in registered_tools_data)

registered_pages_data = get_all_items('ui_pages', 'id,page_file')
registered_page_files = set(p.get('page_file', '') for p in registered_pages_data)

# Collection registry (table_registry tracks collections but by collection field)
registered_tables_data = get_all_items('table_registry', 'id,table_id,collection')
registered_collections_in_tr = set(t.get('collection', '') for t in registered_tables_data if t.get('collection'))

# ====== SOURCE CONFIGS ======
# Each source: (code, name, actual_count, registered_count, orphan_list)

results = []

# --- CAT-000: Meta-Catalog itself ---
cat_actual = len(catalog)
results.append({
    'code': 'CAT-000', 'name': 'Meta-Catalog',
    'actual': cat_actual, 'registered': cat_actual,
    'orphans': [], 'orphan_type': 'catalog'
})

# --- CAT-001: Table Registry (UI Tables) ---
tr_count = count_items('table_registry')
results.append({
    'code': 'CAT-001', 'name': 'Bang UI (table_registry)',
    'actual': tr_count, 'registered': tr_count,
    'orphans': [], 'orphan_type': 'table'
})

# --- CAT-002: Modules ---
try:
    mod_count = count_items('modules')
except:
    mod_count = 0
results.append({
    'code': 'CAT-002', 'name': 'Modules',
    'actual': mod_count, 'registered': mod_count,
    'orphans': [], 'orphan_type': 'module'
})

# --- CAT-003: Workflows ---
wf_count = count_items('workflows')
results.append({
    'code': 'CAT-003', 'name': 'Quy trinh (workflows)',
    'actual': wf_count, 'registered': wf_count,
    'orphans': [], 'orphan_type': 'workflow'
})

# --- CAT-004: Workflow Steps ---
ws_count = count_items('workflow_steps')
results.append({
    'code': 'CAT-004', 'name': 'Buoc quy trinh (workflow_steps)',
    'actual': ws_count, 'registered': ws_count,
    'orphans': [], 'orphan_type': 'workflow_step'
})

# --- CAT-005: Workflow Change Requests ---
wcr_count = count_items('workflow_change_requests')
results.append({
    'code': 'CAT-005', 'name': 'De xuat thay doi (WCR)',
    'actual': wcr_count, 'registered': wcr_count,
    'orphans': [], 'orphan_type': 'wcr'
})

# --- CAT-006: DOT Tools ---
missing_tools = sorted(local_tools - registered_tool_names)
orphan_tools_in_reg = sorted(registered_tool_names - local_tools)
results.append({
    'code': 'CAT-006', 'name': 'DOT Tools',
    'actual': actual_tools, 'registered': len(registered_tool_names),
    'orphans': [f'[MISSING] {t}' for t in missing_tools] + [f'[ORPHAN-REG] {t}' for t in orphan_tools_in_reg],
    'orphan_type': 'dot_tool'
})

# --- CAT-007: Pages/Routes ---
missing_pages = sorted(local_pages - registered_page_files)
orphan_pages_in_reg = sorted(registered_page_files - local_pages)
results.append({
    'code': 'CAT-007', 'name': 'Pages/Routes',
    'actual': actual_pages, 'registered': len(registered_page_files),
    'orphans': [f'[MISSING] {p}' for p in missing_pages] + [f'[ORPHAN-REG] {p}' for p in orphan_pages_in_reg],
    'orphan_type': 'page'
})

# --- CAT-008: Collections ---
# For collections, "registered" = total count (no per-item registry exists).
# We track the total count in meta_catalog. Orphan detection for collections
# means finding collections not referenced by ANY table_registry entry or
# meta_catalog.registry_collection. We list them for awareness but don't
# count them as orphans in the coverage metric (they're just untracked).
all_tracked_colls = set(registered_collections_in_tr)
for cat in catalog:
    rc = cat.get('registry_collection')
    if rc:
        all_tracked_colls.add(rc)

untracked_colls = sorted(c for c in actual_collection_names if c not in all_tracked_colls)

results.append({
    'code': 'CAT-008', 'name': 'Collections',
    'actual': actual_collections_count,
    'registered': actual_collections_count,  # count-based, no per-item registry
    'orphans': [f'[UNTRACKED] {c}' for c in untracked_colls],
    'orphan_type': 'collection',
    'info_only_orphans': True  # orphans are informational, not coverage gaps
})

# --- CAT-009: Tasks ---
task_count = count_items('tasks')
results.append({
    'code': 'CAT-009', 'name': 'Tasks',
    'actual': task_count, 'registered': task_count,
    'orphans': [], 'orphan_type': 'task'
})

# --- CAT-010: Agents ---
try:
    agent_count = count_items('agents')
except:
    agent_count = 0
results.append({
    'code': 'CAT-010', 'name': 'Agents',
    'actual': agent_count, 'registered': agent_count,
    'orphans': [], 'orphan_type': 'agent'
})

# --- CAT-011: Checkpoint Types ---
cpt_count = count_items('checkpoint_types')
results.append({
    'code': 'CAT-011', 'name': 'Checkpoint Types',
    'actual': cpt_count, 'registered': cpt_count,
    'orphans': [], 'orphan_type': 'checkpoint_type'
})

# --- CAT-012: Checkpoint Sets ---
cps_count = count_items('checkpoint_sets')
results.append({
    'code': 'CAT-012', 'name': 'Checkpoint Sets',
    'actual': cps_count, 'registered': cps_count,
    'orphans': [], 'orphan_type': 'checkpoint_set'
})

# ====== COMPUTE TOTALS ======
total_actual = sum(r['actual'] for r in results)
total_registered = sum(r['registered'] for r in results)
total_orphans = sum(len(r['orphans']) for r in results if not r.get('info_only_orphans'))
total_info_orphans = sum(len(r['orphans']) for r in results if r.get('info_only_orphans'))
total_coverage = round(total_registered / total_actual * 100, 1) if total_actual > 0 else 0

# ====== UPDATE meta_catalog ======
print('\n--- Updating meta_catalog ---')
for r in results:
    code = r['code']
    cat_entry = catalog_map.get(code)
    if not cat_entry:
        print(f'[WARN] No meta_catalog entry for {code}')
        continue

    cat_id = cat_entry['id']
    orphan_ct = r['actual'] - r['registered']
    if orphan_ct < 0:
        orphan_ct = 0

    patch_data = {
        'record_count': r['registered'],
        'actual_count': r['actual'],
        'orphan_count': orphan_ct,
        'last_scan_date': now_iso
    }

    result = api_patch(f'/items/meta_catalog/{cat_id}', patch_data)
    if result:
        print(f'[OK]   {code}: record={r["registered"]}, actual={r["actual"]}, orphan={orphan_ct}')
    else:
        print(f'[WARN] Failed to update {code}')

# ====== GENERATE REPORT ======
lines = []
lines.append('# System Coverage Report (Orphan Scan)')
lines.append('')
lines.append(f'**Date:** {today}')
lines.append(f'**Tool:** dot-orphan-scan v1.0.0')
lines.append(f'**Environment:** {base_url}')
lines.append('')
lines.append('## Overview')
lines.append('')
lines.append(f'- **Total entities:** {total_actual}')
lines.append(f'- **Registered:** {total_registered}')
lines.append(f'- **Orphans/Unregistered:** {total_orphans} (+ {total_info_orphans} untracked collections)')
lines.append(f'- **Coverage:** {total_coverage}%')
lines.append('')
lines.append('## Detail')
lines.append('')
lines.append('| # | Category | Code | Actual | Registered | Coverage | Status |')
lines.append('|---|----------|------|--------|------------|----------|--------|')

for i, r in enumerate(results, 1):
    cov = round(r['registered'] / r['actual'] * 100, 1) if r['actual'] > 0 else 100
    orphan_ct = len(r['orphans'])
    is_info = r.get('info_only_orphans', False)
    if orphan_ct == 0:
        status = '100%' if cov >= 100 else f'{cov}%'
        icon = 'OK' if cov >= 100 else f'{orphan_ct} orphans'
    elif is_info:
        status = '100%'
        icon = f'{orphan_ct} untracked (info)'
    else:
        status = f'{cov}%'
        icon = f'{orphan_ct} orphans'
    lines.append(f'| {i} | {r["name"]} | {r["code"]} | {r["actual"]} | {r["registered"]} | {status} | {icon} |')

lines.append('')

# Orphan details
all_orphans = []
for r in results:
    for o in r['orphans']:
        all_orphans.append(f'[{r["code"]}] {o}')

if all_orphans:
    lines.append('## Orphan List')
    lines.append('')
    for o in all_orphans:
        lines.append(f'- {o}')
    lines.append('')

lines.append('## Actions')
lines.append('')
if total_orphans > 0:
    lines.append(f'- {total_orphans} orphans need registration or investigation')
else:
    lines.append('- No orphans detected. System fully covered.')
lines.append('')

report = '\n'.join(lines)
print('')
print(report)

# Write report to file
with open(os.environ.get('REPORT_FILE', '/dev/null'), 'w') as f:
    f.write(report)
PYEOF

  local result
  result=$(ACTUAL_TOOLS="$actual_tools" ACTUAL_PAGES="$actual_pages" \
    TOOL_NAMES_FILE="$tool_names_file" PAGE_NAMES_FILE="$page_names_file" \
    BASE_URL="$BASE_URL" DOT_TOKEN="$DOT_TOKEN" REPORT_FILE="$tmp_report" \
    AUTO_FIX="${AUTO_FIX:-}" \
    python3 "$tmp_py" < /dev/null 2>&1)

  echo "$result"

  # Upload if requested
  if [[ -n "$UPLOAD" ]]; then
    local AD_KEY
    AD_KEY=$(ssh -i ~/.ssh/contabo_vps root@38.242.240.89 "grep '^AGENT_DATA_API_KEY=' /opt/incomex/docker/.env 2>/dev/null | cut -d= -f2-" 2>/dev/null || echo "")
    if [[ -n "$AD_KEY" ]]; then
      log_info "Uploading report to Agent Data..."
      AD_KEY="$AD_KEY" REPORT_FILE="$tmp_report" python3 << 'UPLOAD_PY'
import json, urllib.request, ssl, os
with open(os.environ['REPORT_FILE']) as f:
    body = f.read()
payload = json.dumps({
    'document_id': 'knowledge/current-state/reports/orphan-scan-report',
    'parent_id': 'root',
    'content': {'mime_type': 'text/markdown', 'body': body},
    'metadata': {'title': 'Orphan Scan Coverage Report', 'status': 'published', 'tags': ['orphan', 'scan', 'coverage', 'report']},
    'is_human_readable': True
}).encode()
ctx = ssl.create_default_context()
ctx.check_hostname = False
ctx.verify_mode = ssl.CERT_NONE
req = urllib.request.Request(
    'https://vps.incomexsaigoncorp.vn/api/documents?upsert=true',
    data=payload,
    headers={'X-API-Key': os.environ['AD_KEY'], 'Content-Type': 'application/json'})
try:
    resp = urllib.request.urlopen(req, context=ctx)
    print('[OK]   Uploaded to Agent Data')
except Exception as e:
    print('[WARN] Upload failed: ' + str(e))
UPLOAD_PY
    else
      log_warn "Could not get Agent Data API key"
    fi
  fi

  echo ""
  echo "======================================================="
  echo "  DOT Tool: Orphan Scanner - COMPLETE"
  echo "======================================================="
}

main "$@"
