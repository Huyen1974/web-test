#!/usr/bin/env bash
# =============================================================================
# dot-selftest-registries — Comprehensive Registry System Self-Test
# =============================================================================
# VERSION: 1.0.0
# CHECKED-NO-DUPLICATE: [grep dot/bin/ for "selftest-registries" — no match]
#
# Tests ALL 3 layers of the Registry system plus data integrity:
#   Layer 1: Main index (/knowledge/registries) — meta_catalog renders
#   Layer 2: Entity type pages — table_registry config present + data renders
#   Layer 3: Individual entity detail pages — sample items load
#   Completeness: meta_catalog ↔ table_registry alignment
#   Data Presence: Each collection has actual records
#
# Usage:
#   dot-selftest-registries [--cloud|--local] [--url=URL] [--fix]
#
# Options:
#   --url=URL    Override public site URL
#   --fix        Auto-fix missing table_registry entries (requires auth)
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

VERSION="1.1.0"
BASE_URL="https://vps.incomexsaigoncorp.vn"
DIRECTUS_URL="https://directus.incomexsaigoncorp.vn"
FIX_MODE=false

for arg in "$@"; do
  case "$arg" in
    --url=*) BASE_URL="${arg#--url=}" ;;
    --fix) FIX_MODE=true ;;
    --help|-h)
      echo "dot-selftest-registries v${VERSION}"
      echo ""
      echo "Comprehensive Registry System Self-Test"
      echo ""
      echo "Usage: dot-selftest-registries [--url=URL]"
      echo "  --url=URL   Override public site URL"
      exit 0
      ;;
  esac
done

FAIL=0
PASS=0
WARN=0
TOTAL=0

pass() { echo "  PASS: $1"; PASS=$((PASS+1)); TOTAL=$((TOTAL+1)); }
fail() { echo "  FAIL: $1"; FAIL=$((FAIL+1)); TOTAL=$((TOTAL+1)); }
warn() { echo "  WARN: $1"; WARN=$((WARN+1)); TOTAL=$((TOTAL+1)); }

# Shared temp file for page fetches
_PAGE_TMP=$(mktemp)
trap "rm -f '$_PAGE_TMP'" EXIT

fetch_page_status() {
  # Fetch URL, save body to $_PAGE_TMP, return HTTP status code
  local url="$1"
  curl -sk -o "$_PAGE_TMP" -w "%{http_code}" --max-time 30 "$url" 2>/dev/null || echo "000"
}

page_size() {
  wc -c < "$_PAGE_TMP" 2>/dev/null | tr -d '[:space:]'
}

page_grep_count() {
  local c
  c=$(grep -c "$1" "$_PAGE_TMP" 2>/dev/null || true)
  echo "${c:-0}" | tr -d '[:space:]'
}

page_grep_ci_count() {
  local c
  c=$(grep -ci "$1" "$_PAGE_TMP" 2>/dev/null || true)
  echo "${c:-0}" | tr -d '[:space:]'
}

echo "========================================="
echo "DOT Self-Test: Registries v${VERSION}"
echo "========================================="
echo "Site URL:     ${BASE_URL}"
echo "Directus URL: ${DIRECTUS_URL}"
echo ""

# =========================================================================
# TEST 1: Directus API Health
# =========================================================================
echo "--- Test 1: Directus API Health ---"

API_STATUS=$(curl -sk -o /dev/null -w "%{http_code}" --max-time 10 "${DIRECTUS_URL}/server/health" 2>/dev/null || echo "000")
if [[ "$API_STATUS" == "200" ]]; then
  pass "Directus API healthy"
else
  fail "Directus API returned HTTP ${API_STATUS}"
fi

# =========================================================================
# TEST 2: Completeness — meta_catalog ↔ table_registry alignment
# =========================================================================
echo ""
echo "--- Test 2: meta_catalog ↔ table_registry Alignment ---"

# Fetch meta_catalog entries
META_JSON=$(curl -sk --max-time 15 "${DIRECTUS_URL}/items/meta_catalog?fields=id,code,name,entity_type,registry_collection&limit=100" 2>/dev/null || echo '{"data":[]}')
META_COUNT=$(echo "$META_JSON" | python3 -c "import sys,json; d=json.load(sys.stdin); print(len(d.get('data',[])))" 2>/dev/null || echo "0")

if [[ "$META_COUNT" -gt 0 ]]; then
  pass "meta_catalog has ${META_COUNT} entries"
else
  fail "meta_catalog is empty or inaccessible"
fi

# Fetch table_registry entries
TBL_JSON=$(curl -sk --max-time 15 "${DIRECTUS_URL}/items/table_registry?fields=id,table_id,collection,status&limit=100" 2>/dev/null || echo '{"data":[]}')
TBL_COUNT=$(echo "$TBL_JSON" | python3 -c "import sys,json; d=json.load(sys.stdin); print(len(d.get('data',[])))" 2>/dev/null || echo "0")

if [[ "$TBL_COUNT" -gt 0 ]]; then
  pass "table_registry has ${TBL_COUNT} entries"
else
  fail "table_registry is empty or inaccessible"
fi

# Cross-check: each meta_catalog.registry_collection should have a table_registry record
MISSING_TBL=$(echo "$META_JSON" | python3 -c "
import sys, json
meta = json.load(sys.stdin).get('data', [])
tbl_data = json.loads('''${TBL_JSON}''').get('data', [])
tbl_collections = {t['collection'] for t in tbl_data}
# table_registry itself is meta, skip it
skip = {'table_registry', 'meta_catalog'}
missing = []
for m in meta:
    rc = m.get('registry_collection', '')
    if rc and rc not in skip and rc not in tbl_collections:
        missing.append(f\"{m.get('code','?')}: {m.get('name','')} ({rc})\")
for m in missing:
    print(m)
" 2>/dev/null || echo "")

if [[ -z "$MISSING_TBL" ]]; then
  pass "All meta_catalog entries have matching table_registry records"
else
  while IFS= read -r line; do
    fail "Missing table_registry for: ${line}"
  done <<< "$MISSING_TBL"
fi

# =========================================================================
# TEST 3: Layer 1 — Main Index Page
# =========================================================================
echo ""
echo "--- Test 3: Layer 1 — Main Index ---"

L1_STATUS=$(fetch_page_status "${BASE_URL}/knowledge/registries")
L1_SIZE=$(page_size)

if [[ "$L1_STATUS" != "200" ]]; then
  fail "Layer 1 index: HTTP ${L1_STATUS}"
else
  CAT_COUNT=$(page_grep_count "CAT-")
  ERR=$(page_grep_ci_count "Chưa có bảng\|FORBIDDEN\|statusCode.*403\|don't have permission")

  if [[ "${ERR:-0}" -gt 0 ]]; then
    fail "Layer 1 index: HTTP 200 but has embedded errors"
  elif [[ "${CAT_COUNT:-0}" -lt 1 ]]; then
    fail "Layer 1 index: HTTP 200 but no CAT- markers found"
  else
    pass "Layer 1 index: OK (${L1_SIZE}b, ${CAT_COUNT}x CAT-)"
  fi
fi

# =========================================================================
# TEST 4: Layer 2 — All Entity Type Pages
# =========================================================================
echo ""
echo "--- Test 4: Layer 2 — Entity Type Pages ---"

# Build page list from meta_catalog entity_types
ENTITY_TYPES=$(echo "$META_JSON" | python3 -c "
import sys, json
meta = json.load(sys.stdin).get('data', [])
for m in meta:
    et = m.get('entity_type', '')
    if et:
        print(et)
" 2>/dev/null || echo "")

# Known data code prefixes per entity_type (bash 3.x compatible)
get_code_prefix() {
  case "$1" in
    catalog) echo "CAT-" ;;
    module) echo "MOD-" ;;
    workflow) echo "WF-" ;;
    workflow_step) echo "ND-" ;;
    wcr) echo "WCR-" ;;
    dot_tool) echo "DOT-" ;;
    page) echo "PG-" ;;
    collection) echo "COL-" ;;
    task) echo "TASK-" ;;
    agent) echo "AGT-" ;;
    checkpoint_type) echo "CP-" ;;
    checkpoint_set) echo "CPS-" ;;
    entity_dependency) echo "DEP-" ;;
    *) echo "" ;;
  esac
}

while IFS= read -r et; do
  [[ -z "$et" ]] && continue
  URL="${BASE_URL}/knowledge/registries/${et}"
  STATUS=$(fetch_page_status "$URL")
  SIZE=$(page_size)

  if [[ "$STATUS" != "200" ]]; then
    fail "Layer 2 [${et}]: HTTP ${STATUS}"
    continue
  fi

  HAS_NO_TABLE=$(page_grep_count "Chưa có bảng registry")
  if [[ "${HAS_NO_TABLE:-0}" -gt 0 ]]; then
    fail "Layer 2 [${et}]: Shows 'Chưa có bảng registry' — missing table_registry record"
    continue
  fi

  HAS_ERR=$(page_grep_ci_count "FORBIDDEN\|statusCode.*403\|statusCode.*500\|don't have permission")
  if [[ "${HAS_ERR:-0}" -gt 0 ]]; then
    fail "Layer 2 [${et}]: HTTP 200 but has permission/server errors"
    continue
  fi

  PREFIX=$(get_code_prefix "$et")
  if [[ -n "$PREFIX" ]]; then
    DATA_HIT=$(page_grep_count "$PREFIX")
    if [[ "${DATA_HIT:-0}" -eq 0 ]]; then
      warn "Layer 2 [${et}]: No data markers '${PREFIX}' found (${SIZE}b) — collection may be empty"
    else
      pass "Layer 2 [${et}]: OK (${SIZE}b, ${DATA_HIT}x ${PREFIX})"
    fi
  else
    pass "Layer 2 [${et}]: OK (${SIZE}b)"
  fi
done <<< "$ENTITY_TYPES"

# =========================================================================
# TEST 5: Data Presence — Each collection has records via API
# =========================================================================
echo ""
echo "--- Test 5: Data Presence via Directus API ---"

COLLECTIONS=$(echo "$META_JSON" | python3 -c "
import sys, json
meta = json.load(sys.stdin).get('data', [])
for m in meta:
    rc = m.get('registry_collection', '')
    name = m.get('name', '')
    code = m.get('code', '')
    if rc:
        print(f'{rc}|{code}|{name}')
" 2>/dev/null || echo "")

while IFS='|' read -r col code name; do
  [[ -z "$col" ]] && continue
  API_RESP=$(curl -sk --max-time 10 "${DIRECTUS_URL}/items/${col}?fields=id&limit=1" 2>/dev/null || echo '{}')
  RESULT=$(echo "$API_RESP" | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    if 'errors' in d:
        print('error')
    else:
        data = d.get('data', [])
        print(len(data))
except:
    print('error')
" 2>/dev/null || echo "error")

  if [[ "$RESULT" == "error" ]]; then
    warn "API [${code}] ${col}: Not accessible via public API (${name})"
  elif [[ "$RESULT" == "0" ]]; then
    warn "API [${code}] ${col}: 0 records (${name})"
  else
    pass "API [${code}] ${col}: Has data (${name})"
  fi
done <<< "$COLLECTIONS"

# =========================================================================
# TEST 6: Layer 3 — Detail Pages (Config + Discovery Mode)
# =========================================================================
echo ""
echo "--- Test 6: Layer 3 — Detail Pages ---"

# Get sample items for each entity type and check detail page rendering
LAYER3_TYPES=$(echo "$META_JSON" | python3 -c "
import sys, json
meta = json.load(sys.stdin).get('data', [])
for m in meta:
    et = m.get('entity_type', '')
    rc = m.get('registry_collection', '')
    if et and rc:
        print(f'{et}|{rc}')
" 2>/dev/null || echo "")

# Config-mode entity types (have sectionConfig in detail-sections.ts)
CONFIG_TYPES="checkpoint_type checkpoint_set workflow workflow_step dot_tool collection"

get_l3_code_field() {
  case "$1" in
    workflows) echo "process_code" ;;
    table_registry) echo "table_id" ;;
    *) echo "code" ;;
  esac
}

DISCOVERY_TESTED=0
CONFIG_TESTED=0

while IFS='|' read -r et rc; do
  [[ -z "$et" ]] && continue

  local_cf=$(get_l3_code_field "$rc")

  # Get 1 sample item
  SAMPLE=$(curl -sk --max-time 10 "${DIRECTUS_URL}/items/${rc}?fields=${local_cf},id&limit=1" 2>/dev/null || echo '{"data":[]}')
  ITEM_CODE=$(echo "$SAMPLE" | python3 -c "
import sys, json
d = json.load(sys.stdin).get('data', [])
cf = '${local_cf}'
if d:
    code = d[0].get(cf, '') or d[0].get('code', '') or str(d[0].get('id', ''))
    print(code)
else:
    print('')
" 2>/dev/null || echo "")

  [[ -z "$ITEM_CODE" ]] && continue

  # Fetch detail page
  DETAIL_URL="${BASE_URL}/knowledge/registries/${et}/${ITEM_CODE}"
  D_STATUS=$(fetch_page_status "$DETAIL_URL")
  D_SIZE=$(page_size)

  if [[ "$D_STATUS" != "200" ]]; then
    fail "Layer 3 [${et}/${ITEM_CODE}]: HTTP ${D_STATUS}"
    continue
  fi

  # Count rendered sections (UCard headers with font-semibold)
  SECTION_COUNT=$(page_grep_count 'font-semibold text-gray-900')

  # Determine if this is config or discovery mode
  IS_CONFIG=0
  for ct in $CONFIG_TYPES; do
    if [[ "$et" == "$ct" ]]; then
      IS_CONFIG=1
      break
    fi
  done

  if [[ "$IS_CONFIG" == "1" ]]; then
    # Config mode: expect ≥2 sections
    if [[ "${SECTION_COUNT:-0}" -ge 2 ]]; then
      pass "Layer 3 config [${et}/${ITEM_CODE}]: ${SECTION_COUNT} sections"
    elif [[ "${SECTION_COUNT:-0}" -ge 1 ]]; then
      warn "Layer 3 config [${et}/${ITEM_CODE}]: only ${SECTION_COUNT} section (expected ≥2)"
    else
      fail "Layer 3 config [${et}/${ITEM_CODE}]: 0 sections rendered"
    fi
    CONFIG_TESTED=$((CONFIG_TESTED + 1))
  else
    # Discovery mode: expect ≥1 section (info at minimum)
    if [[ "${SECTION_COUNT:-0}" -ge 2 ]]; then
      pass "Layer 3 discovery [${et}/${ITEM_CODE}]: ${SECTION_COUNT} sections"
    elif [[ "${SECTION_COUNT:-0}" -ge 1 ]]; then
      pass "Layer 3 discovery [${et}/${ITEM_CODE}]: ${SECTION_COUNT} section (info)"
    else
      fail "Layer 3 discovery [${et}/${ITEM_CODE}]: 0 sections rendered"
    fi
    DISCOVERY_TESTED=$((DISCOVERY_TESTED + 1))
  fi

done <<< "$LAYER3_TYPES"

echo "  (Config: ${CONFIG_TESTED} types, Discovery: ${DISCOVERY_TESTED} types)"

# =========================================================================
# TEST 7: Entity Dependencies — Data Volume
# =========================================================================
echo ""
echo "--- Test 7: Entity Dependencies ---"

DEP_COUNT=$(curl -sk --max-time 10 "${DIRECTUS_URL}/items/entity_dependencies?fields=id&limit=200&meta=total_count" 2>/dev/null | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    # Try meta.total_count first, fallback to counting returned items
    meta = d.get('meta', {})
    if meta and meta.get('total_count'):
        print(int(meta['total_count']))
    else:
        print(len(d.get('data', [])))
except:
    print(0)
" 2>/dev/null || echo "0")
DEP_COUNT=$(echo "$DEP_COUNT" | tr -d '[:space:]')

if [[ "$DEP_COUNT" -ge 150 ]]; then
  pass "entity_dependencies: ${DEP_COUNT} records (≥150)"
elif [[ "$DEP_COUNT" -ge 50 ]]; then
  warn "entity_dependencies: ${DEP_COUNT} records (target: ≥150)"
elif [[ "$DEP_COUNT" -gt 0 ]]; then
  warn "entity_dependencies: ${DEP_COUNT} records (low — run dot-dependency-scan)"
else
  fail "entity_dependencies: 0 records"
fi

# =========================================================================
# SUMMARY
# =========================================================================
echo ""
echo "========================================="
echo "Self-Test Results: ${PASS}/${TOTAL} PASS, ${FAIL}/${TOTAL} FAIL, ${WARN}/${TOTAL} WARN"
echo "========================================="

if [[ $FAIL -gt 0 ]]; then
  echo "SELFTEST: FAILED (${FAIL} failures)"
  exit 1
elif [[ $WARN -gt 0 ]]; then
  echo "SELFTEST: PASS WITH WARNINGS (${WARN} warnings)"
  exit 0
else
  echo "SELFTEST: ALL PASS"
  exit 0
fi
