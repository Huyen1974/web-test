('LBL-003', 'Giao diện & trải nghiệm', 'UI & Experience', (SELECT id FROM taxonomy_facets WHERE code='FAC-01'), 0, '{atom,molecule,compound,material,product,building}', 'Pages, components, tables, layouts, navigation, forms', 3),
