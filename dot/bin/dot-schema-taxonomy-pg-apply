ON CONFLICT (code) DO NOTHING;
EOSQL
  )"
  log_ok "D3: 8 parent labels (Chiều 1) inserted"

  # Insert taxonomy labels — Chiều 1 children (depth=1)
  run_pg_file "$(cat <<'EOSQL'
INSERT INTO taxonomy (code, name, name_en, facet_id, parent_id, depth, scope, description, sort) VALUES
