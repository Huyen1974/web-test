#!/usr/bin/env bash
# =============================================================================
# dot-schema-taxonomy-pg-apply — PG constraints + triggers + seed data + VIEW
# =============================================================================
# VERSION: 1.0.0
# S122: Applied AFTER dot-schema-taxonomy-ensure (Directus registration)
# Creates: constraints, triggers, functions, indexes, seed data, v_all_entity_codes VIEW
# Also: system_issues status lifecycle (D1) + v_registry_counts entry
# Idempotent: uses IF NOT EXISTS / CREATE OR REPLACE / ON CONFLICT
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/../config/environment.sh"

VERSION="1.0.0"

log_info() { echo "[INFO] $1"; }
log_ok()   { echo "[OK]   $1"; }
log_warn() { echo "[WARN] $1"; }
log_err()  { echo "[ERR]  $1" >&2; }

# =============================================================================
# PG CONNECTION
# =============================================================================

run_pg() {
  local sql="$1"
  if [[ "$(detect_environment "${FLAG:-}")" == "local" ]]; then
    docker compose exec -T postgres psql -U directus -d directus -c "$sql"
  else
    ssh -i ~/.ssh/contabo_vps -o ConnectTimeout=10 root@38.242.240.89 \
      "cd /opt/incomex/docker && docker compose exec -T postgres psql -U directus -d directus -c $(printf '%q' "$sql")"
  fi
}

run_pg_file() {
  local sql="$1"
  if [[ "$(detect_environment "${FLAG:-}")" == "local" ]]; then
    echo "$sql" | docker compose exec -T postgres psql -U directus -d directus
  else
    echo "$sql" | ssh -i ~/.ssh/contabo_vps -o ConnectTimeout=10 root@38.242.240.89 \
      "cd /opt/incomex/docker && docker compose exec -T postgres psql -U directus -d directus"
  fi
}

# =============================================================================
# MAIN
# =============================================================================

main() {
  local FLAG="${1:-}"
  init_environment "$@"
  print_environment_banner "$@"

  log_info "=== dot-schema-taxonomy-pg-apply v${VERSION} ==="

  # ─── D1: system_issues status lifecycle ─────────────────────────────
  log_info "--- D1: system_issues status lifecycle ---"

  run_pg_file "$(cat <<'EOSQL'
-- Migrate status values: 'mở' → 'open'
UPDATE system_issues SET status = 'open' WHERE status = 'mở' OR status IS NULL;

-- Add CHECK constraint (idempotent)
DO $$ BEGIN
  IF NOT EXISTS (
    SELECT 1 FROM pg_constraint WHERE conname = 'chk_system_issues_status'
  ) THEN
    ALTER TABLE system_issues ADD CONSTRAINT chk_system_issues_status
      CHECK (status IN ('open','resolved','archived'));
  END IF;
END $$;

-- Partial index for open issues (idempotent)
CREATE INDEX IF NOT EXISTS idx_issues_open ON system_issues(status) WHERE status = 'open';
EOSQL
  )"
  log_ok "D1: system_issues status lifecycle applied"

  # Add system_issues to v_registry_counts if not present
  run_pg_file "$(cat <<'EOSQL'
INSERT INTO v_registry_counts (cat_code, entity_type, record_count, orphan_count, composition_level, code_column, prev_count)
SELECT 'CAT-017', 'system_issue',
  (SELECT COUNT(*) FROM system_issues WHERE status = 'open'),
  (SELECT COUNT(*) FROM system_issues WHERE code IS NULL OR btrim(code) = ''),
  'atom', 'code', 0
WHERE NOT EXISTS (SELECT 1 FROM v_registry_counts WHERE cat_code = 'CAT-017');
EOSQL
  )"

  # Create count trigger for system_issues (counting only open issues)
  run_pg_file "$(cat <<'EOSQL'
CREATE OR REPLACE FUNCTION refresh_registry_count_issues()
RETURNS trigger AS $$
BEGIN
  UPDATE v_registry_counts SET
    prev_count = record_count,
    record_count = (SELECT COUNT(*) FROM system_issues WHERE status = 'open'),
    orphan_count = (SELECT COUNT(*) FROM system_issues WHERE code IS NULL OR btrim(code) = '')
  WHERE cat_code = 'CAT-017';
  RETURN NULL;
END; $$ LANGUAGE plpgsql;

DROP TRIGGER IF EXISTS trg_count_system_issues ON system_issues;
CREATE TRIGGER trg_count_system_issues
  AFTER INSERT OR UPDATE OR DELETE ON system_issues
  FOR EACH STATEMENT
  EXECUTE FUNCTION refresh_registry_count_issues();
EOSQL
  )"
  log_ok "D1: system_issues count trigger created"

  # ─── D2: PG constraints + triggers for taxonomy tables ──────────────
  log_info "--- D2: PG constraints + triggers ---"

  # Constraints for taxonomy table
  run_pg_file "$(cat <<'EOSQL'
-- Add CHECK constraints (idempotent via DO block)
DO $$ BEGIN
  -- depth check
  IF NOT EXISTS (SELECT 1 FROM pg_constraint WHERE conname = 'taxonomy_depth_check') THEN
    ALTER TABLE taxonomy ADD CONSTRAINT taxonomy_depth_check CHECK (depth >= 0 AND depth <= 2);
  END IF;

  -- root/non-root parent check
  IF NOT EXISTS (SELECT 1 FROM pg_constraint WHERE conname = 'chk_root_no_parent') THEN
    ALTER TABLE taxonomy ADD CONSTRAINT chk_root_no_parent CHECK (
      (depth = 0 AND parent_id IS NULL AND parent_facet IS NULL)
      OR (depth > 0 AND parent_id IS NOT NULL AND parent_facet IS NOT NULL)
    );
  END IF;

  -- Composite FK same-facet: unique constraint
  IF NOT EXISTS (SELECT 1 FROM pg_constraint WHERE conname = 'uq_taxonomy_id_facet') THEN
    ALTER TABLE taxonomy ADD CONSTRAINT uq_taxonomy_id_facet UNIQUE (id, facet_id);
  END IF;

  -- Composite FK: parent must be same facet
  IF NOT EXISTS (SELECT 1 FROM pg_constraint WHERE conname = 'fk_taxonomy_parent_same_facet') THEN
    ALTER TABLE taxonomy ADD CONSTRAINT fk_taxonomy_parent_same_facet
      FOREIGN KEY (parent_id, parent_facet) REFERENCES taxonomy(id, facet_id);
  END IF;

  -- parent_facet must match facet_id
  IF NOT EXISTS (SELECT 1 FROM pg_constraint WHERE conname = 'chk_parent_facet_match') THEN
    ALTER TABLE taxonomy ADD CONSTRAINT chk_parent_facet_match CHECK (parent_facet = facet_id);
  END IF;

  -- replaced_by constraints
  IF NOT EXISTS (SELECT 1 FROM pg_constraint WHERE conname = 'chk_replaced_by_not_self') THEN
    ALTER TABLE taxonomy ADD CONSTRAINT chk_replaced_by_not_self CHECK (replaced_by != code);
  END IF;

  IF NOT EXISTS (SELECT 1 FROM pg_constraint WHERE conname = 'fk_replaced_by') THEN
    ALTER TABLE taxonomy ADD CONSTRAINT fk_replaced_by FOREIGN KEY (replaced_by) REFERENCES taxonomy(code);
  END IF;

  -- status check
  IF NOT EXISTS (SELECT 1 FROM pg_constraint WHERE conname = 'taxonomy_status_check') THEN
    ALTER TABLE taxonomy ADD CONSTRAINT taxonomy_status_check CHECK (status IN ('active','deprecated'));
  END IF;
END $$;

-- Indexes
CREATE INDEX IF NOT EXISTS idx_taxonomy_facet_parent_sort ON taxonomy(facet_id, parent_id, sort);
CREATE INDEX IF NOT EXISTS idx_taxonomy_depth ON taxonomy(depth);

-- taxonomy_facets constraints
DO $$ BEGIN
  IF NOT EXISTS (SELECT 1 FROM pg_constraint WHERE conname = 'taxonomy_facets_cardinality_check') THEN
    ALTER TABLE taxonomy_facets ADD CONSTRAINT taxonomy_facets_cardinality_check
      CHECK (cardinality IN ('single','multiple'));
  END IF;
END $$;

-- taxonomy_matrix constraints
DO $$ BEGIN
  IF NOT EXISTS (SELECT 1 FROM pg_constraint WHERE conname = 'taxonomy_matrix_requirement_check') THEN
    ALTER TABLE taxonomy_matrix ADD CONSTRAINT taxonomy_matrix_requirement_check
      CHECK (requirement IN ('mandatory','optional','not_applicable'));
  END IF;
  IF NOT EXISTS (SELECT 1 FROM pg_constraint WHERE conname = 'taxonomy_matrix_facet_level_unique') THEN
    ALTER TABLE taxonomy_matrix ADD CONSTRAINT taxonomy_matrix_facet_level_unique UNIQUE (facet_id, composition_level);
  END IF;
END $$;

-- entity_labels constraints
DO $$ BEGIN
  IF NOT EXISTS (SELECT 1 FROM pg_constraint WHERE conname = 'entity_labels_assigned_by_check') THEN
    ALTER TABLE entity_labels ADD CONSTRAINT entity_labels_assigned_by_check
      CHECK (assigned_by IN ('auto','rule','user','ai','dot'));
  END IF;
  IF NOT EXISTS (SELECT 1 FROM pg_constraint WHERE conname = 'entity_labels_unique') THEN
    ALTER TABLE entity_labels ADD CONSTRAINT entity_labels_unique UNIQUE (entity_code, label_code);
  END IF;
END $$;
CREATE INDEX IF NOT EXISTS idx_el_entity ON entity_labels(entity_code);
CREATE INDEX IF NOT EXISTS idx_el_label ON entity_labels(label_code);

-- label_rules constraints
DO $$ BEGIN
  IF NOT EXISTS (SELECT 1 FROM pg_constraint WHERE conname = 'label_rules_rule_type_check') THEN
    ALTER TABLE label_rules ADD CONSTRAINT label_rules_rule_type_check
      CHECK (rule_type IN ('collection','keyword','relation'));
  END IF;
  IF NOT EXISTS (SELECT 1 FROM pg_constraint WHERE conname = 'label_rules_condition_object_check') THEN
    ALTER TABLE label_rules ADD CONSTRAINT label_rules_condition_object_check
      CHECK (jsonb_typeof(condition) = 'object');
  END IF;
END $$;
EOSQL
  )"
  log_ok "D2: PG constraints applied"

  # Triggers (CREATE OR REPLACE = idempotent)
  run_pg_file "$(cat <<'EOSQL'
-- Auto-fill parent_facet trigger
CREATE OR REPLACE FUNCTION fn_taxonomy_auto_fill_parent_facet()
RETURNS trigger AS $$
BEGIN
  IF NEW.parent_id IS NOT NULL THEN
    NEW.parent_facet := NEW.facet_id;
  ELSE
    NEW.parent_facet := NULL;
  END IF;
  RETURN NEW;
END; $$ LANGUAGE plpgsql;

DROP TRIGGER IF EXISTS trg_taxonomy_fill_parent_facet ON taxonomy;
CREATE TRIGGER trg_taxonomy_fill_parent_facet
  BEFORE INSERT OR UPDATE ON taxonomy FOR EACH ROW
  EXECUTE FUNCTION fn_taxonomy_auto_fill_parent_facet();

-- Cycle detection trigger
CREATE OR REPLACE FUNCTION chk_no_cycle() RETURNS trigger AS $$
DECLARE v_current integer; v_depth integer := 0;
BEGIN
  IF NEW.parent_id IS NULL THEN RETURN NEW; END IF;
  v_current := NEW.parent_id;
  WHILE v_current IS NOT NULL AND v_depth < 5 LOOP
    IF v_current = NEW.id THEN
      RAISE EXCEPTION 'Cycle detected in taxonomy tree';
    END IF;
    SELECT parent_id INTO v_current FROM taxonomy WHERE id = v_current;
    v_depth := v_depth + 1;
  END LOOP;
  RETURN NEW;
END; $$ LANGUAGE plpgsql;

DROP TRIGGER IF EXISTS trg_taxonomy_no_cycle ON taxonomy;
CREATE TRIGGER trg_taxonomy_no_cycle
  BEFORE INSERT OR UPDATE ON taxonomy FOR EACH ROW
  EXECUTE FUNCTION chk_no_cycle();

-- replaced_by validation trigger
CREATE OR REPLACE FUNCTION chk_replaced_by_valid() RETURNS trigger AS $$
DECLARE v_target_facet integer; v_chain text; v_depth integer := 0;
BEGIN
  IF NEW.replaced_by IS NULL THEN RETURN NEW; END IF;
  SELECT facet_id INTO v_target_facet FROM taxonomy WHERE code = NEW.replaced_by;
  IF v_target_facet != NEW.facet_id THEN
    RAISE EXCEPTION 'replaced_by must point to same facet';
  END IF;
  v_chain := NEW.replaced_by;
  WHILE v_chain IS NOT NULL AND v_depth < 5 LOOP
    IF v_chain = NEW.code THEN RAISE EXCEPTION 'Replacement cycle detected'; END IF;
    SELECT replaced_by INTO v_chain FROM taxonomy WHERE code = v_chain;
    v_depth := v_depth + 1;
  END LOOP;
  RETURN NEW;
END; $$ LANGUAGE plpgsql;

DROP TRIGGER IF EXISTS trg_taxonomy_replaced_by ON taxonomy;
CREATE TRIGGER trg_taxonomy_replaced_by
  BEFORE INSERT OR UPDATE ON taxonomy FOR EACH ROW
  EXECUTE FUNCTION chk_replaced_by_valid();
EOSQL
  )"
  log_ok "D2: PG triggers applied"

  # ─── D3: Seed data ─────────────────────────────────────────────────
  log_info "--- D3: Seed data ---"

  # Insert facets (idempotent via ON CONFLICT)
  run_pg_file "$(cat <<'EOSQL'
INSERT INTO taxonomy_facets (code, name, description, cardinality, max_labels_per_entity, sort) VALUES
('FAC-01', 'Chuyên môn gì?', 'Entity thuộc lĩnh vực chuyên môn nào? Cấu trúc cha-con 3 tầng.', 'multiple', 3, 1),
('FAC-02', 'Vai trò hệ thống?', 'Entity đóng vai trò gì trong hệ thống?', 'single', 0, 2),
('FAC-03', 'Hành động gì?', 'Entity làm gì hoặc phục vụ cho hành động gì?', 'multiple', 0, 3),
('FAC-04', 'Phạm vi tác động?', 'Entity ảnh hưởng đến đâu?', 'single', 0, 4),
('FAC-05', 'Giai đoạn?', 'Entity đang ở giai đoạn nào trong vòng đời?', 'single', 0, 5),
('FAC-06', 'Phục vụ ai?', 'Entity phục vụ cho đối tượng nào?', 'multiple', 0, 6)
ON CONFLICT (code) DO NOTHING;
EOSQL
  )"
  log_ok "D3: 6 facets inserted"

  # Insert taxonomy labels — Chiều 1 parents (depth=0)
  run_pg_file "$(cat <<'EOSQL'
INSERT INTO taxonomy (code, name, name_en, facet_id, depth, scope, description, sort) VALUES
('LBL-001', 'Hạ tầng & vận hành', 'Infrastructure & Operations', (SELECT id FROM taxonomy_facets WHERE code='FAC-01'), 0, '{atom,molecule,compound,material,product,building}', 'Server, Docker, CI/CD, deploy, monitoring, mạng', 1),
