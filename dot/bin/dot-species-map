#!/usr/bin/env bash
# =============================================================================
# dot-species-map — Map species to collection in species_collection_map
# =============================================================================
# CHECKED-NO-DUPLICATE: [searched dot/bin/dot-*species* — no species map tool]
# VERSION: 1.0.0
# §0-E DOT-FIRST: All governance declarations MUST go through DOT tools.
#
# Usage:
#   dot-species-map <species_code> <collection_name> [options]
#
# Options:
#   --primary                     Mark as primary collection (default: true)
#   --no-primary                  Mark as non-primary
#   --discriminator_field F       Discriminator field name
#   --discriminator_value V       Discriminator value
#   --discriminator_operator O    eq|neq|regex|in|not_null
#   --cloud|--local               Environment
#   --dry-run                     Preview mode
#   --help, -h                    Show help
#
# Examples:
#   dot-species-map dot_tool dot_tools --primary
#   dot-species-map workflow tasks --discriminator_field type --discriminator_value workflow
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/../config/environment.sh"

VERSION="1.0.0"

show_help() {
  cat << 'EOF'
dot-species-map v1.0.0 — Map species to collection

Usage: dot-species-map <species_code> <collection_name> [options]

Positional:
  species_code      Must exist in entity_species
  collection_name   Must exist in collection_registry

Options:
  --primary                   Primary collection (default)
  --no-primary                Non-primary
  --discriminator_field F     Field for multi-species collections
  --discriminator_value V     Discriminator value
  --discriminator_operator O  eq|neq|regex|in|not_null
  --cloud|--local             Environment
  --dry-run                   Preview mode
  --help, -h                  This help

Idempotent: skips if mapping already exists.
EOF
  show_environment_help
}

main() {
  local SPECIES_CODE="" COLLECTION_NAME="" IS_PRIMARY="true"
  local DISC_FIELD="" DISC_VALUE="" DISC_OP="" DRY_RUN=""
  local POSITIONAL=()

  while [[ $# -gt 0 ]]; do
    case $1 in
      --primary) IS_PRIMARY="true"; shift ;;
      --no-primary) IS_PRIMARY="false"; shift ;;
      --discriminator_field) DISC_FIELD="$2"; shift 2 ;;
      --discriminator_value) DISC_VALUE="$2"; shift 2 ;;
      --discriminator_operator) DISC_OP="$2"; shift 2 ;;
      --dry-run) DRY_RUN="1"; shift ;;
      --help|-h) show_help; exit 0 ;;
      --local|--cloud) shift ;;
      -*) echo "[ERR] Unknown option: $1" >&2; exit 1 ;;
      *) POSITIONAL+=("$1"); shift ;;
    esac
  done

  if [[ ${#POSITIONAL[@]} -lt 2 ]]; then
    echo "[ERR] 2 positional args required: species_code collection_name" >&2
    exit 1
  fi

  SPECIES_CODE="${POSITIONAL[0]}"
  COLLECTION_NAME="${POSITIONAL[1]}"

  init_environment "$@" 2>/dev/null || init_environment
  local BASE_URL="$DIRECTUS_URL"

  if [[ -z "${DOT_TOKEN:-}" ]]; then
    source "${SCRIPT_DIR}/dot-auth" "$@" 2>/dev/null || source "${SCRIPT_DIR}/dot-auth"
  fi
  if [[ -z "${DOT_TOKEN:-}" ]]; then
    echo "[ERR] Authentication failed" >&2; exit 1
  fi

  # Validate species_code exists
  local SP_CHECK
  SP_CHECK=$(curl -sS --globoff -k \
    "${BASE_URL}/items/entity_species?filter[species_code][_eq]=${SPECIES_CODE}&fields=code" \
    -H "Authorization: Bearer $DOT_TOKEN")
  local SP_EXISTS
  SP_EXISTS=$(echo "$SP_CHECK" | jq '.data | length' 2>/dev/null || echo "0")
  if [[ "$SP_EXISTS" == "0" ]]; then
    echo "[ERR] species_code '${SPECIES_CODE}' not found in entity_species" >&2
    exit 1
  fi

  # Check if mapping exists
  local MAP_CHECK
  MAP_CHECK=$(curl -sS --globoff -k \
    "${BASE_URL}/items/species_collection_map?filter[species_code][_eq]=${SPECIES_CODE}&filter[collection_name][_eq]=${COLLECTION_NAME}&fields=id" \
    -H "Authorization: Bearer $DOT_TOKEN")
  local MAP_EXISTS
  MAP_EXISTS=$(echo "$MAP_CHECK" | jq '.data | length' 2>/dev/null || echo "0")
  if [[ "$MAP_EXISTS" -gt 0 ]]; then
    echo "[SKIP] Mapping ${SPECIES_CODE} -> ${COLLECTION_NAME} already exists"
    exit 0
  fi

  if [[ -n "$DRY_RUN" ]]; then
    echo "[DRY] Would map ${SPECIES_CODE} -> ${COLLECTION_NAME} (primary=${IS_PRIMARY})"
    exit 0
  fi

  local PAYLOAD
  PAYLOAD=$(jq -nc \
    --arg sc "$SPECIES_CODE" \
    --arg cn "$COLLECTION_NAME" \
    --argjson ip "$IS_PRIMARY" \
    --arg df "$DISC_FIELD" \
    --arg dv "$DISC_VALUE" \
    --arg do_ "$DISC_OP" \
    '{
      species_code: $sc,
      collection_name: $cn,
      is_primary: $ip
    }
    + (if $df != "" then {discriminator_field: $df} else {} end)
    + (if $dv != "" then {discriminator_value: $dv} else {} end)
    + (if $do_ != "" then {discriminator_operator: $do_} else {} end)')

  local RESP RESP_CODE
  RESP=$(curl -sS --globoff -k -X POST "${BASE_URL}/items/species_collection_map" \
    -H "Authorization: Bearer $DOT_TOKEN" \
    -H "Content-Type: application/json" \
    -d "$PAYLOAD" -w "\n%{http_code}")
  RESP_CODE="${RESP##*$'\n'}"

  if [[ "$RESP_CODE" == "200" ]]; then
    echo "[OK] Mapped ${SPECIES_CODE} -> ${COLLECTION_NAME} (primary=${IS_PRIMARY})"
  else
    local RESP_BODY="${RESP%$'\n'*}"
    echo "[ERR] Failed: HTTP ${RESP_CODE}" >&2
    echo "$RESP_BODY" | head -c 200 >&2
    exit 1
  fi
}

main "$@"
