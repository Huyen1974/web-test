#!/usr/bin/env bash
# =============================================================================
# dot-schema-table-registry-ensure - Ensure table_registry collection in Directus
# =============================================================================
# VERSION: 1.0.0
# CHANGELOG:
#   v1.0.0 (2026-03-05): Initial version for TABLE-REGISTRY SSOT
#     - table_registry: 14 fields — config store for every table in the system
#     - Each record = 1 table UI instance with collection, fields, sort, filter, flags
#     - Idempotent: checks existence before create, patches missing fields
#     - Based on dot-schema-table-proposals-ensure pattern
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOT_AUTH="${SCRIPT_DIR}/dot-auth"

# Source environment configuration
source "${SCRIPT_DIR}/../config/environment.sh"

VERSION="1.0.0"
COLLECTION="table_registry"

# Logging
log_info() { echo "[INFO] $1"; }
log_ok()   { echo "[OK]   $1"; }
log_warn() { echo "[WARN] $1"; }
log_skip() { echo "[SKIP] $1"; }
log_err()  { echo "[ERR]  $1" >&2; }

require_cmds() {
  for cmd in curl jq; do
    command -v "$cmd" >/dev/null 2>&1 || { log_err "Missing required command: $cmd"; exit 1; }
  done
}

api_request() {
  local method="$1" url="$2" data="${3-}"
  if [[ -n "${data-}" ]]; then
    curl -sS --globoff -X "$method" "$url" \
      -H "Authorization: Bearer $DOT_TOKEN" \
      -H "Content-Type: application/json" \
      -d "$data" -w "\n%{http_code}"
  else
    curl -sS --globoff -X "$method" "$url" \
      -H "Authorization: Bearer $DOT_TOKEN" \
      -w "\n%{http_code}"
  fi
}

REQUIRED_FIELDS=(table_id name collection fields default_sort default_filter page_url enable_insert_marks enable_proposals enable_search enable_pagination rows_per_page status module description)

field_payload() {
  case "$1" in
    table_id)
      cat <<'JSON'
{"field":"table_id","type":"string","meta":{"required":true,"interface":"input","width":"half","note":"Unique table identifier (e.g. tbl_workflow_list)"},"schema":{"is_nullable":false,"is_unique":true}}
JSON
      ;;
    name)
      cat <<'JSON'
{"field":"name","type":"string","meta":{"required":true,"interface":"input","width":"half","note":"Human-readable table name"},"schema":{"is_nullable":false}}
JSON
      ;;
    collection)
      cat <<'JSON'
{"field":"collection","type":"string","meta":{"required":true,"interface":"input","width":"half","note":"Directus collection to query"},"schema":{"is_nullable":false}}
JSON
      ;;
    fields)
      cat <<'JSON'
{"field":"fields","type":"json","meta":{"required":true,"interface":"input-code","options":{"language":"json"},"width":"full","note":"Array of field configs: [{key, label, sortable?, filterable?, filterOptions?, render?, description?}]"},"schema":{"is_nullable":false}}
JSON
      ;;
    default_sort)
      cat <<'JSON'
{"field":"default_sort","type":"string","meta":{"required":false,"interface":"input","width":"half","note":"Default sort field (prefix - for desc, e.g. -date_created)"},"schema":{"is_nullable":true}}
JSON
      ;;
    default_filter)
      cat <<'JSON'
{"field":"default_filter","type":"json","meta":{"required":false,"interface":"input-code","options":{"language":"json"},"width":"full","note":"Static Directus filter object. Use {{DYNAMIC}} for runtime-replaced values."},"schema":{"is_nullable":true}}
JSON
      ;;
    page_url)
      cat <<'JSON'
{"field":"page_url","type":"string","meta":{"required":true,"interface":"input","width":"half","note":"Page URL where this table is rendered"},"schema":{"is_nullable":false}}
JSON
      ;;
    enable_insert_marks)
      cat <<'JSON'
{"field":"enable_insert_marks","type":"boolean","meta":{"required":false,"interface":"boolean","width":"half","note":"Show row/column insert marks"},"schema":{"is_nullable":false,"default_value":true}}
JSON
      ;;
    enable_proposals)
      cat <<'JSON'
{"field":"enable_proposals","type":"boolean","meta":{"required":false,"interface":"boolean","width":"half","note":"Enable proposal submission system"},"schema":{"is_nullable":false,"default_value":true}}
JSON
      ;;
    enable_search)
      cat <<'JSON'
{"field":"enable_search","type":"boolean","meta":{"required":false,"interface":"boolean","width":"half","note":"Show search input"},"schema":{"is_nullable":false,"default_value":true}}
JSON
      ;;
    enable_pagination)
      cat <<'JSON'
{"field":"enable_pagination","type":"boolean","meta":{"required":false,"interface":"boolean","width":"half","note":"Enable pagination controls"},"schema":{"is_nullable":false,"default_value":true}}
JSON
      ;;
    rows_per_page)
      cat <<'JSON'
{"field":"rows_per_page","type":"integer","meta":{"required":false,"interface":"input","width":"half","note":"Number of rows per page (default 50)"},"schema":{"is_nullable":false,"default_value":50}}
JSON
      ;;
    status)
      cat <<'JSON'
{"field":"status","type":"string","meta":{"required":true,"interface":"select-dropdown","options":{"choices":[{"text":"Active","value":"active"},{"text":"Draft","value":"draft"},{"text":"Archived","value":"archived"}]},"width":"half","note":"Registry entry status"},"schema":{"is_nullable":false,"default_value":"active"}}
JSON
      ;;
    module)
      cat <<'JSON'
{"field":"module","type":"string","meta":{"required":false,"interface":"input","width":"half","note":"Module code that owns this table (e.g. M-002, M-003)"},"schema":{"is_nullable":true}}
JSON
      ;;
    description)
      cat <<'JSON'
{"field":"description","type":"text","meta":{"required":false,"interface":"input-multiline","width":"full","note":"Description of this table instance"},"schema":{"is_nullable":true}}
JSON
      ;;
    *) return 1 ;;
  esac
}

collection_exists() {
  local resp body code
  resp=$(api_request GET "${BASE_URL}/collections/${COLLECTION}")
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"
  [[ "$code" == "200" ]]
}

field_exists() {
  local field_name="$1"
  local resp body code
  resp=$(api_request GET "${BASE_URL}/fields/${COLLECTION}")
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"
  if [[ "$code" == "200" ]]; then
    echo "$body" | jq -e --arg field "$field_name" '.data[]? | select(.field == $field)' >/dev/null 2>&1
    return $?
  fi
  return 1
}

create_collection() {
  local payload
  payload=$(jq -nc \
    --arg collection "$COLLECTION" \
    '{
      collection: $collection,
      schema: {},
      meta: {
        collection: $collection,
        icon: "table_chart",
        note: "Table Registry SSOT — config for every table UI in the system. Created by DOT v1.0.0",
        display_template: "{{table_id}} — {{name}} [{{status}}]",
        sort_field: "table_id"
      }
    }')

  log_info "Creating collection ${COLLECTION}"
  local resp body code
  resp=$(api_request POST "${BASE_URL}/collections" "$payload")
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"

  if [[ "$code" != "200" ]]; then
    log_err "Failed to create collection ${COLLECTION} (HTTP $code)"
    echo "$body" | head -c 300 >&2
    exit 1
  fi
  log_ok "Collection ${COLLECTION} created"
}

create_field() {
  local field_name="$1"
  local payload resp body code
  payload=$(field_payload "$field_name")

  log_info "Creating field ${COLLECTION}.${field_name}"
  resp=$(api_request POST "${BASE_URL}/fields/${COLLECTION}" "$payload")
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"

  if [[ "$code" != "200" ]]; then
    log_err "Failed to create field ${COLLECTION}.${field_name} (HTTP $code)"
    echo "$body" | head -c 200 >&2
    exit 1
  fi
  log_ok "Field ${COLLECTION}.${field_name} created"
}

setup_permissions() {
  log_info "Setting up permissions..."

  # Public read access (for DirectusTable to fetch config)
  local public_read
  public_read=$(jq -nc \
    --arg collection "$COLLECTION" \
    '{
      role: null,
      collection: $collection,
      action: "read",
      fields: ["*"],
      permissions: {},
      validation: {}
    }')

  local resp code
  resp=$(api_request POST "${BASE_URL}/permissions" "$public_read")
  code="${resp##*$'\n'}"

  if [[ "$code" == "200" ]]; then
    log_ok "Public READ permission created"
  elif [[ "$code" == "400" ]]; then
    log_skip "Public READ permission already exists"
  else
    log_warn "Could not create public READ permission (HTTP $code)"
  fi
}

verify_fields() {
  local resp body code missing=()
  resp=$(api_request GET "${BASE_URL}/fields/${COLLECTION}")
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"

  if [[ "$code" != "200" ]]; then
    log_err "Failed to list fields for ${COLLECTION} (HTTP $code)"
    exit 1
  fi

  local field_count
  field_count=$(echo "$body" | jq '.data | length')

  for field in "${REQUIRED_FIELDS[@]}"; do
    if ! echo "$body" | jq -e --arg field "$field" '.data[]? | select(.field == $field)' >/dev/null 2>&1; then
      missing+=("$field")
    fi
  done

  if [[ "${#missing[@]}" -gt 0 ]]; then
    log_err "Missing required fields: ${missing[*]}"
    exit 1
  fi

  log_ok "${COLLECTION}: All required fields present (${field_count} total)"
}

show_help() {
  cat << EOF
dot-schema-table-registry-ensure v${VERSION} - Ensure table_registry collection

Usage:
  dot-schema-table-registry-ensure [options]

Options:
  --local       Use local development environment
  --cloud       Use cloud/production environment (default)
  --dry-run     Show what would be done without making changes
  --help, -h    Show this help message

Collection: table_registry (14 fields)
  - table_id             Unique table identifier (required, unique)
  - name                 Human-readable name (required)
  - collection           Directus collection name (required)
  - fields               JSON array of field configs (required)
  - default_sort         Default sort field
  - default_filter       Static Directus filter (JSON)
  - page_url             URL where table renders (required)
  - enable_insert_marks  Show insert marks (default: true)
  - enable_proposals     Enable proposal system (default: true)
  - enable_search        Show search bar (default: true)
  - enable_pagination    Enable pagination (default: true)
  - rows_per_page        Rows per page (default: 50)
  - status               active|draft|archived (default: active)
  - module               Owning module code
  - description          Description text

EOF
  show_environment_help
}

main() {
  local DRY_RUN=false

  for arg in "$@"; do
    case "$arg" in
      --help|-h) show_help; exit 0 ;;
      --dry-run) DRY_RUN=true ;;
    esac
  done

  require_cmds
  init_environment "$@"
  BASE_URL="$DIRECTUS_URL"

  echo "========================================="
  echo "DOT Tool: Schema Table Registry Ensure v${VERSION}"
  echo "========================================="
  print_environment_banner "$@"
  echo "Ensuring table_registry collection for TABLE-REGISTRY SSOT"
  echo ""

  if [[ "$DRY_RUN" == "true" ]]; then
    log_warn "DRY RUN MODE - No changes will be made"
    echo ""
  fi

  # Authentication
  if [[ -z "${DOT_TOKEN:-}" ]]; then
    if [[ ! -f "$DOT_AUTH" ]]; then
      log_err "dot-auth not found at ${DOT_AUTH}"
      exit 1
    fi
    log_info "Authenticating with Directus..."
    source "$DOT_AUTH" "$@"
  fi

  if [[ -z "${DOT_TOKEN:-}" ]]; then
    log_err "DOT_TOKEN is empty after authentication"
    exit 1
  fi

  # === COLLECTION ===
  echo ""
  echo "--- Collection: ${COLLECTION} ---"

  if collection_exists; then
    log_skip "Collection '${COLLECTION}' already exists"
  else
    if [[ "$DRY_RUN" == "true" ]]; then
      log_info "Would create collection '${COLLECTION}'"
    else
      create_collection
    fi
  fi

  # === FIELDS ===
  log_info "Ensuring required fields..."
  for field in "${REQUIRED_FIELDS[@]}"; do
    if field_exists "$field"; then
      log_skip "Field ${COLLECTION}.${field} already exists"
    else
      if [[ "$DRY_RUN" == "true" ]]; then
        log_info "Would create field ${COLLECTION}.${field}"
      else
        create_field "$field"
      fi
    fi
  done

  # === PERMISSIONS ===
  echo ""
  if [[ "$DRY_RUN" != "true" ]]; then
    setup_permissions
  else
    log_info "Would create public READ permission"
  fi

  # === VERIFICATION ===
  echo ""
  if [[ "$DRY_RUN" != "true" ]]; then
    log_info "Running final verification..."
    if ! collection_exists; then
      log_err "Collection ${COLLECTION} missing after ensure"
      exit 1
    fi
    verify_fields
  fi

  log_ok "Collection table_registry ready"
  echo ""
  echo "========================================="
  echo "DOT Tool: Schema Table Registry Ensure - COMPLETE"
  echo "========================================="
}

main "$@"
