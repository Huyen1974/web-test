#!/usr/bin/env bash
# =============================================================================
# dot-update-tool-categories-vn — Chuyển category DOT tools sang tiếng Việt có dấu
# =============================================================================
# CHECKED-NO-DUPLICATE: [searched dot/bin/ for "categories-vn" — no match]
# VERSION: 1.0.0
#
# Chuyển đổi category tiếng Anh → tiếng Việt cho tất cả dot_tools.
# Idempotent: chỉ update nếu category hiện tại là tiếng Anh.
#
# Bảng chuyển:
#   agent→quản_lý_ai, ai→tích_hợp_ai, audit→kiểm_tra_lỗi,
#   ops→vận_hành, schema→cấu_trúc_dữ_liệu, health→kiểm_tra_sức_khoẻ,
#   flow→tự_động_hoá, content→nội_dung, knowledge→tri_thức,
#   permission→phân_quyền, catalog→quản_lý_danh_mục, mcp→kết_nối_mcp,
#   metadata→dữ_liệu_mô_tả, env→biến_môi_trường, seed→khởi_tạo,
#   sync→đồng_bộ, auth→xác_thực, registry→đăng_ký
#
# Usage:
#   dot-update-tool-categories-vn [--cloud|--local] [--dry-run]
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/../config/environment.sh"

VERSION="1.0.0"
DRY_RUN=""

for arg in "$@"; do
  case "$arg" in
    --dry-run) DRY_RUN="yes" ;;
    --help|-h)
      head -22 "$0" | tail -20
      show_environment_help
      exit 0
      ;;
  esac
done

init_environment "$@"

echo ""
echo "═══════════════════════════════════════════════════════════"
echo "  Chuyển đổi Category DOT Tools → Tiếng Việt v${VERSION}"
echo "═══════════════════════════════════════════════════════════"
print_environment_banner "$@"

TOKEN="${DIRECTUS_TOKEN:-}"
if [[ -z "$TOKEN" ]]; then
  echo -e "${RED}[LỖI]${NC} Không thể xác thực với Directus" >&2
  exit 1
fi

tmp_py=$(mktemp /tmp/dot-cat-vn-XXXXXX.py)
trap "rm -f '$tmp_py'" EXIT

cat > "$tmp_py" << 'PYEOF'
import json, os, sys, ssl, urllib.request

base_url = os.environ['DIRECTUS_URL']
token = os.environ['DIRECTUS_TOKEN']
dry_run = os.environ.get('DRY_RUN', '') == 'yes'

ctx = ssl.create_default_context()
ctx.check_hostname = False
ctx.verify_mode = ssl.CERT_NONE

CATEGORY_MAP = {
    'agent': 'quản_lý_ai',
    'ai': 'tích_hợp_ai',
    'audit': 'kiểm_tra_lỗi',
    'ops': 'vận_hành',
    'schema': 'cấu_trúc_dữ_liệu',
    'health': 'kiểm_tra_sức_khoẻ',
    'flow': 'tự_động_hoá',
    'content': 'nội_dung',
    'knowledge': 'tri_thức',
    'permission': 'phân_quyền',
    'catalog': 'quản_lý_danh_mục',
    'mcp': 'kết_nối_mcp',
    'metadata': 'dữ_liệu_mô_tả',
    'env': 'biến_môi_trường',
    'seed': 'khởi_tạo',
    'sync': 'đồng_bộ',
    'auth': 'xác_thực',
    'registry': 'đăng_ký',
    'other': 'khác',
}

# Reverse map to detect already-Vietnamese categories
VN_VALUES = set(CATEGORY_MAP.values())

def api_get(path):
    url = base_url + path
    req = urllib.request.Request(url, headers={'Authorization': f'Bearer {token}'})
    resp = urllib.request.urlopen(req, context=ctx, timeout=30)
    return json.loads(resp.read())

def api_patch(path, data):
    url = base_url + path
    payload = json.dumps(data).encode()
    req = urllib.request.Request(url, data=payload, headers={
        'Authorization': f'Bearer {token}',
        'Content-Type': 'application/json'
    }, method='PATCH')
    resp = urllib.request.urlopen(req, context=ctx, timeout=30)
    return json.loads(resp.read())

# Fetch all dot_tools
resp = api_get('/items/dot_tools?fields=id,name,code,category&limit=-1&sort=code')
tools = resp.get('data', [])
print(f'[INFO] {len(tools)} DOT tools')

updated = 0
skipped = 0
already_vn = 0
no_category = 0

for tool in tools:
    tool_id = tool['id']
    name = tool.get('name', '')
    code = tool.get('code', '')
    current = tool.get('category', '') or ''

    # Already Vietnamese
    if current in VN_VALUES:
        already_vn += 1
        continue

    # No category
    if not current:
        no_category += 1
        continue

    # Map English → Vietnamese
    vn = CATEGORY_MAP.get(current.lower())
    if not vn:
        print(f'  [WARN] {code} {name}: unknown category "{current}"')
        skipped += 1
        continue

    if dry_run:
        print(f'  [DRY] {code}: "{current}" → "{vn}"')
        updated += 1
    else:
        try:
            api_patch(f'/items/dot_tools/{tool_id}', {'category': vn})
            print(f'  [OK]  {code}: "{current}" → "{vn}"')
            updated += 1
        except Exception as e:
            print(f'  [ERR] {code}: {e}')
            skipped += 1

print()
print('═══════════════════════════════════════════════════════════')
print(f'  Cập nhật: {updated}, Bỏ qua: {skipped}, Đã VN: {already_vn}, Trống: {no_category}')
print('═══════════════════════════════════════════════════════════')
PYEOF

DIRECTUS_URL="$DIRECTUS_URL" DIRECTUS_TOKEN="$TOKEN" \
  DRY_RUN="${DRY_RUN}" \
  python3 "$tmp_py" < /dev/null

echo ""
echo "═══════════════════════════════════════════════════════════"
echo "  DOT Tool: Chuyển đổi Category - HOÀN THÀNH"
echo "═══════════════════════════════════════════════════════════"
