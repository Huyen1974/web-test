#!/usr/bin/env bash
# =============================================================================
# dot-layer-integrity-audit — Layer 2+3 integrity audit for all entity types
# =============================================================================
# CHECKED-NO-DUPLICATE: [searched dot/bin/ for "layer-integrity" — no match]
# VERSION: 2.0.0
#
# Runs 6 checks × N entity types (from meta_catalog):
#   CHECK 1 — Layer 2 page renders data (not empty)
#   CHECK 2 — Items have code (PREFIX-NNN) identifiers
#   CHECK 3 — Entity has relationships in entity_dependencies
#   CHECK 4 — Dedicated page link works (if configured)
#   CHECK 5 — Cross-check: meta_catalog.record_count == actual item count
#   CHECK 6 — Items have description (not empty, ≥ 20 words)
#
# Issues found are written to system_issues collection (idempotent).
#
# Exit 0 = ALL PASS, Exit 1 = FAIL detected
#
# Usage:
#   dot-layer-integrity-audit [--cloud|--local] [--dry-run] [--no-write]
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/../config/environment.sh"

VERSION="2.0.0"
DRY_RUN=""
NO_WRITE=""

for arg in "$@"; do
  case "$arg" in
    --dry-run) DRY_RUN="yes" ;;
    --no-write) NO_WRITE="yes" ;;
    --help|-h)
      head -20 "$0" | tail -18
      show_environment_help
      exit 0
      ;;
  esac
done

init_environment "$@"

echo ""
echo "═══════════════════════════════════════════════════════════"
echo "  LỚP 2+3 INTEGRITY AUDIT v${VERSION} (6 checks)"
echo "═══════════════════════════════════════════════════════════"
print_environment_banner "$@"

TOKEN="${DIRECTUS_TOKEN:-}"
if [[ -z "$TOKEN" ]]; then
  echo -e "${RED}[LỖI]${NC} Không thể xác thực với Directus" >&2
  exit 1
fi

NUXT_BASE="${NUXT_URL:-https://vps.incomexsaigoncorp.vn}"

# Create Python audit script
tmp_py=$(mktemp /tmp/dot-layer-audit-XXXXXX.py)
trap "rm -f '$tmp_py'" EXIT

cat > "$tmp_py" << 'PYEOF'
import json, os, sys, ssl, urllib.request, urllib.parse
from datetime import datetime, timezone

base_url = os.environ['DIRECTUS_URL']
nuxt_url = os.environ['NUXT_BASE']
token = os.environ['DIRECTUS_TOKEN']
dry_run = os.environ.get('DRY_RUN', '') == 'yes'
no_write = os.environ.get('NO_WRITE', '') == 'yes'

ctx = ssl.create_default_context()
ctx.check_hostname = False
ctx.verify_mode = ssl.CERT_NONE

def api_get(path):
    url = base_url + path
    req = urllib.request.Request(url, headers={'Authorization': f'Bearer {token}'})
    try:
        resp = urllib.request.urlopen(req, context=ctx, timeout=30)
        return json.loads(resp.read())
    except Exception as e:
        return {'error': str(e)}

def api_post(path, data):
    url = base_url + path
    payload = json.dumps(data).encode()
    req = urllib.request.Request(url, data=payload, headers={
        'Authorization': f'Bearer {token}',
        'Content-Type': 'application/json'
    }, method='POST')
    try:
        resp = urllib.request.urlopen(req, context=ctx, timeout=30)
        return json.loads(resp.read())
    except Exception as e:
        return {'error': str(e)}

def fetch_page(url):
    """Fetch a page and return (status_code, body_text)"""
    req = urllib.request.Request(url)
    try:
        resp = urllib.request.urlopen(req, context=ctx, timeout=15)
        body = resp.read().decode('utf-8', errors='replace')
        return resp.status, body
    except urllib.error.HTTPError as e:
        return e.code, ''
    except Exception:
        return 0, ''

# Known code prefixes + code field per entity_type
# (prefix, code_field) — code_field is the field that holds the identifier
CODE_INFO = {
    'catalog':             ('CAT-',  'code'),
    'table':               ('tbl_',  'table_id'),
    'module':              ('MOD-',  'code'),
    'workflow':            ('WF-',   'process_code'),
    'workflow_step':       ('ND-',   'code'),
    'wcr':                 ('WCR-',  'code'),
    'dot_tool':            ('DOT-',  'code'),
    'page':                ('PG-',   'code'),
    'collection':          ('COL-',  'code'),
    'task':                ('TASK-', 'code'),
    'agent':               ('AGT-',  'code'),
    'checkpoint_type':     ('CP-',   'code'),
    'checkpoint_set':      ('CPS-',  'code'),
    'entity_dependency':   ('DEP-',  'code'),
    'table_proposal':      ('TP-',   'code'),
    'checkpoint_instance': ('CPI-',  'code'),
    'changelog':           ('',      'code'),
    'system_issue':        ('ISS-',  'code'),
    'uncategorized':       ('',      ''),
}

# ============================================================
# Fetch meta_catalog
# ============================================================
resp = api_get('/items/meta_catalog?fields=id,code,name,entity_type,identity_class,registry_collection,record_count,actual_count,source_model,status,ui_page,description_field&sort=code&limit=-1')
catalog = resp.get('data', [])

if not catalog:
    print('[LỖI] Không thể đọc meta_catalog')
    sys.exit(1)

print(f'[INFO] Kiểm tra {len(catalog)} loại thực thể')
print()

PASS = 0
FAIL = 0
WARN = 0
issues = []  # Collected issues to write

def check_pass(et, msg):
    global PASS
    PASS += 1

def check_fail(et, msg, issue_type, severity='nghiêm_trọng'):
    global FAIL
    FAIL += 1
    print(f'  ❌ {msg}')
    issues.append({
        'entity_type': et.get('entity_type', ''),
        'entity_code': et.get('code', ''),
        'title': msg,
        'issue_type': issue_type,
        'severity': severity,
        'source': 'dot-layer-integrity-audit',
    })

def check_warn(et, msg, issue_type):
    global WARN
    WARN += 1
    print(f'  ⚠️  {msg}')
    issues.append({
        'entity_type': et.get('entity_type', ''),
        'entity_code': et.get('code', ''),
        'title': msg,
        'issue_type': issue_type,
        'severity': 'cảnh_báo',
        'source': 'dot-layer-integrity-audit',
    })

# ============================================================
# Run 5 checks per entity type
# ============================================================
results = []

for entry in catalog:
    et = entry.get('entity_type', '')
    code = entry.get('code', '')
    name = entry.get('name', '')
    reg_col = entry.get('registry_collection', '')
    rec_count = entry.get('record_count') or 0
    act_count = entry.get('actual_count') or 0
    status = entry.get('status', '')

    if status not in ('active', 'published'):
        continue

    r = {
        'code': code, 'name': name, 'et': et,
        'c1': '—', 'c2': '—', 'c3': '—', 'c4': '—', 'c5': '—', 'c6': '—'
    }

    print(f'{code} {name} ({et}):')

    # CHECK 1 — Layer 2 page renders data
    page_url = f'{nuxt_url}/knowledge/registries/{et}'
    http_code, body = fetch_page(page_url)
    if http_code != 200:
        check_fail(entry, f'{code} {name} — Lớp 2 trả mã {http_code}', 'lỗi_lớp_2')
        r['c1'] = f'❌ HTTP {http_code}'
    elif 'Chưa có bảng registry' in body:
        check_fail(entry, f'{code} {name} — Lớp 2 thiếu cấu hình bảng registry', 'lỗi_lớp_2')
        r['c1'] = '❌ Thiếu config'
    elif 'Không có dữ liệu' in body and rec_count > 0:
        check_fail(entry, f'{code} {name} — Lớp 2 trống dù có {rec_count} bản ghi', 'lỗi_lớp_2')
        r['c1'] = '❌ TRỐNG'
    elif body and len(body) > 500:
        check_pass(entry, f'{code} Lớp 2 OK')
        r['c1'] = '✅'
    else:
        check_warn(entry, f'{code} {name} — Lớp 2 nội dung ít ({len(body)}b)', 'lỗi_lớp_2')
        r['c1'] = f'⚠️ {len(body)}b'

    # CHECK 2 — Items have code identifiers
    ci = CODE_INFO.get(et, ('', 'code'))
    prefix = ci[0]
    code_field = ci[1]
    if reg_col and prefix and code_field:
        code_resp = api_get(f'/items/{reg_col}?fields={code_field}&filter[{code_field}][_nnull]=true&limit=0&meta=filter_count')
        with_code = (code_resp.get('meta', {}).get('filter_count') or 0)
        total_resp = api_get(f'/items/{reg_col}?limit=0&meta=total_count')
        total = (total_resp.get('meta', {}).get('total_count') or 0)
        if total > 0:
            pct = round(with_code / total * 100)
            if pct == 100:
                check_pass(entry, f'{code} ID 100%')
                r['c2'] = '100%'
            elif pct >= 80:
                check_warn(entry, f'{code} {name} — {pct}% items có mã định danh ({with_code}/{total})', 'thiếu_mã_định_danh')
                r['c2'] = f'⚠️ {pct}%'
            else:
                check_fail(entry, f'{code} {name} — Chỉ {pct}% items có mã định danh ({with_code}/{total})', 'thiếu_mã_định_danh', 'cảnh_báo')
                r['c2'] = f'❌ {pct}%'
        else:
            r['c2'] = '—'
    else:
        r['c2'] = '—'

    # CHECK 3 — Entity has relationships in entity_dependencies
    # Skip for: relationship types (they ARE deps), log/virtual types, types without meaningful deps
    identity_class = entry.get('identity_class', 'managed')
    DEP_CHECK_SKIP_TYPES = {'entity_dependency', 'changelog', 'system_issue', 'comment', 'uncategorized', 'table_proposal', 'checkpoint_instance'}
    DEP_CHECK_SKIP_CLASSES = {'log', 'virtual'}
    if et in DEP_CHECK_SKIP_TYPES or identity_class in DEP_CHECK_SKIP_CLASSES:
        r['c3'] = '—'
    else:
        dep_resp = api_get(f'/items/entity_dependencies?filter[source_type][_eq]={urllib.parse.quote(et)}&limit=0&meta=filter_count')
        dep_count = dep_resp.get('meta', {}).get('filter_count') or 0
        if dep_count > 0:
            check_pass(entry, f'{code} Quan hệ={dep_count}')
            r['c3'] = str(dep_count)
        else:
            check_warn(entry, f'{code} {name} — Không có quan hệ entity_dependencies', 'thiếu_quan_hệ')
            r['c3'] = '⚠️ 0'

    # CHECK 4 — Dedicated page link works
    ui_page = entry.get('ui_page', '')
    if ui_page:
        link_url = f'{nuxt_url}{ui_page}' if ui_page.startswith('/') else ui_page
        link_code, _ = fetch_page(link_url)
        if link_code == 200:
            check_pass(entry, f'{code} Link OK')
            r['c4'] = '✅'
        else:
            check_warn(entry, f'{code} {name} — Link riêng trả {link_code}: {ui_page}', 'link_hỏng')
            r['c4'] = f'⚠️ {link_code}'
    else:
        r['c4'] = '—'

    # CHECK 5 — Cross-check actual_count consistency
    # For Model A: actual_count comes from Directus total → compare with live total_count
    # For Model B: actual_count comes from independent source (FS, API) → skip collection comparison
    source_model = entry.get('source_model', 'A')
    if reg_col and source_model == 'A':
        count_resp = api_get(f'/items/{reg_col}?limit=0&meta=total_count')
        real_count = count_resp.get('meta', {}).get('total_count') or 0
        if real_count == act_count:
            check_pass(entry, f'{code} Nhất quán ({act_count})')
            r['c5'] = '✅'
        else:
            check_fail(entry, f'{code} {name} — meta_catalog nói {act_count} nhưng thực tế {real_count}', 'sai_lệch_dữ_liệu', 'cảnh_báo')
            r['c5'] = f'❌ {act_count}≠{real_count}'
    elif reg_col and source_model == 'B':
        # Model B: actual_count is from independent source, skip collection comparison
        check_pass(entry, f'{code} Model B — bỏ qua so sánh collection')
        r['c5'] = '✅ B'
    else:
        r['c5'] = '—'

    # CHECK 6 — Items have description (not empty, ≥ 20 words)
    # Use 'description' field for all collections; skip known exceptions
    SKIP_DESC = {'_uncategorized', 'registry_changelog'}
    desc_field = 'description'
    if reg_col and reg_col not in SKIP_DESC:
        # Count items with empty or NULL description
        empty_resp = api_get(
            f'/items/{reg_col}?filter[{desc_field}][_null]=true&limit=0&meta=filter_count'
        )
        if 'error' in empty_resp:
            # Collection may not have description field
            r['c6'] = '—'
            results.append(r)
            print()
            continue
        empty_count = empty_resp.get('meta', {}).get('filter_count') or 0

        # Count items with non-null but short description (< 20 words)
        desc_resp = api_get(
            f'/items/{reg_col}?fields={desc_field}&filter[{desc_field}][_nnull]=true&limit=-1'
        )
        desc_items = desc_resp.get('data', [])
        short_count = 0
        for item in desc_items:
            desc_text = (item.get(desc_field) or '').strip()
            if desc_text and len(desc_text.split()) < 20:
                short_count += 1

        total_resp = api_get(f'/items/{reg_col}?limit=0&meta=total_count')
        total_items = total_resp.get('meta', {}).get('total_count') or 0

        missing = empty_count + short_count
        if total_items > 0 and missing > 0:
            pct_missing = round(missing / total_items * 100)
            if pct_missing > 50:
                check_fail(entry, f'{code} {name} — {missing}/{total_items} items thiếu mô tả ({empty_count} trống, {short_count} < 20 từ)', 'thiếu_mô_tả', 'cảnh_báo')
                r['c6'] = f'❌ {pct_missing}%'
            elif missing > 0:
                check_warn(entry, f'{code} {name} — {missing}/{total_items} items thiếu mô tả ({empty_count} trống, {short_count} < 20 từ)', 'thiếu_mô_tả')
                r['c6'] = f'⚠️ {missing}'
        elif total_items > 0:
            check_pass(entry, f'{code} Mô tả đầy đủ')
            r['c6'] = '✅'
    else:
        r['c6'] = '—'

    results.append(r)
    print()

# ============================================================
# Summary table
# ============================================================
print('═══════════════════════════════════════════════════════════')
print(f'  TỔNG: {PASS} PASS, {WARN} CẢNH BÁO, {FAIL} LỖI')
print('═══════════════════════════════════════════════════════════')
print()
print(f'{"Mã":<10} {"Tên":<30} {"Lớp2":<15} {"ID%":<10} {"QuanHệ":<10} {"Link":<10} {"NhấtQuán":<10} {"MôTả":<10}')
print('─' * 105)
for r in results:
    print(f'{r["code"]:<10} {r["name"]:<30} {r["c1"]:<15} {r["c2"]:<10} {r["c3"]:<10} {r["c4"]:<10} {r["c5"]:<10} {r["c6"]:<10}')

# ============================================================
# Write issues to system_issues (idempotent)
# ============================================================
if issues and not dry_run and not no_write:
    print()
    print(f'[GHI] Ghi {len(issues)} vấn đề vào system_issues...')
    written = 0
    skipped = 0
    for issue in issues:
        # Check for existing open issue with same entity_type + title
        et_filter = urllib.parse.quote(issue['entity_type'])
        title_filter = urllib.parse.quote(issue['title'])
        existing = api_get(
            f'/items/system_issues?filter[entity_type][_eq]={et_filter}'
            f'&filter[title][_eq]={title_filter}'
            f'&filter[status][_in]=mở,đang_xử_lý'
            f'&limit=1&fields=id'
        )
        existing_items = existing.get('data', [])
        if existing_items:
            skipped += 1
            continue

        # Create new issue
        result = api_post('/items/system_issues', {
            'title': issue['title'],
            'entity_type': issue['entity_type'],
            'entity_code': issue['entity_code'],
            'issue_type': issue['issue_type'],
            'severity': issue['severity'],
            'source': issue['source'],
            'status': 'mở',
        })
        if 'error' not in result:
            written += 1
        else:
            print(f'  [CẢNH BÁO] Không ghi được: {result["error"]}')

    print(f'  Đã ghi: {written}, Bỏ qua (đã tồn tại): {skipped}')
elif issues and (dry_run or no_write):
    print()
    print(f'[DRY RUN] Sẽ ghi {len(issues)} vấn đề (bỏ qua do --dry-run hoặc --no-write)')
else:
    print()
    print('[TUYỆT] Không phát hiện vấn đề nào cần ghi.')

# ============================================================
# Issues list
# ============================================================
if issues:
    print()
    print('VẤN ĐỀ PHÁT HIỆN:')
    for i, issue in enumerate(issues, 1):
        sev = 'LỖI' if issue['severity'] == 'nghiêm_trọng' else 'CẢNH BÁO'
        print(f'  {i}. [{sev}] {issue["entity_code"]} — {issue["title"]}')

# ============================================================
# AUTO-RESOLVE: close issues whose problems no longer exist
# ============================================================
if not dry_run and not no_write:
    print()
    print('[AUTO-RESOLVE] Kiểm tra vấn đề cũ đã được fix...')
    # Collect current issue titles (problems found THIS scan)
    current_titles = {iss['title'] for iss in issues}

    # Fetch all existing open/archived issues from this scanner
    page = 1
    all_existing = []
    while True:
        batch = api_get(
            f'/items/system_issues?filter[source_system][_eq]=dot-scanner'
            f'&filter[status][_neq]=resolved'
            f'&fields=id,title,status,sub_class'
            f'&limit=100&page={page}'
        )
        items = batch.get('data', [])
        if not items:
            break
        all_existing.extend(items)
        page += 1

    # Resolve issues whose title is NOT in current scan results
    # (= the problem no longer detected → it's been fixed)
    # Exclude watchdog issues (runner_liveness) from auto-resolve
    resolved_count = 0
    for ex in all_existing:
        if ex.get('sub_class') == 'runner_liveness':
            continue  # Watchdog must always stay open
        if ex['title'] not in current_titles:
            result = api_post(f'/items/system_issues/{ex["id"]}', {
                'status': 'resolved',
                'resolved_at': datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%S.000Z'),
                'resolution': 'Auto-resolved: problem no longer detected by dot-layer-integrity-audit',
            })
            if 'error' not in str(result):
                resolved_count += 1

    still_open = len([e for e in all_existing if e['title'] in current_titles])
    print(f'  Auto-resolved: {resolved_count} | Still open: {still_open} | Skipped (watchdog): {len([e for e in all_existing if e.get("sub_class") == "runner_liveness"])}')

print()
total = PASS + FAIL + WARN
print('═══════════════════════════════════════════════════════════')
print(f'  Kết quả: {PASS}/{total} PASS, {FAIL}/{total} LỖI, {WARN}/{total} CẢNH BÁO')
print('═══════════════════════════════════════════════════════════')

if FAIL > 0:
    print('KẾT LUẬN: CÓ LỖI')
    sys.exit(1)
elif WARN > 0:
    print('KẾT LUẬN: PASS VỚI CẢNH BÁO')
    sys.exit(0)
else:
    print('KẾT LUẬN: TẤT CẢ PASS')
    sys.exit(0)
PYEOF

DIRECTUS_URL="$DIRECTUS_URL" DIRECTUS_TOKEN="$TOKEN" NUXT_BASE="$NUXT_BASE" \
  DRY_RUN="${DRY_RUN}" NO_WRITE="${NO_WRITE}" \
  python3 "$tmp_py" < /dev/null

exit_code=$?

echo ""
echo "═══════════════════════════════════════════════════════════"
echo "  DOT Tool: Layer Integrity Audit - HOÀN THÀNH"
echo "═══════════════════════════════════════════════════════════"

exit $exit_code
