#!/usr/bin/env bash
# CHECKED-NO-DUPLICATE: [searched dot/bin/dot-*pivot* dot/bin/dot-*health* — no conflict]
# =============================================================================
# dot-pivot-health — Health check for pivot_definitions + pivot_count() system
# =============================================================================
# VERSION: 1.0.0
# Điều 26 v3.5 Mission 2 — pivot health check
#
# Usage:
#   dot-pivot-health [--fix] [--verbose]
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/../config/environment.sh"

VERSION="1.0.0"
VPS_HOST="38.242.240.89"
VPS_KEY="${HOME}/.ssh/contabo_vps"
PG_CONTAINER="postgres"
PG_USER="directus"
PG_DB="directus"

FIX_MODE=false
VERBOSE=false
PASS=0
WARN=0
FAIL=0

for arg in "$@"; do
  case "$arg" in
    --help|-h) echo "dot-pivot-health v${VERSION}"; echo "Usage: dot-pivot-health [--fix] [--verbose]"; exit 0 ;;
    --fix) FIX_MODE=true ;;
    --verbose) VERBOSE=true ;;
  esac
done

pg_sql() {
  local _on_vps=false
  { docker ps --format '{{.Names}}' 2>/dev/null | grep -q "^${PG_CONTAINER}$"; } && _on_vps=true
  if [[ "$_on_vps" == "true" ]]; then
    docker exec -i "${PG_CONTAINER}" psql -U "${PG_USER}" -d "${PG_DB}" -t -A <<< "$1" 2>&1
  else
    ssh -i "$VPS_KEY" "root@${VPS_HOST}" \
      "docker exec -i ${PG_CONTAINER} psql -U ${PG_USER} -d ${PG_DB} -t -A" <<< "$1" 2>&1
  fi
}

pass() { PASS=$((PASS + 1)); echo "  $1 $(printf '.%.0s' {1..30}) ✅ PASS${2:+ ($2)}"; }
warn() { WARN=$((WARN + 1)); echo "  $1 $(printf '.%.0s' {1..30}) ⚠️  WARN${2:+ ($2)}"; }
fail() { FAIL=$((FAIL + 1)); echo "  $1 $(printf '.%.0s' {1..30}) ❌ FAIL${2:+ ($2)}"; }

echo "═══ PIVOT HEALTH CHECK v${VERSION} ═══"

# Stats
TOTAL=$(pg_sql "SELECT COUNT(*) FROM pivot_definitions;" | tr -d '[:space:]')
ACTIVE=$(pg_sql "SELECT COUNT(*) FROM pivot_definitions WHERE is_active = true;" | tr -d '[:space:]')
INACTIVE=$((TOTAL - ACTIVE))
echo "Total definitions: ${TOTAL} (${ACTIVE} active, ${INACTIVE} inactive)"
echo ""

# H1: pivot_count() executes without error
H1_START=$(date +%s%N)
H1_RESULT=$(pg_sql "SELECT COUNT(*) FROM pivot_count();" 2>&1)
H1_END=$(date +%s%N)
H1_MS=$(( (H1_END - H1_START) / 1000000 ))
H1_COUNT=$(echo "$H1_RESULT" | tr -d '[:space:]')
if [[ "$H1_COUNT" =~ ^[0-9]+$ ]]; then
  pass "H1: pivot_count() executes" "${H1_COUNT} rows, ${H1_MS}ms"
else
  fail "H1: pivot_count() executes" "ERROR: ${H1_RESULT}"
fi

# H2: All counts non-negative
H2_BAD=$(pg_sql "SELECT COUNT(*) FROM pivot_count() WHERE count_value < 0 OR count_value IS NULL;" | tr -d '[:space:]')
if [[ "$H2_BAD" == "0" ]]; then
  pass "H2: All counts non-negative" ""
else
  fail "H2: All counts non-negative" "${H2_BAD} bad values"
fi

# H3: All source_objects exist in PG
H3_MISSING=$(pg_sql "
  SELECT pd.code || ':' || pd.source_object
  FROM pivot_definitions pd
  WHERE pd.is_active = true
    AND NOT EXISTS (SELECT 1 FROM information_schema.tables WHERE table_name = pd.source_object);
")
H3_LIST=$(echo "$H3_MISSING" | grep -v '^$' || true)
if [[ -z "$H3_LIST" ]]; then
  pass "H3: All source_objects exist" "${ACTIVE}/${ACTIVE}"
else
  H3_COUNT=$(echo "$H3_LIST" | wc -l | tr -d '[:space:]')
  fail "H3: All source_objects exist" "${H3_COUNT} missing"
  if [[ "$VERBOSE" == "true" ]]; then
    echo "$H3_LIST" | while read -r line; do echo "       → $line"; done
  fi
fi

# H4: meta_catalog coverage — every active meta_catalog entry has a pivot
H4_MISSING=$(pg_sql "
  SELECT mc.code || ':' || mc.registry_collection
  FROM meta_catalog mc
  WHERE mc.registry_collection IS NOT NULL
    AND mc.status = 'active'
    AND mc.registry_collection NOT IN (SELECT source_object FROM pivot_definitions WHERE is_active = true);
")
H4_LIST=$(echo "$H4_MISSING" | grep -v '^$' || true)
if [[ -z "$H4_LIST" ]]; then
  pass "H4: meta_catalog coverage" ""
else
  H4_COUNT=$(echo "$H4_LIST" | wc -l | tr -d '[:space:]')
  warn "H4: meta_catalog coverage" "${H4_COUNT} entries missing pivot"
  if [[ "$VERBOSE" == "true" ]]; then
    echo "$H4_LIST" | while read -r line; do echo "       → $line"; done
  fi
  if [[ "$FIX_MODE" == "true" ]]; then
    echo "  [FIX] Running dot-pivot-declare --auto-from-meta-catalog..."
    "${SCRIPT_DIR}/dot-pivot-declare" --auto-from-meta-catalog
  fi
fi

# H5: Orphan pivots — pivot source_object not in PG AND not deactivated
H5_ORPHANS=$(pg_sql "
  SELECT pd.code || ':' || pd.source_object
  FROM pivot_definitions pd
  WHERE pd.is_active = true
    AND NOT EXISTS (SELECT 1 FROM information_schema.tables WHERE table_name = pd.source_object);
")
H5_LIST=$(echo "$H5_ORPHANS" | grep -v '^$' || true)
if [[ -z "$H5_LIST" ]]; then
  pass "H5: Orphan pivots" "0 orphans"
else
  H5_COUNT=$(echo "$H5_LIST" | wc -l | tr -d '[:space:]')
  warn "H5: Orphan pivots" "${H5_COUNT} orphans"
  if [[ "$VERBOSE" == "true" ]]; then
    echo "$H5_LIST" | while read -r line; do echo "       → $line"; done
  fi
  if [[ "$FIX_MODE" == "true" ]]; then
    echo "  [FIX] Deactivating orphan pivots..."
    pg_sql "
      UPDATE pivot_definitions SET is_active = false
      WHERE is_active = true
        AND NOT EXISTS (SELECT 1 FROM information_schema.tables WHERE table_name = source_object);
    " > /dev/null
    echo "  [FIX] Done."
  fi
fi

# H6: Duplicate detection — same source + filter
H6_DUPS=$(pg_sql "
  SELECT source_object || ' (' || COUNT(*) || ' dups)'
  FROM pivot_definitions
  WHERE is_active = true
  GROUP BY source_object, filter_spec
  HAVING COUNT(*) > 1;
")
H6_LIST=$(echo "$H6_DUPS" | grep -v '^$' || true)
if [[ -z "$H6_LIST" ]]; then
  pass "H6: Duplicate detection" "0 duplicates"
else
  H6_COUNT=$(echo "$H6_LIST" | wc -l | tr -d '[:space:]')
  warn "H6: Duplicate detection" "${H6_COUNT} duplicates"
  if [[ "$VERBOSE" == "true" ]]; then
    echo "$H6_LIST" | while read -r line; do echo "       → $line"; done
  fi
fi

# H7: Count cross-check — pivot_count() vs direct COUNT(*) for no-filter pivots (AP-12 fix)
H7_MISMATCH=$(pg_sql "
  DO \\\$\\\$
  DECLARE
    r RECORD;
    direct_cnt bigint;
    results text[] := ARRAY[]::text[];
  BEGIN
    FOR r IN
      SELECT pc.code, pc.count_value, pd.source_object
      FROM pivot_count() pc
      JOIN pivot_definitions pd ON pd.code = pc.code
      WHERE pd.is_active = true
        AND pd.filter_spec = '{\"filters\":[]}'::jsonb
        AND pd.group_spec = '{\"groups\":[]}'::jsonb
    LOOP
      EXECUTE format('SELECT COUNT(*) FROM %I', r.source_object) INTO direct_cnt;
      IF r.count_value != direct_cnt THEN
        results := array_append(results,
          r.code || ': pivot=' || r.count_value || ' vs direct=' || direct_cnt);
      END IF;
    END LOOP;
    IF array_length(results, 1) > 0 THEN
      RAISE NOTICE '%', array_to_string(results, E'\n');
    END IF;
  END \\\$\\\$;
")
H7_LIST=$(echo "$H7_MISMATCH" | grep -E '^(PIV-|NOTICE:)' | sed 's/^NOTICE:  //' | grep -v '^$' || true)
if [[ -z "$H7_LIST" ]]; then
  NOFILTER_COUNT=$(pg_sql "SELECT COUNT(*) FROM pivot_definitions WHERE is_active = true AND filter_spec = '{\"filters\":[]}'::jsonb AND group_spec = '{\"groups\":[]}'::jsonb;" | tr -d '[:space:]')
  pass "H7: Count cross-check (real COUNT)" "${NOFILTER_COUNT}/${NOFILTER_COUNT} match"
else
  H7_COUNT=$(echo "$H7_LIST" | wc -l | tr -d '[:space:]')
  fail "H7: Count cross-check (real COUNT)" "${H7_COUNT} mismatches"
  echo "$H7_LIST" | while read -r line; do echo "       → $line"; done
fi

# H8: L1 Integrity — 9 rows × 5 cols = 45 cells ALL NOT NULL (§0-BD)
H8_NULLS=$(pg_sql "
  SELECT code || '.' || col AS cell FROM (
    SELECT code,
      CASE WHEN record_count IS NULL THEN 'record_count' END AS c1,
      CASE WHEN species_count IS NULL THEN 'species_count' END AS c2,
      CASE WHEN orphan_count IS NULL THEN 'orphan_count' END AS c3,
      CASE WHEN display_order IS NULL THEN 'display_order' END AS c4
    FROM meta_catalog WHERE identity_class = 'virtual' AND display_order > 0
  ) sub CROSS JOIN LATERAL unnest(ARRAY[c1,c2,c3,c4]) AS col
  WHERE col IS NOT NULL;
")
H8_LIST=$(echo "$H8_NULLS" | grep -v '^$' || true)
H8_TOTAL=$(pg_sql "SELECT COUNT(*) * 5 FROM meta_catalog WHERE identity_class = 'virtual' AND display_order > 0;" | tr -d '[:space:]')
if [[ -z "$H8_LIST" ]]; then
  pass "H8: L1 Integrity (${H8_TOTAL} cells)" "ALL NOT NULL"
else
  H8_COUNT=$(echo "$H8_LIST" | wc -l | tr -d '[:space:]')
  H8_OK=$((H8_TOTAL - H8_COUNT))
  fail "H8: L1 Integrity" "${H8_OK}/${H8_TOTAL} — ${H8_COUNT} NULL cells"
  echo "$H8_LIST" | while read -r line; do echo "       → $line"; done
fi

echo ""
TOTAL_CHECKS=$((PASS + WARN + FAIL))
echo "RESULT: ${PASS}/${TOTAL_CHECKS} PASS, ${WARN} WARNING, ${FAIL} FAIL"

if [[ "$FAIL" -gt 0 ]]; then
  echo "ACTION NEEDED: Fix FAIL items above"
  exit 1
elif [[ "$WARN" -gt 0 ]]; then
  echo "ACTION NEEDED: Review WARNING items (use --fix to auto-repair)"
  exit 0
else
  echo "All checks passed."
  exit 0
fi
