#!/usr/bin/env bash
# =============================================================================
# dot-registry-baseline-set — Ghi baseline_count cho tất cả entity types
# =============================================================================
# CHECKED-NO-DUPLICATE: [searched dot/bin/ for "baseline" — only schema tool]
# VERSION: 1.0.0
#
# Lấy actual_count hiện tại của mỗi entity type trong meta_catalog,
# ghi vào baseline_count. Chỉ ghi 1 lần (skip nếu đã có baseline > 0).
#
# Dùng --force để ghi đè baseline hiện có.
#
# Usage:
#   dot-registry-baseline-set [--cloud|--local] [--dry-run] [--force]
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/../config/environment.sh"

VERSION="1.0.0"
DRY_RUN=""
FORCE=""

for arg in "$@"; do
  case "$arg" in
    --dry-run) DRY_RUN="yes" ;;
    --force) FORCE="yes" ;;
    --help|-h)
      head -14 "$0" | tail -12
      show_environment_help
      exit 0
      ;;
  esac
done

init_environment "$@"

echo ""
echo "═══════════════════════════════════════════════════════════"
echo "  Ghi Baseline Count v${VERSION}"
echo "═══════════════════════════════════════════════════════════"
print_environment_banner "$@"

TOKEN="${DIRECTUS_TOKEN:-}"
if [[ -z "$TOKEN" ]]; then
  echo -e "${RED}[LỖI]${NC} Không thể xác thực với Directus" >&2
  exit 1
fi

tmp_py=$(mktemp /tmp/dot-baseline-XXXXXX.py)
trap "rm -f '$tmp_py'" EXIT

cat > "$tmp_py" << 'PYEOF'
import json, os, sys, ssl, urllib.request

base_url = os.environ['DIRECTUS_URL']
token = os.environ['DIRECTUS_TOKEN']
dry_run = os.environ.get('DRY_RUN', '') == 'yes'
force = os.environ.get('FORCE', '') == 'yes'

ctx = ssl.create_default_context()
ctx.check_hostname = False
ctx.verify_mode = ssl.CERT_NONE

def api_get(path):
    url = base_url + path
    req = urllib.request.Request(url, headers={'Authorization': f'Bearer {token}'})
    resp = urllib.request.urlopen(req, context=ctx, timeout=30)
    return json.loads(resp.read())

def api_patch(path, data):
    url = base_url + path
    payload = json.dumps(data).encode()
    req = urllib.request.Request(url, data=payload, headers={
        'Authorization': f'Bearer {token}',
        'Content-Type': 'application/json'
    }, method='PATCH')
    resp = urllib.request.urlopen(req, context=ctx, timeout=30)
    return json.loads(resp.read())

def api_aggregate_count(collection):
    path = f'/items/{collection}?aggregate[count]=id'
    try:
        resp = api_get(path)
        data = resp.get('data', [])
        if data and isinstance(data, list) and len(data) > 0:
            cnt = data[0].get('count', {})
            return int(cnt.get('id', 0) if isinstance(cnt, dict) else cnt)
    except:
        pass
    return None

# Fetch meta_catalog
resp = api_get('/items/meta_catalog?fields=id,code,name,entity_type,registry_collection,actual_count,baseline_count,status&sort=code&limit=-1')
catalog = resp.get('data', [])
active = [e for e in catalog if e.get('status') in ('active', 'published')]

print(f'[INFO] {len(active)} active entity types')

updated = 0
skipped = 0
failed = 0

for entry in active:
    entry_id = entry['id']
    code = entry.get('code', '')
    name = entry.get('name', '')
    col = entry.get('registry_collection', '')
    current_baseline = entry.get('baseline_count') or 0

    # Skip if already has baseline (unless --force)
    if current_baseline > 0 and not force:
        print(f'  [SKIP] {code} {name}: baseline đã có = {current_baseline}')
        skipped += 1
        continue

    # Get live count from collection
    if col:
        live_count = api_aggregate_count(col)
    else:
        live_count = entry.get('actual_count') or 0

    if live_count is None:
        print(f'  [WARN] {code} {name}: không đếm được collection "{col}"')
        failed += 1
        continue

    if dry_run:
        print(f'  [DRY] {code} {name}: baseline_count = {live_count}')
        updated += 1
    else:
        try:
            api_patch(f'/items/meta_catalog/{entry_id}', {'baseline_count': live_count})
            print(f'  [OK]  {code} {name}: baseline_count = {live_count}')
            updated += 1
        except Exception as e:
            print(f'  [ERR] {code} {name}: {e}')
            failed += 1

print()
print('═══════════════════════════════════════════════════════════')
print(f'  Ghi baseline: {updated}, Bỏ qua: {skipped}, Lỗi: {failed}')
print('═══════════════════════════════════════════════════════════')
PYEOF

DIRECTUS_URL="$DIRECTUS_URL" DIRECTUS_TOKEN="$TOKEN" \
  DRY_RUN="${DRY_RUN}" FORCE="${FORCE}" \
  python3 "$tmp_py" < /dev/null

echo ""
echo "═══════════════════════════════════════════════════════════"
echo "  Ghi Baseline Count — HOÀN THÀNH"
echo "═══════════════════════════════════════════════════════════"
