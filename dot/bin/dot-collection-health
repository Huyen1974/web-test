#!/usr/bin/env bash
# =============================================================================
# dot-collection-health — Collection integrity checks (Cấp A, auto-counted)
# =============================================================================
# VERSION: 2.2.0
# CHANGELOG:
#   v2.2.0 (2026-04-02): +governance_role 'locked' support. H15 skips locked (auto).
#     H17 covers locked (no DELETE). Governance warning recognizes 4 roles.
#   v2.1.1 (2026-04-02): Checks 1,2,11 bulk SQL (eliminate per-collection loops).
#   v2.1.0 (2026-04-02): H14+H15 PG-only (0 API calls), H17 retroactive Luật Bảo toàn
#     on ALL governed collections, H16 bulk species mapping, governance_role validation.
#   v2.0.0 (2026-04-02): +H14 FK constraints, +H15 permissions, +H16 species mapping,
#     +H17 no DELETE permission. Self-healing: auto-fix + log system_issues.
#   v1.0.0 (2026-03-31): 13 checks for collection health
#
# Usage:
#   dot-collection-health [--cloud|--local]
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/../config/environment.sh"

VERSION="2.2.0"

VPS_HOST="38.242.240.89"
VPS_KEY="${HOME}/.ssh/contabo_vps"
PG_CONTAINER="postgres"
PG_USER="directus"
PG_DB="directus"
LOCK_ID=35360001

log_info() { echo "[INFO] $1"; }
log_ok()   { echo "[OK]   $1"; }
log_warn() { echo "[WARN] $1"; }
log_err()  { echo "[ERR]  $1" >&2; }

show_help() {
  cat << EOF
dot-collection-health v${VERSION} — Collection integrity (Cấp A, 13 checks)

Uses pg_try_advisory_lock(${LOCK_ID}) for singleton execution.

Usage:
  dot-collection-health [--cloud|--local]
EOF
  show_environment_help
}

run_pg() {
  local SQL="$1"
  if command -v docker &>/dev/null && docker ps --format '{{.Names}}' 2>/dev/null | grep -q "^${PG_CONTAINER}$"; then
    docker exec -i ${PG_CONTAINER} psql -U ${PG_USER} -d ${PG_DB} -t -A <<< "$SQL" 2>/dev/null
  else
    ssh -i "$VPS_KEY" -o ConnectTimeout=10 -o StrictHostKeyChecking=no "root@${VPS_HOST}" \
      "docker exec -i ${PG_CONTAINER} psql -U ${PG_USER} -d ${PG_DB} -t -A" <<< "$SQL" 2>/dev/null
  fi
}

log_system_issue() {
  local TITLE="$1" ISSUE_TYPE="$2" DETAIL="$3" BASE_URL="$4"
  curl -sS --globoff -k -X POST \
    "${BASE_URL}/items/system_issues" \
    -H "Authorization: Bearer $DOT_TOKEN" \
    -H "Content-Type: application/json" \
    -d "$(jq -n \
      --arg title "$TITLE" \
      --arg it "$ISSUE_TYPE" \
      --arg desc "$DETAIL" \
      '{
        title: $title,
        issue_type: $it,
        description: $desc,
        source: "dot-collection-health",
        severity: "warning",
        status: "open",
        detected_at: (now | todate)
      }')" > /dev/null 2>&1 || true
}

main() {
  for arg in "$@"; do
    case "$arg" in
      --help|-h) show_help; exit 0 ;;
    esac
  done

  init_environment "$@"
  local BASE_URL="$DIRECTUS_URL"

  echo "========================================="
  echo "DOT Tool: Collection Health v${VERSION}"
  echo "Cấp A (self-healing) — checks auto-counted"
  echo "========================================="
  print_environment_banner "$@"

  if [[ -z "${DOT_TOKEN:-}" ]]; then
    source "${SCRIPT_DIR}/dot-auth" "$@"
  fi
  if [[ -z "${DOT_TOKEN:-}" ]]; then
    log_err "Authentication failed"; exit 1
  fi

  # Advisory lock
  local LOCK
  LOCK=$(run_pg "SELECT pg_try_advisory_lock(${LOCK_ID});")
  if [[ "$LOCK" != "t" ]]; then
    log_err "Another instance running (lock ${LOCK_ID})"; exit 1
  fi
  log_info "Advisory lock acquired"

  local ISSUES=0 CHECKS=0 FIXES=0

  # Get all collections from meta_catalog
  local COLLECTIONS
  COLLECTIONS=$(run_pg "SELECT registry_collection FROM meta_catalog WHERE status='active' ORDER BY registry_collection;")

  # === CHECK 1: Missing Tier 1 fields ===
  # Bulk SQL: one query instead of per-collection loop
  log_info "Check 1: Missing Tier-1 standard fields..."
  CHECKS=$((CHECKS+1))
  local C1
  C1=$(run_pg "
    SELECT count(DISTINCT mc.registry_collection)
    FROM meta_catalog mc
    CROSS JOIN collection_field_standards cfs
    WHERE mc.status = 'active'
      AND cfs.tier = 1
      AND (cfs.applies_to_group IS NULL OR cfs.applies_to_group = mc.atom_group)
      AND NOT EXISTS (
        SELECT 1 FROM information_schema.columns ic
        WHERE ic.table_name = mc.registry_collection
          AND ic.column_name = cfs.field_name
          AND ic.table_schema = 'public'
      );
  ")
  [[ "${C1:-0}" -gt 0 ]] && { log_warn "CHECK 1: ${C1} collections missing tier-1 fields"; ISSUES=$((ISSUES+1)); } || log_ok "CHECK 1 PASS"

  # === CHECK 2: Missing Tier 2 fields (informational) ===
  log_info "Check 2: Missing Tier-2 fields (informational)..."
  CHECKS=$((CHECKS+1))
  local C2
  C2=$(run_pg "
    SELECT count(DISTINCT mc.registry_collection)
    FROM meta_catalog mc
    CROSS JOIN collection_field_standards cfs
    WHERE mc.status = 'active'
      AND cfs.tier = 2
      AND (cfs.applies_to_group IS NULL OR cfs.applies_to_group = mc.atom_group)
      AND NOT EXISTS (
        SELECT 1 FROM information_schema.columns ic
        WHERE ic.table_name = mc.registry_collection
          AND ic.column_name = cfs.field_name
          AND ic.table_schema = 'public'
      );
  ")
  [[ "${C2:-0}" -gt 0 ]] && log_info "CHECK 2 INFO: ${C2} collections missing tier-2 fields" || log_ok "CHECK 2 PASS"

  # === CHECK 3: Status mismatch ===
  log_info "Check 3: Status mismatch (meta_catalog vs PG)..."
  CHECKS=$((CHECKS+1))
  local C3
  C3=$(run_pg "
    SELECT count(*) FROM meta_catalog mc
    WHERE mc.status = 'active'
      AND NOT EXISTS (
        SELECT 1 FROM information_schema.tables
        WHERE table_name = mc.registry_collection AND table_schema = 'public'
      );
  ")
  [[ "${C3:-0}" -gt 0 ]] && { log_warn "CHECK 3: ${C3} active in meta_catalog but missing in PG"; ISSUES=$((ISSUES+1)); } || log_ok "CHECK 3 PASS"

  # === CHECK 4: Orphan in registry but not in PG ===
  log_info "Check 4: Orphan in table_registry but not in PG..."
  CHECKS=$((CHECKS+1))
  local C4
  C4=$(run_pg "
    SELECT count(*) FROM table_registry tr
    WHERE NOT EXISTS (
      SELECT 1 FROM information_schema.tables
      WHERE table_name = tr.table_id AND table_schema = 'public'
    );
  ")
  [[ "${C4:-0}" -gt 0 ]] && { log_warn "CHECK 4: ${C4} orphans in table_registry"; ISSUES=$((ISSUES+1)); } || log_ok "CHECK 4 PASS"

  # === CHECK 5: No birth record ===
  log_info "Check 5: Collections without birth record..."
  CHECKS=$((CHECKS+1))
  local C5
  C5=$(run_pg "
    SELECT count(*) FROM meta_catalog mc
    WHERE mc.status = 'active'
      AND NOT EXISTS (
        SELECT 1 FROM schema_birth_registry sbr
        WHERE sbr.collection_name = mc.registry_collection
      );
  ")
  [[ "${C5:-0}" -gt 0 ]] && { log_warn "CHECK 5: ${C5} collections without birth record"; ISSUES=$((ISSUES+1)); } || log_ok "CHECK 5 PASS"

  # === CHECK 6: No species assignment ===
  log_info "Check 6: No species assignment..."
  CHECKS=$((CHECKS+1))
  local C6
  C6=$(run_pg "
    SELECT count(*) FROM meta_catalog mc
    WHERE mc.status = 'active'
      AND NOT EXISTS (
        SELECT 1 FROM collection_species cs
        WHERE cs.collection_name = mc.registry_collection
      );
  ")
  [[ "${C6:-0}" -gt 0 ]] && { log_warn "CHECK 6: ${C6} collections without species"; ISSUES=$((ISSUES+1)); } || log_ok "CHECK 6 PASS"

  # === CHECK 7: No labels ===
  log_info "Check 7: No labels..."
  CHECKS=$((CHECKS+1))
  local C7
  C7=$(run_pg "
    SELECT count(*) FROM meta_catalog mc
    WHERE mc.status = 'active'
      AND NOT EXISTS (
        SELECT 1 FROM collection_labels cl
        WHERE cl.collection_name = mc.registry_collection
      );
  ")
  [[ "${C7:-0}" -gt 0 ]] && { log_warn "CHECK 7: ${C7} collections without labels"; ISSUES=$((ISSUES+1)); } || log_ok "CHECK 7 PASS"

  # === CHECK 8: field_type conflict ===
  log_info "Check 8: field_type conflicts..."
  CHECKS=$((CHECKS+1))
  local C8
  C8=$(run_pg "
    SELECT count(*) FROM (
      SELECT ic.table_name, ic.column_name, ic.data_type, cfs.field_type
      FROM information_schema.columns ic
      JOIN collection_field_standards cfs ON cfs.field_name = ic.column_name
      WHERE ic.table_schema = 'public'
        AND cfs.field_type IS NOT NULL
        AND ic.data_type != cfs.field_type
    ) sub;
  ")
  [[ "${C8:-0}" -gt 0 ]] && { log_warn "CHECK 8: ${C8} field_type conflicts"; ISSUES=$((ISSUES+1)); } || log_ok "CHECK 8 PASS"

  # === CHECK 9: Group invalid ===
  # Validate: meta_catalog.atom_group must match collection_registry "group" for same collection.
  # NOTE: atom_group (Vietnamese semantic names) ≠ collection_groups.code (GRP-* codes).
  # No direct lookup table exists for atom_group → validate via cross-reference.
  log_info "Check 9: Invalid group..."
  CHECKS=$((CHECKS+1))
  local C9
  C9=$(run_pg "
    SELECT count(*) FROM meta_catalog mc
    WHERE mc.atom_group IS NOT NULL
      AND mc.atom_group NOT IN (
        SELECT DISTINCT mc2.atom_group FROM meta_catalog mc2
        JOIN collection_registry cr ON cr.collection_name = mc2.registry_collection
        WHERE mc2.atom_group IS NOT NULL AND cr.status IS DISTINCT FROM 'retired'
      );
  ")
  [[ "${C9:-0}" -gt 0 ]] && { log_warn "CHECK 9: ${C9} invalid atom_groups (not cross-referenced in collection_registry)"; ISSUES=$((ISSUES+1)); } || log_ok "CHECK 9 PASS"

  # === CHECK 10: Group NULL ===
  log_info "Check 10: Group NULL..."
  CHECKS=$((CHECKS+1))
  local C10
  C10=$(run_pg "SELECT count(*) FROM meta_catalog WHERE atom_group IS NULL AND status='active';")
  [[ "${C10:-0}" -gt 0 ]] && { log_warn "CHECK 10: ${C10} collections with NULL atom_group"; ISSUES=$((ISSUES+1)); } || log_ok "CHECK 10 PASS"

  # === CHECK 11: sync=true but missing standard fields ===
  # Bulk SQL: one query instead of per-collection loop
  log_info "Check 11: sync=true but missing standard fields..."
  CHECKS=$((CHECKS+1))
  local C11
  C11=$(run_pg "
    SELECT count(DISTINCT cr.collection_name)
    FROM collection_registry cr
    JOIN collection_groups cg ON cg.code = cr.\"group\"
    CROSS JOIN collection_field_standards cfs
    WHERE cg.sync_field_standards = true
      AND cr.status = 'active'
      AND cfs.tier = 1
      AND NOT EXISTS (
        SELECT 1 FROM information_schema.columns ic
        WHERE ic.table_name = cr.collection_name
          AND ic.column_name = cfs.field_name
          AND ic.table_schema = 'public'
      );
  " 2>/dev/null || echo "0")
  [[ "${C11:-0}" -gt 0 ]] && { log_warn "CHECK 11: ${C11} sync collections missing std fields"; ISSUES=$((ISSUES+1)); } || log_ok "CHECK 11 PASS"

  # === CHECK 12: sync=false verification for certain groups ===
  log_info "Check 12: sync=false for CMS/LOG/JUNCTION/SYSTEM verify..."
  CHECKS=$((CHECKS+1))
  local C12
  C12=$(run_pg "
    SELECT count(*) FROM collection_registry cr
    JOIN collection_groups cg ON cg.code = cr.\"group\"
    WHERE cr.\"group\" IN ('GRP-CMS','GRP-LOG','GRP-JUNCTION','GRP-SYSTEM')
      AND cg.sync_field_standards = false
      AND cr.status = 'active';
  " 2>/dev/null || echo "0")
  [[ "${C12:-0}" -gt 0 ]] && log_info "CHECK 12 INFO: ${C12} CMS/LOG/JUNCTION/SYSTEM with sync=false (verify intentional)" || log_ok "CHECK 12 PASS"

  # === Governance scope: detect unknown governance_roles ===
  # Four stable roles: governed (full checks + no DELETE), observed (monitoring),
  # excluded (opted out of governance), locked (read-only — no agent create/update/delete).
  # A new role beyond these 4 = a change in governance law — must be flagged.
  local UNKNOWN_GOV_ROLES
  UNKNOWN_GOV_ROLES=$(run_pg "
    SELECT DISTINCT governance_role FROM collection_registry
    WHERE governance_role IS NOT NULL
      AND governance_role NOT IN ('governed','observed','excluded','locked')
      AND status IS DISTINCT FROM 'retired';
  ")
  if [[ -n "${UNKNOWN_GOV_ROLES:-}" ]]; then
    while IFS= read -r role; do
      [[ -z "$role" ]] && continue
      log_warn "Unknown governance_role: '${role}' — review collection_registry"
      log_system_issue "Unknown governance_role: ${role}" "collection_onboarding_gap" \
        "collection_registry contains governance_role '${role}'. Only 'governed' and 'observed' are recognized. New role = governance law change — must be reviewed." "$BASE_URL"
    done <<< "$UNKNOWN_GOV_ROLES"
  fi

  # === CHECK 14: FK constraints match (self-healing) ===
  # Assembly First: directus_fields is a PG table. 0 API calls, 2 SQL queries.
  log_info "Check 14: FK constraints match Directus meta (PG-only)..."
  CHECKS=$((CHECKS+1))
  local C14=0 C14_FIXES=0
  # Intended FKs: from directus_fields PG table (NOT Directus HTTP API)
  local INTENDED_FKS
  INTENDED_FKS=$(run_pg "
    SELECT df.collection || '|' || df.field || '|' || (df.schema->>'foreign_key_table') || '|' || (df.schema->>'foreign_key_column')
    FROM directus_fields df
    WHERE df.schema->>'foreign_key_table' IS NOT NULL
      AND df.collection IN (
        SELECT collection_name FROM collection_registry
        WHERE governance_role IN ('governed','observed')
          AND status IS DISTINCT FROM 'retired'
      );
  ")
  # Actual FKs: from PG information_schema (one query for ALL tables)
  local ACTUAL_FKS
  ACTUAL_FKS=$(run_pg "
    SELECT tc.table_name || '|' || kcu.column_name || '|' || ccu.table_name || '|' || ccu.column_name
    FROM information_schema.table_constraints tc
    JOIN information_schema.key_column_usage kcu
      ON tc.constraint_name = kcu.constraint_name AND tc.table_schema = kcu.table_schema
    JOIN information_schema.constraint_column_usage ccu
      ON ccu.constraint_name = tc.constraint_name AND ccu.table_schema = tc.table_schema
    WHERE tc.constraint_type = 'FOREIGN KEY'
      AND tc.table_schema = 'public';
  ")
  # Compare: find intended FKs not present in PG catalog
  if [[ -n "${INTENDED_FKS:-}" ]]; then
    while IFS='|' read -r col fld fk_table fk_col; do
      [[ -z "$col" ]] && continue
      if ! echo "$ACTUAL_FKS" | grep -qxF "${col}|${fld}|${fk_table}|${fk_col}"; then
        log_warn "  ${col}.${fld} → ${fk_table}.${fk_col}: FK MISSING — auto-fixing..."
        run_pg "ALTER TABLE \"${col}\" ADD CONSTRAINT \"fk_${col}_${fld}\" FOREIGN KEY (\"${fld}\") REFERENCES \"${fk_table}\"(\"${fk_col}\") ON DELETE RESTRICT;" 2>/dev/null && {
          log_ok "  FIXED: FK ${col}.${fld}"
          C14_FIXES=$((C14_FIXES+1))
          FIXES=$((FIXES+1))
          log_system_issue "FK missing: ${col}.${fld}" "collection_onboarding_gap" "Auto-fixed FK ${col}.${fld} → ${fk_table}.${fk_col}" "$BASE_URL"
        } || log_warn "  CANNOT FIX: FK ${col}.${fld} (may need manual intervention)"
        C14=$((C14+1))
      fi
    done <<< "$INTENDED_FKS"
  fi
  [[ "$C14" -gt 0 ]] && { log_warn "CHECK 14: ${C14} FK gaps (${C14_FIXES} auto-fixed)"; ISSUES=$((ISSUES+1)); } || log_ok "CHECK 14 PASS"

  # === CHECK 15: Permissions complete (self-healing) ===
  # Assembly First: directus_permissions + directus_policies are PG tables. 0 API calls.
  # Bulk INSERT...WHERE NOT EXISTS — one query per action type instead of N*M loops.
  log_info "Check 15: Permissions complete (PG-only)..."
  CHECKS=$((CHECKS+1))
  local C15=0

  # 15a: Read permissions — 5 policies on ALL governed/observed collections
  local READ_GAPS
  READ_GAPS=$(run_pg "
    WITH inserted AS (
      INSERT INTO directus_permissions (collection, action, permissions, fields, policy)
      SELECT cr.collection_name, 'read', '{}', '{\"*\"}', pol.id
      FROM collection_registry cr
      CROSS JOIN directus_policies pol
      WHERE cr.governance_role IN ('governed','observed')
        AND cr.status IS DISTINCT FROM 'retired'
        AND pol.name IN ('AI Agent Policy','Agent Policy','\$t:public_label','Public Access','Editor Policy')
        AND NOT EXISTS (
          SELECT 1 FROM directus_permissions dp
          WHERE dp.collection = cr.collection_name AND dp.action = 'read' AND dp.policy = pol.id
        )
      RETURNING collection, policy
    )
    SELECT count(*) FROM inserted;
  ")
  READ_GAPS="${READ_GAPS:-0}"
  C15=$((C15 + READ_GAPS))

  # 15b: Create permissions — agent policies on ALL governed/observed collections
  local CREATE_GAPS
  CREATE_GAPS=$(run_pg "
    WITH inserted AS (
      INSERT INTO directus_permissions (collection, action, permissions, fields, policy)
      SELECT cr.collection_name, 'create', '{}', '{\"*\"}', pol.id
      FROM collection_registry cr
      CROSS JOIN directus_policies pol
      WHERE cr.governance_role IN ('governed','observed')
        AND cr.status IS DISTINCT FROM 'retired'
        AND pol.name IN ('AI Agent Policy','Agent Policy')
        AND NOT EXISTS (
          SELECT 1 FROM directus_permissions dp
          WHERE dp.collection = cr.collection_name AND dp.action = 'create' AND dp.policy = pol.id
        )
      RETURNING collection, policy
    )
    SELECT count(*) FROM inserted;
  ")
  CREATE_GAPS="${CREATE_GAPS:-0}"
  C15=$((C15 + CREATE_GAPS))

  # 15c: Update permissions — agent policies on governed collections ONLY
  local UPDATE_GAPS
  UPDATE_GAPS=$(run_pg "
    WITH inserted AS (
      INSERT INTO directus_permissions (collection, action, permissions, fields, policy)
      SELECT cr.collection_name, 'update', '{}', '{\"*\"}', pol.id
      FROM collection_registry cr
      CROSS JOIN directus_policies pol
      WHERE cr.governance_role = 'governed'
        AND cr.status IS DISTINCT FROM 'retired'
        AND pol.name IN ('AI Agent Policy','Agent Policy')
        AND NOT EXISTS (
          SELECT 1 FROM directus_permissions dp
          WHERE dp.collection = cr.collection_name AND dp.action = 'update' AND dp.policy = pol.id
        )
      RETURNING collection, policy
    )
    SELECT count(*) FROM inserted;
  ")
  UPDATE_GAPS="${UPDATE_GAPS:-0}"
  C15=$((C15 + UPDATE_GAPS))

  FIXES=$((FIXES + C15))
  if [[ "$C15" -gt 0 ]]; then
    log_warn "CHECK 15: ${C15} permission gaps (auto-fixed: read=${READ_GAPS}, create=${CREATE_GAPS}, update=${UPDATE_GAPS})"
    log_system_issue "Permissions gaps" "collection_onboarding_gap" \
      "Auto-fixed ${C15} missing permissions (read=${READ_GAPS}, create=${CREATE_GAPS}, update=${UPDATE_GAPS})" "$BASE_URL"
    ISSUES=$((ISSUES+1))
  else
    log_ok "CHECK 15 PASS"
  fi

  # === CHECK 16: Species mapping (self-healing for governed) ===
  # Bulk queries: one for NULL species_code warnings, one for missing mappings.
  log_info "Check 16: Species mapping (PG-only)..."
  CHECKS=$((CHECKS+1))
  local C16=0

  # 16a: Governed collections with NULL/empty species_code → warning only
  local NULL_SPECIES
  NULL_SPECIES=$(run_pg "
    SELECT collection_name FROM collection_registry
    WHERE governance_role = 'governed'
      AND status IS DISTINCT FROM 'retired'
      AND (species_code IS NULL OR species_code = '');
  ")
  if [[ -n "${NULL_SPECIES:-}" ]]; then
    while IFS= read -r col; do
      [[ -z "$col" ]] && continue
      log_warn "  ${col}: governed but species_code NULL"
      log_system_issue "Species code missing: ${col}" "collection_onboarding_gap" \
        "${col} is governed but has no species_code in collection_registry" "$BASE_URL"
      C16=$((C16+1))
    done <<< "$NULL_SPECIES"
  fi

  # 16b: Governed collections with species_code but missing mapping → auto-fix
  local SPECIES_FIXED
  SPECIES_FIXED=$(run_pg "
    WITH inserted AS (
      INSERT INTO species_collection_map (species_code, collection_name, is_primary)
      SELECT cr.species_code, cr.collection_name, true
      FROM collection_registry cr
      WHERE cr.governance_role = 'governed'
        AND cr.status IS DISTINCT FROM 'retired'
        AND cr.species_code IS NOT NULL AND cr.species_code != ''
        AND NOT EXISTS (
          SELECT 1 FROM species_collection_map scm
          WHERE scm.collection_name = cr.collection_name AND scm.species_code = cr.species_code
        )
      ON CONFLICT DO NOTHING
      RETURNING collection_name || ' -> ' || species_code
    )
    SELECT * FROM inserted;
  ")
  if [[ -n "${SPECIES_FIXED:-}" ]]; then
    local SP_COUNT
    SP_COUNT=$(echo "$SPECIES_FIXED" | grep -c '.' || echo "0")
    C16=$((C16 + SP_COUNT))
    FIXES=$((FIXES + SP_COUNT))
    while IFS= read -r mapping; do
      [[ -z "$mapping" ]] && continue
      log_ok "  FIXED: species mapping ${mapping}"
      log_system_issue "Species mapping missing" "collection_onboarding_gap" "Auto-fixed species mapping ${mapping}" "$BASE_URL"
    done <<< "$SPECIES_FIXED"
  fi
  [[ "$C16" -gt 0 ]] && { log_warn "CHECK 16: ${C16} species gaps (auto-fixed where possible)"; ISSUES=$((ISSUES+1)); } || log_ok "CHECK 16 PASS"

  # === CHECK 17: No DELETE permission — Luật Bảo toàn (retroactive, ALL governed) ===
  # governed = NO DELETE. No exceptions. Want to "delete" → retire (status='retired').
  # If removing DELETE permission causes errors → the error is a clue → the process
  # violates Luật Bảo toàn → fix the process, not the permission.
  log_info "Check 17: No DELETE on governed+locked collections (Luật Bảo toàn, retroactive)..."
  CHECKS=$((CHECKS+1))
  local C17=0
  # Single query: find ALL DELETE permissions on governed + locked collections
  local DEL_PERMS
  DEL_PERMS=$(run_pg "
    SELECT dp.id || '|' || dp.collection || '|' || COALESCE(pol.name, 'unknown')
    FROM directus_permissions dp
    LEFT JOIN directus_policies pol ON dp.policy = pol.id
    WHERE dp.action = 'delete'
      AND dp.collection IN (
        SELECT collection_name FROM collection_registry
        WHERE governance_role IN ('governed','locked')
          AND status IS DISTINCT FROM 'retired'
      );
  ")
  if [[ -n "${DEL_PERMS:-}" ]]; then
    C17=$(echo "$DEL_PERMS" | grep -c '.' || echo "0")
    # Log each violation before bulk delete
    while IFS='|' read -r del_id del_col pol_name; do
      [[ -z "$del_id" ]] && continue
      log_warn "  ${del_col}: DELETE permission (policy: ${pol_name}) — removing..."
      log_system_issue "DELETE permission found: ${del_col}" "collection_onboarding_gap" \
        "Removed DELETE permission from governed collection ${del_col} (policy: ${pol_name})" "$BASE_URL"
    done <<< "$DEL_PERMS"
    # Bulk delete ALL DELETE permissions on governed + locked collections
    run_pg "
      DELETE FROM directus_permissions
      WHERE action = 'delete'
        AND collection IN (
          SELECT collection_name FROM collection_registry
          WHERE governance_role IN ('governed','locked')
            AND status IS DISTINCT FROM 'retired'
        );
    " 2>/dev/null && {
      FIXES=$((FIXES + C17))
      log_ok "  FIXED: removed ${C17} DELETE permissions"
    }
  fi
  [[ "$C17" -gt 0 ]] && { log_warn "CHECK 17: ${C17} governed/locked collections had DELETE permissions (removed)"; ISSUES=$((ISSUES+1)); } || log_ok "CHECK 17 PASS"

  # === CHECK 13: compliance_pct calculation ===
  log_info "Check 13: Compliance percentage..."
  CHECKS=$((CHECKS+1))
  local TOTAL_COLS COMPLIANT
  TOTAL_COLS=$(echo "$COLLECTIONS" | grep -c '.' || echo "0")
  COMPLIANT=$((TOTAL_COLS - ISSUES))
  [[ "$COMPLIANT" -lt 0 ]] && COMPLIANT=0
  local PCT=0
  if [[ "$TOTAL_COLS" -gt 0 ]]; then
    PCT=$(echo "scale=1; 100 * $COMPLIANT / $TOTAL_COLS" | bc 2>/dev/null || echo "0")
  fi
  log_info "CHECK 13: Compliance ${PCT}% (${COMPLIANT}/${TOTAL_COLS} clean)"

  # Release lock
  run_pg "SELECT pg_advisory_unlock(${LOCK_ID});" > /dev/null 2>&1

  # Summary
  echo ""
  echo "========================================="
  echo "${CHECKS} checks, ${ISSUES} issue(s), ${FIXES} auto-fix(es), compliance ${PCT}%"
  if [[ "$ISSUES" -eq 0 ]]; then
    log_ok "ALL CHECKS PASS"
  else
    log_warn "${ISSUES} issue(s) — see details above"
    for I_TITLE in "tier-1 fields" "status mismatch" "orphan registry" "no birth" "no species" "no labels" "field_type conflict" "invalid group" "null group" "sync missing fields"; do
      :  # issues already logged inline
    done
  fi
  echo "========================================="
}

main "$@"
