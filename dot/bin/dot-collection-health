#!/usr/bin/env bash
# =============================================================================
# dot-collection-health — Collection integrity checks (Cấp A, 17 checks)
# =============================================================================
# VERSION: 2.0.0
# CHANGELOG:
#   v2.0.0 (2026-04-02): +H14 FK constraints, +H15 permissions, +H16 species mapping,
#     +H17 no DELETE permission. Self-healing: auto-fix + log system_issues.
#   v1.0.0 (2026-03-31): 13 checks for collection health
#
# Usage:
#   dot-collection-health [--cloud|--local]
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/../config/environment.sh"

VERSION="2.0.0"

VPS_HOST="38.242.240.89"
VPS_KEY="${HOME}/.ssh/contabo_vps"
PG_CONTAINER="postgres"
PG_USER="directus"
PG_DB="directus"
LOCK_ID=35360001

log_info() { echo "[INFO] $1"; }
log_ok()   { echo "[OK]   $1"; }
log_warn() { echo "[WARN] $1"; }
log_err()  { echo "[ERR]  $1" >&2; }

show_help() {
  cat << EOF
dot-collection-health v${VERSION} — Collection integrity (Cấp A, 13 checks)

Uses pg_try_advisory_lock(${LOCK_ID}) for singleton execution.

Usage:
  dot-collection-health [--cloud|--local]
EOF
  show_environment_help
}

run_pg() {
  local SQL="$1"
  if command -v docker &>/dev/null && docker ps --format '{{.Names}}' 2>/dev/null | grep -q "^${PG_CONTAINER}$"; then
    docker exec -i ${PG_CONTAINER} psql -U ${PG_USER} -d ${PG_DB} -t -A <<< "$SQL" 2>/dev/null
  else
    ssh -i "$VPS_KEY" -o ConnectTimeout=10 -o StrictHostKeyChecking=no "root@${VPS_HOST}" \
      "docker exec -i ${PG_CONTAINER} psql -U ${PG_USER} -d ${PG_DB} -t -A" <<< "$SQL" 2>/dev/null
  fi
}

log_system_issue() {
  local TITLE="$1" ISSUE_TYPE="$2" DETAIL="$3" BASE_URL="$4"
  curl -sS --globoff -k -X POST \
    "${BASE_URL}/items/system_issues" \
    -H "Authorization: Bearer $DOT_TOKEN" \
    -H "Content-Type: application/json" \
    -d "$(jq -n \
      --arg title "$TITLE" \
      --arg it "$ISSUE_TYPE" \
      --arg desc "$DETAIL" \
      '{
        title: $title,
        issue_type: $it,
        description: $desc,
        source: "dot-collection-health",
        severity: "warning",
        status: "open",
        detected_at: (now | todate)
      }')" > /dev/null 2>&1 || true
}

main() {
  for arg in "$@"; do
    case "$arg" in
      --help|-h) show_help; exit 0 ;;
    esac
  done

  init_environment "$@"
  local BASE_URL="$DIRECTUS_URL"

  echo "========================================="
  echo "DOT Tool: Collection Health v${VERSION}"
  echo "17 checks — Cấp A (self-healing)"
  echo "========================================="
  print_environment_banner "$@"

  if [[ -z "${DOT_TOKEN:-}" ]]; then
    source "${SCRIPT_DIR}/dot-auth" "$@"
  fi
  if [[ -z "${DOT_TOKEN:-}" ]]; then
    log_err "Authentication failed"; exit 1
  fi

  # Advisory lock
  local LOCK
  LOCK=$(run_pg "SELECT pg_try_advisory_lock(${LOCK_ID});")
  if [[ "$LOCK" != "t" ]]; then
    log_err "Another instance running (lock ${LOCK_ID})"; exit 1
  fi
  log_info "Advisory lock acquired"

  local ISSUES=0 CHECKS=17 FIXES=0

  # Get all collections from meta_catalog
  local COLLECTIONS
  COLLECTIONS=$(run_pg "SELECT registry_collection FROM meta_catalog WHERE status='active' ORDER BY registry_collection;")

  # === CHECK 1: Missing Tier 1 fields ===
  log_info "Check 1: Missing Tier-1 standard fields..."
  local C1=0
  while IFS= read -r col; do
    [[ -z "$col" ]] && continue
    local MISSING
    MISSING=$(run_pg "
      SELECT cfs.field_name FROM collection_field_standards cfs
      WHERE cfs.tier = 1
        AND (cfs.applies_to_group IS NULL OR cfs.applies_to_group = (
          SELECT atom_group FROM meta_catalog WHERE registry_collection = '${col}' LIMIT 1
        ))
        AND NOT EXISTS (
          SELECT 1 FROM information_schema.columns
          WHERE table_name = '${col}' AND column_name = cfs.field_name AND table_schema = 'public'
        );
    ")
    if [[ -n "${MISSING:-}" ]]; then
      log_warn "  ${col}: missing tier-1 fields: $(echo "$MISSING" | tr '\n' ', ')"
      C1=$((C1 + 1))
    fi
  done <<< "$COLLECTIONS"
  [[ "$C1" -gt 0 ]] && { log_warn "CHECK 1: ${C1} collections missing tier-1 fields"; ISSUES=$((ISSUES+1)); } || log_ok "CHECK 1 PASS"

  # === CHECK 2: Missing Tier 2 fields (informational) ===
  log_info "Check 2: Missing Tier-2 fields (informational)..."
  local C2=0
  while IFS= read -r col; do
    [[ -z "$col" ]] && continue
    local MISSING2
    MISSING2=$(run_pg "
      SELECT cfs.field_name FROM collection_field_standards cfs
      WHERE cfs.tier = 2
        AND (cfs.applies_to_group IS NULL OR cfs.applies_to_group = (
          SELECT atom_group FROM meta_catalog WHERE registry_collection = '${col}' LIMIT 1
        ))
        AND NOT EXISTS (
          SELECT 1 FROM information_schema.columns
          WHERE table_name = '${col}' AND column_name = cfs.field_name AND table_schema = 'public'
        );
    ")
    [[ -n "${MISSING2:-}" ]] && C2=$((C2 + 1))
  done <<< "$COLLECTIONS"
  [[ "$C2" -gt 0 ]] && log_info "CHECK 2 INFO: ${C2} collections missing tier-2 fields" || log_ok "CHECK 2 PASS"

  # === CHECK 3: Status mismatch ===
  log_info "Check 3: Status mismatch (meta_catalog vs PG)..."
  local C3
  C3=$(run_pg "
    SELECT count(*) FROM meta_catalog mc
    WHERE mc.status = 'active'
      AND NOT EXISTS (
        SELECT 1 FROM information_schema.tables
        WHERE table_name = mc.registry_collection AND table_schema = 'public'
      );
  ")
  [[ "${C3:-0}" -gt 0 ]] && { log_warn "CHECK 3: ${C3} active in meta_catalog but missing in PG"; ISSUES=$((ISSUES+1)); } || log_ok "CHECK 3 PASS"

  # === CHECK 4: Orphan in registry but not in PG ===
  log_info "Check 4: Orphan in table_registry but not in PG..."
  local C4
  C4=$(run_pg "
    SELECT count(*) FROM table_registry tr
    WHERE NOT EXISTS (
      SELECT 1 FROM information_schema.tables
      WHERE table_name = tr.table_id AND table_schema = 'public'
    );
  ")
  [[ "${C4:-0}" -gt 0 ]] && { log_warn "CHECK 4: ${C4} orphans in table_registry"; ISSUES=$((ISSUES+1)); } || log_ok "CHECK 4 PASS"

  # === CHECK 5: No birth record ===
  log_info "Check 5: Collections without birth record..."
  local C5
  C5=$(run_pg "
    SELECT count(*) FROM meta_catalog mc
    WHERE mc.status = 'active'
      AND NOT EXISTS (
        SELECT 1 FROM schema_birth_registry sbr
        WHERE sbr.collection_name = mc.registry_collection
      );
  ")
  [[ "${C5:-0}" -gt 0 ]] && { log_warn "CHECK 5: ${C5} collections without birth record"; ISSUES=$((ISSUES+1)); } || log_ok "CHECK 5 PASS"

  # === CHECK 6: No species assignment ===
  log_info "Check 6: No species assignment..."
  local C6
  C6=$(run_pg "
    SELECT count(*) FROM meta_catalog mc
    WHERE mc.status = 'active'
      AND NOT EXISTS (
        SELECT 1 FROM collection_species cs
        WHERE cs.collection_name = mc.registry_collection
      );
  ")
  [[ "${C6:-0}" -gt 0 ]] && { log_warn "CHECK 6: ${C6} collections without species"; ISSUES=$((ISSUES+1)); } || log_ok "CHECK 6 PASS"

  # === CHECK 7: No labels ===
  log_info "Check 7: No labels..."
  local C7
  C7=$(run_pg "
    SELECT count(*) FROM meta_catalog mc
    WHERE mc.status = 'active'
      AND NOT EXISTS (
        SELECT 1 FROM collection_labels cl
        WHERE cl.collection_name = mc.registry_collection
      );
  ")
  [[ "${C7:-0}" -gt 0 ]] && { log_warn "CHECK 7: ${C7} collections without labels"; ISSUES=$((ISSUES+1)); } || log_ok "CHECK 7 PASS"

  # === CHECK 8: field_type conflict ===
  log_info "Check 8: field_type conflicts..."
  local C8
  C8=$(run_pg "
    SELECT count(*) FROM (
      SELECT ic.table_name, ic.column_name, ic.data_type, cfs.field_type
      FROM information_schema.columns ic
      JOIN collection_field_standards cfs ON cfs.field_name = ic.column_name
      WHERE ic.table_schema = 'public'
        AND cfs.field_type IS NOT NULL
        AND ic.data_type != cfs.field_type
    ) sub;
  ")
  [[ "${C8:-0}" -gt 0 ]] && { log_warn "CHECK 8: ${C8} field_type conflicts"; ISSUES=$((ISSUES+1)); } || log_ok "CHECK 8 PASS"

  # === CHECK 9: Group invalid ===
  log_info "Check 9: Invalid group..."
  local C9
  C9=$(run_pg "
    SELECT count(*) FROM meta_catalog mc
    WHERE mc.atom_group IS NOT NULL
      AND mc.atom_group NOT IN ('CMS','LOG','REGISTRY','JUNCTION','SYSTEM','GOVERNANCE','KNOWLEDGE','AGENT','CONFIG');
  ")
  [[ "${C9:-0}" -gt 0 ]] && { log_warn "CHECK 9: ${C9} invalid atom_groups"; ISSUES=$((ISSUES+1)); } || log_ok "CHECK 9 PASS"

  # === CHECK 10: Group NULL ===
  log_info "Check 10: Group NULL..."
  local C10
  C10=$(run_pg "SELECT count(*) FROM meta_catalog WHERE atom_group IS NULL AND status='active';")
  [[ "${C10:-0}" -gt 0 ]] && { log_warn "CHECK 10: ${C10} collections with NULL atom_group"; ISSUES=$((ISSUES+1)); } || log_ok "CHECK 10 PASS"

  # === CHECK 11: sync=true but missing standard fields ===
  log_info "Check 11: sync=true but missing standard fields..."
  local C11=0
  local SYNC_COLS
  SYNC_COLS=$(run_pg "
    SELECT cr.collection_name FROM collection_registry cr
    JOIN collection_groups cg ON cg.code = cr.\"group\"
    WHERE cg.sync_field_standards = true AND cr.status = 'active';
  " 2>/dev/null || true)
  while IFS= read -r col; do
    [[ -z "$col" ]] && continue
    local MISS
    MISS=$(run_pg "
      SELECT count(*) FROM collection_field_standards cfs
      WHERE cfs.tier = 1
        AND NOT EXISTS (
          SELECT 1 FROM information_schema.columns
          WHERE table_name = '${col}' AND column_name = cfs.field_name AND table_schema = 'public'
        );
    ")
    [[ "${MISS:-0}" -gt 0 ]] && C11=$((C11 + 1))
  done <<< "$SYNC_COLS"
  [[ "$C11" -gt 0 ]] && { log_warn "CHECK 11: ${C11} sync collections missing std fields"; ISSUES=$((ISSUES+1)); } || log_ok "CHECK 11 PASS"

  # === CHECK 12: sync=false verification for certain groups ===
  log_info "Check 12: sync=false for CMS/LOG/JUNCTION/SYSTEM verify..."
  local C12
  C12=$(run_pg "
    SELECT count(*) FROM collection_registry cr
    JOIN collection_groups cg ON cg.code = cr.\"group\"
    WHERE cr.\"group\" IN ('GRP-CMS','GRP-LOG','GRP-JUNCTION','GRP-SYSTEM')
      AND cg.sync_field_standards = false
      AND cr.status = 'active';
  " 2>/dev/null || echo "0")
  [[ "${C12:-0}" -gt 0 ]] && log_info "CHECK 12 INFO: ${C12} CMS/LOG/JUNCTION/SYSTEM with sync=false (verify intentional)" || log_ok "CHECK 12 PASS"

  # === CHECK 14: FK constraints match (self-healing) ===
  log_info "Check 14: FK constraints match Directus meta..."
  local C14=0
  # Get collections from collection_registry (governed + observed)
  local GOV_COLS
  GOV_COLS=$(run_pg "SELECT collection_name FROM collection_registry WHERE governance_role IN ('governed','observed') AND status IS DISTINCT FROM 'retired' ORDER BY collection_name;")
  while IFS= read -r col; do
    [[ -z "$col" ]] && continue
    # Get fields with foreign_key metadata from Directus
    local FK_FIELDS
    FK_FIELDS=$(curl -sS --globoff -k -X GET \
      "${BASE_URL}/fields/${col}" \
      -H "Authorization: Bearer $DOT_TOKEN" 2>/dev/null | jq -r '.data[] | select(.schema.foreign_key_table != null) | "\(.field)|\(.schema.foreign_key_table)|\(.schema.foreign_key_column)"' 2>/dev/null)
    while IFS='|' read -r fld fk_table fk_col; do
      [[ -z "$fld" ]] && continue
      local FK_EXISTS
      FK_EXISTS=$(run_pg "
        SELECT count(*) FROM information_schema.table_constraints tc
        JOIN information_schema.key_column_usage kcu ON tc.constraint_name = kcu.constraint_name
        JOIN information_schema.constraint_column_usage ccu ON tc.constraint_name = ccu.constraint_name
        WHERE tc.constraint_type = 'FOREIGN KEY'
          AND tc.table_name = '${col}' AND kcu.column_name = '${fld}'
          AND ccu.table_name = '${fk_table}' AND ccu.column_name = '${fk_col}';
      ")
      if [[ "${FK_EXISTS:-0}" -eq 0 ]]; then
        log_warn "  ${col}.${fld} → ${fk_table}.${fk_col}: FK MISSING — auto-fixing..."
        run_pg "ALTER TABLE ${col} ADD CONSTRAINT fk_${col}_${fld} FOREIGN KEY (${fld}) REFERENCES ${fk_table}(${fk_col}) ON DELETE RESTRICT;" 2>/dev/null && {
          log_ok "  FIXED: FK ${col}.${fld}"
          FIXES=$((FIXES+1))
          log_system_issue "FK missing: ${col}.${fld}" "collection_onboarding_gap" "Auto-fixed FK ${col}.${fld} → ${fk_table}.${fk_col}" "$BASE_URL"
        } || log_warn "  CANNOT FIX: FK ${col}.${fld} (may need manual intervention)"
        C14=$((C14+1))
      fi
    done <<< "$FK_FIELDS"
  done <<< "$GOV_COLS"
  [[ "$C14" -gt 0 ]] && { log_warn "CHECK 14: ${C14} FK gaps found (${FIXES} auto-fixed)"; ISSUES=$((ISSUES+1)); } || log_ok "CHECK 14 PASS"

  # === CHECK 15: Permissions complete (self-healing) ===
  log_info "Check 15: Permissions complete..."
  local C15=0
  # Get policy IDs dynamically
  local AI_POLICY AGENT_POLICY PUBLIC_LABEL PUBLIC_ACCESS EDITOR_POLICY
  AI_POLICY=$(run_pg "SELECT id FROM directus_policies WHERE name = 'AI Agent Policy' LIMIT 1;")
  AGENT_POLICY=$(run_pg "SELECT id FROM directus_policies WHERE name = 'Agent Policy' LIMIT 1;")
  PUBLIC_LABEL=$(run_pg "SELECT id FROM directus_policies WHERE name = '\$t:public_label' LIMIT 1;")
  PUBLIC_ACCESS=$(run_pg "SELECT id FROM directus_policies WHERE name = 'Public Access' LIMIT 1;")
  EDITOR_POLICY=$(run_pg "SELECT id FROM directus_policies WHERE name = 'Editor Policy' LIMIT 1;")

  while IFS= read -r col; do
    [[ -z "$col" ]] && continue
    local GOV_ROLE
    GOV_ROLE=$(run_pg "SELECT governance_role FROM collection_registry WHERE collection_name = '${col}' LIMIT 1;")
    [[ -z "$GOV_ROLE" ]] && continue

    # Expected: read for 5 policies
    for POL_ID in "$PUBLIC_LABEL" "$PUBLIC_ACCESS" "$EDITOR_POLICY" "$AI_POLICY" "$AGENT_POLICY"; do
      [[ -z "$POL_ID" ]] && continue
      local HAS_READ
      HAS_READ=$(run_pg "SELECT count(*) FROM directus_permissions WHERE collection='${col}' AND action='read' AND policy='${POL_ID}';")
      if [[ "${HAS_READ:-0}" -eq 0 ]]; then
        run_pg "INSERT INTO directus_permissions (collection, action, permissions, fields, policy) VALUES ('${col}','read','{}','{\"*\"}','${POL_ID}');" 2>/dev/null && {
          FIXES=$((FIXES+1))
          C15=$((C15+1))
        }
      fi
    done
    # Expected: create for agent policies
    for POL_ID in "$AI_POLICY" "$AGENT_POLICY"; do
      [[ -z "$POL_ID" ]] && continue
      local HAS_CREATE
      HAS_CREATE=$(run_pg "SELECT count(*) FROM directus_permissions WHERE collection='${col}' AND action='create' AND policy='${POL_ID}';")
      if [[ "${HAS_CREATE:-0}" -eq 0 ]]; then
        run_pg "INSERT INTO directus_permissions (collection, action, permissions, fields, policy) VALUES ('${col}','create','{}','{\"*\"}','${POL_ID}');" 2>/dev/null && {
          FIXES=$((FIXES+1))
          C15=$((C15+1))
        }
      fi
    done
    # Expected: update for agent policies IF governed
    if [[ "$GOV_ROLE" == "governed" ]]; then
      for POL_ID in "$AI_POLICY" "$AGENT_POLICY"; do
        [[ -z "$POL_ID" ]] && continue
        local HAS_UPDATE
        HAS_UPDATE=$(run_pg "SELECT count(*) FROM directus_permissions WHERE collection='${col}' AND action='update' AND policy='${POL_ID}';")
        if [[ "${HAS_UPDATE:-0}" -eq 0 ]]; then
          run_pg "INSERT INTO directus_permissions (collection, action, permissions, fields, policy) VALUES ('${col}','update','{}','{\"*\"}','${POL_ID}');" 2>/dev/null && {
            FIXES=$((FIXES+1))
            C15=$((C15+1))
          }
        fi
      done
    fi
  done <<< "$GOV_COLS"
  if [[ "$C15" -gt 0 ]]; then
    log_warn "CHECK 15: ${C15} permission gaps found (auto-fixed)"
    log_system_issue "Permissions gaps" "collection_onboarding_gap" "Auto-fixed ${C15} missing permissions across governance collections" "$BASE_URL"
    ISSUES=$((ISSUES+1))
  else
    log_ok "CHECK 15 PASS"
  fi

  # === CHECK 16: Species mapping (self-healing for governed) ===
  log_info "Check 16: Species mapping..."
  local C16=0
  while IFS= read -r col; do
    [[ -z "$col" ]] && continue
    local GOV_ROLE SP_CODE
    GOV_ROLE=$(run_pg "SELECT governance_role FROM collection_registry WHERE collection_name = '${col}' LIMIT 1;")
    [[ "$GOV_ROLE" != "governed" ]] && continue
    SP_CODE=$(run_pg "SELECT species_code FROM collection_registry WHERE collection_name = '${col}' LIMIT 1;")
    if [[ -z "$SP_CODE" || "$SP_CODE" == "" ]]; then
      log_warn "  ${col}: governed but species_code NULL in collection_registry"
      log_system_issue "Species code missing: ${col}" "collection_onboarding_gap" "${col} is governed but has no species_code in collection_registry" "$BASE_URL"
      C16=$((C16+1))
      continue
    fi
    local MAP_EXISTS
    MAP_EXISTS=$(run_pg "SELECT count(*) FROM species_collection_map WHERE collection_name = '${col}' AND species_code = '${SP_CODE}';")
    if [[ "${MAP_EXISTS:-0}" -eq 0 ]]; then
      log_warn "  ${col}: species mapping MISSING for ${SP_CODE} — auto-fixing..."
      run_pg "INSERT INTO species_collection_map (species_code, collection_name, is_primary) VALUES ('${SP_CODE}', '${col}', true) ON CONFLICT DO NOTHING;" 2>/dev/null && {
        log_ok "  FIXED: species mapping ${col} → ${SP_CODE}"
        FIXES=$((FIXES+1))
        log_system_issue "Species mapping missing: ${col}" "collection_onboarding_gap" "Auto-fixed species mapping ${col} → ${SP_CODE}" "$BASE_URL"
      }
      C16=$((C16+1))
    fi
  done <<< "$GOV_COLS"
  [[ "$C16" -gt 0 ]] && { log_warn "CHECK 16: ${C16} species gaps (auto-fixed where possible)"; ISSUES=$((ISSUES+1)); } || log_ok "CHECK 16 PASS"

  # === CHECK 17: No DELETE permission (Luật Bảo toàn) ===
  log_info "Check 17: No DELETE permission on governance collections..."
  local C17=0
  while IFS= read -r col; do
    [[ -z "$col" ]] && continue
    local DEL_COUNT
    DEL_COUNT=$(run_pg "SELECT count(*) FROM directus_permissions WHERE collection='${col}' AND action='delete';")
    if [[ "${DEL_COUNT:-0}" -gt 0 ]]; then
      log_warn "  ${col}: HAS ${DEL_COUNT} DELETE permissions — removing..."
      run_pg "DELETE FROM directus_permissions WHERE collection='${col}' AND action='delete';" 2>/dev/null && {
        log_ok "  FIXED: removed DELETE permissions from ${col}"
        FIXES=$((FIXES+1))
        log_system_issue "DELETE permission found: ${col}" "collection_onboarding_gap" "Removed DELETE permission from governed collection ${col}" "$BASE_URL"
      }
      C17=$((C17+1))
    fi
  done <<< "$GOV_COLS"
  [[ "$C17" -gt 0 ]] && { log_warn "CHECK 17: ${C17} collections had DELETE permissions (removed)"; ISSUES=$((ISSUES+1)); } || log_ok "CHECK 17 PASS"

  # === CHECK 13: compliance_pct calculation ===
  log_info "Check 13: Compliance percentage..."
  local TOTAL_COLS COMPLIANT
  TOTAL_COLS=$(echo "$COLLECTIONS" | grep -c '.' || echo "0")
  COMPLIANT=$((TOTAL_COLS - ISSUES))
  [[ "$COMPLIANT" -lt 0 ]] && COMPLIANT=0
  local PCT=0
  if [[ "$TOTAL_COLS" -gt 0 ]]; then
    PCT=$(echo "scale=1; 100 * $COMPLIANT / $TOTAL_COLS" | bc 2>/dev/null || echo "0")
  fi
  log_info "CHECK 13: Compliance ${PCT}% (${COMPLIANT}/${TOTAL_COLS} clean)"

  # Release lock
  run_pg "SELECT pg_advisory_unlock(${LOCK_ID});" > /dev/null 2>&1

  # Summary
  echo ""
  echo "========================================="
  echo "${CHECKS} checks, ${ISSUES} issue(s), ${FIXES} auto-fix(es), compliance ${PCT}%"
  if [[ "$ISSUES" -eq 0 ]]; then
    log_ok "ALL CHECKS PASS"
  else
    log_warn "${ISSUES} issue(s) — see details above"
    for I_TITLE in "tier-1 fields" "status mismatch" "orphan registry" "no birth" "no species" "no labels" "field_type conflict" "invalid group" "null group" "sync missing fields"; do
      :  # issues already logged inline
    done
  fi
  echo "========================================="
}

main "$@"
