#!/usr/bin/env bash
# =============================================================================
# dot-collection-create — 18-step collection creation protocol (Cấp B)
# =============================================================================
# VERSION: 2.0.0
# CHANGELOG:
#   v2.0.0 (2026-04-02): +Step 15-18: Auto FK constraints, permissions,
#     species mapping, birth trigger. Accepts --species-code, --governance-role.
#   v1.0.0 (2026-03-31): Full 14-step collection bootstrap
#
# Usage:
#   dot-collection-create --collection-name <name> --group <group> [--cloud|--local]
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/../config/environment.sh"

VERSION="2.0.0"

VPS_HOST="38.242.240.89"
VPS_KEY="${HOME}/.ssh/contabo_vps"
PG_CONTAINER="postgres"
PG_USER="directus"
PG_DB="directus"

COLLECTION_NAME=""
GROUP=""
SPECIES_CODE=""
GOVERNANCE_ROLE="governed"

log_info() { echo "[INFO] $1"; }
log_ok()   { echo "[OK]   $1"; }
log_warn() { echo "[WARN] $1"; }
log_err()  { echo "[ERR]  $1" >&2; }
log_step() { echo ""; echo "=== STEP $1: $2 ==="; }

show_help() {
  cat << EOF
dot-collection-create v${VERSION} — 14-step collection creation (Cấp B)

Usage:
  dot-collection-create --collection-name <name> --group <group> [options]

Options:
  --collection-name    Table name (e.g., my_table)
  --group              Atom group (e.g., CMS, LOG, REGISTRY, JUNCTION, SYSTEM)
  --species-code       Species code for birth mapping (required for governed)
  --governance-role    governed (default) or observed
EOF
  show_environment_help
}

run_pg() {
  local SQL="$1"
  if command -v docker &>/dev/null && docker ps --format '{{.Names}}' 2>/dev/null | grep -q "^${PG_CONTAINER}$"; then
    docker exec -i ${PG_CONTAINER} psql -U ${PG_USER} -d ${PG_DB} -t -A <<< "$SQL" 2>/dev/null
  else
    ssh -i "$VPS_KEY" -o ConnectTimeout=10 -o StrictHostKeyChecking=no "root@${VPS_HOST}" \
      "docker exec -i ${PG_CONTAINER} psql -U ${PG_USER} -d ${PG_DB} -t -A" <<< "$SQL" 2>/dev/null
  fi
}

api_call() {
  local METHOD="$1" ENDPOINT="$2" DATA="${3:-}"
  local ARGS=(-sS --globoff -k -X "$METHOD"
    "${DIRECTUS_URL}${ENDPOINT}"
    -H "Authorization: Bearer $DOT_TOKEN"
    -H "Content-Type: application/json")
  if [[ -n "$DATA" ]]; then
    ARGS+=(-d "$DATA")
  fi
  curl "${ARGS[@]}" 2>/dev/null
}

main() {
  local PASSTHROUGH_ARGS=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h) show_help; exit 0 ;;
      --collection-name) COLLECTION_NAME="$2"; shift 2 ;;
      --group) GROUP="$2"; shift 2 ;;
      --species-code) SPECIES_CODE="$2"; shift 2 ;;
      --governance-role) GOVERNANCE_ROLE="$2"; shift 2 ;;
      *) PASSTHROUGH_ARGS+=("$1"); shift ;;
    esac
  done

  if [[ -z "$COLLECTION_NAME" || -z "$GROUP" ]]; then
    log_err "Required: --collection-name and --group"
    show_help; exit 1
  fi

  init_environment "${PASSTHROUGH_ARGS[@]}"
  local BASE_URL="$DIRECTUS_URL"

  echo "========================================="
  echo "DOT Tool: Collection Create v${VERSION}"
  echo "Collection: ${COLLECTION_NAME}"
  echo "Group: ${GROUP}"
  echo "========================================="
  print_environment_banner "${PASSTHROUGH_ARGS[@]}"

  if [[ -z "${DOT_TOKEN:-}" ]]; then
    source "${SCRIPT_DIR}/dot-auth" "${PASSTHROUGH_ARGS[@]}"
  fi
  if [[ -z "${DOT_TOKEN:-}" ]]; then
    log_err "Authentication failed"; exit 1
  fi

  # Step 1: Check if table already exists
  log_step 1 "Pre-flight check"
  local EXISTS
  EXISTS=$(run_pg "SELECT count(*) FROM information_schema.tables WHERE table_name='${COLLECTION_NAME}' AND table_schema='public';")
  if [[ "${EXISTS:-0}" -gt 0 ]]; then
    log_err "Table '${COLLECTION_NAME}' already exists"; exit 1
  fi
  log_ok "Table does not exist — proceeding"

  # Step 2: CREATE TABLE with standard fields
  log_step 2 "CREATE TABLE"
  run_pg "
    CREATE TABLE ${COLLECTION_NAME} (
      id SERIAL PRIMARY KEY,
      status VARCHAR(20) DEFAULT 'draft',
      sort INTEGER,
      user_created UUID REFERENCES directus_users(id),
      date_created TIMESTAMPTZ DEFAULT NOW(),
      user_updated UUID REFERENCES directus_users(id),
      date_updated TIMESTAMPTZ DEFAULT NOW()
    );
  "
  log_ok "Table created"

  # Step 3: Register in Directus
  log_step 3 "Register in Directus"
  api_call POST "/collections" "$(jq -n \
    --arg col "$COLLECTION_NAME" \
    '{
      collection: $col,
      meta: {
        collection: $col,
        icon: "box",
        hidden: false,
        singleton: false
      },
      schema: {}
    }')" > /dev/null
  log_ok "Registered in Directus"

  # Step 4: Register system fields in Directus
  log_step 4 "Register system fields"
  for FIELD in status sort user_created date_created user_updated date_updated; do
    local FIELD_TYPE="string" INTERFACE="input"
    case "$FIELD" in
      status)       FIELD_TYPE="string"; INTERFACE="select-dropdown" ;;
      sort)         FIELD_TYPE="integer"; INTERFACE="input" ;;
      user_created) FIELD_TYPE="uuid"; INTERFACE="select-dropdown-m2o" ;;
      date_created) FIELD_TYPE="timestamp"; INTERFACE="datetime" ;;
      user_updated) FIELD_TYPE="uuid"; INTERFACE="select-dropdown-m2o" ;;
      date_updated) FIELD_TYPE="timestamp"; INTERFACE="datetime" ;;
    esac
    api_call POST "/fields/${COLLECTION_NAME}" "$(jq -n \
      --arg f "$FIELD" --arg ft "$FIELD_TYPE" --arg iface "$INTERFACE" \
      '{field: $f, type: $ft, meta: {interface: $iface}}')" > /dev/null 2>&1 || true
  done
  log_ok "System fields registered"

  # Step 5: meta_catalog entry
  log_step 5 "meta_catalog entry"
  api_call POST "/items/meta_catalog" "$(jq -n \
    --arg col "$COLLECTION_NAME" --arg grp "$GROUP" \
    '{
      registry_collection: $col,
      atom_group: $grp,
      record_count: 0,
      actual_count: 0,
      status: "active"
    }')" > /dev/null
  log_ok "meta_catalog entry created"

  # Step 6: Birth record
  log_step 6 "Birth record"
  api_call POST "/items/schema_birth_registry" "$(jq -n \
    --arg col "$COLLECTION_NAME" --arg src "dot-collection-create" \
    '{
      collection_name: $col,
      birth_source: $src,
      birth_type: "dot_created",
      born_at: (now | todate)
    }')" > /dev/null
  log_ok "Birth record created"

  # Step 7: Verify birth
  log_step 7 "Verify birth"
  local BIRTH
  BIRTH=$(run_pg "SELECT count(*) FROM schema_birth_registry WHERE collection_name='${COLLECTION_NAME}';")
  if [[ "${BIRTH:-0}" -gt 0 ]]; then
    log_ok "Birth verified"
  else
    log_warn "Birth record not found — manual check needed"
  fi

  # Step 8: Labels
  log_step 8 "Labels"
  api_call POST "/items/collection_labels" "$(jq -n \
    --arg col "$COLLECTION_NAME" --arg grp "$GROUP" \
    '{collection_name: $col, label: $grp, assigned_by: "dot-collection-create"}')" > /dev/null 2>&1 || true
  log_ok "Label assigned"

  # Step 9: Species
  log_step 9 "Species assignment"
  local SPECIES="data_table"
  case "$GROUP" in
    LOG)      SPECIES="log_table" ;;
    JUNCTION) SPECIES="junction_table" ;;
    SYSTEM)   SPECIES="system_table" ;;
    REGISTRY) SPECIES="registry_table" ;;
  esac
  api_call POST "/items/collection_species" "$(jq -n \
    --arg col "$COLLECTION_NAME" --arg sp "$SPECIES" \
    '{collection_name: $col, species: $sp}')" > /dev/null 2>&1 || true
  log_ok "Species: $SPECIES"

  # Step 10: Edges
  log_step 10 "Entity edges"
  api_call POST "/items/entity_dependencies" "$(jq -n \
    --arg col "$COLLECTION_NAME" \
    '{source_entity: $col, dependency_type: "self", status: "active"}')" > /dev/null 2>&1 || true
  log_ok "Self-edge created"

  # Step 11: Pivot
  log_step 11 "Cron pivot"
  log_info "Skipped — pivot setup is domain-specific"

  # Step 12: Group assignment
  log_step 12 "Group assignment"
  run_pg "
    UPDATE collection_registry SET \"group\" = '${GROUP}'
    WHERE collection_name = '${COLLECTION_NAME}';
  " > /dev/null 2>&1 || true
  log_ok "Group: $GROUP"

  # Step 13: Field standards check
  log_step 13 "Field standards"
  local STD_FIELDS
  STD_FIELDS=$(run_pg "
    SELECT field_name FROM collection_field_standards
    WHERE tier = 1 AND (applies_to_group IS NULL OR applies_to_group = '${GROUP}');
  ")
  if [[ -n "${STD_FIELDS:-}" ]]; then
    log_info "Tier-1 standard fields to verify: $(echo "$STD_FIELDS" | tr '\n' ', ')"
  else
    log_info "No tier-1 field standards defined"
  fi

  # Step 14: Health check
  log_step 14 "Post-creation health"
  local FINAL
  FINAL=$(run_pg "SELECT count(*) FROM information_schema.tables WHERE table_name='${COLLECTION_NAME}' AND table_schema='public';")
  if [[ "${FINAL:-0}" -gt 0 ]]; then
    log_ok "Table exists in PG"
  else
    log_err "Table NOT found in PG!"; exit 1
  fi
  local MC
  MC=$(run_pg "SELECT count(*) FROM meta_catalog WHERE registry_collection='${COLLECTION_NAME}';")
  log_ok "meta_catalog entry: ${MC:-0}"

  # Step 15: Auto FK constraints
  log_step 15 "Auto FK constraints"
  local FK_FIELDS
  FK_FIELDS=$(curl -sS --globoff -k -X GET \
    "${BASE_URL}/fields/${COLLECTION_NAME}" \
    -H "Authorization: Bearer $DOT_TOKEN" 2>/dev/null | jq -r '.data[] | select(.schema.foreign_key_table != null) | "\(.field)|\(.schema.foreign_key_table)|\(.schema.foreign_key_column)"' 2>/dev/null)
  local FK_COUNT=0
  while IFS='|' read -r fld fk_table fk_col; do
    [[ -z "$fld" ]] && continue
    local FK_EXISTS
    FK_EXISTS=$(run_pg "SELECT count(*) FROM information_schema.table_constraints tc JOIN information_schema.key_column_usage kcu ON tc.constraint_name=kcu.constraint_name JOIN information_schema.constraint_column_usage ccu ON tc.constraint_name=ccu.constraint_name WHERE tc.constraint_type='FOREIGN KEY' AND tc.table_name='${COLLECTION_NAME}' AND kcu.column_name='${fld}';")
    if [[ "${FK_EXISTS:-0}" -eq 0 ]]; then
      run_pg "ALTER TABLE ${COLLECTION_NAME} ADD CONSTRAINT fk_${COLLECTION_NAME}_${fld} FOREIGN KEY (${fld}) REFERENCES ${fk_table}(${fk_col}) ON DELETE RESTRICT;" 2>/dev/null && FK_COUNT=$((FK_COUNT+1))
    fi
  done <<< "$FK_FIELDS"
  log_ok "FK constraints: ${FK_COUNT} created"

  # Step 16: Auto permissions
  log_step 16 "Auto permissions"
  local AI_POL AGENT_POL PL_POL PA_POL ED_POL
  AI_POL=$(run_pg "SELECT id FROM directus_policies WHERE name='AI Agent Policy' LIMIT 1;")
  AGENT_POL=$(run_pg "SELECT id FROM directus_policies WHERE name='Agent Policy' LIMIT 1;")
  PL_POL=$(run_pg "SELECT id FROM directus_policies WHERE name='\$t:public_label' LIMIT 1;")
  PA_POL=$(run_pg "SELECT id FROM directus_policies WHERE name='Public Access' LIMIT 1;")
  ED_POL=$(run_pg "SELECT id FROM directus_policies WHERE name='Editor Policy' LIMIT 1;")
  local PERM_COUNT=0
  # Read for all policies
  for POL_ID in "$PL_POL" "$PA_POL" "$ED_POL" "$AI_POL" "$AGENT_POL"; do
    [[ -z "$POL_ID" ]] && continue
    local HAS
    HAS=$(run_pg "SELECT count(*) FROM directus_permissions WHERE collection='${COLLECTION_NAME}' AND action='read' AND policy='${POL_ID}';")
    if [[ "${HAS:-0}" -eq 0 ]]; then
      run_pg "INSERT INTO directus_permissions (collection,action,permissions,fields,policy) VALUES ('${COLLECTION_NAME}','read','{}','{\"*\"}','${POL_ID}');" 2>/dev/null && PERM_COUNT=$((PERM_COUNT+1))
    fi
  done
  # Create for agent policies
  for POL_ID in "$AI_POL" "$AGENT_POL"; do
    [[ -z "$POL_ID" ]] && continue
    local HAS
    HAS=$(run_pg "SELECT count(*) FROM directus_permissions WHERE collection='${COLLECTION_NAME}' AND action='create' AND policy='${POL_ID}';")
    if [[ "${HAS:-0}" -eq 0 ]]; then
      run_pg "INSERT INTO directus_permissions (collection,action,permissions,fields,policy) VALUES ('${COLLECTION_NAME}','create','{}','{\"*\"}','${POL_ID}');" 2>/dev/null && PERM_COUNT=$((PERM_COUNT+1))
    fi
  done
  # Update for agent policies IF governed
  if [[ "$GOVERNANCE_ROLE" == "governed" ]]; then
    for POL_ID in "$AI_POL" "$AGENT_POL"; do
      [[ -z "$POL_ID" ]] && continue
      local HAS
      HAS=$(run_pg "SELECT count(*) FROM directus_permissions WHERE collection='${COLLECTION_NAME}' AND action='update' AND policy='${POL_ID}';")
      if [[ "${HAS:-0}" -eq 0 ]]; then
        run_pg "INSERT INTO directus_permissions (collection,action,permissions,fields,policy) VALUES ('${COLLECTION_NAME}','update','{}','{\"*\"}','${POL_ID}');" 2>/dev/null && PERM_COUNT=$((PERM_COUNT+1))
      fi
    done
  fi
  log_ok "Permissions: ${PERM_COUNT} created (NO DELETE)"

  # Step 17: Auto species mapping
  log_step 17 "Species mapping"
  if [[ -n "$SPECIES_CODE" ]]; then
    # Update collection_registry with species_code
    run_pg "UPDATE collection_registry SET species_code='${SPECIES_CODE}' WHERE collection_name='${COLLECTION_NAME}';" 2>/dev/null
    local MAP_EXISTS
    MAP_EXISTS=$(run_pg "SELECT count(*) FROM species_collection_map WHERE collection_name='${COLLECTION_NAME}' AND species_code='${SPECIES_CODE}';")
    if [[ "${MAP_EXISTS:-0}" -eq 0 ]]; then
      run_pg "INSERT INTO species_collection_map (species_code, collection_name, is_primary) VALUES ('${SPECIES_CODE}','${COLLECTION_NAME}',true) ON CONFLICT DO NOTHING;" 2>/dev/null
      log_ok "Species mapped: ${SPECIES_CODE}"
    else
      log_ok "Species mapping already exists"
    fi
  else
    if [[ "$GOVERNANCE_ROLE" == "governed" ]]; then
      log_warn "No --species-code provided for governed collection!"
    else
      log_info "No species-code (observed collection — OK)"
    fi
  fi

  # Step 18: Birth trigger
  log_step 18 "Birth trigger setup"
  if [[ -x "${SCRIPT_DIR}/dot-birth-trigger-setup" ]]; then
    "${SCRIPT_DIR}/dot-birth-trigger-setup" "${PASSTHROUGH_ARGS[@]}" 2>/dev/null || true
    log_ok "Birth trigger setup ran"
  else
    log_info "dot-birth-trigger-setup not found — skipping"
  fi

  echo ""
  echo "========================================="
  log_ok "18-step protocol complete for '${COLLECTION_NAME}'"
  echo "========================================="
}

main "$@"
