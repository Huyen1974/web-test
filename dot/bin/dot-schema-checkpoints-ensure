#!/usr/bin/env bash
# =============================================================================
# dot-schema-checkpoints-ensure - Ensure task_checkpoints collection in Directus
# =============================================================================
# VERSION: 1.0.0
# CHANGELOG:
#   v1.0.0 (2026-03-03): Initial version for M-001 v2 Checkpoint 3 tầng
#     - task_checkpoints: 7 fields (task_id, checkpoint_key, layer, status, etc.)
#     - Relations: task_id M2O -> tasks, comment_id M2O -> task_comments
#     - Idempotent: checks existence before create, patches missing fields
#     - Based on dot-schema-tasks-ensure pattern
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOT_AUTH="${SCRIPT_DIR}/dot-auth"

# Source environment configuration
source "${SCRIPT_DIR}/../config/environment.sh"

VERSION="1.0.0"
COLLECTION="task_checkpoints"

# Logging
log_info() { echo "[INFO] $1"; }
log_ok()   { echo "[OK]   $1"; }
log_warn() { echo "[WARN] $1"; }
log_skip() { echo "[SKIP] $1"; }
log_err()  { echo "[ERR]  $1" >&2; }

require_cmds() {
  for cmd in curl jq; do
    command -v "$cmd" >/dev/null 2>&1 || { log_err "Missing required command: $cmd"; exit 1; }
  done
}

api_request() {
  local method="$1" url="$2" data="${3-}"
  if [[ -n "${data-}" ]]; then
    curl -sS --globoff -X "$method" "$url" \
      -H "Authorization: Bearer $DOT_TOKEN" \
      -H "Content-Type: application/json" \
      -d "$data" -w "\n%{http_code}"
  else
    curl -sS --globoff -X "$method" "$url" \
      -H "Authorization: Bearer $DOT_TOKEN" \
      -w "\n%{http_code}"
  fi
}

# Required fields list (for verification)
REQUIRED_FIELDS=(task_id checkpoint_key layer status verified_by comment_id date_created date_updated)

field_payload() {
  case "$1" in
    task_id)
      cat <<'JSON'
{"field":"task_id","type":"integer","meta":{"required":true,"interface":"select-dropdown-m2o","special":["m2o"],"width":"half","note":"FK -> tasks (required)"},"schema":{"is_nullable":false}}
JSON
      ;;
    checkpoint_key)
      cat <<'JSON'
{"field":"checkpoint_key","type":"string","meta":{"required":true,"interface":"input","width":"half","note":"e.g. L0_ci_green, L1_code_review"},"schema":{"is_nullable":false}}
JSON
      ;;
    layer)
      cat <<'JSON'
{"field":"layer","type":"string","meta":{"required":true,"interface":"select-dropdown","options":{"choices":[{"text":"L0 - Universal","value":"L0"},{"text":"L1 - Domain","value":"L1"},{"text":"L2 - Custom","value":"L2"}]},"width":"half","note":"Checkpoint layer: L0/L1/L2"},"schema":{"is_nullable":false}}
JSON
      ;;
    status)
      cat <<'JSON'
{"field":"status","type":"string","meta":{"required":true,"interface":"select-dropdown","options":{"choices":[{"text":"Pending","value":"pending"},{"text":"Passed","value":"passed"},{"text":"Failed","value":"failed"},{"text":"Skipped","value":"skipped"}]},"width":"half","note":"Checkpoint status"},"schema":{"is_nullable":false,"default_value":"pending"}}
JSON
      ;;
    verified_by)
      cat <<'JSON'
{"field":"verified_by","type":"string","meta":{"required":false,"interface":"input","width":"half","note":"agent_type or 'user'"},"schema":{"is_nullable":true}}
JSON
      ;;
    comment_id)
      cat <<'JSON'
{"field":"comment_id","type":"integer","meta":{"required":false,"interface":"select-dropdown-m2o","special":["m2o"],"width":"half","note":"FK -> task_comments"},"schema":{"is_nullable":true}}
JSON
      ;;
    date_created)
      cat <<'JSON'
{"field":"date_created","type":"timestamp","meta":{"interface":"datetime","special":["date-created"],"readonly":true,"width":"half"},"schema":{"is_nullable":false}}
JSON
      ;;
    date_updated)
      cat <<'JSON'
{"field":"date_updated","type":"timestamp","meta":{"interface":"datetime","special":["date-updated"],"readonly":true,"width":"half"},"schema":{"is_nullable":true}}
JSON
      ;;
    *) return 1 ;;
  esac
}

collection_exists() {
  local resp body code
  resp=$(api_request GET "${BASE_URL}/collections/${COLLECTION}")
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"
  [[ "$code" == "200" ]]
}

field_exists() {
  local field_name="$1"
  local resp body code
  resp=$(api_request GET "${BASE_URL}/fields/${COLLECTION}")
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"
  if [[ "$code" == "200" ]]; then
    echo "$body" | jq -e --arg field "$field_name" '.data[]? | select(.field == $field)' >/dev/null 2>&1
    return $?
  fi
  return 1
}

create_collection() {
  local payload
  payload=$(jq -nc \
    --arg collection "$COLLECTION" \
    '{
      collection: $collection,
      schema: {},
      meta: {
        collection: $collection,
        icon: "verified",
        note: "Task checkpoints for M-001 v2 (L0/L1/L2) - Created by DOT v1.0.0",
        display_template: "{{checkpoint_key}} [{{layer}}] {{status}}",
        sort_field: "date_created"
      }
    }')

  log_info "Creating collection ${COLLECTION}"
  local resp body code
  resp=$(api_request POST "${BASE_URL}/collections" "$payload")
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"

  if [[ "$code" != "200" ]]; then
    log_err "Failed to create collection ${COLLECTION} (HTTP $code)"
    echo "$body" | head -c 300 >&2
    exit 1
  fi
  log_ok "Collection ${COLLECTION} created"
}

create_field() {
  local field_name="$1"
  local payload resp body code
  payload=$(field_payload "$field_name")

  log_info "Creating field ${COLLECTION}.${field_name}"
  resp=$(api_request POST "${BASE_URL}/fields/${COLLECTION}" "$payload")
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"

  if [[ "$code" != "200" ]]; then
    log_err "Failed to create field ${COLLECTION}.${field_name} (HTTP $code)"
    echo "$body" | head -c 200 >&2
    exit 1
  fi
  log_ok "Field ${COLLECTION}.${field_name} created"
}

setup_relations() {
  log_info "Setting up relations..."

  # task_checkpoints.task_id -> tasks (CASCADE delete)
  local task_relation
  task_relation=$(jq -nc '{
    collection: "task_checkpoints",
    field: "task_id",
    related_collection: "tasks",
    meta: {
      one_field: "checkpoints",
      sort_field: null,
      one_deselect_action: "nullify"
    },
    schema: {
      on_delete: "CASCADE"
    }
  }')

  local resp code
  resp=$(api_request POST "${BASE_URL}/relations" "$task_relation")
  code="${resp##*$'\n'}"

  if [[ "$code" == "200" ]]; then
    log_ok "Relation task_checkpoints.task_id -> tasks created (CASCADE)"
  elif [[ "$code" == "400" ]]; then
    log_skip "Relation task_checkpoints.task_id -> tasks already exists"
  else
    log_warn "Could not create task_id relation (HTTP $code)"
  fi

  # task_checkpoints.comment_id -> task_comments (SET NULL)
  local comment_relation
  comment_relation=$(jq -nc '{
    collection: "task_checkpoints",
    field: "comment_id",
    related_collection: "task_comments",
    meta: {
      one_field: null,
      sort_field: null,
      one_deselect_action: "nullify"
    },
    schema: {
      on_delete: "SET NULL"
    }
  }')

  resp=$(api_request POST "${BASE_URL}/relations" "$comment_relation")
  code="${resp##*$'\n'}"

  if [[ "$code" == "200" ]]; then
    log_ok "Relation task_checkpoints.comment_id -> task_comments created (SET NULL)"
  elif [[ "$code" == "400" ]]; then
    log_skip "Relation task_checkpoints.comment_id -> task_comments already exists"
  else
    log_warn "Could not create comment_id relation (HTTP $code)"
  fi
}

verify_fields() {
  local resp body code missing=()
  resp=$(api_request GET "${BASE_URL}/fields/${COLLECTION}")
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"

  if [[ "$code" != "200" ]]; then
    log_err "Failed to list fields for ${COLLECTION} (HTTP $code)"
    exit 1
  fi

  local field_count
  field_count=$(echo "$body" | jq '.data | length')

  for field in "${REQUIRED_FIELDS[@]}"; do
    if ! echo "$body" | jq -e --arg field "$field" '.data[]? | select(.field == $field)' >/dev/null 2>&1; then
      missing+=("$field")
    fi
  done

  if [[ "${#missing[@]}" -gt 0 ]]; then
    log_err "Missing required fields: ${missing[*]}"
    exit 1
  fi

  log_ok "${COLLECTION}: All required fields present (${field_count} total)"
}

show_help() {
  cat << EOF
dot-schema-checkpoints-ensure v${VERSION} - Ensure task_checkpoints collection

Usage:
  dot-schema-checkpoints-ensure [options]

Options:
  --local       Use local development environment
  --cloud       Use cloud/production environment (default)
  --dry-run     Show what would be done without making changes
  --help, -h    Show this help message

Collection: task_checkpoints (8 fields)
  - task_id          M2O -> tasks (CASCADE delete, required)
  - checkpoint_key   e.g. L0_ci_green, L1_code_review (required)
  - layer            L0|L1|L2 (required)
  - status           pending|passed|failed|skipped (default: pending)
  - verified_by      agent_type or "user" (nullable)
  - comment_id       M2O -> task_comments (SET NULL)
  - date_created     Auto: creation timestamp
  - date_updated     Auto: update timestamp

EOF
  show_environment_help
}

main() {
  local DRY_RUN=false

  for arg in "$@"; do
    case "$arg" in
      --help|-h) show_help; exit 0 ;;
      --dry-run) DRY_RUN=true ;;
    esac
  done

  require_cmds
  init_environment "$@"
  BASE_URL="$DIRECTUS_URL"

  echo "========================================="
  echo "DOT Tool: Schema Checkpoints Ensure v${VERSION}"
  echo "========================================="
  print_environment_banner "$@"
  echo "Ensuring task_checkpoints collection for M-001 v2"
  echo ""

  if [[ "$DRY_RUN" == "true" ]]; then
    log_warn "DRY RUN MODE - No changes will be made"
    echo ""
  fi

  # Authentication
  if [[ -z "${DOT_TOKEN:-}" ]]; then
    if [[ ! -f "$DOT_AUTH" ]]; then
      log_err "dot-auth not found at ${DOT_AUTH}"
      exit 1
    fi
    log_info "Authenticating with Directus..."
    source "$DOT_AUTH" "$@"
  fi

  if [[ -z "${DOT_TOKEN:-}" ]]; then
    log_err "DOT_TOKEN is empty after authentication"
    exit 1
  fi

  # === COLLECTION: task_checkpoints ===
  echo ""
  echo "--- Collection: ${COLLECTION} ---"

  if collection_exists; then
    log_skip "Collection '${COLLECTION}' already exists"
  else
    if [[ "$DRY_RUN" == "true" ]]; then
      log_info "Would create collection '${COLLECTION}'"
    else
      create_collection
    fi
  fi

  # === FIELDS ===
  log_info "Ensuring required fields..."
  for field in "${REQUIRED_FIELDS[@]}"; do
    if field_exists "$field"; then
      log_skip "Field ${COLLECTION}.${field} already exists"
    else
      if [[ "$DRY_RUN" == "true" ]]; then
        log_info "Would create field ${COLLECTION}.${field}"
      else
        create_field "$field"
      fi
    fi
  done

  # === RELATIONS ===
  echo ""
  if [[ "$DRY_RUN" != "true" ]]; then
    setup_relations
  else
    log_info "Would create relation task_checkpoints.task_id -> tasks"
    log_info "Would create relation task_checkpoints.comment_id -> task_comments"
  fi

  # === VERIFICATION ===
  echo ""
  if [[ "$DRY_RUN" != "true" ]]; then
    log_info "Running final verification..."
    if ! collection_exists; then
      log_err "Collection ${COLLECTION} missing after ensure"
      exit 1
    fi
    verify_fields
  fi

  log_ok "Collection task_checkpoints ready"
  echo ""
  echo "========================================="
  echo "DOT Tool: Schema Checkpoints Ensure - COMPLETE"
  echo "========================================="
}

main "$@"
