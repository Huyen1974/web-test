#!/usr/bin/env bash
# =============================================================================
# dot-schema-meta-catalog-add-baseline — Thêm field baseline_count vào meta_catalog
# =============================================================================
# CHECKED-NO-DUPLICATE: [searched dot/bin/ for "baseline" — no match]
# VERSION: 1.0.0
#
# Thêm field baseline_count (integer, default 0) vào collection meta_catalog.
# Idempotent: bỏ qua nếu field đã tồn tại.
#
# Usage:
#   dot-schema-meta-catalog-add-baseline [--cloud|--local] [--dry-run]
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/../config/environment.sh"

VERSION="1.0.0"
DRY_RUN=""

for arg in "$@"; do
  case "$arg" in
    --dry-run) DRY_RUN="yes" ;;
    --help|-h)
      head -12 "$0" | tail -10
      show_environment_help
      exit 0
      ;;
  esac
done

init_environment "$@"

echo ""
echo "═══════════════════════════════════════════════════════════"
echo "  Thêm baseline_count vào meta_catalog v${VERSION}"
echo "═══════════════════════════════════════════════════════════"
print_environment_banner "$@"

TOKEN="${DIRECTUS_TOKEN:-}"
if [[ -z "$TOKEN" ]]; then
  echo -e "${RED}[LỖI]${NC} Không thể xác thực với Directus" >&2
  exit 1
fi

# Check if field already exists
HTTP_CODE=$(curl -sS -o /dev/null -w "%{http_code}" \
  "${DIRECTUS_URL}/fields/meta_catalog/baseline_count" \
  -H "Authorization: Bearer $TOKEN")

if [[ "$HTTP_CODE" == "200" ]]; then
  echo "[SKIP] Field baseline_count đã tồn tại"
  exit 0
fi

echo "[INFO] Field baseline_count chưa tồn tại, tạo mới..."

if [[ "$DRY_RUN" == "yes" ]]; then
  echo "[DRY] Sẽ tạo field baseline_count (integer, default 0)"
  exit 0
fi

PAYLOAD=$(cat <<'JSON'
{
  "field": "baseline_count",
  "type": "integer",
  "schema": {
    "default_value": 0,
    "is_nullable": true
  },
  "meta": {
    "interface": "input",
    "display": "raw",
    "note": "Số lượng gốc tại thời điểm bắt đầu kiểm chứng ngược (baseline snapshot)",
    "width": "half",
    "sort": 18,
    "group": null,
    "hidden": false,
    "options": {
      "min": 0
    }
  }
}
JSON
)

RESPONSE=$(curl -sS -w "\n%{http_code}" \
  -X POST "${DIRECTUS_URL}/fields/meta_catalog" \
  -H "Authorization: Bearer $TOKEN" \
  -H "Content-Type: application/json" \
  -d "$PAYLOAD")

HTTP_CODE=$(echo "$RESPONSE" | tail -1)
BODY=$(echo "$RESPONSE" | sed '$d')

if [[ "$HTTP_CODE" == "200" ]] || [[ "$HTTP_CODE" == "204" ]]; then
  echo "[OK] Field baseline_count đã tạo thành công"
else
  echo "[ERR] HTTP $HTTP_CODE: $BODY" >&2
  exit 1
fi

echo ""
echo "═══════════════════════════════════════════════════════════"
echo "  Thêm baseline_count — HOÀN THÀNH"
echo "═══════════════════════════════════════════════════════════"
