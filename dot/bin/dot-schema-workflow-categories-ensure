#!/usr/bin/env bash
# =============================================================================
# dot-schema-workflow-categories-ensure - Ensure workflow_categories collection
# =============================================================================
# VERSION: 1.0.0
# CHANGELOG:
#   v1.0.0 (2026-03-04): Initial — 3-level category hierarchy for workflows
#     - workflow_categories: name, code, level, parent_id (self M2O), sort, status, description
#     - Adds category_id M2O field to workflows collection
#     - Seeds one sample branch (3 levels)
#     - Idempotent: checks existence before create
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOT_AUTH="${SCRIPT_DIR}/dot-auth"

# Source environment configuration
source "${SCRIPT_DIR}/../config/environment.sh"

VERSION="1.0.0"
COLLECTION="workflow_categories"

# Logging
log_info() { echo "[INFO] $1"; }
log_ok()   { echo "[OK]   $1"; }
log_warn() { echo "[WARN] $1"; }
log_skip() { echo "[SKIP] $1"; }
log_err()  { echo "[ERR]  $1" >&2; }

require_cmds() {
  for cmd in curl jq; do
    command -v "$cmd" >/dev/null 2>&1 || { log_err "Missing required command: $cmd"; exit 1; }
  done
}

api_request() {
  local method="$1" url="$2" data="${3-}"
  if [[ -n "${data-}" ]]; then
    curl -sS --globoff -X "$method" "$url" \
      -H "Authorization: Bearer $DOT_TOKEN" \
      -H "Content-Type: application/json" \
      -d "$data" -w "\n%{http_code}"
  else
    curl -sS --globoff -X "$method" "$url" \
      -H "Authorization: Bearer $DOT_TOKEN" \
      -w "\n%{http_code}"
  fi
}

REQUIRED_FIELDS=(name code level parent_id sort status description user_created date_created date_updated)

field_payload() {
  case "$1" in
    name)
      cat <<'JSON'
{"field":"name","type":"string","meta":{"required":true,"interface":"input","width":"full","note":"Category name"},"schema":{"is_nullable":false}}
JSON
      ;;
    code)
      cat <<'JSON'
{"field":"code","type":"string","meta":{"required":true,"interface":"input","width":"half","note":"Unique category code e.g. C1-HR, C2-HR-RECRUIT"},"schema":{"is_nullable":false,"is_unique":true}}
JSON
      ;;
    level)
      cat <<'JSON'
{"field":"level","type":"integer","meta":{"required":true,"interface":"select-dropdown","options":{"choices":[{"text":"1 — Cap cao nhat","value":1},{"text":"2 — Cap trung","value":2},{"text":"3 — Cap thap nhat","value":3}]},"width":"half","note":"Hierarchy level: 1=highest, 3=lowest"},"schema":{"is_nullable":false,"default_value":1}}
JSON
      ;;
    parent_id)
      cat <<'JSON'
{"field":"parent_id","type":"integer","meta":{"required":false,"interface":"select-dropdown-m2o","special":["m2o"],"width":"half","note":"FK self -> workflow_categories.id"},"schema":{"is_nullable":true}}
JSON
      ;;
    sort)
      cat <<'JSON'
{"field":"sort","type":"integer","meta":{"required":false,"interface":"input","width":"half","note":"Display order"},"schema":{"is_nullable":true}}
JSON
      ;;
    status)
      cat <<'JSON'
{"field":"status","type":"string","meta":{"required":true,"interface":"select-dropdown","options":{"choices":[{"text":"Published","value":"published"},{"text":"Draft","value":"draft"},{"text":"Archived","value":"archived"}]},"width":"half","note":"Category status"},"schema":{"is_nullable":false,"default_value":"published"}}
JSON
      ;;
    description)
      cat <<'JSON'
{"field":"description","type":"text","meta":{"required":false,"interface":"input-multiline","width":"full","note":"Category description"},"schema":{"is_nullable":true}}
JSON
      ;;
    user_created)
      cat <<'JSON'
{"field":"user_created","type":"uuid","meta":{"interface":"select-dropdown-m2o","special":["user-created"],"readonly":true,"hidden":true},"schema":{"foreign_key_table":"directus_users","foreign_key_column":"id"}}
JSON
      ;;
    date_created)
      cat <<'JSON'
{"field":"date_created","type":"timestamp","meta":{"interface":"datetime","special":["date-created"],"readonly":true,"width":"half"},"schema":{"is_nullable":false}}
JSON
      ;;
    date_updated)
      cat <<'JSON'
{"field":"date_updated","type":"timestamp","meta":{"interface":"datetime","special":["date-updated"],"readonly":true,"width":"half"},"schema":{"is_nullable":true}}
JSON
      ;;
    *) return 1 ;;
  esac
}

collection_exists() {
  local resp code
  resp=$(api_request GET "${BASE_URL}/collections/${COLLECTION}")
  code="${resp##*$'\n'}"
  [[ "$code" == "200" ]]
}

field_exists() {
  local field_name="$1" collection="${2:-$COLLECTION}"
  local resp body code
  resp=$(api_request GET "${BASE_URL}/fields/${collection}")
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"
  if [[ "$code" == "200" ]]; then
    echo "$body" | jq -e --arg field "$field_name" '.data[]? | select(.field == $field)' >/dev/null 2>&1
    return $?
  fi
  return 1
}

create_collection() {
  local payload
  payload=$(jq -nc \
    --arg collection "$COLLECTION" \
    '{
      collection: $collection,
      schema: {},
      meta: {
        collection: $collection,
        icon: "category",
        note: "3-level workflow category hierarchy (DOT v1.0.0)",
        display_template: "{{code}} {{name}}",
        sort_field: "sort"
      }
    }')

  log_info "Creating collection ${COLLECTION}"
  local resp body code
  resp=$(api_request POST "${BASE_URL}/collections" "$payload")
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"

  if [[ "$code" != "200" ]]; then
    log_err "Failed to create collection ${COLLECTION} (HTTP $code)"
    echo "$body" | head -c 300 >&2
    exit 1
  fi
  log_ok "Collection ${COLLECTION} created"
}

create_field() {
  local field_name="$1" collection="${2:-$COLLECTION}"
  local payload resp body code
  payload=$(field_payload "$field_name")

  log_info "Creating field ${collection}.${field_name}"
  resp=$(api_request POST "${BASE_URL}/fields/${collection}" "$payload")
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"

  if [[ "$code" != "200" ]]; then
    log_err "Failed to create field ${collection}.${field_name} (HTTP $code)"
    echo "$body" | head -c 200 >&2
    exit 1
  fi
  log_ok "Field ${collection}.${field_name} created"
}

setup_relations() {
  log_info "Setting up relations..."

  # workflow_categories.parent_id -> workflow_categories (self M2O, SET NULL)
  local relation_payload
  relation_payload=$(jq -nc '{
    collection: "workflow_categories",
    field: "parent_id",
    related_collection: "workflow_categories",
    meta: {
      one_field: "children",
      sort_field: "sort",
      one_deselect_action: "nullify"
    },
    schema: {
      on_delete: "SET NULL"
    }
  }')

  local resp code
  resp=$(api_request POST "${BASE_URL}/relations" "$relation_payload")
  code="${resp##*$'\n'}"

  if [[ "$code" == "200" ]]; then
    log_ok "Relation workflow_categories.parent_id -> workflow_categories created"
  elif [[ "$code" == "400" ]]; then
    log_skip "Relation workflow_categories.parent_id already exists"
  else
    log_warn "Could not create parent_id relation (HTTP $code)"
  fi
}

ensure_category_id_on_workflows() {
  log_info "Ensuring category_id field on workflows..."

  if field_exists "category_id" "workflows"; then
    log_skip "Field workflows.category_id already exists"
  else
    local payload
    payload=$(cat <<'JSON'
{"field":"category_id","type":"integer","meta":{"required":false,"interface":"select-dropdown-m2o","special":["m2o"],"width":"half","note":"FK -> workflow_categories.id (level 3 category)"},"schema":{"is_nullable":true}}
JSON
    )

    log_info "Creating field workflows.category_id"
    local resp body code
    resp=$(api_request POST "${BASE_URL}/fields/workflows" "$payload")
    body="${resp%$'\n'*}"
    code="${resp##*$'\n'}"

    if [[ "$code" != "200" ]]; then
      log_err "Failed to create workflows.category_id (HTTP $code)"
      echo "$body" | head -c 200 >&2
      exit 1
    fi
    log_ok "Field workflows.category_id created"
  fi

  # Relation: workflows.category_id -> workflow_categories
  local relation_payload
  relation_payload=$(jq -nc '{
    collection: "workflows",
    field: "category_id",
    related_collection: "workflow_categories",
    meta: {
      one_field: "workflows",
      sort_field: null,
      one_deselect_action: "nullify"
    },
    schema: {
      on_delete: "SET NULL"
    }
  }')

  local resp code
  resp=$(api_request POST "${BASE_URL}/relations" "$relation_payload")
  code="${resp##*$'\n'}"

  if [[ "$code" == "200" ]]; then
    log_ok "Relation workflows.category_id -> workflow_categories created"
  elif [[ "$code" == "400" ]]; then
    log_skip "Relation workflows.category_id already exists"
  else
    log_warn "Could not create category_id relation (HTTP $code)"
  fi
}

seed_sample_data() {
  log_info "Seeding sample category branch..."

  # Check if data already exists
  local resp body code
  resp=$(api_request GET "${BASE_URL}/items/${COLLECTION}?filter[code][_eq]=C1-GEN&limit=1")
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"

  if [[ "$code" == "200" ]]; then
    local existing
    existing=$(echo "$body" | jq '.data | length')
    if [[ "$existing" -gt 0 ]]; then
      log_skip "Sample data already exists (C1-GEN found)"
      return
    fi
  fi

  # Level 1
  resp=$(api_request POST "${BASE_URL}/items/${COLLECTION}" \
    '{"name":"Quan ly chung","code":"C1-GEN","level":1,"parent_id":null,"sort":1,"status":"published","description":"Nhom quy trinh quan ly chung"}')
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"
  if [[ "$code" != "200" ]]; then
    log_err "Failed to seed level 1 (HTTP $code)"
    return
  fi
  local c1_id
  c1_id=$(echo "$body" | jq '.data.id')
  log_ok "Level 1: C1-GEN (id=$c1_id)"

  # Level 2
  resp=$(api_request POST "${BASE_URL}/items/${COLLECTION}" \
    "{\"name\":\"Quy trinh noi bo\",\"code\":\"C2-GEN-INT\",\"level\":2,\"parent_id\":${c1_id},\"sort\":1,\"status\":\"published\",\"description\":\"Nhom quy trinh noi bo cua Quan ly chung\"}")
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"
  if [[ "$code" != "200" ]]; then
    log_err "Failed to seed level 2 (HTTP $code)"
    return
  fi
  local c2_id
  c2_id=$(echo "$body" | jq '.data.id')
  log_ok "Level 2: C2-GEN-INT (id=$c2_id)"

  # Level 3
  resp=$(api_request POST "${BASE_URL}/items/${COLLECTION}" \
    "{\"name\":\"De xuat thay doi quy trinh\",\"code\":\"C3-GEN-INT-WCR\",\"level\":3,\"parent_id\":${c2_id},\"sort\":1,\"status\":\"published\",\"description\":\"Quy trinh xu ly Workflow Change Request\"}")
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"
  if [[ "$code" != "200" ]]; then
    log_err "Failed to seed level 3 (HTTP $code)"
    return
  fi
  local c3_id
  c3_id=$(echo "$body" | jq '.data.id')
  log_ok "Level 3: C3-GEN-INT-WCR (id=$c3_id)"

  # Assign workflow #1 -> category_id = level 3
  log_info "Assigning workflow #1 -> category_id=${c3_id}..."
  resp=$(api_request PATCH "${BASE_URL}/items/workflows/1" "{\"category_id\":${c3_id}}")
  code="${resp##*$'\n'}"
  if [[ "$code" == "200" ]]; then
    log_ok "Workflow #1 assigned to category C3-GEN-INT-WCR"
  else
    log_warn "Could not assign workflow #1 (HTTP $code) — may not exist"
  fi
}

verify_fields() {
  local resp body code missing=()
  resp=$(api_request GET "${BASE_URL}/fields/${COLLECTION}")
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"

  if [[ "$code" != "200" ]]; then
    log_err "Failed to list fields for ${COLLECTION} (HTTP $code)"
    exit 1
  fi

  local field_count
  field_count=$(echo "$body" | jq '.data | length')

  for field in "${REQUIRED_FIELDS[@]}"; do
    if ! echo "$body" | jq -e --arg field "$field" '.data[]? | select(.field == $field)' >/dev/null 2>&1; then
      missing+=("$field")
    fi
  done

  if [[ "${#missing[@]}" -gt 0 ]]; then
    log_err "Missing required fields: ${missing[*]}"
    exit 1
  fi

  log_ok "${COLLECTION}: All required fields present (${field_count} total)"
}

show_help() {
  cat << EOF
dot-schema-workflow-categories-ensure v${VERSION} - Ensure workflow_categories collection

Usage:
  dot-schema-workflow-categories-ensure [options]

Options:
  --local       Use local development environment
  --cloud       Use cloud/production environment (default)
  --dry-run     Show what would be done without making changes
  --no-seed     Skip seeding sample data
  --help, -h    Show this help message

Collection: workflow_categories (10 fields)
  - name          Category name (required)
  - code          Unique category code (required)
  - level         Hierarchy level 1/2/3 (required)
  - parent_id     Self M2O -> workflow_categories (nullable)
  - sort          Display order
  - status        published|draft|archived (default: published)
  - description   Category description (nullable)
  - user_created  Auto: creator user
  - date_created  Auto: creation timestamp
  - date_updated  Auto: update timestamp

Also adds: workflows.category_id -> workflow_categories (M2O)

EOF
  show_environment_help
}

main() {
  local DRY_RUN=false
  local NO_SEED=false

  for arg in "$@"; do
    case "$arg" in
      --help|-h) show_help; exit 0 ;;
      --dry-run) DRY_RUN=true ;;
      --no-seed) NO_SEED=true ;;
    esac
  done

  require_cmds
  init_environment "$@"
  BASE_URL="$DIRECTUS_URL"

  echo "========================================="
  echo "DOT Tool: Schema Workflow Categories v${VERSION}"
  echo "========================================="
  print_environment_banner "$@"
  echo "Ensuring workflow_categories collection"
  echo ""

  if [[ "$DRY_RUN" == "true" ]]; then
    log_warn "DRY RUN MODE - No changes will be made"
    echo ""
  fi

  # Authentication
  if [[ -z "${DOT_TOKEN:-}" ]]; then
    if [[ ! -f "$DOT_AUTH" ]]; then
      log_err "dot-auth not found at ${DOT_AUTH}"
      exit 1
    fi
    log_info "Authenticating with Directus..."
    source "$DOT_AUTH" "$@"
  fi

  if [[ -z "${DOT_TOKEN:-}" ]]; then
    log_err "DOT_TOKEN is empty after authentication"
    exit 1
  fi

  # === COLLECTION ===
  echo ""
  echo "--- Collection: ${COLLECTION} ---"

  if collection_exists; then
    log_skip "Collection '${COLLECTION}' already exists"
  else
    if [[ "$DRY_RUN" == "true" ]]; then
      log_info "Would create collection '${COLLECTION}'"
    else
      create_collection
    fi
  fi

  # === FIELDS ===
  log_info "Ensuring required fields..."
  for field in "${REQUIRED_FIELDS[@]}"; do
    if field_exists "$field"; then
      log_skip "Field ${COLLECTION}.${field} already exists"
    else
      if [[ "$DRY_RUN" == "true" ]]; then
        log_info "Would create field ${COLLECTION}.${field}"
      else
        create_field "$field"
      fi
    fi
  done

  # === RELATIONS ===
  echo ""
  if [[ "$DRY_RUN" != "true" ]]; then
    setup_relations
  else
    log_info "Would create relation workflow_categories.parent_id -> workflow_categories"
  fi

  # === CATEGORY_ID ON WORKFLOWS ===
  echo ""
  if [[ "$DRY_RUN" != "true" ]]; then
    ensure_category_id_on_workflows
  else
    log_info "Would add category_id field to workflows"
  fi

  # === VERIFICATION ===
  echo ""
  if [[ "$DRY_RUN" != "true" ]]; then
    log_info "Running final verification..."
    if ! collection_exists; then
      log_err "Collection ${COLLECTION} missing after ensure"
      exit 1
    fi
    verify_fields
  fi

  # === SEED DATA ===
  echo ""
  if [[ "$DRY_RUN" != "true" && "$NO_SEED" != "true" ]]; then
    seed_sample_data
  elif [[ "$DRY_RUN" == "true" ]]; then
    log_info "Would seed sample category branch (3 levels)"
  fi

  log_ok "Collection workflow_categories ready"
  echo ""
  echo "========================================="
  echo "DOT Tool: Schema Workflow Categories - COMPLETE"
  echo "========================================="
}

main "$@"
