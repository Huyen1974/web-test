#!/usr/bin/env bash
# CHECKED-NO-DUPLICATE: [searched dot/bin/dot-*audit* — dot-layer-integrity-audit exists but is different scope]
# =============================================================================
# dot-pg-audit-ensure — PG functions: audit_relationships + audit_dead_links
# =============================================================================
# VERSION: 2.0.0
# CHANGELOG:
#   v2.0.0 (2026-03-14): Add run_audit_to_issues() — writes audit results to system_issues
#     - Idempotent: skips duplicates by entity_code + issue_type
#     - Issue types: thiếu_quan_hệ (warning), link_hỏng (critical)
#   v1.0.0 (2026-03-14): Initial — 2 audit functions for DOT scanning
#     - audit_relationships(): find entities without any relationship data
#     - audit_dead_links(): find dependencies pointing to deleted entities
#     - Both return SETOF with scan_id, entity_code, entity_type, issue_description, severity
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/../config/environment.sh"

VERSION="2.0.0"
VPS_HOST="38.242.240.89"
VPS_KEY="${HOME}/.ssh/contabo_vps"
PG_CONTAINER="postgres"
PG_USER="directus"
PG_DB="directus"

log_info() { echo "[INFO] $1"; }
log_ok()   { echo "[OK]   $1"; }
log_err()  { echo "[ERR]  $1" >&2; }

for arg in "$@"; do
  case "$arg" in
    --help|-h)
      echo "dot-pg-audit-ensure v${VERSION} — PG audit functions for DOT scanning"
      echo ""
      echo "Usage: dot-pg-audit-ensure [--cloud]"
      echo ""
      echo "Creates 2 PG functions:"
      echo "  audit_relationships() — entities without any relationship data"
      echo "  audit_dead_links()    — dependencies pointing to deleted entities"
      exit 0
      ;;
  esac
done

init_environment "$@"

echo "========================================="
echo "DOT Tool: PG Audit Ensure v${VERSION}"
echo "========================================="
print_environment_banner "$@"

# =============================================================================
# STEP 1: Create audit_relationships()
# =============================================================================
log_info "Step 1: Create audit_relationships()..."

AUDIT_REL_SQL=$(cat <<'ENDSQL'
-- =============================================================================
-- audit_relationships() — Find entities WITHOUT any relationship data
-- For EACH managed entity (from all 16 managed collections):
--   Check: has AT LEAST 1 row in entity_dependencies (source or target)?
--   No → report: "[CODE] — Chưa có dữ liệu quan hệ"
-- =============================================================================
DROP TYPE IF EXISTS audit_result CASCADE;
CREATE TYPE audit_result AS (
  scan_id int,
  entity_code text,
  entity_type text,
  issue_description text,
  severity text
);

CREATE OR REPLACE FUNCTION audit_relationships()
RETURNS SETOF audit_result AS $$
DECLARE
  cfg RECORD;
  r RECORD;
  seq int := 0;
BEGIN
  FOR cfg IN
    SELECT * FROM (VALUES
      ('meta_catalog',            'code',         'catalog'),
      ('table_registry',          'table_id',     'table'),
      ('modules',                 'code',         'module'),
      ('workflows',               'process_code', 'workflow'),
      ('workflow_steps',          'code',         'workflow_step'),
      ('workflow_change_requests','code',         'wcr'),
      ('dot_tools',               'code',         'dot_tool'),
      ('ui_pages',                'code',         'page'),
      ('collection_registry',     'code',         'collection'),
      ('tasks',                   'code',         'task'),
      ('agents',                  'code',         'agent'),
      ('checkpoint_types',        'code',         'checkpoint_type'),
      ('checkpoint_sets',         'code',         'checkpoint_set'),
      ('entity_dependencies',     'code',         'entity_dependency'),
      ('table_proposals',         'code',         'table_proposal'),
      ('checkpoint_instances',    'code',         'checkpoint_instance')
    ) AS t(tbl, code_field, etype)
  LOOP
    FOR r IN EXECUTE format(
      'SELECT %I::text AS ecode FROM %I WHERE %I IS NOT NULL AND %I != ''''
       AND %I::text NOT IN (
         SELECT source_code::text FROM entity_dependencies WHERE source_code IS NOT NULL
         UNION
         SELECT target_code::text FROM entity_dependencies WHERE target_code IS NOT NULL
       )',
      cfg.code_field, cfg.tbl, cfg.code_field, cfg.code_field, cfg.code_field
    )
    LOOP
      seq := seq + 1;
      RETURN NEXT (seq, r.ecode::text, cfg.etype::text,
        (r.ecode || ' — Chưa có dữ liệu quan hệ')::text,
        'warning'::text)::audit_result;
    END LOOP;
  END LOOP;
  RETURN;
END;
$$ LANGUAGE plpgsql;
ENDSQL
)

ssh -i "$VPS_KEY" "root@${VPS_HOST}" \
  "docker exec -i ${PG_CONTAINER} psql -U ${PG_USER} -d ${PG_DB}" <<< "$AUDIT_REL_SQL"

if [[ $? -eq 0 ]]; then
  log_ok "audit_relationships() created"
else
  log_err "Failed to create audit_relationships()"
  exit 1
fi

# =============================================================================
# STEP 2: Create audit_dead_links()
# =============================================================================
log_info "Step 2: Create audit_dead_links()..."

AUDIT_DEAD_SQL=$(cat <<'ENDSQL'
-- =============================================================================
-- audit_dead_links() — Find dependencies pointing to DELETED entities
-- For EACH row in entity_dependencies:
--   Check: source_code/target_code exists in managed collections?
--   No → report: "Quan hệ [source]→[target] — target không tồn tại"
-- =============================================================================
CREATE OR REPLACE FUNCTION audit_dead_links()
RETURNS SETOF audit_result AS $$
DECLARE
  dep RECORD;
  seq int := 0;
  found boolean;
BEGIN
  -- Build a temp table of ALL known entity codes for fast lookup
  CREATE TEMP TABLE IF NOT EXISTS _all_codes (code text PRIMARY KEY) ON COMMIT DROP;
  TRUNCATE _all_codes;

  INSERT INTO _all_codes (code)
    SELECT code::text FROM meta_catalog WHERE code IS NOT NULL AND code != ''
    UNION SELECT table_id::text FROM table_registry WHERE table_id IS NOT NULL AND table_id != ''
    UNION SELECT code::text FROM modules WHERE code IS NOT NULL AND code != ''
    UNION SELECT process_code::text FROM workflows WHERE process_code IS NOT NULL AND process_code != ''
    UNION SELECT code::text FROM workflow_steps WHERE code IS NOT NULL AND code != ''
    UNION SELECT code::text FROM workflow_change_requests WHERE code IS NOT NULL AND code != ''
    UNION SELECT code::text FROM dot_tools WHERE code IS NOT NULL AND code != ''
    UNION SELECT code::text FROM ui_pages WHERE code IS NOT NULL AND code != ''
    UNION SELECT code::text FROM collection_registry WHERE code IS NOT NULL AND code != ''
    UNION SELECT code::text FROM tasks WHERE code IS NOT NULL AND code != ''
    UNION SELECT code::text FROM agents WHERE code IS NOT NULL AND code != ''
    UNION SELECT code::text FROM checkpoint_types WHERE code IS NOT NULL AND code != ''
    UNION SELECT code::text FROM checkpoint_sets WHERE code IS NOT NULL AND code != ''
    UNION SELECT code::text FROM entity_dependencies WHERE code IS NOT NULL AND code != ''
    UNION SELECT code::text FROM table_proposals WHERE code IS NOT NULL AND code != ''
    UNION SELECT code::text FROM checkpoint_instances WHERE code IS NOT NULL AND code != ''
  ON CONFLICT DO NOTHING;

  FOR dep IN
    SELECT id, source_code, source_type, target_code, target_type
    FROM entity_dependencies
    WHERE source_code IS NOT NULL AND target_code IS NOT NULL
  LOOP
    -- Check source exists
    SELECT EXISTS(SELECT 1 FROM _all_codes WHERE code = dep.source_code::text) INTO found;
    IF NOT found THEN
      seq := seq + 1;
      RETURN NEXT (seq, dep.source_code::text, dep.source_type::text,
        ('Quan hệ ' || dep.source_code || '→' || dep.target_code || ' — source không tồn tại')::text,
        'error'::text)::audit_result;
    END IF;

    -- Check target exists
    SELECT EXISTS(SELECT 1 FROM _all_codes WHERE code = dep.target_code::text) INTO found;
    IF NOT found THEN
      seq := seq + 1;
      RETURN NEXT (seq, dep.target_code::text, dep.target_type::text,
        ('Quan hệ ' || dep.source_code || '→' || dep.target_code || ' — target không tồn tại')::text,
        'error'::text)::audit_result;
    END IF;
  END LOOP;

  RETURN;
END;
$$ LANGUAGE plpgsql;
ENDSQL
)

ssh -i "$VPS_KEY" "root@${VPS_HOST}" \
  "docker exec -i ${PG_CONTAINER} psql -U ${PG_USER} -d ${PG_DB}" <<< "$AUDIT_DEAD_SQL"

if [[ $? -eq 0 ]]; then
  log_ok "audit_dead_links() created"
else
  log_err "Failed to create audit_dead_links()"
  exit 1
fi

# =============================================================================
# STEP 3: Create run_audit_to_issues() — writes audit results to system_issues
# =============================================================================
log_info "Step 3: Create run_audit_to_issues()..."

AUDIT_ISSUES_SQL=$(cat <<'ENDSQL'
-- =============================================================================
-- run_audit_to_issues() — Run audit functions and INSERT into system_issues
-- Idempotent: skips if matching entity_code + issue_type already exists (status='mở')
-- Returns: count of NEW issues inserted
-- =============================================================================
CREATE OR REPLACE FUNCTION run_audit_to_issues()
RETURNS int AS $$
DECLARE
  r audit_result;
  new_count int := 0;
  next_code text;
  max_num int;
BEGIN
  -- Find current max ISS code number
  SELECT COALESCE(MAX(
    CASE WHEN code ~ '^\s*ISS-[0-9]+$'
      THEN CAST(regexp_replace(code, '^.*-', '') AS int)
      ELSE 0
    END
  ), 0) INTO max_num FROM system_issues;

  -- Process audit_relationships results
  FOR r IN SELECT * FROM audit_relationships()
  LOOP
    -- Skip if already exists (dedup by entity_code + issue_type)
    IF NOT EXISTS (
      SELECT 1 FROM system_issues
      WHERE entity_code = r.entity_code
        AND issue_type = 'thiếu_quan_hệ'
        AND status = 'mở'
    ) THEN
      max_num := max_num + 1;
      next_code := 'ISS-' || lpad(max_num::text, 4, '0');
      INSERT INTO system_issues (code, title, entity_code, entity_type, issue_type, severity, source, status)
      VALUES (
        next_code,
        r.entity_code || ' — Chưa có dữ liệu quan hệ',
        r.entity_code,
        r.entity_type,
        'thiếu_quan_hệ',
        'cảnh_báo',
        'dot-pg-audit-ensure',
        'mở'
      );
      new_count := new_count + 1;
    END IF;
  END LOOP;

  -- Process audit_dead_links results
  FOR r IN SELECT * FROM audit_dead_links()
  LOOP
    IF NOT EXISTS (
      SELECT 1 FROM system_issues
      WHERE entity_code = r.entity_code
        AND issue_type = 'link_hỏng'
        AND status = 'mở'
        AND title = r.issue_description
    ) THEN
      max_num := max_num + 1;
      next_code := 'ISS-' || lpad(max_num::text, 4, '0');
      INSERT INTO system_issues (code, title, entity_code, entity_type, issue_type, severity, source, status)
      VALUES (
        next_code,
        r.issue_description,
        r.entity_code,
        r.entity_type,
        'link_hỏng',
        'nghiêm_trọng',
        'dot-pg-audit-ensure',
        'mở'
      );
      new_count := new_count + 1;
    END IF;
  END LOOP;

  RETURN new_count;
END;
$$ LANGUAGE plpgsql;
ENDSQL
)

ssh -i "$VPS_KEY" "root@${VPS_HOST}" \
  "docker exec -i ${PG_CONTAINER} psql -U ${PG_USER} -d ${PG_DB}" <<< "$AUDIT_ISSUES_SQL"

if [[ $? -eq 0 ]]; then
  log_ok "run_audit_to_issues() created"
else
  log_err "Failed to create run_audit_to_issues()"
  exit 1
fi

# =============================================================================
# STEP 4: Run audit and write to system_issues
# =============================================================================
log_info "Step 4: Running audit → system_issues..."

echo ""
echo "--- Count BEFORE ---"
ssh -i "$VPS_KEY" "root@${VPS_HOST}" \
  "docker exec ${PG_CONTAINER} psql -U ${PG_USER} -d ${PG_DB} -c \"SELECT count(*) AS issues_before FROM system_issues WHERE status='mở';\""

echo ""
echo "--- Running run_audit_to_issues() ---"
ssh -i "$VPS_KEY" "root@${VPS_HOST}" \
  "docker exec ${PG_CONTAINER} psql -U ${PG_USER} -d ${PG_DB} -c 'SELECT run_audit_to_issues() AS new_issues_inserted;'"

echo ""
echo "--- Count AFTER ---"
ssh -i "$VPS_KEY" "root@${VPS_HOST}" \
  "docker exec ${PG_CONTAINER} psql -U ${PG_USER} -d ${PG_DB} -c \"SELECT count(*) AS issues_after FROM system_issues WHERE status='mở';\""

echo ""
echo "--- Idempotent test (run again) ---"
ssh -i "$VPS_KEY" "root@${VPS_HOST}" \
  "docker exec ${PG_CONTAINER} psql -U ${PG_USER} -d ${PG_DB} -c 'SELECT run_audit_to_issues() AS should_be_zero;'"

# =============================================================================
# STEP 5: Verify
# =============================================================================
log_info "Step 5: Verify..."

echo ""
echo "--- Issue types breakdown ---"
ssh -i "$VPS_KEY" "root@${VPS_HOST}" \
  "docker exec ${PG_CONTAINER} psql -U ${PG_USER} -d ${PG_DB} -c \"SELECT issue_type, count(*) FROM system_issues WHERE status='mở' GROUP BY issue_type ORDER BY count DESC;\""

echo ""
echo "========================================="
echo "DOT Tool: PG Audit Ensure — HOÀN TẤT"
echo "========================================="
