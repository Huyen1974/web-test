#!/usr/bin/env bash
# CHECKED-NO-DUPLICATE: [searched dot/bin/ for "comments-ensure" — no match. dot-schema-comments-extend exists but extends task_comments, not create comments collection]
# =============================================================================
# dot-schema-comments-ensure — Ensure comments collection + CMT meta_catalog entry
# =============================================================================
# VERSION: 1.0.0
# CHANGELOG:
#   v1.0.0 (2026-03-13): Initial — comments collection for system-wide comments
#     - 8 fields: code, entity_type, entity_code, author, content, status,
#       created_at, parent_comment_id
#     - CMT entry in meta_catalog (atom, managed)
#     - Idempotent: checks existence before create
#     - Based on dot-schema-system-issues-ensure pattern
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Source environment configuration
source "${SCRIPT_DIR}/../config/environment.sh"

VERSION="1.0.0"
COLLECTION="comments"

# Logging
log_info() { echo "[INFO] $1"; }
log_ok()   { echo "[OK]   $1"; }
log_warn() { echo "[WARN] $1"; }
log_skip() { echo "[SKIP] $1"; }
log_err()  { echo "[ERR]  $1" >&2; }

require_cmds() {
  for cmd in curl jq; do
    command -v "$cmd" >/dev/null 2>&1 || { log_err "Missing required command: $cmd"; exit 1; }
  done
}

api_request() {
  local method="$1" url="$2" data="${3-}"
  if [[ -n "${data-}" ]]; then
    curl -sS --globoff -X "$method" "$url" \
      -H "Authorization: Bearer $DOT_TOKEN" \
      -H "Content-Type: application/json" \
      -d "$data" -w "\n%{http_code}"
  else
    curl -sS --globoff -X "$method" "$url" \
      -H "Authorization: Bearer $DOT_TOKEN" \
      -w "\n%{http_code}"
  fi
}

# Required fields list (for verification)
REQUIRED_FIELDS=(code entity_type entity_code author content status created_at parent_comment_id)

field_payload() {
  case "$1" in
    code)
      cat <<'JSON'
{"field":"code","type":"string","meta":{"required":true,"readonly":false,"hidden":false,"searchable":true,"interface":"input","width":"half","note":"Mã tự động: CMT-NNNN","options":{"placeholder":"CMT-001"}},"schema":{"is_nullable":false,"is_unique":true,"max_length":20}}
JSON
      ;;
    entity_type)
      cat <<'JSON'
{"field":"entity_type","type":"string","meta":{"required":true,"readonly":false,"hidden":false,"searchable":true,"interface":"input","width":"half","note":"Loại thực thể được bình luận (workflow, task, table, ...)"},"schema":{"is_nullable":false,"max_length":50}}
JSON
      ;;
    entity_code)
      cat <<'JSON'
{"field":"entity_code","type":"string","meta":{"required":true,"readonly":false,"hidden":false,"searchable":true,"interface":"input","width":"half","note":"Mã thực thể (WF-001, TSK-005, ...)"},"schema":{"is_nullable":false,"max_length":50}}
JSON
      ;;
    author)
      cat <<'JSON'
{"field":"author","type":"string","meta":{"required":true,"readonly":false,"hidden":false,"searchable":true,"interface":"input","width":"half","note":"Người viết bình luận"},"schema":{"is_nullable":false,"max_length":100}}
JSON
      ;;
    content)
      cat <<'JSON'
{"field":"content","type":"text","meta":{"required":true,"readonly":false,"hidden":false,"searchable":true,"interface":"input-multiline","width":"full","note":"Nội dung bình luận"},"schema":{"is_nullable":false}}
JSON
      ;;
    status)
      cat <<'JSON'
{"field":"status","type":"string","meta":{"required":true,"readonly":false,"hidden":false,"searchable":true,"interface":"select-dropdown","width":"half","note":"Trạng thái","default_value":"active","options":{"choices":[{"text":"Hoạt động","value":"active"},{"text":"Đã xoá","value":"deleted"},{"text":"Đã ẩn","value":"hidden"}]}},"schema":{"is_nullable":false,"max_length":20,"default_value":"active"}}
JSON
      ;;
    created_at)
      cat <<'JSON'
{"field":"created_at","type":"timestamp","meta":{"special":["date-created"],"readonly":true,"hidden":false,"searchable":false,"width":"half","note":"Thời điểm tạo"},"schema":{"is_nullable":false}}
JSON
      ;;
    parent_comment_id)
      cat <<'JSON'
{"field":"parent_comment_id","type":"integer","meta":{"readonly":false,"hidden":false,"searchable":false,"interface":"input","width":"half","note":"ID bình luận cha (nếu là reply)"},"schema":{"is_nullable":true}}
JSON
      ;;
    *) return 1 ;;
  esac
}

collection_exists() {
  local resp body code
  resp=$(api_request GET "${BASE_URL}/collections/${COLLECTION}")
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"
  [[ "$code" == "200" ]]
}

field_exists() {
  local field_name="$1"
  local resp body code
  resp=$(api_request GET "${BASE_URL}/fields/${COLLECTION}")
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"
  if [[ "$code" == "200" ]]; then
    echo "$body" | jq -e --arg field "$field_name" '.data[]? | select(.field == $field)' >/dev/null 2>&1
    return $?
  fi
  return 1
}

create_collection() {
  local payload
  payload=$(jq -nc \
    --arg collection "$COLLECTION" \
    '{
      collection: $collection,
      schema: {},
      meta: {
        collection: $collection,
        icon: "chat_bubble",
        color: "#2563EB",
        note: "Bình luận hệ thống — Comments cho mọi thực thể — Created by DOT v1.0.0",
        display_template: "{{code}}: {{entity_type}}/{{entity_code}} — {{author}}",
        hidden: false,
        singleton: false,
        sort_field: null,
        archive_field: "status",
        archive_value: "deleted",
        unarchive_value: "active",
        archive_app_filter: true,
        collapse: "open",
        versioning: false
      },
      fields: [
        {
          field: "id",
          type: "integer",
          schema: { is_primary_key: true, has_auto_increment: true },
          meta: { hidden: true, readonly: true, searchable: false, interface: "input", special: ["no-data"] }
        }
      ]
    }')

  log_info "Creating collection ${COLLECTION}"
  local resp body code
  resp=$(api_request POST "${BASE_URL}/collections" "$payload")
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"

  if [[ "$code" != "200" ]]; then
    log_err "Failed to create collection ${COLLECTION} (HTTP $code)"
    echo "$body" | head -c 300 >&2
    exit 1
  fi
  log_ok "Collection ${COLLECTION} created"
}

create_field() {
  local field_name="$1"
  local payload resp body code
  payload=$(field_payload "$field_name")

  log_info "Creating field ${COLLECTION}.${field_name}"
  resp=$(api_request POST "${BASE_URL}/fields/${COLLECTION}" "$payload")
  body="${resp%$'\n'*}"
  code="${resp##*$'\n'}"

  if [[ "$code" != "200" ]]; then
    log_err "Failed to create field ${COLLECTION}.${field_name} (HTTP $code)"
    echo "$body" | head -c 200 >&2
    exit 1
  fi
  log_ok "Field ${COLLECTION}.${field_name} created"
}

for arg in "$@"; do
  case "$arg" in
    --help|-h)
      echo "dot-schema-comments-ensure v${VERSION}"
      echo ""
      echo "Usage: dot-schema-comments-ensure [--cloud]"
      echo ""
      echo "Creates comments collection + CMT meta_catalog entry."
      exit 0
      ;;
  esac
done

init_environment "$@"
BASE_URL="$DIRECTUS_URL"

# Auth
if [[ -z "${DOT_TOKEN:-}" ]]; then
  local_auth="${SCRIPT_DIR}/dot-auth"
  if [[ -f "$local_auth" ]]; then
    source "$local_auth" "$@"
  fi
fi

if [[ -z "${DOT_TOKEN:-}" ]]; then
  log_err "Xác thực thất bại"
  exit 1
fi

require_cmds

echo ""
echo "========================================="
echo "DOT Tool: Comments Ensure v${VERSION}"
echo "========================================="
print_environment_banner "$@"

# =============================================================================
# STEP 1: Create collection (idempotent)
# =============================================================================
if collection_exists; then
  log_skip "Collection ${COLLECTION} đã tồn tại"
else
  create_collection
fi

# =============================================================================
# STEP 2: Create fields (idempotent)
# =============================================================================
for field in "${REQUIRED_FIELDS[@]}"; do
  if field_exists "$field"; then
    log_skip "Field ${field} đã tồn tại"
  else
    create_field "$field"
  fi
done

# =============================================================================
# STEP 3: Verify
# =============================================================================
log_info "Verify: listing all fields..."
resp=$(api_request GET "${BASE_URL}/fields/${COLLECTION}")
body="${resp%$'\n'*}"
code="${resp##*$'\n'}"

if [[ "$code" == "200" ]]; then
  field_count=$(echo "$body" | jq '.data | length')
  log_ok "Collection ${COLLECTION}: ${field_count} fields"
else
  log_err "Verify failed (HTTP $code)"
fi

echo ""
echo "========================================="
echo "DOT Tool: Comments Ensure — HOÀN TẤT"
echo "========================================="
