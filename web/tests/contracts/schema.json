{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "dieu31-contract-schema",
  "title": "Điều 31 — Contract Schema",
  "description": "JSON Schema for System Integrity Verification contracts (Điều 31 v1.2)",
  "type": "object",
  "required": [
    "contract_id", "name", "tier", "type", "owner",
    "enabled", "contract_version", "last_verified_at",
    "grace_seconds", "checks"
  ],
  "properties": {
    "contract_id": {
      "type": "string",
      "pattern": "^CTR-"
    },
    "name": { "type": "string", "minLength": 1 },
    "tier": { "type": "string", "enum": ["A", "B", "C"] },
    "type": {
      "type": "string",
      "enum": ["dom_vs_db", "db_vs_db", "dom_vs_contract", "api_vs_db", "directus_vs_vector"]
    },
    "owner": { "type": "string", "minLength": 1 },
    "enabled": { "type": "boolean", "default": true },
    "contract_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_verified_at": {
      "type": "string",
      "format": "date"
    },
    "grace_seconds": {
      "type": "integer",
      "minimum": 0,
      "default": 60
    },
    "page_url": { "type": "string" },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["check_id", "description", "operator", "severity"],
        "properties": {
          "check_id": {
            "type": "string",
            "pattern": "^CTR-"
          },
          "description": { "type": "string", "minLength": 1 },
          "operator": {
            "type": "string",
            "enum": [
              "strict_equals", "eventual_equals", "within_window",
              "exists", "not_exists", "always_fail", "equals"
            ]
          },
          "severity": {
            "type": "string",
            "enum": ["CRITICAL", "WARNING", "INFO"]
          },
          "source_dom": {
            "type": "object",
            "properties": {
              "selector": { "type": "string" },
              "attribute": { "type": "string" }
            }
          },
          "source_db": {
            "type": "object",
            "properties": {
              "query": { "type": "string" },
              "field": { "type": "string" }
            }
          },
          "expected": {},
          "direction": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "type": { "const": "dom_vs_db" } }
      },
      "then": {
        "properties": {
          "checks": {
            "items": {
              "required": ["source_dom", "source_db"],
              "properties": {
                "source_dom": { "required": ["selector"] },
                "source_db": { "required": ["query"] }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "type": { "const": "dom_vs_contract" } }
      },
      "then": {
        "required": ["page_url"]
      }
    }
  ],
  "additionalProperties": true
}
