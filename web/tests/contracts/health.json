{
  "contract_id": "CTR-002",
  "name": "Health Dashboard — Registry Health Check",
  "tier": "A",
  "type": "dom_vs_db",
  "owner": "orchestrator",
  "enabled": true,
  "contract_version": "1.0.0",
  "last_verified_at": "2026-03-23",
  "grace_seconds": 60,
  "page_url": "https://vps.incomexsaigoncorp.vn/knowledge/registries/health",
  "route": "/knowledge/registries/health",
  "table_testid": "health-table",
  "cards": [
    { "label": "KHỚP", "testid": "health-card-khop" },
    { "label": "Orphan", "testid": "health-card-orphan" },
    { "label": "Phantom", "testid": "health-card-phantom" }
  ],
  "columns": [
    { "key": "stt", "label": "STT", "testid": "health-col-stt" },
    { "key": "collection_name", "label": "Collection", "testid": "health-col-collection" },
    { "key": "noi_chua", "label": "Nơi chứa", "testid": "health-col-noi-chua" },
    { "key": "noi_sinh", "label": "Nơi sinh", "testid": "health-col-noi-sinh" },
    { "key": "gap", "label": "Gap", "testid": "health-col-gap" },
    { "key": "status", "label": "Trạng thái", "testid": "health-col-status" }
  ],
  "min_rows": 3,
  "checks": [
    {
      "check_id": "CTR-002-01",
      "description": "Card KHỚP exists",
      "operator": "exists",
      "severity": "CRITICAL",
      "source_dom": { "selector": "[data-testid='health-card-khop']" },
      "source_db": { "query": "SELECT count(*) FROM v_registry_health WHERE status = 'KHỚP'" }
    },
    {
      "check_id": "CTR-002-02",
      "description": "Card Orphan exists",
      "operator": "exists",
      "severity": "CRITICAL",
      "source_dom": { "selector": "[data-testid='health-card-orphan']" },
      "source_db": { "query": "SELECT count(*) FROM v_registry_health WHERE status = 'ORPHAN'" }
    },
    {
      "check_id": "CTR-002-03",
      "description": "Card Phantom exists",
      "operator": "exists",
      "severity": "CRITICAL",
      "source_dom": { "selector": "[data-testid='health-card-phantom']" },
      "source_db": { "query": "SELECT count(*) FROM v_registry_health WHERE status = 'PHANTOM'" }
    },
    {
      "check_id": "CTR-002-04",
      "description": "Health table exists with at least 3 rows",
      "operator": "exists",
      "severity": "CRITICAL",
      "source_dom": { "selector": "[data-testid='health-table'] tbody tr:nth-child(3)" },
      "source_db": { "query": "SELECT count(*) FROM v_registry_health" }
    },
    {
      "check_id": "CTR-002-05",
      "description": "All 6 column headers present",
      "operator": "exists",
      "severity": "CRITICAL",
      "source_dom": { "selector": "[data-testid='health-col-status']" },
      "source_db": { "query": "SELECT 1" }
    }
  ]
}
